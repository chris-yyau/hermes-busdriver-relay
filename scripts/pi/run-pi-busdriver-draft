def authority_false_payload() -> dict[str, bool]:
    return {field: False for field in AUTHORITY_FALSE_FIELDS}


def run(cmd: list[str], cwd: Path | None = None, env: dict[str, str] | None = None, timeout: int | None = None) -> subprocess.CompletedProcess[str]:
    """Every child of this wrapper, bounded at the pipe — including the untrusted pi worker.

    The worker is the reason. It ran under `capture_output=True`, so the number of bytes this
    process allocated was the worker's to choose; `tail()` afterwards bounded what got PERSISTED,
    never what got read. Overflow is rc 125 with a fixed token, which the callers already treat as
    a worker failure.
    """
    result = run_bounded(cmd, cwd=cwd, env=env, timeout=timeout)
    if result.overflowed:
        return subprocess.CompletedProcess(cmd, 125, "", "worker_output_too_large")
    if result.timed_out:
        raise subprocess.TimeoutExpired(cmd, timeout or 0)
    return subprocess.CompletedProcess(cmd, result.returncode, result.stdout, result.stderr)


def timeout_text(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, bytes):
        return value.decode("utf-8", errors="replace")
    return str(value)


def startup_failure(error: str, **extra: Any) -> NoReturn:
