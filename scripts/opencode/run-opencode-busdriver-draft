def run(cmd: list[str], cwd: Path, env: dict[str, str], timeout: int) -> subprocess.CompletedProcess[str]:
    """Every child of this wrapper, bounded at the pipe — including the untrusted opencode worker."""
    result = run_bounded(cmd, cwd=cwd, env=env, timeout=timeout)
    if result.overflowed:
        return subprocess.CompletedProcess(cmd, 125, "", "worker_output_too_large")
    if result.timed_out:
        raise subprocess.TimeoutExpired(cmd, timeout)
    return subprocess.CompletedProcess(cmd, result.returncode, result.stdout, result.stderr)


