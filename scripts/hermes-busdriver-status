TRUSTED_EXECUTABLE_DIGESTS = {
    # git's digest is the CommandLineTools multi-call shim's, byte-identical to python3's (one
    # inode). A supply-chain pin, not an identity check — the path is the identity.
    "git": "ffdb53736fc808e793863887f2dba66c49d68f6aa0b43db5caa0fd8b1ec11aef",
    "git-real": "7018952d11ea59620a34ea929ffdcb3252cb0ad4bdfabd61e531a141d6bc1701",
    "sandbox-exec": "4b65c7cbdfb11fd6199b8587d6f0334fe9277958be55d0168e29836d867b4866",
}
# Fixed root-owned system sources, executed in place. No `.resolve()`: it follows symlinks, and a
# symlinked name is what this contract refuses. See _validated_root_owned_source().
TRUSTED_EXECUTABLE_SOURCES = {
    "git": Path("/usr/bin/git"),
    "git-real": Path("/Library/Developer/CommandLineTools/usr/bin/git"),
    "sandbox-exec": Path("/usr/bin/sandbox-exec"),
}


def private_runtime_error(error: str, executable: "str | None" = None, detail: "str | None" = None) -> SystemExit:
    payload: dict[str, Any] = {"ok": False, "error": error}
    if executable:
        payload["executable"] = executable
    if detail:
        payload["detail"] = detail
    return SystemExit(json.dumps(payload, sort_keys=True))


# =============================================================================================
# Fixed root-owned source execution contract. Copy of the primitive in hermes-busdriver-deliver;
# these are standalone executables with no shared import path, so a contract test asserts the
# copies agree. The full rationale lives in the deliver copy; the short version:
#
# executing a private copy relocated the substitutable name instead of removing it. macOS has no
# fexecve and will not exec /dev/fd/N, so the kernel re-resolves a *pathname* at exec time, and any
# pathname we can write is one a same-UID adversary can rename first (r34's two-rename ABA leaves
# st_nlink at 1 and every descriptor-visible field intact). The source therefore has to live where
# the adversary cannot write at all: root-owned, non-group/world-writable, root to leaf. The walk
# proves there is no race rather than trying to win one.
#
# /usr/bin/git is the CommandLineTools shim — same inode as /usr/bin/python3, nlink 78 — so nlink==1
# is waived for it and SF_RESTRICTED (SIP; denies even root) required instead. That shim also
# honours $DEVELOPER_DIR through xcrun, which no ancestry walk can see, so the child environment is
# owned here too: see ENV_DENIED_FOR_TRUSTED_DISPATCH.
# =============================================================================================

SF_RESTRICTED = 0x00080000  # macOS SIP: modification denied even to root.
_NON_OWNER_WRITABLE = stat.S_IWGRP | stat.S_IWOTH
SHIM_BACKED_SOURCES = frozenset({"git"})
ENV_DENIED_FOR_TRUSTED_DISPATCH = frozenset({
    "DEVELOPER_DIR", "SDKROOT", "XCODE_DEVELOPER_DIR_PATH", "TOOLCHAINS", "XCRUN_CACHE_PATH",
})
MAX_TRUSTED_EXECUTABLE_BYTES = 256 * 1024 * 1024


def _trusted_source_refusal(name: str, reason: str, detail: "str | None" = None) -> SystemExit:
    """gh gets its own top-level reason: a missing credential-bearing binary is an operational
    state an administrator resolves by provisioning /usr/local/bin/gh, not an integrity failure."""
    if reason == "unavailable" and name == "gh":
        return private_runtime_error("trusted_root_owned_gh_unavailable", name, detail)
    return private_runtime_error(f"trusted_root_owned_source_{reason}", name, detail)


def _require_trusted_directory(st: os.stat_result, name: str, component: str) -> None:
    if not stat.S_ISDIR(st.st_mode) or st.st_uid != 0 or (st.st_mode & _NON_OWNER_WRITABLE):
        raise _trusted_source_refusal(name, "ancestry_untrusted", component)


def _open_root_owned_ancestry(path: Path, name: str) -> int:
    """Walk root-to-parent with O_NOFOLLOW directory descriptors; return the parent fd.

    The fd, not the path: the leaf must be opened relative to the directory just validated.
    Re-opening by full pathname would re-traverse every component and restore the TOCTOU.
    """
    try:
        dir_fd = os.open("/", os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
    except OSError as exc:
        raise _trusted_source_refusal(name, "ancestry_untrusted", "/") from exc
    try:
        _require_trusted_directory(os.fstat(dir_fd), name, "/")
        for component in path.parts[1:-1]:
            try:
                nxt = os.open(
                    component,
                    os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC | os.O_NOFOLLOW,
                    dir_fd=dir_fd,
                )
            except OSError as exc:
                raise _trusted_source_refusal(name, "ancestry_untrusted", component) from exc
            os.close(dir_fd)
            dir_fd = nxt
            _require_trusted_directory(os.fstat(dir_fd), name, component)
    except BaseException:
        os.close(dir_fd)
        raise
    return dir_fd


def _require_trusted_leaf(st: os.stat_result, name: str) -> None:
    if not stat.S_ISREG(st.st_mode):
        raise _trusted_source_refusal(name, "metadata_invalid", "not_regular")
    if st.st_uid != 0 or (st.st_mode & _NON_OWNER_WRITABLE):
        raise _trusted_source_refusal(name, "metadata_invalid", "writable_or_unowned")
    if not (st.st_mode & (stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)):
        raise _trusted_source_refusal(name, "metadata_invalid", "not_executable")
    if name in SHIM_BACKED_SOURCES:
        if not (getattr(st, "st_flags", 0) & SF_RESTRICTED):
            raise _trusted_source_refusal(name, "metadata_invalid", "not_sip_restricted")
    elif st.st_nlink != 1:
        raise _trusted_source_refusal(name, "metadata_invalid", "multiply_linked")


def _identity(st: os.stat_result) -> tuple:
    return (
        st.st_dev, st.st_ino, st.st_uid, st.st_gid, st.st_mode,
        st.st_nlink, st.st_size, st.st_mtime_ns, st.st_ctime_ns,
    )


def _read_trusted_source_bytes(fd: int, name: str) -> bytes:
    chunks: list[bytes] = []
    total = 0
    while True:
        chunk = os.read(fd, 1024 * 1024)
        if not chunk:
            break
        total += len(chunk)
        if total > MAX_TRUSTED_EXECUTABLE_BYTES:
            raise _trusted_source_refusal(name, "metadata_invalid", "oversized")
        chunks.append(chunk)
    return b"".join(chunks)


def _validated_root_owned_source(path: Path, name: str) -> Path:
    """Pure seam: production reaches this only via trusted_executable_path(), which supplies the
    path from a frozen table. Tests pass harmless already-root-owned system binaries."""
    expected = TRUSTED_EXECUTABLE_DIGESTS[name]
    if not path.is_absolute():
        raise _trusted_source_refusal(name, "metadata_invalid", "not_absolute")
    parent_fd = _open_root_owned_ancestry(path, name)
    try:
        try:
            fd = os.open(path.name, os.O_RDONLY | os.O_CLOEXEC | os.O_NOFOLLOW, dir_fd=parent_fd)
        except OSError as exc:
            if exc.errno == errno.ELOOP:
                raise _trusted_source_refusal(name, "metadata_invalid", "symlink") from exc
            raise _trusted_source_refusal(name, "unavailable", type(exc).__name__) from exc
        try:
            opened = os.fstat(fd)
            _require_trusted_leaf(opened, name)
            data = _read_trusted_source_bytes(fd, name)
            if hashlib.sha256(data).hexdigest() != expected:
                raise _trusted_source_refusal(name, "integrity_failed")
            if _identity(os.fstat(fd)) != _identity(opened):
                raise _trusted_source_refusal(name, "identity_changed", "descriptor")
            final = os.lstat(path.name, dir_fd=parent_fd)
            if (final.st_dev, final.st_ino) != (opened.st_dev, opened.st_ino):
                raise _trusted_source_refusal(name, "identity_changed", "path")
        finally:
            os.close(fd)
    finally:
        os.close(parent_fd)
    return path


def trusted_executable_path(name: str) -> Path:
    """The only production entry point. Takes a name; the path is not negotiable.

    Revalidated on every call rather than cached: the contract is "validated immediately before
    dispatch", and a cache is a promise about the past.
    """
    source = TRUSTED_EXECUTABLE_SOURCES.get(name)
    if source is None:
        raise _trusted_source_refusal(name, "unsupported")
    return _validated_root_owned_source(source, name)


def _refusal_reason(exc: SystemExit) -> str:
    """Lift the machine-readable token back out of the primitive's JSON payload."""
    try:
        payload = json.loads(str(exc))
    except (json.JSONDecodeError, TypeError, ValueError):
        return "trusted_root_owned_source_unavailable"
    if not isinstance(payload, dict):
        return "trusted_root_owned_source_unavailable"
    reason = str(payload.get("error") or "trusted_root_owned_source_unavailable")
    detail = payload.get("detail")
    return f"{reason}:{detail}" if detail else reason


def trusted_git_path() -> Path:
    """OSError, not SystemExit: git_status() folds the reason into its envelope rather than letting
    an unauthenticatable git take every unrelated diagnostic down with it. The shared primitive
    raises SystemExit for parity with every other copy, so the token is lifted out of its payload
    here and the envelope still names the exact refusal."""
    try:
        return trusted_executable_path("git")
    except SystemExit as exc:
        raise OSError(_refusal_reason(exc)) from exc


CONTAINED_PATH = "/usr/bin:/bin:/usr/sbin:/sbin"


def child_env(extra: dict[str, str] | None = None) -> dict[str, str]:
    """Explicit allowlist for every child of this probe.

    The caller's environment is untrusted input: PATH decides which `git` runs, and
    PYTHONPATH/BASH_ENV/LD_*/DYLD_* let a caller inject code into a child's startup or loader.
    Ambient GIT_* (GIT_DIR, GIT_INDEX_FILE, GIT_EXTERNAL_DIFF, ...) likewise redirect or
    execute on behalf of git, so GIT_* is rebuilt here rather than inherited.
    """
    allowed = {"HOME", "TMPDIR", "TMP", "TEMP", "LANG", "LC_ALL", "LC_CTYPE", "USER", "LOGNAME", "TERM", "NO_COLOR"}
    env = {key: value for key, value in os.environ.items() if key in allowed or key.startswith("LC_")}
    env["PATH"] = CONTAINED_PATH
    env["GIT_CONFIG_NOSYSTEM"] = "1"
    env["GIT_CONFIG_GLOBAL"] = os.devnull
    if extra:
        env.update(extra)
    return git_observation_env(env)


def run(cmd: list[str], cwd: Path | None = None, timeout: int = 10, stdin_bytes: bytes | None = None, env: dict[str, str] | None = None) -> dict[str, Any]:
    try:
        # text=False so stdin_bytes are handed to the child verbatim — the digest was taken over
        # those exact bytes, and a decode/re-encode round trip would not preserve them.
        p = run_bounded(cmd, cwd=cwd, env=child_env() if env is None else env, timeout=timeout, stdin_bytes=stdin_bytes, text=False)
        if p.overflowed:
            # This probe retained `stdout_bytes` raw AND a decoded copy of whatever git emitted, and
            # put both in the envelope with no redaction helper in this file at all. Over the bound
            # there is nothing to retain and nothing worth emitting.
            return {"ok": False, "returncode": 125, "stdout": "", "stderr": "child_output_too_large", "stdout_bytes": b""}
        if p.timed_out:
            return {"ok": False, "returncode": 124, "stdout": "", "stderr": f"timeout after {timeout}s", "stdout_bytes": b""}
        if git_observation_stderr_refused(cmd, p.stderr):
            return {"ok": False, "returncode": 126, "stdout": "", "stderr": "git_observation_stderr", "stdout_bytes": b""}
        decode = lambda raw: (raw or b"").decode("utf-8", errors="replace").strip()  # noqa: E731
        # stdout_bytes is kept alongside the decoded text for `-z` reads: NUL framing only survives
        # in the bytes, and a stripped string cannot be reframed back into records.
        return {"ok": p.returncode == 0, "returncode": p.returncode, "stdout": decode(p.stdout), "stderr": decode(p.stderr), "stdout_bytes": p.stdout or b""}
    except subprocess.TimeoutExpired:
        return {"ok": False, "returncode": 124, "stdout": "", "stderr": f"timeout after {timeout}s", "stdout_bytes": b""}
    except OSError as e:
        # Covers FileNotFoundError plus NotADirectoryError/PermissionError from an unusable
        # cwd or executable: a caller-supplied --repo must fail closed, never traceback.
        return {"ok": False, "returncode": 127, "stdout": "", "stderr": str(e), "stdout_bytes": b""}


# Enumerated from the CONSUMER, not restated by hand: every character `str.splitlines()` treats as
# a line boundary can fabricate a porcelain record. git quotes C0 controls in a pathname even under
# `core.quotePath=false`, but NOT the non-ASCII separators — and splitlines() splits on NEL
# (U+0085), LS (U+2028) and PS (U+2029) all the same, so a repo-local `core.quotePath=false` plus a
# directory named `evil<U+2028> M .claude` fabricated a marker record from one untracked file.
# Framing is therefore taken from `-z` NUL, which the inspected repo cannot reconfigure.
STATUS_PATH_DELIMITERS = frozenset(
    {"\t"}
    | {chr(code) for code in range(0x11000) if len(f"a{chr(code)}b".splitlines()) > 1}
    | {chr(code) for code in range(0x00, 0x20)}
    | {chr(0x7F)}
    | {chr(code) for code in range(0x80, 0xA0)}
)


def escape_status_path(path: str) -> str:
    """NUL framing protects this parser; escaping protects every consumer of the entry strings."""
    return "".join(f"\\x{ord(char):02x}" if char in STATUS_PATH_DELIMITERS else char for char in path)


def parse_porcelain_z(raw: bytes) -> list[tuple[str, list[str]]]:
    """NUL-framed `status --porcelain=v1 -z` → [(xy, [paths])]; `-z` never quotes, so never unquote."""
    fields = raw.split(b"\0")
    if fields and fields[-1] == b"":
        fields.pop()
    records: list[tuple[str, list[str]]] = []
    index = 0
    while index < len(fields):
        field = fields[index].decode("utf-8", errors="replace")
        index += 1
        if len(field) < 4 or field[2] != " ":
            continue
        xy, destination = field[:2], field[3:]
        if xy[0:1] in {"R", "C"} and index < len(fields):
            source = fields[index].decode("utf-8", errors="replace")
            index += 1
            records.append((xy, [source, destination]))
            continue
        records.append((xy, [destination]))
    return records


def porcelain_entries(raw: bytes) -> list[str]:
    return [f"{xy} " + " -> ".join(escape_status_path(path) for path in paths) for xy, paths in parse_porcelain_z(raw)]


def read_json(path: Path) -> tuple[Any | None, str | None]:
    try:
        return json.loads(path.read_text()), None
    except Exception as e:  # noqa: BLE001 - status probe should report parse errors
        return None, str(e)


def resolve_plugin_root(arg: str | None) -> Path:
    candidates = []
    if arg:
        candidates.append(Path(arg).expanduser())
    for env_name in ("BUSDRIVER_PLUGIN_ROOT", "CLAUDE_PLUGIN_ROOT"):
        if os.environ.get(env_name):
            candidates.append(Path(os.environ[env_name]).expanduser())
    candidates.append(Path.home() / ".claude/plugins/marketplaces/busdriver")
    for c in candidates:
        if c.exists():
            return c.resolve()
    return candidates[0].resolve()


def package_status(root: Path) -> dict[str, Any]:
    pkg = root / "package.json"
    data, err = read_json(pkg)
    return {
        "path": str(pkg),
        "exists": pkg.exists(),
        "parse_error": err,
        "name": data.get("name") if isinstance(data, dict) else None,
        "version": data.get("version") if isinstance(data, dict) else None,
    }


def user_config_status(state_dir: str, user_config: str | None = None) -> dict[str, Any]:
    cfg = Path(user_config).expanduser() if user_config else Path.home() / state_dir / "busdriver.json"
    data, err = read_json(cfg)
    routes = data.get("routes", {}) if isinstance(data, dict) else {}
    return {
        "path": str(cfg),
        "exists": cfg.exists(),
        "parse_error": err,
        "route_keys": sorted(routes.keys()) if isinstance(routes, dict) else [],
        "ultra_oracle_enabled_keys": sorted((data.get("ultraOracle") or {}).keys()) if isinstance(data, dict) else [],
    }


def relay_config_status(relay_config: str | None = None, relay_state_dir: str | None = None) -> tuple[dict[str, Any], dict[str, Any]]:
    cfg = Path(relay_config).expanduser() if relay_config else relay_state_root(relay_state_dir) / "config.json"
    if not cfg.exists():
        return {
            "path": str(cfg),
            "exists": False,
            "parse_error": None,
            "route_keys": [],
        }, {}
    data, err = read_json(cfg)
    shape_error = None if err or isinstance(data, dict) else "config_must_be_object"
    routes = data.get("routes", {}) if isinstance(data, dict) else {}
    return {
        "path": str(cfg),
        "exists": True,
        "parse_error": err,
        "shape_error": shape_error,
        "route_keys": sorted(routes.keys()) if isinstance(routes, dict) else [],
    }, data if isinstance(data, dict) else {}


def hook_inventory(root: Path) -> dict[str, Any]:
    path = root / "hooks/hooks.json"
    data, err = read_json(path)
    inv: dict[str, Any] = {"path": str(path), "exists": path.exists(), "parse_error": err, "events": {}, "commands": []}
    if not isinstance(data, dict):
        return inv
    hooks = data.get("hooks", {})
    if not isinstance(hooks, dict):
        return inv
    commands: list[str] = []
    for event, entries in hooks.items():
        event_info = {"entries": 0, "matchers": [], "descriptions": []}
        if isinstance(entries, list):
            event_info["entries"] = len(entries)
            for entry in entries:
                if not isinstance(entry, dict):
                    continue
                if "matcher" in entry:
                    event_info["matchers"].append(entry.get("matcher"))
                if "description" in entry:
                    event_info["descriptions"].append(entry.get("description"))
                for h in entry.get("hooks", []) or []:
                    if isinstance(h, dict) and h.get("command"):
                        commands.append(h["command"])
        inv["events"][event] = event_info
    inv["commands"] = commands
    return inv


def file_presence(root: Path, rels: list[str]) -> dict[str, bool]:
    return {rel: (root / rel).exists() for rel in rels}


def sha256_file(path: Path) -> str | None:
    if not path.is_file():
        return None
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def critical_file_hashes(root: Path, hook_refs: list[str]) -> dict[str, Any]:
    rels = sorted(set(KEY_ENTRYPOINTS + MIN_GATE_SCRIPTS + hook_refs))
    out: dict[str, Any] = {}
    for rel in rels:
        path = root / rel
        if path.is_file():
            st = path.stat()
            out[rel] = {"exists": True, "sha256": sha256_file(path), "size": st.st_size, "mtime": int(st.st_mtime)}
        else:
            out[rel] = {"exists": path.exists(), "sha256": None, "size": None, "mtime": None}
    return out


def drift_baseline_status(baseline_arg: str | None, package: dict[str, Any], hashes: dict[str, Any]) -> dict[str, Any] | None:
    if not baseline_arg:
        return None
    path = Path(baseline_arg).expanduser().resolve()
    flags = {
        "commit_allowed": False,
        "push_allowed": False,
        "pr_allowed": False,
        "merge_allowed": False,
        "deploy_allowed": False,
        "marker_write_allowed": False,
    }
    base: dict[str, Any] = {
        "schema": "hermes-busdriver-drift/v0",
        "baseline_path": str(path),
        "baseline_exists": path.exists(),
        "read_only": True,
        "finalization_flags": flags,
    }
    if not path.exists():
        return {
            **base,
            "status": "baseline_missing",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_missing"],
            "parse_error": None,
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    data, err = read_json(path)
    if not isinstance(data, dict):
        return {
            **base,
            "status": "baseline_invalid",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_invalid"],
            "parse_error": err or "baseline root is not a JSON object",
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    for key, expected in {
        "status_schema": "hermes-busdriver-status/v0",
        "schema": "hermes-busdriver-drift/v0",
    }.items():
        declared = data.get(key)
        if declared is not None and declared != expected:
            return {
                **base,
                "status": "baseline_invalid",
                "finalization_compatible": False,
                "finalization_disabled_reasons": ["baseline_invalid"],
                "parse_error": f"unsupported {key}: {declared}",
                "package_version_changed": False,
                "added": [],
                "removed": [],
                "changed": [],
                "missing": [],
            }

    expected_hashes = data.get("critical_file_hashes")
    if not isinstance(expected_hashes, dict):
        return {
            **base,
            "status": "baseline_invalid",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_invalid"],
            "parse_error": "missing critical_file_hashes object",
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    expected_package = data.get("package") if isinstance(data.get("package"), dict) else {}
    expected_version = expected_package.get("version")
    current_version = package.get("version")
    package_version_changed = expected_version is not None and expected_version != current_version
    expected_keys = set(expected_hashes)
    current_keys = set(hashes)
    added = sorted(current_keys - expected_keys)
    removed = sorted(expected_keys - current_keys)
    changed: list[str] = []
    missing: list[str] = []
    for rel in sorted(expected_keys & current_keys):
        expected = expected_hashes.get(rel) if isinstance(expected_hashes.get(rel), dict) else {}
        current = hashes.get(rel) if isinstance(hashes.get(rel), dict) else {}
        if expected.get("exists") is True and current.get("exists") is not True:
            missing.append(rel)
        if expected.get("sha256") != current.get("sha256") or expected.get("exists") != current.get("exists"):
            changed.append(rel)

    reasons: list[str] = []
    if package_version_changed:
        reasons.append("package_version_changed")
    if added or removed or changed or missing:
        reasons.append("baseline_drift")
    compatible = not reasons
    return {
        **base,
        "status": "compatible" if compatible else "drifted",
        "finalization_compatible": compatible,
        "finalization_disabled_reasons": reasons,
        "parse_error": None,
        "baseline_package_version": expected_version,
        "current_package_version": current_version,
        "package_version_changed": package_version_changed,
        "compared_count": len(expected_keys & current_keys),
        "added": added,
        "removed": removed,
        "changed": changed,
        "missing": missing,
    }


def effective_routes(user_cfg: dict[str, Any], resolved_cli: dict[str, Any]) -> dict[str, Any]:
    routes = user_cfg.get("routes", {}) if isinstance(user_cfg, dict) else {}
    clis = ((resolved_cli.get("data") or {}).get("clis") or {}) if resolved_cli.get("ok") else {}
    result: dict[str, Any] = {}
    for role, default_route in DEFAULT_ROLE_ROUTES.items():
        configured = routes.get(role, default_route) if isinstance(routes, dict) else default_route
        if isinstance(configured, str):
            route = [configured]
        elif isinstance(configured, list):
            route = [str(x) for x in configured]
        else:
            route = list(default_route)
        resolved = None
        unavailable = []
        for cli in route:
            info = clis.get(cli)
            if info and info.get("available") is True:
                resolved = cli
                break
            unavailable.append(cli)
        result[role] = {
            "route": route,
            "source": "user" if isinstance(routes, dict) and role in routes else "default",
            "resolved": resolved,
            "available": resolved is not None,
            "unavailable_before_resolution": unavailable if resolved else route,
        }
    return result


def relay_equivalent_roles(
    relay_cfg: dict[str, Any], relay_config_parse_error: str | None = None, relay_config_shape_error: str | None = None
) -> dict[str, Any]:
    if not isinstance(relay_cfg, dict):
        relay_cfg = {}
    routes_config_error = None
    raw_routes = relay_cfg.get("routes", {})
    if relay_config_parse_error:
        routes_config_error = "config_parse_error"
        routes = {}
    elif relay_config_shape_error:
        routes_config_error = relay_config_shape_error
        routes = {}
    elif "routes" in relay_cfg and not isinstance(raw_routes, dict):
        routes_config_error = "routes_must_be_object"
        routes = {}
    else:
        routes = raw_routes
    configured_coding_agent = relay_cfg.get("coding_agent")
    coding_agent_config_error = None
    if "coding_agent" in relay_cfg and (not isinstance(configured_coding_agent, str) or not configured_coding_agent):
        coding_agent_config_error = "coding_agent_must_be_non_empty_string"
    coding_agent = configured_coding_agent if coding_agent_config_error is None and isinstance(configured_coding_agent, str) else DEFAULT_RELAY_CODING_AGENT
    configured_avoid = relay_cfg.get("avoid_coding_agent_for_review")
    avoid_config_error = None
    if "avoid_coding_agent_for_review" in relay_cfg and not isinstance(configured_avoid, bool):
        avoid_config_error = "avoid_coding_agent_for_review_must_be_boolean"
    elif configured_avoid is False:
        avoid_config_error = "avoid_coding_agent_for_review_must_be_true"
    avoid = DEFAULT_RELAY_AVOID_CODING_AGENT_FOR_REVIEW
    roles: dict[str, Any] = {}
    for role, defaults in DEFAULT_RELAY_EQUIVALENT_ROUTES.items():
        default_route = defaults["route"]
        review_sensitive = defaults.get("review_independence_sensitive", True)
        metadata_config_error = None
        raw_programmatic_dispatch_allowed = defaults.get("programmatic_dispatch_allowed")
        raw_adapter_verified = defaults.get("adapter_verified")
        if "programmatic_dispatch_allowed" not in defaults:
            metadata_config_error = "default_role_metadata_missing_programmatic_dispatch_allowed"
        elif not isinstance(raw_programmatic_dispatch_allowed, bool):
            metadata_config_error = "default_role_metadata_invalid_programmatic_dispatch_allowed"
        elif "adapter_verified" not in defaults:
            metadata_config_error = "default_role_metadata_missing_adapter_verified"
        elif not isinstance(raw_adapter_verified, bool):
            metadata_config_error = "default_role_metadata_invalid_adapter_verified"
        if metadata_config_error is None:
            programmatic_dispatch_allowed = raw_programmatic_dispatch_allowed
            adapter_verified = raw_adapter_verified
            dispatch_blocker = defaults.get("dispatch_blocker")
        else:
            programmatic_dispatch_allowed = False
            adapter_verified = False
            dispatch_blocker = "default_role_metadata_invalid"
        configured = routes.get(role, default_route)
        config_error = metadata_config_error
        if routes_config_error is not None:
            route = []
            config_error = routes_config_error
        elif isinstance(configured, str):
            route = [configured] if configured else []
        elif isinstance(configured, list):
            if all(isinstance(x, str) and x for x in configured):
                route = list(configured)
            else:
                route = []
                config_error = "route_entries_must_be_non_empty_strings"
        else:
            if role in routes:
                route = []
                config_error = "route_must_be_string_or_array"
            else:
                route = list(default_route)
        if not route and config_error is None:
            config_error = "empty_route"
        selected = next((agent for agent in route if not (avoid and review_sensitive) or agent != coding_agent), route[0] if route else None)
        same_as_coding_agent = selected == coding_agent
        independence_degraded = config_error is None and avoid and review_sensitive and same_as_coding_agent
        if independence_degraded:
            dispatch_blocker = "independent_review_session_contract_unavailable"
        roles[role] = {
            "native_busdriver_role": defaults["native_busdriver_role"],
            "configured_route": route,
            "default_route": list(default_route),
            "source": "relay_config" if role in routes or routes_config_error is not None else "default",
            "selected_agent": selected,
            "same_as_coding_agent": same_as_coding_agent,
            "review_independence_sensitive": review_sensitive,
            "programmatic_dispatch_allowed": programmatic_dispatch_allowed,
            "adapter_verified": adapter_verified,
            "adapter_proof": defaults.get("adapter_proof"),
            "dispatch_blocker": dispatch_blocker,
            "degraded": bool(config_error) or independence_degraded,
            "config_error": config_error,
            "configurable": True,
            "not_busdriver_native_claude_runtime": True,
            "finalization_allowed": False,
            "mutation_allowed": False,
        }
    return {
        "coding_agent": coding_agent,
        "coding_agent_source": "relay_config" if "coding_agent" in relay_cfg and coding_agent_config_error is None else "default",
        "coding_agent_config_error": coding_agent_config_error,
        "role_policy": "codex_primary_opencode_fallback_pi_deferred",
        "review_independence_policy": "avoid_coding_agent_for_review_roles",
        "avoid_coding_agent_for_review": avoid,
        "avoid_coding_agent_for_review_source": "relay_config" if "avoid_coding_agent_for_review" in relay_cfg and avoid_config_error is None else "default",
        "avoid_coding_agent_for_review_config_error": avoid_config_error,
        "routes_config_error": routes_config_error,
        "relay_config_parse_error": relay_config_parse_error,
        "relay_config_shape_error": relay_config_shape_error,
        "roles": roles,
    }


MARKER_PREVIEW_MAX_BYTES = 4096


def marker_preview_lines(
    path: Path, expected: os.stat_result | None = None, *, parent_fd: int | None = None,
) -> tuple[list[str] | None, str | None]:
    """Read the first lines of a marker without ever following a symlink to its target.

    `<repo>/.claude` is attacker-controlled: `--repo` names a repository this probe does not
    trust. r25 probed every marker with exists()/stat()/is_file()/read_text(), all of which follow
    symlinks — so stat() reported the TARGET's size and the <=4096 gate failed to exclude typical
    key material. `.claude/litmus-passed.local -> ~/.ssh/id_rsa` copied three lines of that key
    into an envelope advertising read_only: true. That is egress, not just disclosure.

    This is the same O_NOFOLLOW + S_ISREG + size bound litmus-status already applies to these
    exact marker names; status alone had no symlink handling.
    """
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0) | getattr(os, "O_NONBLOCK", 0)
    fd: int | None = None
    try:
        fd = os.open(path.name if parent_fd is not None else path, flags, dir_fd=parent_fd)
        before = os.fstat(fd)
        if not stat.S_ISREG(before.st_mode):
            return None, "refusing_to_read_non_regular_file"
        if before.st_nlink != 1:
            return None, "refusing_to_read_linked_file"
        if expected is not None and (before.st_dev, before.st_ino, before.st_mode) != (
            expected.st_dev, expected.st_ino, expected.st_mode,
        ):
            return None, "marker_identity_changed"
        if before.st_size > MARKER_PREVIEW_MAX_BYTES:
            return None, "refusing_to_read_large_marker"
        chunks: list[bytes] = []
        remaining = before.st_size
        while remaining:
            chunk = os.read(fd, remaining)
            if not chunk:
                return None, "marker_changed_during_read"
            chunks.append(chunk)
            remaining -= len(chunk)
        if os.read(fd, 1):
            return None, "marker_changed_during_read"
        after = os.fstat(fd)
        stable_fields = ("st_dev", "st_ino", "st_mode", "st_nlink", "st_size", "st_mtime_ns", "st_ctime_ns")
        if any(getattr(before, key) != getattr(after, key) for key in stable_fields):
            return None, "marker_changed_during_read"
        landed = os.lstat(path.name, dir_fd=parent_fd) if parent_fd is not None else os.lstat(path)
        if (landed.st_dev, landed.st_ino, landed.st_mode) != (before.st_dev, before.st_ino, before.st_mode):
            return None, "marker_identity_changed"
        return b"".join(chunks).decode(errors="replace").splitlines()[:3], None
    except OSError as e:
        if getattr(e, "errno", None) == errno.ELOOP:
            return None, "refusing_to_follow_symlink"
        return None, str(e)
    finally:
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


def active_markers(repo_status: dict[str, Any] | None, state_dir: str) -> dict[str, Any] | None:
    if repo_status is None:
        return None
    if not repo_status.get("is_git_repo") or not repo_status.get("root"):
        return None
    # An unobserved repo has no head/branch/dirty to compare a marker's freshness against, and
    # emitting the comparison against synthesized nulls reads as "compared, not fresh".
    if repo_status.get("observed") is False:
        return {"state_dir": str(Path(repo_status["root"]) / state_dir), "available": False, "reason": "repo_not_observed"}
    root = Path(repo_status["root"])
    state = root / state_dir
    state_fd: int | None = None
    state_st: os.stat_result | None = None
    state_is_symlink = False
    try:
        state_st = state.lstat()
        state_is_symlink = stat.S_ISLNK(state_st.st_mode)
        if not state_is_symlink and stat.S_ISDIR(state_st.st_mode):
            state_fd = os.open(
                state,
                os.O_RDONLY | getattr(os, "O_DIRECTORY", 0) | getattr(os, "O_NOFOLLOW", 0),
            )
            opened = os.fstat(state_fd)
            if (opened.st_dev, opened.st_ino, opened.st_mode) != (state_st.st_dev, state_st.st_ino, state_st.st_mode):
                os.close(state_fd)
                state_fd = None
    except OSError:
        state_st = None
    markers: dict[str, Any] = {"state_dir": str(state), "exists": state_st is not None, "files": {}}
    if state_is_symlink or (state_st is not None and state_fd is None):
        markers["state_dir_unsafe"] = True
    now = time.time()
    repo_head_commit_time = repo_status.get("head_commit_time")
    try:
        for name in MARKER_FILES:
            path = state / name
            if state_fd is None:
                markers["files"][name] = {"exists": False}
                continue
            try:
                st = os.lstat(name, dir_fd=state_fd)
            except OSError:
                markers["files"][name] = {"exists": False}
                continue
            is_symlink = stat.S_ISLNK(st.st_mode)
            marker_mtime = int(st.st_mtime)
            marker_age_sec = int(now - st.st_mtime)
            entry: dict[str, Any] = {
                "exists": True,
                # lstat, so this is the link's own size, never the target's.
                "size": st.st_size,
                "is_symlink": is_symlink,
                "mtime": marker_mtime,
                "age_sec": marker_age_sec,
                "freshness": {
                    "compared_to_repo_head": repo_status.get("head"),
                    "repo_branch": repo_status.get("branch"),
                    "repo_dirty": repo_status.get("dirty"),
                    "marker_mtime": marker_mtime,
                    "marker_age_sec": marker_age_sec,
                    "repo_head_commit_time": repo_head_commit_time,
                    "marker_mtime_after_repo_head_commit_time": None
                    if repo_head_commit_time is None
                    else marker_mtime > repo_head_commit_time,
                },
            }
            if is_symlink:
                entry["read_error"] = "refusing_to_follow_symlink"
            elif not stat.S_ISREG(st.st_mode):
                entry["read_error"] = "refusing_to_read_non_regular_file"
            elif st.st_nlink != 1:
                entry["read_error"] = "refusing_to_read_linked_file"
            elif st.st_size > MARKER_PREVIEW_MAX_BYTES:
                entry["read_error"] = "refusing_to_read_large_marker"
            elif name not in {"bypass-log.jsonl"}:
                preview, read_error = marker_preview_lines(path, st, parent_fd=state_fd)
                if read_error:
                    entry["read_error"] = read_error
                else:
                    entry["preview_lines"] = preview
            markers["files"][name] = entry
    finally:
        if state_fd is not None:
            os.close(state_fd)
    markers["active_count"] = sum(1 for v in markers["files"].values() if v.get("exists"))
    return markers


def extract_script_refs(commands: list[str]) -> list[str]:
    refs = set()
    for cmd in commands:
        # Conservative extraction of Busdriver-relative script paths from hook command strings.
        for m in re.finditer(r"(?:(?:hooks|scripts|skills)/[^\"'\s;]+)", cmd):
            refs.add(m.group(0))
    return sorted(refs)


def git_argv(*args: str) -> list[str]:
    """Build one OS-sandboxed, transport-closed Git observation argv."""
    return git_observation_argv(*args)


GIT_OBSERVATION_INERT_CONFIG = (
    "core.fsmonitor=false", "core.hooksPath=/dev/null", "log.showSignature=false",
    "gpg.program=false", "gpg.ssh.program=false", "gpg.x509.program=false",
    "diff.external=", "core.pager=cat", "core.sshCommand=false", "core.editor=false",
    "core.askPass=", "credential.helper=",
    "protocol.allow=never", "protocol.file.allow=never", "protocol.ext.allow=never",
    "submodule.recurse=false", "fetch.recurseSubmodules=false", "status.showUntrackedFiles=all",
    "core.fileMode=true",
)
GIT_OBSERVATION_SANDBOX_PROFILE = (
    '(version 1) (allow default) (deny network*) (deny file-write*) '
    '(allow file-write* (literal "/dev/null")) (deny process-exec) '
    '(allow process-exec (literal "/Library/Developer/CommandLineTools/usr/bin/git"))'
)
GIT_OBSERVATION_ENV_ALLOWLIST = {
    "HOME", "TMPDIR", "TMP", "TEMP", "LANG", "LC_ALL", "LC_CTYPE",
    "USER", "LOGNAME", "TERM", "NO_COLOR",
}


def git_observation_env(source: dict[str, str] | None = None) -> dict[str, str]:
    ambient = os.environ if source is None else source
    env = {key: value for key, value in ambient.items() if key in GIT_OBSERVATION_ENV_ALLOWLIST or key.startswith("LC_")}
    env.update({
        "PATH": CONTAINED_PATH, "GIT_CONFIG_NOSYSTEM": "1", "GIT_CONFIG_GLOBAL": os.devnull,
        "GIT_TERMINAL_PROMPT": "0", "GIT_PAGER": "cat", "GIT_OPTIONAL_LOCKS": "0",
        "GIT_NO_LAZY_FETCH": "1", "GIT_ALLOW_PROTOCOL": "",
    })
    return env


def git_observation_argv(*args: str) -> list[str]:
    safe_args = list(args)
    if "status" in safe_args:
        safe_args = [
            arg for arg in safe_args
            if not arg.startswith("--untracked-files") and not arg.startswith("--ignore-submodules")
        ]
        at = safe_args.index("status") + 1
        safe_args[at:at] = ["--untracked-files=all", "--ignore-submodules=none"]
    if "diff" in safe_args:
        at = safe_args.index("diff") + 1
        for flag in reversed(("--no-ext-diff", "--no-textconv")):
            if flag not in safe_args:
                safe_args.insert(at, flag)
    try:
        sandbox = trusted_executable_path("sandbox-exec")
        git_real = trusted_executable_path("git-real")
    except SystemExit as exc:
        raise OSError(_refusal_reason(exc)) from exc
    global_options = ["--no-pager"]
    for pin in GIT_OBSERVATION_INERT_CONFIG:
        global_options.extend(("-c", pin))
    return [str(sandbox), "-p", GIT_OBSERVATION_SANDBOX_PROFILE, str(git_real), *global_options, *safe_args]


def git_observation_stderr_refused(cmd: list[str], stderr: str | bytes | None) -> bool:
    """A zero exit with Git errors is not an observation; it is partial, untrusted output."""
    prefix = [
        str(TRUSTED_EXECUTABLE_SOURCES["sandbox-exec"]), "-p",
        GIT_OBSERVATION_SANDBOX_PROFILE, str(TRUSTED_EXECUTABLE_SOURCES["git-real"]),
    ]
    return bool(stderr) and cmd[:4] == prefix


def git_status(repo: str | None) -> dict[str, Any] | None:
    """Observe the worktree, or say plainly that it could not be observed.

    An unresolvable trusted git is one of the ways it cannot be observed, and it is reported the
    same way as any other: this probe is the one an operator runs to find out what is broken, so
    dying on a git it cannot authenticate would take every unrelated diagnostic in the envelope —
    Busdriver root, config, hooks, routes, markers, locks — down with it. The refusal is still
    fail-closed and still names itself; it just does not get to be fatal here.
    """
    if not repo:
        return None
    path = Path(repo).expanduser().resolve()
    try:
        return _observed_git_status(path)
    except OSError as exc:
        return {"path": str(path), "is_git_repo": False, "observed": False, "error": str(exc)}


def _observed_git_status(path: Path) -> dict[str, Any] | None:
    """Every git call below has its return code checked. r25 checked only --show-toplevel and then
    read `.stdout` from each later call regardless of exit status: a failed or timed-out
    `status --porcelain` yields empty stdout, which is byte-identical to a clean tree, so the
    envelope reported dirty=false with an empty porcelain list and no error anywhere — a clean
    repository state that was never observed. Branch and HEAD had the same shape, emitting "" as
    if it were identity. An unobserved repo must block, never certify. This is the sibling of
    delivery-status.repo_status, which already fails closed this way.
    """
    root_result = run(git_argv("rev-parse", "--show-toplevel"), cwd=path)
    if not root_result["ok"]:
        return {"path": str(path), "is_git_repo": False, "observed": False, "error": root_result["stderr"] or root_result["stdout"]}
    root = Path(root_result["stdout"])
    observations = {
        "branch": run(git_argv("branch", "--show-current"), cwd=root),
        "status": run(git_argv("status", "--porcelain=v1", "-z"), cwd=root),
        "head": run(git_argv("rev-parse", "--short", "HEAD"), cwd=root),
        "git_dir": run(git_argv("rev-parse", "--git-dir"), cwd=root),
    }
    failed = next((label for label, result in observations.items() if not result["ok"]), None)
    if failed is not None:
        cp = observations[failed]
        return {
            "path": str(path),
            "is_git_repo": True,
            "observed": False,
            "root": str(root),
            "error": "git_observation_failed",
            "observation_failed": failed,
            "returncode": cp["returncode"],
            "stderr": cp["stderr"],
            "branch": None,
            "head": None,
            "head_commit_time": None,
            "dirty": None,
            "porcelain": [],
            "states": {},
        }
    # HEAD's commit time is the one call whose failure is tolerable: a repo with an unborn HEAD
    # has no commit to time, and the freshness comparison already treats None as "cannot compare".
    head_time = run(git_argv("show", "-s", "--format=%ct", "HEAD"), cwd=root)
    git_dir_stdout = observations["git_dir"]["stdout"]
    git_dir_path = (root / git_dir_stdout).resolve() if not Path(git_dir_stdout).is_absolute() else Path(git_dir_stdout)
    lines = porcelain_entries(observations["status"].get("stdout_bytes") or b"")
    return {
        "path": str(path),
        "is_git_repo": True,
        "observed": True,
        "root": str(root),
        "branch": observations["branch"]["stdout"],
        "head": observations["head"]["stdout"],
        "head_commit_time": int(head_time["stdout"])
        if head_time["ok"] and head_time["stdout"].isdigit()
        else None,
        "dirty": bool(lines),
        "porcelain": lines,
        "states": {
            "merge_head": (git_dir_path / "MERGE_HEAD").exists(),
            "rebase_apply": (git_dir_path / "rebase-apply").exists(),
            "rebase_merge": (git_dir_path / "rebase-merge").exists(),
            "cherry_pick_head": (git_dir_path / "CHERRY_PICK_HEAD").exists(),
        },
    }


def relay_state_root(arg: str | None = None) -> Path:
    if arg:
        return Path(arg).expanduser().resolve()
    return Path(os.environ.get("HERMES_BUSDRIVER_RELAY_STATE", Path.home() / ".hermes" / "busdriver-relay")).expanduser().resolve()


def _strip_release_tokens(node: Any) -> Any:
    if isinstance(node, dict):
        return {key: _strip_release_tokens(value) for key, value in node.items() if key != "token"}
    if isinstance(node, list):
        return [_strip_release_tokens(value) for value in node]
    return node


def public_lock(lock: dict[str, Any]) -> dict[str, Any]:
    """A lock payload with its release token stripped at every depth.

    Mirrors hermes-busdriver-lock.public_lock(): `token` is the ONLY authenticator `release`
    checks, so it is a capability, not evidence, and a reader who is not the acquiring holder
    must never receive it. status is the sharpest case — it is read-only, it publishes to
    anyone, and it reads lock.json off disk rather than going through the lock CLI, so it is the
    one consumer that can republish a token the lock's own public_lock() never got to strip.

    The recursion is the deliberate difference from the lock's copy. The lock strips a payload it
    just built and whose shape it therefore knows; status strips payloads it did not construct
    and cannot constrain, so `token` under any nesting is still the capability.
    """
    published = _strip_release_tokens(lock)
    published["token_redacted"] = True
    return published


def relay_lock_summary(repo_status: dict[str, Any] | None, operation: str, relay_state_dir: str | None) -> dict[str, Any]:
    root = relay_state_root(relay_state_dir)
    locks_root = root / "locks"
    locks = []
    active_for_repo = []
    repo_root = repo_status.get("root") if repo_status else None
    for path in sorted(locks_root.glob("*.lock")) if locks_root.exists() else []:
        try:
            payload = json.loads((path / "lock.json").read_text())
        except Exception:
            payload = {"parse_error": True}
        if not isinstance(payload, dict):
            # Parsing said "valid JSON", not "a lock". r26 assumed the difference did not matter
            # and assigned payload["path"] straight after, which a JSON array or scalar turns into
            # an uncaught TypeError that takes the whole probe down — and readiness forwards the
            # caller's --relay-state-dir into exactly this loop.
            payload = {"parse_error": True, "reason": "lock_payload_not_object"}
        # Strip before anything else touches the payload: every downstream list here is published.
        payload = public_lock(payload)
        payload["path"] = str(path)
        locks.append(payload)
        lock_repo = (payload.get("repo") or {} if isinstance(payload.get("repo"), dict) else {}).get("root")
        lock_operation = payload.get("operation")
        if repo_root and lock_repo == repo_root and lock_operation == operation:
            active_for_repo.append(payload)
    return {
        "state_dir": str(root),
        "operation": operation,
        "count": len(locks),
        "active_for_repo": active_for_repo,
        "active_for_repo_count": len(active_for_repo),
    }


def resolver_env() -> dict[str, str]:
    # Same allowlist as child_env, but the resolver shells out to CLIs that live in the
    # Homebrew/local prefixes, so its PATH is the contained PATH plus those two fixed roots.
    # BASH_ENV/ENV would let a caller inject a startup file into the verified bytes' own shell.
    env = child_env()
    env["PATH"] = f"{CONTAINED_PATH}:/usr/local/bin"
    return env


def trusted_resolver_bytes(root: Path) -> tuple[bytes | None, dict[str, Any] | None]:
    """Authenticate the resolver before it is allowed to run.

    --plugin-root and BUSDRIVER_PLUGIN_ROOT are caller-controlled, so executing whatever
    resolve-cli.sh sits under them is arbitrary code execution for anyone who can place a file.
    The resolver only ever runs when it is the canonical install AND its bytes match the pinned
    digest; the caller's root is a claim to be checked, never an instruction to be obeyed.
    """
    try:
        canonical = CANONICAL_PLUGIN_ROOT.expanduser().resolve(strict=True)
    except OSError:
        return None, {"ok": False, "error": "plugin_root_untrusted", "detail": "canonical_plugin_root_unavailable"}
    try:
        claimed = root.expanduser().resolve(strict=True)
    except OSError:
        return None, {"ok": False, "error": "plugin_root_untrusted", "detail": "plugin_root_unresolvable"}
    if claimed != canonical:
        return None, {"ok": False, "error": "plugin_root_untrusted", "detail": "plugin_root_is_not_the_canonical_busdriver_install"}
    script = canonical / TRUSTED_RESOLVER_REL
    if script.is_symlink() or not script.is_file():
        return None, {"ok": False, "error": "plugin_root_integrity_failed", "detail": "resolver_must_be_a_non_symlink_regular_file"}
    try:
        content = script.read_bytes()
    except OSError as e:
        return None, {"ok": False, "error": "plugin_root_integrity_failed", "detail": f"resolver_unreadable: {e}"}
    if hashlib.sha256(content).hexdigest() != TRUSTED_RESOLVER_SHA256:
        return None, {"ok": False, "error": "plugin_root_integrity_failed", "detail": "resolver_digest_mismatch"}
    return content, None


def resolve_cli(root: Path) -> dict[str, Any]:
    content, failure = trusted_resolver_bytes(root)
    if failure is not None:
        return failure
    # Execute the verified bytes over stdin rather than re-opening the pathname: a re-open would
    # reintroduce the TOCTOU window the digest check just closed.
    res = run(
        ["/bin/bash", "-s", "--", "--json"],
        cwd=CANONICAL_PLUGIN_ROOT.expanduser().resolve(),
        timeout=20,
        stdin_bytes=content,
        env=resolver_env(),
    )
    if not res["ok"]:
        return res
    try:
        return {"ok": True, "data": json.loads(res["stdout"])}
    except json.JSONDecodeError as e:
        return {"ok": False, "error": f"invalid json: {e}", "raw": res["stdout"]}


def main() -> int:
    ap = argparse.ArgumentParser(description="Read-only Hermes ↔ Busdriver status probe")
    ap.add_argument("--plugin-root", help="Busdriver plugin root (default: env or ~/.claude/plugins/marketplaces/busdriver)")
    ap.add_argument("--state-dir", default=os.environ.get("BUSDRIVER_STATE_DIR", ".claude"), help="Busdriver state dir name (default: .claude)")
    ap.add_argument("--user-config", help="Busdriver user config path (default: ~/<state-dir>/busdriver.json)")
    ap.add_argument("--relay-config", help="Hermes relay config JSON path (default: <relay-state-dir>/config.json)")
    ap.add_argument("--repo", help="Project repo/worktree to inspect read-only")
    ap.add_argument("--relay-state-dir", help="Hermes Busdriver Relay state dir for lock summary")
    ap.add_argument("--operation", default="repo-mutation", help="Operation class for lock summary")
    ap.add_argument("--drift-baseline", help="Read-only Busdriver drift baseline JSON to compare against")
    ap.add_argument("--no-external-resolver", action="store_true", help="Do not execute plugin-root resolver bytes")
    ap.add_argument("--pretty", action="store_true", help="Pretty-print JSON")
    args = ap.parse_args()

    root = resolve_plugin_root(args.plugin_root)
    hooks = hook_inventory(root)
    hook_refs = extract_script_refs(hooks.get("commands", []))
    repo = git_status(args.repo)
    resolver = {"ok": False, "error": "external_resolver_disabled"} if args.no_external_resolver else resolve_cli(root)
    cfg_status = user_config_status(args.state_dir, args.user_config)
    cfg_data, _cfg_err = read_json(Path(cfg_status["path"]))
    if not isinstance(cfg_data, dict):
        cfg_data = {}
    relay_cfg_status, relay_cfg_data = relay_config_status(args.relay_config, args.relay_state_dir)
    package = package_status(root)
    hashes = critical_file_hashes(root, hook_refs)
    out = {
        "status_schema": "hermes-busdriver-status/v0",
        "read_only": True,
        "plugin_root": {"path": str(root), "exists": root.exists()},
        "state_dir": args.state_dir,
        "package": package,
        "user_config": cfg_status,
        "relay_config": relay_cfg_status,
        "hooks": hooks,
        "hook_script_refs": {rel: (root / rel).exists() for rel in hook_refs},
        "key_entrypoints": file_presence(root, KEY_ENTRYPOINTS),
        "minimum_gate_scripts": file_presence(root, MIN_GATE_SCRIPTS),
        "critical_file_hashes": hashes,
        "busdriver_drift": drift_baseline_status(args.drift_baseline, package, hashes),
        "resolve_cli": resolver,
        "effective_routes": effective_routes(cfg_data, resolver),
        "relay_equivalent_roles": relay_equivalent_roles(
            relay_cfg_data, relay_cfg_status.get("parse_error"), relay_cfg_status.get("shape_error")
        ),
        "repo": repo,
        "active_markers": active_markers(repo, args.state_dir),
        "relay_locks": relay_lock_summary(repo, args.operation, args.relay_state_dir),
    }
    json.dump(out, sys.stdout, indent=2 if args.pretty else None, sort_keys=True)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
