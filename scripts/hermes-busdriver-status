def run(cmd: list[str], cwd: Path | None = None, timeout: int = 10) -> dict[str, Any]:
    try:
        p = subprocess.run(cmd, cwd=str(cwd) if cwd else None, text=True, capture_output=True, timeout=timeout)
        return {"ok": p.returncode == 0, "returncode": p.returncode, "stdout": p.stdout.strip(), "stderr": p.stderr.strip()}
    except FileNotFoundError as e:
        return {"ok": False, "returncode": 127, "stdout": "", "stderr": str(e)}
    except subprocess.TimeoutExpired:
        return {"ok": False, "returncode": 124, "stdout": "", "stderr": f"timeout after {timeout}s"}


def read_json(path: Path) -> tuple[Any | None, str | None]:
    try:
        return json.loads(path.read_text()), None
    except Exception as e:  # noqa: BLE001 - status probe should report parse errors
        return None, str(e)


def resolve_plugin_root(arg: str | None) -> Path:
    candidates = []
    if arg:
        candidates.append(Path(arg).expanduser())
    for env_name in ("BUSDRIVER_PLUGIN_ROOT", "CLAUDE_PLUGIN_ROOT"):
        if os.environ.get(env_name):
            candidates.append(Path(os.environ[env_name]).expanduser())
    candidates.append(Path.home() / ".claude/plugins/marketplaces/busdriver")
    for c in candidates:
        if c.exists():
            return c.resolve()
    return candidates[0].resolve()


def package_status(root: Path) -> dict[str, Any]:
    pkg = root / "package.json"
    data, err = read_json(pkg)
    return {
        "path": str(pkg),
        "exists": pkg.exists(),
        "parse_error": err,
        "name": data.get("name") if isinstance(data, dict) else None,
        "version": data.get("version") if isinstance(data, dict) else None,
    }


def user_config_status(state_dir: str, user_config: str | None = None) -> dict[str, Any]:
    cfg = Path(user_config).expanduser() if user_config else Path.home() / state_dir / "busdriver.json"
    data, err = read_json(cfg)
    routes = data.get("routes", {}) if isinstance(data, dict) else {}
    return {
        "path": str(cfg),
        "exists": cfg.exists(),
        "parse_error": err,
        "route_keys": sorted(routes.keys()) if isinstance(routes, dict) else [],
        "ultra_oracle_enabled_keys": sorted((data.get("ultraOracle") or {}).keys()) if isinstance(data, dict) else [],
    }


def relay_config_status(relay_config: str | None = None, relay_state_dir: str | None = None) -> tuple[dict[str, Any], dict[str, Any]]:
    cfg = Path(relay_config).expanduser() if relay_config else relay_state_root(relay_state_dir) / "config.json"
    if not cfg.exists():
        return {
            "path": str(cfg),
            "exists": False,
            "parse_error": None,
            "route_keys": [],
        }, {}
    data, err = read_json(cfg)
    shape_error = None if err or isinstance(data, dict) else "config_must_be_object"
    routes = data.get("routes", {}) if isinstance(data, dict) else {}
    return {
        "path": str(cfg),
        "exists": True,
        "parse_error": err,
        "shape_error": shape_error,
        "route_keys": sorted(routes.keys()) if isinstance(routes, dict) else [],
    }, data if isinstance(data, dict) else {}


def hook_inventory(root: Path) -> dict[str, Any]:
    path = root / "hooks/hooks.json"
    data, err = read_json(path)
    inv: dict[str, Any] = {"path": str(path), "exists": path.exists(), "parse_error": err, "events": {}, "commands": []}
    if not isinstance(data, dict):
        return inv
    hooks = data.get("hooks", {})
    if not isinstance(hooks, dict):
        return inv
    commands: list[str] = []
    for event, entries in hooks.items():
        event_info = {"entries": 0, "matchers": [], "descriptions": []}
        if isinstance(entries, list):
            event_info["entries"] = len(entries)
            for entry in entries:
                if not isinstance(entry, dict):
                    continue
                if "matcher" in entry:
                    event_info["matchers"].append(entry.get("matcher"))
                if "description" in entry:
                    event_info["descriptions"].append(entry.get("description"))
                for h in entry.get("hooks", []) or []:
                    if isinstance(h, dict) and h.get("command"):
                        commands.append(h["command"])
        inv["events"][event] = event_info
    inv["commands"] = commands
    return inv


def file_presence(root: Path, rels: list[str]) -> dict[str, bool]:
    return {rel: (root / rel).exists() for rel in rels}


def sha256_file(path: Path) -> str | None:
    if not path.is_file():
        return None
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def critical_file_hashes(root: Path, hook_refs: list[str]) -> dict[str, Any]:
    rels = sorted(set(KEY_ENTRYPOINTS + MIN_GATE_SCRIPTS + hook_refs))
    out: dict[str, Any] = {}
    for rel in rels:
        path = root / rel
        if path.is_file():
            st = path.stat()
            out[rel] = {"exists": True, "sha256": sha256_file(path), "size": st.st_size, "mtime": int(st.st_mtime)}
        else:
            out[rel] = {"exists": path.exists(), "sha256": None, "size": None, "mtime": None}
    return out


def drift_baseline_status(baseline_arg: str | None, package: dict[str, Any], hashes: dict[str, Any]) -> dict[str, Any] | None:
    if not baseline_arg:
        return None
    path = Path(baseline_arg).expanduser().resolve()
    flags = {
        "commit_allowed": False,
        "push_allowed": False,
        "pr_allowed": False,
        "merge_allowed": False,
        "deploy_allowed": False,
        "marker_write_allowed": False,
    }
    base: dict[str, Any] = {
        "schema": "hermes-busdriver-drift/v0",
        "baseline_path": str(path),
        "baseline_exists": path.exists(),
        "read_only": True,
        "finalization_flags": flags,
    }
    if not path.exists():
        return {
            **base,
            "status": "baseline_missing",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_missing"],
            "parse_error": None,
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    data, err = read_json(path)
    if not isinstance(data, dict):
        return {
            **base,
            "status": "baseline_invalid",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_invalid"],
            "parse_error": err or "baseline root is not a JSON object",
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    for key, expected in {
        "status_schema": "hermes-busdriver-status/v0",
        "schema": "hermes-busdriver-drift/v0",
    }.items():
        declared = data.get(key)
        if declared is not None and declared != expected:
            return {
                **base,
                "status": "baseline_invalid",
                "finalization_compatible": False,
                "finalization_disabled_reasons": ["baseline_invalid"],
                "parse_error": f"unsupported {key}: {declared}",
                "package_version_changed": False,
                "added": [],
                "removed": [],
                "changed": [],
                "missing": [],
            }

    expected_hashes = data.get("critical_file_hashes")
    if not isinstance(expected_hashes, dict):
        return {
            **base,
            "status": "baseline_invalid",
            "finalization_compatible": False,
            "finalization_disabled_reasons": ["baseline_invalid"],
            "parse_error": "missing critical_file_hashes object",
            "package_version_changed": False,
            "added": [],
            "removed": [],
            "changed": [],
            "missing": [],
        }

    expected_package = data.get("package") if isinstance(data.get("package"), dict) else {}
    expected_version = expected_package.get("version")
    current_version = package.get("version")
    package_version_changed = expected_version is not None and expected_version != current_version
    expected_keys = set(expected_hashes)
    current_keys = set(hashes)
    added = sorted(current_keys - expected_keys)
    removed = sorted(expected_keys - current_keys)
    changed: list[str] = []
    missing: list[str] = []
    for rel in sorted(expected_keys & current_keys):
        expected = expected_hashes.get(rel) if isinstance(expected_hashes.get(rel), dict) else {}
        current = hashes.get(rel) if isinstance(hashes.get(rel), dict) else {}
        if expected.get("exists") is True and current.get("exists") is not True:
            missing.append(rel)
        if expected.get("sha256") != current.get("sha256") or expected.get("exists") != current.get("exists"):
            changed.append(rel)

    reasons: list[str] = []
    if package_version_changed:
        reasons.append("package_version_changed")
    if added or removed or changed or missing:
        reasons.append("baseline_drift")
    compatible = not reasons
    return {
        **base,
        "status": "compatible" if compatible else "drifted",
        "finalization_compatible": compatible,
        "finalization_disabled_reasons": reasons,
        "parse_error": None,
        "baseline_package_version": expected_version,
        "current_package_version": current_version,
        "package_version_changed": package_version_changed,
        "compared_count": len(expected_keys & current_keys),
        "added": added,
        "removed": removed,
        "changed": changed,
        "missing": missing,
    }


def effective_routes(user_cfg: dict[str, Any], resolved_cli: dict[str, Any]) -> dict[str, Any]:
    routes = user_cfg.get("routes", {}) if isinstance(user_cfg, dict) else {}
    clis = ((resolved_cli.get("data") or {}).get("clis") or {}) if resolved_cli.get("ok") else {}
    result: dict[str, Any] = {}
    for role, default_route in DEFAULT_ROLE_ROUTES.items():
        configured = routes.get(role, default_route) if isinstance(routes, dict) else default_route
        if isinstance(configured, str):
            route = [configured]
        elif isinstance(configured, list):
            route = [str(x) for x in configured]
        else:
            route = list(default_route)
        resolved = None
        unavailable = []
        for cli in route:
            info = clis.get(cli)
            if info and info.get("available") is True:
                resolved = cli
                break
            unavailable.append(cli)
        result[role] = {
            "route": route,
            "source": "user" if isinstance(routes, dict) and role in routes else "default",
            "resolved": resolved,
            "available": resolved is not None,
            "unavailable_before_resolution": unavailable if resolved else route,
        }
    return result


def relay_equivalent_roles(
    relay_cfg: dict[str, Any], relay_config_parse_error: str | None = None, relay_config_shape_error: str | None = None
) -> dict[str, Any]:
    if not isinstance(relay_cfg, dict):
        relay_cfg = {}
    routes_config_error = None
    raw_routes = relay_cfg.get("routes", {})
    if relay_config_parse_error:
        routes_config_error = "config_parse_error"
        routes = {}
    elif relay_config_shape_error:
        routes_config_error = relay_config_shape_error
        routes = {}
    elif "routes" in relay_cfg and not isinstance(raw_routes, dict):
        routes_config_error = "routes_must_be_object"
        routes = {}
    else:
        routes = raw_routes
    configured_coding_agent = relay_cfg.get("coding_agent")
    coding_agent_config_error = None
    if "coding_agent" in relay_cfg and (not isinstance(configured_coding_agent, str) or not configured_coding_agent):
        coding_agent_config_error = "coding_agent_must_be_non_empty_string"
    coding_agent = configured_coding_agent if coding_agent_config_error is None and isinstance(configured_coding_agent, str) else DEFAULT_RELAY_CODING_AGENT
    configured_avoid = relay_cfg.get("avoid_coding_agent_for_review")
    avoid_config_error = None
    if "avoid_coding_agent_for_review" in relay_cfg and not isinstance(configured_avoid, bool):
        avoid_config_error = "avoid_coding_agent_for_review_must_be_boolean"
    avoid = configured_avoid if avoid_config_error is None and isinstance(configured_avoid, bool) else DEFAULT_RELAY_AVOID_CODING_AGENT_FOR_REVIEW
    roles: dict[str, Any] = {}
    for role, defaults in DEFAULT_RELAY_EQUIVALENT_ROUTES.items():
        default_route = defaults["route"]
        configured = routes.get(role, default_route)
        config_error = None
        if routes_config_error is not None:
            route = []
            config_error = routes_config_error
        elif isinstance(configured, str):
            route = [configured] if configured else []
        elif isinstance(configured, list):
            if all(isinstance(x, str) and x for x in configured):
                route = list(configured)
            else:
                route = []
                config_error = "route_entries_must_be_non_empty_strings"
        else:
            if role in routes:
                route = []
                config_error = "route_must_be_string_or_array"
            else:
                route = list(default_route)
        if not route and config_error is None:
            config_error = "empty_route"
        selected = next((agent for agent in route if not avoid or agent != coding_agent), route[0] if route else None)
        same_as_coding_agent = selected == coding_agent
        roles[role] = {
            "native_busdriver_role": defaults["native_busdriver_role"],
            "configured_route": route,
            "default_route": list(default_route),
            "source": "relay_config" if role in routes or routes_config_error is not None else "default",
            "selected_agent": selected,
            "same_as_coding_agent": same_as_coding_agent,
            "degraded": bool(config_error) or (avoid and same_as_coding_agent),
            "config_error": config_error,
            "configurable": True,
            "not_busdriver_native_claude_runtime": True,
            "finalization_allowed": False,
            "mutation_allowed": False,
        }
    return {
        "coding_agent": coding_agent,
        "coding_agent_source": "relay_config" if "coding_agent" in relay_cfg and coding_agent_config_error is None else "default",
        "coding_agent_config_error": coding_agent_config_error,
        "avoid_coding_agent_for_review": avoid,
        "avoid_coding_agent_for_review_source": "relay_config" if "avoid_coding_agent_for_review" in relay_cfg and avoid_config_error is None else "default",
        "avoid_coding_agent_for_review_config_error": avoid_config_error,
        "routes_config_error": routes_config_error,
        "relay_config_parse_error": relay_config_parse_error,
        "relay_config_shape_error": relay_config_shape_error,
        "roles": roles,
    }


def active_markers(repo_status: dict[str, Any] | None, state_dir: str) -> dict[str, Any] | None:
    if repo_status is None:
        return None
    if not repo_status.get("is_git_repo") or not repo_status.get("root"):
        return None
    root = Path(repo_status["root"])
    state = root / state_dir
    markers: dict[str, Any] = {"state_dir": str(state), "exists": state.exists(), "files": {}}
    now = time.time()
    repo_head_commit_time = repo_status.get("head_commit_time")
    for name in MARKER_FILES:
        path = state / name
        if path.exists():
            st = path.stat()
            marker_mtime = int(st.st_mtime)
            marker_age_sec = int(now - st.st_mtime)
            entry: dict[str, Any] = {
                "exists": True,
                "size": st.st_size,
                "mtime": marker_mtime,
                "age_sec": marker_age_sec,
                "freshness": {
                    "compared_to_repo_head": repo_status.get("head"),
                    "repo_branch": repo_status.get("branch"),
                    "repo_dirty": repo_status.get("dirty"),
                    "marker_mtime": marker_mtime,
                    "marker_age_sec": marker_age_sec,
                    "repo_head_commit_time": repo_head_commit_time,
                    "marker_mtime_after_repo_head_commit_time": None
                    if repo_head_commit_time is None
                    else marker_mtime > repo_head_commit_time,
                },
            }
            if st.st_size <= 4096 and path.is_file() and name not in {"bypass-log.jsonl"}:
                try:
                    first = path.read_text(errors="replace").splitlines()[:3]
                    entry["preview_lines"] = first
                except OSError:
                    entry["preview_lines"] = []
            markers["files"][name] = entry
        else:
            markers["files"][name] = {"exists": False}
    markers["active_count"] = sum(1 for v in markers["files"].values() if v.get("exists"))
    return markers


def extract_script_refs(commands: list[str]) -> list[str]:
    refs = set()
    for cmd in commands:
        # Conservative extraction of Busdriver-relative script paths from hook command strings.
        for m in re.finditer(r"(?:(?:hooks|scripts|skills)/[^\"'\s;]+)", cmd):
            refs.add(m.group(0))
    return sorted(refs)


def git_status(repo: str | None) -> dict[str, Any] | None:
    if not repo:
        return None
    path = Path(repo).expanduser().resolve()
    root_result = run(["git", "rev-parse", "--show-toplevel"], cwd=path)
    if not root_result["ok"]:
        return {"path": str(path), "is_git_repo": False, "error": root_result["stderr"] or root_result["stdout"]}
    root = Path(root_result["stdout"])
    branch = run(["git", "branch", "--show-current"], cwd=root)
    status = run(["git", "status", "--porcelain=v1"], cwd=root)
    head = run(["git", "rev-parse", "--short", "HEAD"], cwd=root)
    head_time = run(["git", "show", "-s", "--format=%ct", "HEAD"], cwd=root)
    git_dir = run(["git", "rev-parse", "--git-dir"], cwd=root)
    git_dir_path = (root / git_dir["stdout"]).resolve() if git_dir["ok"] and not Path(git_dir["stdout"]).is_absolute() else Path(git_dir["stdout"]) if git_dir["ok"] else None
    states = {}
    if git_dir_path:
        states = {
            "merge_head": (git_dir_path / "MERGE_HEAD").exists(),
            "rebase_apply": (git_dir_path / "rebase-apply").exists(),
            "rebase_merge": (git_dir_path / "rebase-merge").exists(),
            "cherry_pick_head": (git_dir_path / "CHERRY_PICK_HEAD").exists(),
        }
    lines = status["stdout"].splitlines() if status["stdout"] else []
    return {
        "path": str(path),
        "is_git_repo": True,
        "root": str(root),
        "branch": branch["stdout"],
        "head": head["stdout"],
        "head_commit_time": int(head_time["stdout"])
        if head_time["ok"] and head_time["stdout"].isdigit()
        else None,
        "dirty": bool(lines),
        "porcelain": lines,
        "states": states,
    }


def relay_state_root(arg: str | None = None) -> Path:
    if arg:
        return Path(arg).expanduser().resolve()
    return Path(os.environ.get("HERMES_BUSDRIVER_RELAY_STATE", Path.home() / ".hermes" / "busdriver-relay")).expanduser().resolve()


def relay_lock_summary(repo_status: dict[str, Any] | None, operation: str, relay_state_dir: str | None) -> dict[str, Any]:
    root = relay_state_root(relay_state_dir)
    locks_root = root / "locks"
    locks = []
    active_for_repo = []
    repo_root = repo_status.get("root") if repo_status else None
    for path in sorted(locks_root.glob("*.lock")) if locks_root.exists() else []:
        try:
            payload = json.loads((path / "lock.json").read_text())
        except Exception:
            payload = {"parse_error": True}
        payload["path"] = str(path)
        locks.append(payload)
        lock_repo = ((payload.get("repo") or {}) if isinstance(payload, dict) else {}).get("root")
        lock_operation = payload.get("operation") if isinstance(payload, dict) else None
        if repo_root and lock_repo == repo_root and lock_operation == operation:
            active_for_repo.append(payload)
    return {
        "state_dir": str(root),
        "operation": operation,
        "count": len(locks),
        "active_for_repo": active_for_repo,
        "active_for_repo_count": len(active_for_repo),
    }


def resolve_cli(root: Path) -> dict[str, Any]:
    script = root / "scripts/lib/resolve-cli.sh"
    if not script.exists():
        return {"ok": False, "error": "missing scripts/lib/resolve-cli.sh"}
    res = run(["bash", str(script), "--json"], cwd=root, timeout=20)
    if not res["ok"]:
        return res
    try:
        return {"ok": True, "data": json.loads(res["stdout"])}
    except json.JSONDecodeError as e:
        return {"ok": False, "error": f"invalid json: {e}", "raw": res["stdout"]}


def main() -> int:
    ap = argparse.ArgumentParser(description="Read-only Hermes ↔ Busdriver status probe")
    ap.add_argument("--plugin-root", help="Busdriver plugin root (default: env or ~/.claude/plugins/marketplaces/busdriver)")
    ap.add_argument("--state-dir", default=os.environ.get("BUSDRIVER_STATE_DIR", ".claude"), help="Busdriver state dir name (default: .claude)")
    ap.add_argument("--user-config", help="Busdriver user config path (default: ~/<state-dir>/busdriver.json)")
    ap.add_argument("--relay-config", help="Hermes relay config JSON path (default: <relay-state-dir>/config.json)")
    ap.add_argument("--repo", help="Project repo/worktree to inspect read-only")
    ap.add_argument("--relay-state-dir", help="Hermes Busdriver Relay state dir for lock summary")
    ap.add_argument("--operation", default="repo-mutation", help="Operation class for lock summary")
    ap.add_argument("--drift-baseline", help="Read-only Busdriver drift baseline JSON to compare against")
    ap.add_argument("--pretty", action="store_true", help="Pretty-print JSON")
    args = ap.parse_args()

    root = resolve_plugin_root(args.plugin_root)
    hooks = hook_inventory(root)
    hook_refs = extract_script_refs(hooks.get("commands", []))
    repo = git_status(args.repo)
    resolver = resolve_cli(root)
    cfg_status = user_config_status(args.state_dir, args.user_config)
    cfg_data, _cfg_err = read_json(Path(cfg_status["path"]))
    if not isinstance(cfg_data, dict):
        cfg_data = {}
    relay_cfg_status, relay_cfg_data = relay_config_status(args.relay_config, args.relay_state_dir)
    package = package_status(root)
    hashes = critical_file_hashes(root, hook_refs)
    out = {
        "status_schema": "hermes-busdriver-status/v0",
        "read_only": True,
        "plugin_root": {"path": str(root), "exists": root.exists()},
        "state_dir": args.state_dir,
        "package": package,
        "user_config": cfg_status,
        "relay_config": relay_cfg_status,
        "hooks": hooks,
        "hook_script_refs": {rel: (root / rel).exists() for rel in hook_refs},
        "key_entrypoints": file_presence(root, KEY_ENTRYPOINTS),
        "minimum_gate_scripts": file_presence(root, MIN_GATE_SCRIPTS),
        "critical_file_hashes": hashes,
        "busdriver_drift": drift_baseline_status(args.drift_baseline, package, hashes),
        "resolve_cli": resolver,
        "effective_routes": effective_routes(cfg_data, resolver),
        "relay_equivalent_roles": relay_equivalent_roles(
            relay_cfg_data, relay_cfg_status.get("parse_error"), relay_cfg_status.get("shape_error")
        ),
        "repo": repo,
        "active_markers": active_markers(repo, args.state_dir),
        "relay_locks": relay_lock_summary(repo, args.operation, args.relay_state_dir),
    }
    json.dump(out, sys.stdout, indent=2 if args.pretty else None, sort_keys=True)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
