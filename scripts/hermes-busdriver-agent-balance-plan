#!/usr/bin/python3
"""Emit a read-only balanced agent work planning envelope.

This helper is planning metadata only. It describes a safe lane shape for one
mutating draft worker plus multiple read-only reviewers/status lanes, but it
never launches agents, calls Pi/Codex/GitHub, writes markers, or mutates repos.
"""
from __future__ import annotations

import argparse
import json
from typing import Any

SCHEMA = "hermes-busdriver-agent-balance-plan/v0"
POLICY_ID = "single_mutating_worker_multi_readonly_reviewers"

AUTHORITY: dict[str, bool] = {
    "commit_allowed": False,
    "push_allowed": False,
    "pr_allowed": False,
    "merge_allowed": False,
    "deploy_allowed": False,
    "release_allowed": False,
    "publish_allowed": False,
    "marker_write_allowed": False,
    "repo_mutation_allowed": False,
    "mutation_allowed": False,
    "finalization_allowed": False,
    "dispatch_allowed": False,
    "programmatic_execution_allowed": False,
}


def build_plan() -> dict[str, Any]:
    lanes: list[dict[str, Any]] = [
        {
            "id": "implementation_draft",
            "role": "implementation",
            "mode": "mutating_draft",
            "max_parallel": 1,
            "parallelizable": False,
            "requires_gate": True,
            "selected_agent": "codex",
            "current_agent": "codex",
            "repo_mutation_allowed": False,
            "draft_mutation_scope": "would_use_agent_draft_gate_if_separately_dispatched",
            "finalization_allowed": False,
            "commit_allowed": False,
            "push_allowed": False,
            "pr_allowed": False,
            "marker_write_allowed": False,
        },
        {
            "id": "readonly_review",
            "role": "review",
            "mode": "read_only_review",
            "max_parallel": 3,
            "parallelizable": True,
            "requires_gate": False,
            "selected_agent": None,
            "current_agent": None,
            "repo_mutation_allowed": False,
            "finalization_allowed": False,
            "commit_allowed": False,
            "push_allowed": False,
            "pr_allowed": False,
            "marker_write_allowed": False,
        },
        {
            "id": "readonly_status",
            "role": "status",
            "mode": "read_only_status",
            "max_parallel": 2,
            "parallelizable": True,
            "requires_gate": False,
            "selected_agent": None,
            "current_agent": None,
            "repo_mutation_allowed": False,
            "finalization_allowed": False,
            "commit_allowed": False,
            "push_allowed": False,
            "pr_allowed": False,
            "marker_write_allowed": False,
        },
    ]
    return {
        "schema": SCHEMA,
        "version": 0,
        "ok": True,
        "read_only": True,
        "policy": {
            "id": POLICY_ID,
            "metadata_only": True,
            "planning_only": True,
            "max_mutating_draft_workers": 1,
            "read_only_lanes_parallelizable": True,
            "main_hermes_role": "relay_router_verifier_delivery_mode_operator",
            "delivery_mode_required_for_finalization": True,
            "summary": "Select Codex as implementation-primary metadata with parallel read-only review/status lanes; this helper does not dispatch work.",
        },
        "authority": dict(AUTHORITY),
        "lanes": lanes,
        "execution": {
            "metadata_only": True,
            "planning_only": True,
            "external_agents_called": False,
            "subprocess_dispatch_called": False,
            "pi_called": False,
            "codex_called": False,
            "github_called": False,
            "marker_writes_performed": False,
            "repo_mutations_performed": False,
        },
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--pretty", action="store_true")
    args = parser.parse_args()

    print(json.dumps(build_plan(), indent=2 if args.pretty else None, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
