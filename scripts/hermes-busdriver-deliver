#!/usr/bin/env python3
"""Fail-closed Hermes delivery dispatcher."""
from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import time
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
DELIVERY_STATUS = ROOT / "scripts" / "hermes-busdriver-delivery-status"
SCHEMA = "hermes-busdriver-deliver/v0"
ARTIFACT_ENV = "HERMES_BUSDRIVER_DELIVERY_RUNS_DIR"
TAIL_LIMIT = 4000
VERIFIER_LABEL = re.compile(r"^[A-Za-z0-9_.-]+=")
BLOCKED_FLAGS = {
    "finalization_allowed": False,
    "commit_allowed": False,
    "push_allowed": False,
    "pr_allowed": False,
    "merge_allowed": False,
    "deploy_allowed": False,
    "release_allowed": False,
    "publish_allowed": False,
}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Fail-closed Hermes Delivery Mode dispatcher")
    parser.add_argument("--repo", help="Target git repo/worktree to inspect and verify")
    parser.add_argument("--plugin-root", help="Busdriver plugin root")
    parser.add_argument("--pr", help="Pull request number for post-PR status")
    parser.add_argument("--pr-grind-result-file", help="Read-only PR-grind fixture/status JSON to pass through delivery-status")
    parser.add_argument("--delivery-status-timeout", type=int, default=180, help="Seconds to wait for delivery-status before failing closed")
    parser.add_argument("--verifier-timeout", type=int, default=180, help="Seconds to wait for each verifier command")
    parser.add_argument("--mode", default="plan", choices=["plan", "execute"], help="Delivery mode; only execute verify is enabled")
    parser.add_argument("--operation", default="plan", choices=["plan", "verify"], help="Delivery operation; execute supports only verify")
    parser.add_argument(
        "--verifier",
        action="append",
        default=[],
        help="Trusted NAME=COMMAND or COMMAND executed locally with shell=False; launch errors fail closed. May be repeated for execute verify.",
    )
    parser.add_argument("--pretty", action="store_true")
    return parser.parse_args()


def tail(value: str | bytes | None, limit: int = TAIL_LIMIT) -> str:
    if isinstance(value, bytes):
        text = value.decode(errors="replace")
    else:
        text = value or ""
    return text[-limit:]


def run_delivery_status(args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    cmd = [sys.executable, str(DELIVERY_STATUS)]
    if args.repo:
        cmd += ["--repo", args.repo]
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    if args.pr:
        cmd += ["--pr", args.pr]
    if args.pr_grind_result_file:
        cmd += ["--pr-grind-result-file", args.pr_grind_result_file]

    try:
        cp = subprocess.run(cmd, text=True, capture_output=True, check=False, timeout=args.delivery_status_timeout)
    except subprocess.TimeoutExpired as e:
        return {
            "ok": False,
            "error": "delivery_status_timeout",
            "returncode": 124,
            "timeout_seconds": args.delivery_status_timeout,
            "stdout_tail": tail(e.stdout),
            "stderr": tail(e.stderr),
        }, 124

    try:
        data = json.loads(cp.stdout)
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "error": "delivery_status_invalid_json",
            "returncode": cp.returncode,
            "stdout_tail": tail(cp.stdout),
            "stderr": tail(cp.stderr.strip()),
            "parse_error": str(e),
        }, cp.returncode
    if not isinstance(data, dict):
        return {
            "ok": False,
            "error": "delivery_status_invalid_json_type",
            "returncode": cp.returncode,
            "stderr": tail(cp.stderr),
            "stdout_tail": tail(cp.stdout),
        }, cp.returncode
    if cp.returncode != 0:
        data["ok"] = False
        data["returncode"] = cp.returncode
        data["stderr"] = tail(cp.stderr)
    return data, cp.returncode


def pr_summary(pr: str | None, delivery_status: dict[str, Any]) -> dict[str, Any] | None:
    if not pr:
        return None
    pr_grind = delivery_status.get("pr_grind") or {}
    result = pr_grind.get("result") or {}
    return {
        "number": pr,
        "available": pr_grind.get("available"),
        "ok": pr_grind.get("ok"),
        "status": result.get("status"),
        "clean": result.get("clean"),
    }


def parse_verifier(item: str, index: int) -> tuple[str, str]:
    if VERIFIER_LABEL.match(item):
        name, command = item.split("=", 1)
        command = command.strip()
        if not command:
            raise ValueError("empty verifier command")
        return name.strip(), command
    command = item.strip()
    if not command:
        raise ValueError("empty verifier command")
    return f"verifier_{index}", command


def run_verifiers(repo: Path, verifiers: list[str], timeout: int) -> list[dict[str, Any]]:
    results: list[dict[str, Any]] = []
    for index, item in enumerate(verifiers, start=1):
        try:
            name, command = parse_verifier(item, index)
            argv = shlex.split(command)
            if not argv:
                raise ValueError("empty verifier command")
        except ValueError as e:
            results.append({
                "name": f"verifier_{index}",
                "command": item,
                "returncode": 2,
                "ok": False,
                "stdout_tail": "",
                "stderr_tail": str(e),
            })
            continue
        try:
            cp = subprocess.run(argv, cwd=str(repo), shell=False, text=True, capture_output=True, check=False, timeout=timeout)
            results.append({
                "name": name,
                "command": command,
                "returncode": cp.returncode,
                "ok": cp.returncode == 0,
                "stdout_tail": tail(cp.stdout),
                "stderr_tail": tail(cp.stderr),
            })
        except subprocess.TimeoutExpired as e:
            timeout_prefix = f"timeout after {timeout}s\n"
            stderr_tail = timeout_prefix + tail(e.stderr, max(0, TAIL_LIMIT - len(timeout_prefix)))
            results.append({
                "name": name,
                "command": command,
                "returncode": 124,
                "ok": False,
                "stdout_tail": tail(e.stdout),
                "stderr_tail": stderr_tail.rstrip(),
            })
        except OSError as e:
            results.append({
                "name": name,
                "command": command,
                "returncode": 127,
                "ok": False,
                "stdout_tail": "",
                "stderr_tail": tail(f"{type(e).__name__}: {e}"),
            })
    return results


def artifact_path() -> Path:
    base = Path(os.environ.get(ARTIFACT_ENV, "~/.hermes/busdriver-relay/delivery-runs")).expanduser()
    stamp = time.strftime("%Y%m%d-%H%M%S")
    return base / f"{stamp}-{os.getpid()}.json"


def write_artifact(result: dict[str, Any]) -> None:
    path = artifact_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    result["run_artifact_path"] = str(path)
    try:
        path.write_text(json.dumps(result, indent=2, sort_keys=True) + "\n")
    except OSError:
        result["run_artifact_path"] = None
        raise


def steps_for(reason: str | None) -> list[dict[str, str]]:
    if reason == "delivery_status_failed":
        return [
            {"name": "delivery_status", "status": "blocked", "reason": "helper_failed"},
            {"name": "verify", "status": "skipped", "reason": "delivery_status_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "unsupported_operation":
        return [
            {"name": "execute", "status": "blocked", "reason": "unsupported_operation"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "no_verifiers":
        return [
            {"name": "verify", "status": "blocked", "reason": "no_verifiers"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verifier_failed":
        return [
            {"name": "verify", "status": "blocked", "reason": "verifier_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "artifact_write_failed":
        return [
            {"name": "write_artifact", "status": "blocked", "reason": "artifact_write_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verified":
        return [
            {"name": "verify", "status": "passed", "reason": "local_verifiers_passed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    return [
        {"name": "review_delivery_status", "status": "pending", "reason": "plan_only"},
        {"name": "commit", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "push", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "pr", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "merge", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "deploy", "status": "blocked", "reason": "finalization_disabled"},
    ]


def decision(status: str, reason: str) -> dict[str, Any]:
    return {"status": status, "reason": reason, **BLOCKED_FLAGS}


def main() -> int:
    args = parse_args()
    delivery_status, status_rc = run_delivery_status(args)
    delivery_ok = bool(delivery_status.get("ok"))
    reason: str | None = None
    result_ok = delivery_ok
    result_decision = decision("plan_only", "read_only_plan")
    verifiers: list[dict[str, Any]] = []
    returncode = 0 if delivery_ok else (status_rc or 1)

    if not delivery_ok:
        reason = "delivery_status_failed"
        result_ok = False
        result_decision = decision("blocked", reason)
    elif args.mode == "execute":
        if args.operation != "verify":
            reason = "unsupported_operation"
            result_ok = False
            result_decision = decision("blocked", reason)
            returncode = 2
        elif not args.verifier:
            reason = "no_verifiers"
            result_ok = False
            result_decision = decision("blocked", reason)
            returncode = 2
        else:
            repo = Path(args.repo or ".").expanduser().resolve()
            verifiers = run_verifiers(repo, args.verifier, args.verifier_timeout)
            result_ok = all(v["ok"] for v in verifiers)
            reason = "verified" if result_ok else "verifier_failed"
            result_decision = decision("verified" if result_ok else "blocked", reason)
            returncode = 0 if result_ok else 1

    result = {
        "schema": SCHEMA,
        "version": 1,
        "ok": result_ok,
        "mode": args.mode,
        "operation": args.operation,
        "repo": delivery_status.get("repo"),
        "pr": pr_summary(args.pr, delivery_status),
        "delivery_status": delivery_status,
        "verifiers": verifiers,
        "steps": steps_for(reason),
        "decision": result_decision,
        "run_artifact_path": None,
    }
    if args.mode == "execute" and args.operation == "verify":
        try:
            write_artifact(result)
        except OSError as e:
            result["ok"] = False
            result["run_artifact_error"] = str(e)
            result["decision"] = decision("blocked", "artifact_write_failed")
            result["steps"] = steps_for("artifact_write_failed")
            returncode = 1

    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return returncode


if __name__ == "__main__":
    raise SystemExit(main())
