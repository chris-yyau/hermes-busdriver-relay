#!/usr/bin/env python3
"""Fail-closed Hermes delivery dispatcher."""
from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import tempfile
import time
import uuid
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
DELIVERY_STATUS = ROOT / "scripts" / "hermes-busdriver-delivery-status"
SCHEMA = "hermes-busdriver-deliver/v0"
RUN_SCHEMA = "hermes-busdriver-delivery-run/v0"
ARTIFACT_ENV = "HERMES_BUSDRIVER_DELIVERY_RUNS_DIR"
TAIL_LIMIT = 4000
VERIFIER_LABEL = re.compile(r"^[A-Za-z0-9_.-]+=")
REDACTION = "[REDACTED]"
ARTIFACT_TOKEN = re.compile(r"[^A-Za-z0-9_.-]+")
SENSITIVE_PATTERNS = [
    (re.compile(r"(?i)\b(authorization\s*:\s*bearer\s+)([A-Za-z0-9._~+/=-]{8,})"), rf"\1{REDACTION}"),
    (re.compile(r"\bgh[pousr]_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b"), REDACTION),
    (re.compile(r"(?i)((?:--(?:api[_-]?key|secret|token|password|passwd))\s+)([^\s'\"&]+)"), rf"\1{REDACTION}"),
    (re.compile(r"(?i)\b((?:api[_-]?key|secret|token|password|passwd)\s*[:=]\s*)([^\s'\"&]+)"), rf"\1{REDACTION}"),
]
BLOCKED_FLAGS = {
    "finalization_allowed": False,
    "commit_allowed": False,
    "push_allowed": False,
    "pr_allowed": False,
    "merge_allowed": False,
    "deploy_allowed": False,
    "release_allowed": False,
    "publish_allowed": False,
    "marker_write_allowed": False,
}


def redact_text(text: str) -> str:
    for pattern, replacement in SENSITIVE_PATTERNS:
        text = pattern.sub(replacement, text)
    return text


def redact_value(value: Any) -> Any:
    if isinstance(value, str):
        return redact_text(value)
    if isinstance(value, list):
        return [redact_value(item) for item in value]
    if isinstance(value, dict):
        return {key: redact_value(item) for key, item in value.items()}
    return value


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Fail-closed Hermes Delivery Mode dispatcher")
    parser.add_argument("--repo", help="Target git repo/worktree to inspect and verify")
    parser.add_argument("--plugin-root", help="Busdriver plugin root")
    parser.add_argument("--pr", help="Pull request number for post-PR status")
    parser.add_argument("--pr-grind-result-file", help="Read-only PR-grind fixture/status JSON to pass through delivery-status")
    parser.add_argument("--delivery-status-timeout", type=int, default=180, help="Seconds to wait for delivery-status before failing closed")
    parser.add_argument("--verifier-timeout", type=int, default=180, help="Seconds to wait for each verifier command")
    parser.add_argument("--mode", default="plan", choices=["plan", "execute", "status"], help="Delivery mode; only execute verify is enabled; status is read-only run lookup")
    parser.add_argument("--operation", default="plan", choices=["plan", "verify"], help="Delivery operation; execute supports only verify")
    parser.add_argument("--run-id", help="Optional durable delivery run id echoed in the envelope and artifact filename")
    parser.add_argument(
        "--verifier",
        action="append",
        default=[],
        help="Trusted NAME=COMMAND or COMMAND executed locally with shell=False; launch errors fail closed. May be repeated for execute verify.",
    )
    parser.add_argument("--pretty", action="store_true")
    return parser.parse_args()


def tail(value: str | bytes | None, limit: int = TAIL_LIMIT) -> str:
    if isinstance(value, bytes):
        text = value.decode(errors="replace")
    else:
        text = value or ""
    text = redact_text(text)
    if limit <= 0:
        return ""
    return text[-limit:]


def run_delivery_status(args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    cmd = [sys.executable, str(DELIVERY_STATUS)]
    if args.repo:
        cmd += ["--repo", args.repo]
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    if args.pr:
        cmd += ["--pr", args.pr]
    if args.pr_grind_result_file:
        cmd += ["--pr-grind-result-file", args.pr_grind_result_file]

    try:
        cp = subprocess.run(cmd, text=True, capture_output=True, check=False, timeout=args.delivery_status_timeout)
    except subprocess.TimeoutExpired as e:
        return {
            "ok": False,
            "error": "delivery_status_timeout",
            "returncode": 124,
            "timeout_seconds": args.delivery_status_timeout,
            "stdout_tail": tail(e.stdout),
            "stderr": tail(e.stderr),
        }, 124

    try:
        data = json.loads(cp.stdout)
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "error": "delivery_status_invalid_json",
            "returncode": cp.returncode,
            "stdout_tail": tail(cp.stdout),
            "stderr": tail(cp.stderr.strip()),
            "parse_error": str(e),
        }, cp.returncode
    if not isinstance(data, dict):
        return {
            "ok": False,
            "error": "delivery_status_invalid_json_type",
            "returncode": cp.returncode,
            "stderr": tail(cp.stderr),
            "stdout_tail": tail(cp.stdout),
        }, cp.returncode
    if cp.returncode != 0:
        data["ok"] = False
        data["returncode"] = cp.returncode
        data["stderr"] = tail(cp.stderr)
    return data, cp.returncode


def pr_summary(pr: str | None, delivery_status: dict[str, Any]) -> dict[str, Any] | None:
    if not pr:
        return None
    pr_grind = delivery_status.get("pr_grind") or {}
    result = pr_grind.get("result") or {}
    return {
        "number": pr,
        "available": pr_grind.get("available"),
        "ok": pr_grind.get("ok"),
        "status": result.get("status"),
        "clean": result.get("clean"),
    }


def effective_operation(args: argparse.Namespace) -> str:
    if args.mode == "status":
        return "status"
    return args.operation


def parse_verifier(item: str, index: int) -> tuple[str, str]:
    if VERIFIER_LABEL.match(item):
        name, command = item.split("=", 1)
        command = command.strip()
        if not command:
            raise ValueError("empty verifier command")
        return name.strip(), command
    command = item.strip()
    if not command:
        raise ValueError("empty verifier command")
    return f"verifier_{index}", command


def verifier_error_name(item: str, index: int) -> str:
    if VERIFIER_LABEL.match(item):
        name, _command = item.split("=", 1)
        return name.strip() or f"verifier_{index}"
    return f"verifier_{index}"


def run_verifiers(repo: Path, verifiers: list[str], timeout: int) -> list[dict[str, Any]]:
    results: list[dict[str, Any]] = []
    for index, item in enumerate(verifiers, start=1):
        try:
            name, command = parse_verifier(item, index)
            argv = shlex.split(command)
            if not argv:
                raise ValueError("empty verifier command")
        except ValueError as e:
            results.append({
                "name": verifier_error_name(item, index),
                "command": item,
                "returncode": 2,
                "ok": False,
                "stdout_tail": "",
                "stderr_tail": str(e),
            })
            continue
        try:
            cp = subprocess.run(argv, cwd=str(repo), shell=False, text=True, capture_output=True, check=False, timeout=timeout)
            results.append({
                "name": name,
                "command": command,
                "returncode": cp.returncode,
                "ok": cp.returncode == 0,
                "stdout_tail": tail(cp.stdout),
                "stderr_tail": tail(cp.stderr),
            })
        except subprocess.TimeoutExpired as e:
            timeout_prefix = f"timeout after {timeout}s\n"
            stderr_tail = timeout_prefix + tail(e.stderr, max(0, TAIL_LIMIT - len(timeout_prefix)))
            results.append({
                "name": name,
                "command": command,
                "returncode": 124,
                "ok": False,
                "stdout_tail": tail(e.stdout),
                "stderr_tail": stderr_tail.rstrip(),
            })
        except OSError as e:
            results.append({
                "name": name,
                "command": command,
                "returncode": 127,
                "ok": False,
                "stdout_tail": "",
                "stderr_tail": tail(f"{type(e).__name__}: {e}"),
            })
    return results


def new_run_id() -> str:
    return f"{time.strftime('%Y%m%d-%H%M%S')}-{os.getpid()}-{uuid.uuid4().hex[:8]}"


def artifact_token(run_id: str) -> str:
    token = ARTIFACT_TOKEN.sub("-", run_id).strip(".-")
    return token[:96] or "run"


def delivery_phase(args: argparse.Namespace, reason: str | None) -> str:
    if reason == "delivery_status_failed":
        return "delivery_status"
    if args.mode == "status":
        return "status"
    if args.mode == "execute" and args.operation == "verify":
        return "verify"
    if args.mode == "execute":
        return "execute"
    return "plan"


def delivery_run(
    args: argparse.Namespace,
    delivery_status: dict[str, Any],
    result_decision: dict[str, Any],
    reason: str | None,
) -> dict[str, Any]:
    repo = delivery_status.get("repo") if isinstance(delivery_status.get("repo"), dict) else {}
    return {
        "schema": RUN_SCHEMA,
        "version": 1,
        "run_id": args.run_id or new_run_id(),
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "phase": delivery_phase(args, reason),
        "status": result_decision.get("status"),
        "reason": result_decision.get("reason"),
        "repo_root": repo.get("root"),
        "pr_number": args.pr,
        "authority": {key: result_decision[key] for key in BLOCKED_FLAGS},
        "artifacts": [],
    }


def artifact_base() -> Path:
    return Path(os.environ.get(ARTIFACT_ENV, "~/.hermes/busdriver-relay/delivery-runs")).expanduser()


def artifact_path(run_id: str) -> Path:
    base = artifact_base()
    stamp = time.strftime("%Y%m%d-%H%M%S")
    return base / f"{stamp}-{artifact_token(run_id)}-{os.getpid()}.json"


def blocked_flag_value(value: dict[str, Any], key: str) -> Any:
    if key == "marker_write_allowed":
        return value.get(key, False)
    return value.get(key)


def authority_flags_safe(value: Any) -> bool:
    if not isinstance(value, dict):
        return False
    return all(blocked_flag_value(value, key) is False for key in BLOCKED_FLAGS)


def decision_metadata_safe(value: Any) -> bool:
    return (
        isinstance(value, dict)
        and isinstance(value.get("status"), str)
        and isinstance(value.get("reason"), str)
        and authority_flags_safe(value)
    )


VALID_ARTIFACT_RUN_PHASES = {"verify", "delivery_status"}


def artifact_run_artifacts_safe(value: Any) -> bool:
    return isinstance(value, list) and all(
        isinstance(item, dict)
        and item.get("kind") == "result"
        and isinstance(item.get("path"), str)
        for item in value
    )


def run_metadata_safe(value: Any, run_id: str) -> bool:
    return (
        isinstance(value, dict)
        and value.get("schema") == RUN_SCHEMA
        and value.get("version") == 1
        and value.get("run_id") == run_id
        and isinstance(value.get("created_at"), str)
        and value.get("phase") in VALID_ARTIFACT_RUN_PHASES
        and isinstance(value.get("status"), str)
        and isinstance(value.get("reason"), str)
        and isinstance(value.get("repo_root"), (str, type(None)))
        and (value.get("pr_number") is None or isinstance(value.get("pr_number"), (int, str)))
        and authority_flags_safe(value.get("authority"))
        and artifact_run_artifacts_safe(value.get("artifacts"))
    )


def decision_summary(value: dict[str, Any]) -> dict[str, Any]:
    return {"status": value.get("status"), "reason": value.get("reason"), **{key: blocked_flag_value(value, key) for key in BLOCKED_FLAGS}}


def artifact_refs_summary(value: Any) -> list[dict[str, str]]:
    if not isinstance(value, list):
        return []
    return [
        {"kind": item["kind"], "path": item["path"]}
        for item in value
        if isinstance(item, dict) and isinstance(item.get("kind"), str) and isinstance(item.get("path"), str)
    ]


def run_summary(value: dict[str, Any]) -> dict[str, Any]:
    return {
        "schema": value.get("schema"),
        "version": value.get("version"),
        "run_id": value.get("run_id"),
        "created_at": value.get("created_at"),
        "phase": value.get("phase"),
        "status": value.get("status"),
        "reason": value.get("reason"),
        "repo_root": value.get("repo_root"),
        "pr_number": value.get("pr_number"),
        "authority": {key: blocked_flag_value(value.get("authority", {}), key) for key in BLOCKED_FLAGS},
        "artifacts": artifact_refs_summary(value.get("artifacts")),
    }


def artifact_is_valid(data: dict[str, Any], run_id: str) -> bool:
    run = data.get("run")
    decision_data = data.get("decision")
    return (
        data.get("schema") == SCHEMA
        and data.get("version") == 1
        and isinstance(data.get("ok"), bool)
        and decision_metadata_safe(decision_data)
        and run_metadata_safe(run, run_id)
    )


def artifact_for_run_id(run_id: str) -> tuple[Path, dict[str, Any]] | None:
    base = artifact_base()
    if not base.is_dir():
        return None
    matches: list[tuple[float, str, Path, dict[str, Any]]] = []
    for path in base.glob("*.json"):
        try:
            data = json.loads(path.read_text())
        except (OSError, UnicodeDecodeError, json.JSONDecodeError):
            continue
        if not isinstance(data, dict) or not artifact_is_valid(data, run_id):
            continue
        try:
            mtime = path.stat().st_mtime
        except OSError:
            continue
        matches.append((mtime, path.name, path, data))
    if not matches:
        return None
    _mtime, _name, path, data = sorted(matches)[-1]
    return path, data


def write_artifact(result: dict[str, Any]) -> None:
    run = result.get("run") if isinstance(result.get("run"), dict) else {}
    run_id = str(run.get("run_id") or new_run_id())
    path = artifact_path(run_id)
    path.parent.mkdir(parents=True, exist_ok=True)
    result["run_artifact_path"] = str(path)
    if isinstance(result.get("run"), dict):
        result["run"]["artifacts"] = [{"kind": "result", "path": str(path)}]
    tmp_path: Path | None = None
    try:
        with tempfile.NamedTemporaryFile(
            "w",
            encoding="utf-8",
            dir=path.parent,
            prefix=f".{path.name}.",
            suffix=".tmp",
            delete=False,
        ) as tmp:
            tmp_path = Path(tmp.name)
            json.dump(result, tmp, indent=2, sort_keys=True)
            tmp.write("\n")
        os.replace(tmp_path, path)
    except OSError:
        result["run_artifact_path"] = None
        if isinstance(result.get("run"), dict):
            result["run"]["artifacts"] = []
        if tmp_path is not None:
            try:
                tmp_path.unlink()
            except OSError:
                pass
        raise


def status_lookup_run(args: argparse.Namespace, result_decision: dict[str, Any], reason: str) -> dict[str, Any]:
    return {
        "schema": RUN_SCHEMA,
        "version": 1,
        "run_id": args.run_id,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "phase": "status",
        "status": result_decision.get("status"),
        "reason": result_decision.get("reason", reason),
        "repo_root": None,
        "pr_number": None,
        "authority": {key: result_decision[key] for key in BLOCKED_FLAGS},
        "artifacts": [],
    }


def status_mode_result(args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    if not args.run_id:
        result_decision = decision("blocked", "run_id_required")
        result = {
            "schema": SCHEMA,
            "version": 1,
            "ok": False,
            "mode": "status",
            "operation": "status",
            "repo": None,
            "pr": None,
            "delivery_status": None,
            "status_lookup": {"found": False, "reason": "run_id_required"},
            "verifiers": [],
            "steps": steps_for("run_id_required"),
            "decision": result_decision,
            "run": status_lookup_run(args, result_decision, "run_id_required"),
            "run_artifact_path": None,
        }
        return redact_value(result), 2

    found = artifact_for_run_id(args.run_id)
    if found is None:
        result_decision = decision("blocked", "run_not_found")
        result = {
            "schema": SCHEMA,
            "version": 1,
            "ok": False,
            "mode": "status",
            "operation": "status",
            "repo": None,
            "pr": None,
            "delivery_status": None,
            "status_lookup": {"found": False, "reason": "run_not_found", "run_id": args.run_id},
            "verifiers": [],
            "steps": steps_for("run_not_found"),
            "decision": result_decision,
            "run": delivery_run(args, {}, result_decision, "run_not_found"),
            "run_artifact_path": None,
        }
        return redact_value(result), 1

    path, artifact = found
    artifact_run = artifact.get("run") if isinstance(artifact.get("run"), dict) else {}
    result_decision = decision("found", "run_found")
    result = {
        "schema": SCHEMA,
        "version": 1,
        "ok": True,
        "mode": "status",
        "operation": "status",
        "repo": {"root": artifact_run.get("repo_root")},
        "pr": {"number": artifact_run.get("pr_number")} if artifact_run.get("pr_number") is not None else None,
        "delivery_status": None,
        "status_lookup": {
            "found": True,
            "run_id": args.run_id,
            "artifact_path": str(path),
            "artifact_schema": artifact.get("schema"),
            "artifact_ok": artifact.get("ok"),
            "artifact_decision": decision_summary(artifact.get("decision", {})),
            "artifact_run": run_summary(artifact_run),
        },
        "verifiers": [],
        "steps": steps_for("run_found"),
        "decision": result_decision,
        "run": delivery_run(args, {"repo": {"root": artifact_run.get("repo_root")}}, result_decision, "run_found"),
        "run_artifact_path": None,
    }
    result["run"]["pr_number"] = artifact_run.get("pr_number")
    result["run"]["artifacts"] = [{"kind": "result", "path": str(path)}]
    return redact_value(result), 0


def steps_for(reason: str | None) -> list[dict[str, str]]:
    if reason == "run_found":
        return [
            {"name": "status_lookup", "status": "found", "reason": "run_found"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "run_id_required":
        return [
            {"name": "status_lookup", "status": "blocked", "reason": "run_id_required"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "run_not_found":
        return [
            {"name": "status_lookup", "status": "blocked", "reason": "run_not_found"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "delivery_status_failed":
        return [
            {"name": "delivery_status", "status": "blocked", "reason": "helper_failed"},
            {"name": "verify", "status": "skipped", "reason": "delivery_status_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "unsupported_operation":
        return [
            {"name": "execute", "status": "blocked", "reason": "unsupported_operation"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "no_verifiers":
        return [
            {"name": "verify", "status": "blocked", "reason": "no_verifiers"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verifier_failed":
        return [
            {"name": "verify", "status": "blocked", "reason": "verifier_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "artifact_write_failed":
        return [
            {"name": "write_artifact", "status": "blocked", "reason": "artifact_write_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verified":
        return [
            {"name": "verify", "status": "passed", "reason": "local_verifiers_passed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    return [
        {"name": "review_delivery_status", "status": "pending", "reason": "plan_only"},
        {"name": "commit", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "push", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "pr", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "merge", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "deploy", "status": "blocked", "reason": "finalization_disabled"},
    ]


def decision(status: str, reason: str) -> dict[str, Any]:
    return {"status": status, "reason": reason, **BLOCKED_FLAGS}


def main() -> int:
    args = parse_args()
    if args.mode == "status":
        result, returncode = status_mode_result(args)
        print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
        return returncode

    delivery_status, status_rc = run_delivery_status(args)
    delivery_ok = bool(delivery_status.get("ok"))
    reason: str | None = None
    result_ok = delivery_ok
    result_decision = decision("plan_only", "read_only_plan")
    verifiers: list[dict[str, Any]] = []
    returncode = 0 if delivery_ok else (status_rc or 1)

    if not delivery_ok:
        reason = "delivery_status_failed"
        result_ok = False
        result_decision = decision("blocked", reason)
    elif args.mode == "execute":
        if args.operation != "verify":
            reason = "unsupported_operation"
            result_ok = False
            result_decision = decision("blocked", reason)
            returncode = 2
        elif not args.verifier:
            reason = "no_verifiers"
            result_ok = False
            result_decision = decision("blocked", reason)
            returncode = 2
        else:
            repo = Path(args.repo or ".").expanduser().resolve()
            verifiers = run_verifiers(repo, args.verifier, args.verifier_timeout)
            result_ok = all(v["ok"] for v in verifiers)
            reason = "verified" if result_ok else "verifier_failed"
            result_decision = decision("verified" if result_ok else "blocked", reason)
            returncode = 0 if result_ok else 1

    result = {
        "schema": SCHEMA,
        "version": 1,
        "ok": result_ok,
        "mode": args.mode,
        "operation": effective_operation(args),
        "repo": delivery_status.get("repo"),
        "pr": pr_summary(args.pr, delivery_status),
        "delivery_status": delivery_status,
        "verifiers": verifiers,
        "steps": steps_for(reason),
        "decision": result_decision,
        "run": delivery_run(args, delivery_status, result_decision, reason),
        "run_artifact_path": None,
    }
    result = redact_value(result)
    if args.mode == "execute" and args.operation == "verify":
        try:
            write_artifact(result)
        except OSError as e:
            result["ok"] = False
            result["run_artifact_error"] = redact_text(str(e))
            result["decision"] = decision("blocked", "artifact_write_failed")
            if isinstance(result.get("run"), dict):
                result["run"]["status"] = "blocked"
                result["run"]["reason"] = "artifact_write_failed"
                result["run"]["authority"] = {key: False for key in BLOCKED_FLAGS}
                result["run"]["artifacts"] = []
            result["steps"] = steps_for("artifact_write_failed")
            returncode = 1

    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return returncode


if __name__ == "__main__":
    raise SystemExit(main())
