SENSITIVE_PATTERNS = [
    # URL userinfo runs FIRST and on purpose. Generic token matching can redact the whole
    # non-whitespace tail, including the host and repository needed for diagnostics.
    # Collapsing only userinfo removes credentials while preserving that safe suffix.
    (re.compile(r"(?i)\b([a-z][a-z0-9+.-]*://)([^/\s:@]+(?::[^/\s@]*)?)@"), rf"\1{REDACTION}@"),
    (re.compile(r"(?i)\b(authorization\s*:\s*bearer\s+)([A-Za-z0-9._~+/=-]{8,})"), rf"\1{REDACTION}"),
    (re.compile(r"\bgh[pousr]_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bgithub_pat_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b"), REDACTION),
    (re.compile(r"(?i)((?:--(?:api[_-]?key|secret|token|password|passwd))\s+)([^\s'\"&]+)"), rf"\1{REDACTION}"),
    (re.compile(r'(?i)("(?:api[_-]?key|secret|token|password|passwd)"\s*:\s*")([^"]+)(")'), rf"\1{REDACTION}\3"),
    (re.compile(r"(?i)\b((?:api[_-]?key|secret|token|password|passwd)\s*[:=]\s*)([^\s'\"&]+)"), rf"\1{REDACTION}"),
]
BLOCKED_FLAGS = {
    "finalization_allowed": False,
    "commit_allowed": False,
    "push_allowed": False,
    "pr_allowed": False,
    "merge_allowed": False,
    "deploy_allowed": False,
    "release_allowed": False,
    "publish_allowed": False,
    "marker_write_allowed": False,
}
DEFAULT_BUSDRIVER_MARKER_STATE_DIRS = (".claude", ".opencode")


CREDENTIAL_ENV_KEYS = ("GH_TOKEN", "GITHUB_TOKEN", "GH_ENTERPRISE_TOKEN", "GITHUB_ENTERPRISE_TOKEN")


def credential_env_values() -> list[str]:
    """Our own credential values, longest first, so a nested value cannot survive its container."""
    values = {os.environ.get(key) for key in CREDENTIAL_ENV_KEYS}
    return sorted((value for value in values if isinstance(value, str) and len(value) >= 8), key=len, reverse=True)


def redact_text(text: str) -> str:
    for value in credential_env_values():
        text = text.replace(value, REDACTION)
    for pattern, replacement in SENSITIVE_PATTERNS:
        text = pattern.sub(replacement, text)
    return text


def redact_value(value: Any) -> Any:
    if isinstance(value, str):
        return redact_text(value)
    if isinstance(value, list):
        redacted = []
        redact_next = False
        for item in value:
            if redact_next:
                redacted.append(REDACTION)
                redact_next = False
                continue
            redacted_item = redact_value(item)
            redacted.append(redacted_item)
            if isinstance(item, str) and re.fullmatch(r"(?i)--?(?:api[_-]?key|secret|token|password|passwd)", item):
                redact_next = True
        return redacted
    if isinstance(value, dict):
        result = {}
        for key, item in value.items():
            # A key is untrusted text too. These dicts are built from children's JSON and from env
            # snapshots, so a credential can arrive AS a key — where redacting only the value leaves
            # it in the clear in the very envelope this function exists to make safe to print. The
            # four sibling redactors (gate, agent-draft, pi, opencode) already spell it this way.
            safe_key = redact_text(str(key))
            if re.search(r"(?i)(api[_-]?key|secret|token|password|passwd)", str(key)):
                result[safe_key] = REDACTION
            else:
                result[safe_key] = redact_value(item)
        return result
    return value


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Fail-closed Hermes Delivery Mode dispatcher",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Production policy:\n"
            "  commit is the only mutating operation currently dispatchable.\n"
            "  verify: verifier_containment_unavailable\n"
            "  pre-pr-review: isolated_review_runtime_unavailable\n"
            "  push: atomic_push_base_binding_unavailable\n"
            "  pr-create: atomic_pr_create_binding_unavailable\n"
            "  merge: atomic_merge_base_binding_unavailable\n"
            "Fixed blockers return before run identity, delivery status, lock, artifact, credentials, or side effects."
        ),
    )
    parser.add_argument("--repo", help="Target git repo/worktree to inspect and verify")
    parser.add_argument("--expected-repository", help="Trusted canonical GitHub owner/repo binding required for every mutating operation")
    parser.add_argument("--plugin-root", help="Busdriver plugin root")
    parser.add_argument("--relay-role", help="Optionally resolve one relay equivalent role through delivery-status")
    parser.add_argument("--relay-config", help="Relay config JSON path to pass through delivery-status")
    parser.add_argument("--relay-role-timeout", type=int, default=DEFAULT_RELAY_ROLE_TIMEOUT)
    parser.add_argument("--pr", help="Pull request number for post-PR status")

    parser.add_argument(
        "--delivery-status-timeout",
        type=int,
        default=None,
        help="Seconds to wait for delivery-status before failing closed; defaults to max(180, nested helper timeouts + 30s margin)",
    )
    parser.add_argument("--verifier-timeout", type=int, default=180, help="Seconds to wait for each verifier command")
    parser.add_argument("--mode", default="plan", choices=["plan", "execute", "status"], help="Delivery mode; execute supports read-only pr-grind and gated commit; status accepts only same-process artifacts authenticated by a live process-scoped capability, while every unverifiable or cross-process artifact fails closed as run_not_found; other execute operations use the fixed blockers listed below")
    parser.add_argument("--operation", default="plan", choices=["plan", "verify", "pr-grind", "pre-pr-review", "commit", "push", "pr-create", "merge"], help="Delivery operation; only commit currently reaches evidence and finalization lock")
    parser.add_argument("--run-id", help="Optional durable delivery run id echoed in the envelope and artifact filename")
    parser.add_argument("--commit-message", help="Commit message for execute commit")
    parser.add_argument("--push-remote", default="origin", help="Git remote for execute push / post-fix push")
    parser.add_argument("--push-branch", help="Branch name for execute push; defaults to current branch")
    parser.add_argument("--pr-title", help="PR title for execute pr-create")
    parser.add_argument("--pr-body", default="", help="PR body for execute pr-create")
    parser.add_argument("--base", help="Base branch for execute pr-create; defaults to origin/HEAD resolution")
    parser.add_argument("--head", help="Head branch for execute pr-create; defaults to current branch")
    parser.add_argument("--merge-method", choices=["merge", "squash", "rebase"], default="squash", help="Merge method for execute merge")
    parser.add_argument("--delete-branch", action="store_true", help="Pass --delete-branch to gh pr merge")
    parser.add_argument("--backstop-verdict-file", help="Validated read-only backstop verdict JSON to feed to Busdriver trusted writer during execute pre-pr-review")

    parser.add_argument("--max-wait-seconds", type=float, default=300.0, help="Bounded wait budget passed to execute pr-grind loop")
    parser.add_argument("--poll-interval", type=float, default=30.0, help="Poll interval passed to execute pr-grind loop")
    parser.add_argument("--max-polls", type=int, default=20, help="Poll cap passed to execute pr-grind loop")
    parser.add_argument("--pr-grind-timeout", type=int, default=DEFAULT_PR_GRIND_TIMEOUT, help="PR-grind timeout passed to delivery-status")
    parser.add_argument("--litmus-status-timeout", type=int, default=DEFAULT_LITMUS_STATUS_TIMEOUT, help="Litmus-status timeout passed to delivery-status")
    parser.add_argument("--drift-baseline", help="Read-only Busdriver drift baseline JSON to pass through delivery-status")
    parser.add_argument("--phase0-status-timeout", type=int, default=DEFAULT_PHASE0_STATUS_TIMEOUT, help="Phase-0 status timeout passed to delivery-status when --drift-baseline is present")
    parser.add_argument("--busdriver-state-dir-name", help="Busdriver marker state dir name to pass through delivery-status to litmus-status")
    parser.add_argument("--check-timeout", type=float, default=180.0, help="Checker timeout passed to execute pr-grind loop")
    parser.add_argument(
        "--verifier",
        action="append",
        default=[],
        help="Reserved verifier NAME=COMMAND syntax; production execute verify returns verifier_containment_unavailable before launching commands.",
    )
    parser.add_argument("--pretty", action="store_true")
    args = parser.parse_args()
    args.pr_grind_result_file = FIXTURE_PR_GRIND_RESULT_FILE
    return args


# The window handed to redact_text() is bounded BEFORE the regexes run. redact_text() walks every
# SENSITIVE_PATTERN over its whole input — including a URL-userinfo class with no length bound — so
# a hostile subprocess returning 500MB of stderr, or a remote URL of the same size, costs that much
# CPU and memory inside a helper whose entire job is to emit a few KB. Bounding after redaction, as
# r25 did, means the bound never applies to the expensive step it exists to protect.
#
# 8192, not a tight bound: every shape pattern above matches far less than this, so the span exists
# to keep a long-but-real match (a `token: <value>` with a verbose value, a long URL) whole inside
# the budget. It costs 8KB of regex work and buys the guarantee below.
REDACTION_PATTERN_SPAN = 8192

# Over budget, output is REFUSED — not sliced to its last `budget` bytes, which is what r26 did and
# what leaked. The value classes for `token:`, `--token`, `"token":` and `Bearer` are unbounded, so
# a long enough value has the very prefix that IDENTIFIES it as a secret cut away by that slice;
# the remainder matches no shape pattern and the tail is emitted raw. No window size fixes it —
# the prefix sits arbitrarily far from the tail. An unmatched fragment of a secret is still a
# secret, and no diagnostic from an attacker-controlled 12KB+ of output is worth emitting one.
REDACTED_OVERSIZED = "[REDACTED:OVERSIZED_OUTPUT]"


def redaction_overlap() -> int:
    """Enough headroom that anything redact_text() can match fits whole inside the scan budget.

    Sized from our OWN credential values, not guessed: an opaque enterprise token matches no shape
    pattern, so length is the only thing that can guarantee a configured credential lands inside
    the budget whole rather than pushing a legitimate output over it.
    """
    longest_secret = max((len(value) for value in credential_env_values()), default=0)
    return max(REDACTION_PATTERN_SPAN, longest_secret + 64)


def bounded_redacted_tail(value: "str | bytes | None", limit: int) -> str:
    if isinstance(value, bytes):
        text = value.decode(errors="replace")
    else:
        text = value or ""
    if limit <= 0:
        return ""
    if len(text) > limit + redaction_overlap():
        return REDACTED_OVERSIZED
    # Every pattern now sees its whole candidate span, so a match that ends inside the emitted
    # region was matched whole; the slice below can only cut text no pattern claimed.
    return redact_text(text)[-limit:]


def tail(value: str | bytes | None, limit: int = TAIL_LIMIT) -> str:
    """Redact, then bound — over a window bounded first. See bounded_redacted_tail()."""
    return bounded_redacted_tail(value, limit)


def delivery_status_pr_grind_timeout(args: argparse.Namespace) -> int:
    return int(getattr(args, "pr_grind_timeout", DEFAULT_PR_GRIND_TIMEOUT) or 0)


def delivery_status_litmus_timeout(args: argparse.Namespace) -> int:
    return int(getattr(args, "litmus_status_timeout", DEFAULT_LITMUS_STATUS_TIMEOUT) or 0)


def delivery_status_phase0_timeout(args: argparse.Namespace) -> int:
    return int(getattr(args, "phase0_status_timeout", DEFAULT_PHASE0_STATUS_TIMEOUT) or 0)


def delivery_status_relay_role_timeout(args: argparse.Namespace) -> int:
    return int(getattr(args, "relay_role_timeout", DEFAULT_RELAY_ROLE_TIMEOUT) or 0)


def requested_litmus_base_ref(args: argparse.Namespace) -> str | None:
    base = getattr(args, "base", None)
    if not isinstance(base, str) or not base:
        return None
    if base.startswith("refs/remotes/origin/"):
        return "origin/" + base[len("refs/remotes/origin/"):]
    if base.startswith("refs/heads/"):
        return "origin/" + base[len("refs/heads/"):]
    if base.startswith("refs/"):
        return None
    if base.startswith("origin/"):
        return base
    return f"origin/{base}"


def effective_delivery_status_timeout(args: argparse.Namespace) -> int:
    if args.delivery_status_timeout is not None:
        return args.delivery_status_timeout
    nested_budget = delivery_status_pr_grind_timeout(args) + delivery_status_litmus_timeout(args) + DELIVERY_STATUS_TIMEOUT_MARGIN
    if getattr(args, "relay_role", None):
        nested_budget += delivery_status_relay_role_timeout(args)
    if getattr(args, "drift_baseline", None):
        nested_budget += delivery_status_phase0_timeout(args)
    return max(DEFAULT_DELIVERY_STATUS_TIMEOUT, nested_budget)


def _names_created_inode(parent_fd: int, name: str, created: os.stat_result) -> bool:
    """True iff `name` under `parent_fd` still resolves, no-follow, to the inode we created.

    The immediate parent plus the final component, not the whole path: the last component is the
    only one this call created, and resolving it through the descriptor the create already held
    means an ancestor swapped afterwards cannot redirect the answer.
    """
    try:
        landed = os.lstat(name, dir_fd=parent_fd)
    except OSError:
        return False
    return (landed.st_dev, landed.st_ino) == (created.st_dev, created.st_ino)


def write_private_authenticated(target: Path, content: bytes, mode: int) -> None:
    """Write authenticated bytes through a descriptor, then prove that descriptor still holds them.

    `Path.write_bytes()` looks like one operation and is three unproven claims. `os.write` may write
    fewer bytes than it was handed, and a partial write that nobody checks is a silent truncation.
    Nothing is flushed, so the bytes may not be on disk when the child is launched to read them.
    And nothing re-reads what landed, so "we wrote the authenticated content" and "the file holds
    the authenticated content" are separate facts — only the first was ever established.

    That gap is not academic here: these bytes are about to be EXECUTED as a private runtime, and
    the caller's pin check authenticated the bytes in MEMORY, not the file. The closing re-digest is
    what carries that authentication onto disk, and it reads the descriptor rather than the name,
    because a name resolves a second time and a second resolution is a second chance to hand us a
    different file. The identity check then proves the other direction — that the name still reaches
    the inode the digest just cleared — which is the half a descriptor alone cannot see.
    `sha256(content)` is the expected value rather than a pin the caller passes in: the caller
    already proved content matches its pin, so the two are the same number, and a parameter that can
    only ever hold one value is a parameter that can be passed the wrong one.

    O_EXCL: the name must not already exist, so this cannot land in something prepared for it.
    O_NOFOLLOW: and it cannot be a symlink pointing somewhere the containment never authorized.
    """
    # One parent descriptor for the whole operation: the create, the identity check and the failure
    # unlink all resolve the final component through it, so they cannot disagree about the parent.
    parent_fd = os.open(target.parent, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0) | getattr(os, "O_NOFOLLOW", 0))
    try:
        # O_RDWR, not O_WRONLY: the closing digest is read back through THIS descriptor, and a
        # write-only one cannot be read (EBADF). Re-opening the name to read it instead would
        # resolve the name a second time, which is the very thing the descriptor is here to avoid.
        flags = os.O_RDWR | os.O_CREAT | os.O_EXCL | getattr(os, "O_NOFOLLOW", 0)
        fd = os.open(target.name, flags, mode, dir_fd=parent_fd)
        # The inode THIS call created. The failure path deletes only this one, never a replacement.
        created = os.fstat(fd)
        try:
            view = memoryview(content)
            while view:
                written = os.write(fd, view)
                if written <= 0:
                    # Not merely "unusual": consuming the result only as a slice index makes a 0 an
                    # infinite loop, so this is what keeps the loop terminating as well as honest.
                    raise OSError("private_copy_short_write")
                view = view[written:]
            os.fsync(fd)
            # fchmod, not chmod: the mode lands on the inode we wrote, not on whatever the name
            # means by now. The requested mode is also masked by the caller's umask at open.
            os.fchmod(fd, mode)
            st = os.fstat(fd)
            if (
                not stat.S_ISREG(st.st_mode)
                or st.st_uid != os.geteuid()
                or st.st_nlink != 1
                or st.st_size != len(content)
                or stat.S_IMODE(st.st_mode) != mode
            ):
                raise OSError("private_copy_metadata_invalid")
            digest = hashlib.sha256()
            offset = 0
            while offset < st.st_size:
                # pread: neither moves the offset nor rides it, so the digest cannot race the writer.
                chunk = os.pread(fd, min(1 << 16, st.st_size - offset), offset)
                if not chunk:
                    raise OSError("private_copy_truncated")
                digest.update(chunk)
                offset += len(chunk)
            if digest.hexdigest() != hashlib.sha256(content).hexdigest():
                raise OSError("private_copy_integrity_failed")
            if not _names_created_inode(parent_fd, target.name, created):
                # The digest proved OUR inode is intact; this proves `target` still reaches it. A
                # rename over the name publishes someone else's bytes under the name the caller is
                # about to execute.
                raise OSError("private_copy_integrity_failed")
        except BaseException:
            # A half-written private executable must never be left behind for the next step to run.
            # But by now the name may belong to something else — the case the identity check above
            # fails on — and deleting THAT is a second bug wearing the first one's cleanup.
            if _names_created_inode(parent_fd, target.name, created):
                try:
                    os.unlink(target.name, dir_fd=parent_fd)
                except OSError:
                    pass
            raise
        finally:
            os.close(fd)
    finally:
        os.close(parent_fd)


MAX_AUTHENTICATED_RELAY_SOURCE_BYTES = 1 << 20


def _read_authenticated_relay_source(path: Path, expected_digest: str) -> bytes:
    before = path.lstat()
    if path.is_symlink() or not stat.S_ISREG(before.st_mode):
        raise OSError("relay_source_metadata_invalid")
    fd = os.open(path, os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0))
    try:
        opened = os.fstat(fd)
        if (opened.st_dev, opened.st_ino) != (before.st_dev, before.st_ino):
            raise OSError("relay_source_identity_changed")
        if not stat.S_ISREG(opened.st_mode) or opened.st_uid != os.geteuid() or opened.st_nlink != 1:
            raise OSError("relay_source_metadata_invalid")
        if opened.st_size > MAX_AUTHENTICATED_RELAY_SOURCE_BYTES:
            raise OSError("relay_source_too_large")
        chunks: list[bytes] = []
        remaining = MAX_AUTHENTICATED_RELAY_SOURCE_BYTES + 1
        while remaining > 0:
            chunk = os.read(fd, min(1 << 20, remaining))
            if not chunk:
                break
            chunks.append(chunk)
            remaining -= len(chunk)
        data = b"".join(chunks)
        if len(data) > MAX_AUTHENTICATED_RELAY_SOURCE_BYTES:
            raise OSError("relay_source_too_large")
        after = os.fstat(fd)
        if (
            (after.st_dev, after.st_ino) != (opened.st_dev, opened.st_ino)
            or not stat.S_ISREG(after.st_mode)
            or after.st_uid != os.geteuid()
            or after.st_nlink != 1
            or after.st_size != opened.st_size
            or len(data) != after.st_size
        ):
            raise OSError("relay_source_changed_during_read")
        landed = os.lstat(path)
        if (landed.st_dev, landed.st_ino) != (after.st_dev, after.st_ino):
            raise OSError("relay_source_replaced_during_read")
    finally:
        os.close(fd)
    if hashlib.sha256(data).hexdigest() != expected_digest:
        raise OSError("relay_source_integrity_failed")
    return data


DELIVERY_STATUS_STDIN_LOADER = (
    "import sys\n"
    "virtual = sys.argv[1]\n"
    "program = sys.stdin.buffer.read()\n"
    "sys.argv = [virtual, *sys.argv[2:]]\n"
    "namespace = {'__name__': '__main__', '__file__': virtual, '__package__': None, '__cached__': None}\n"
    "exec(compile(program, virtual, 'exec'), namespace)\n"
)


def materialize_delivery_status_runtime(destination: Path) -> tuple[Path, bytes]:
    if set(DELIVERY_STATUS_RUNTIME_SOURCES) != set(TRUSTED_DELIVERY_STATUS_RUNTIME_DIGESTS):
        raise OSError("delivery_status_runtime_inventory_mismatch")
    authenticated: dict[str, bytes] = {}
    for relative, expected_digest in TRUSTED_DELIVERY_STATUS_RUNTIME_DIGESTS.items():
        source = DELIVERY_STATUS_RUNTIME_SOURCES[relative]
        if source.is_symlink() or not source.is_file():
            raise OSError("delivery_status_runtime_source_invalid")
        content = _read_authenticated_relay_source(source, expected_digest)
        authenticated[relative] = content
    for relative, content in authenticated.items():
        target = destination / relative
        target.parent.mkdir(parents=True, exist_ok=True)
        # mkdir's mode is masked by the caller's umask; chmod is not. The private-runtime
        # validators require exactly 0700, so a bundle must not depend on the caller's umask.
        target.parent.chmod(0o700)
        write_private_authenticated(target, content, 0o500)
    entry_relative = "scripts/hermes-busdriver-delivery-status"
    return destination / entry_relative, authenticated[entry_relative]


# materialize_delivery_status_executables() used to live here. It copied git/gh/jq into a 0700
# `trusted-bin/` and put that directory at the head of the child's PATH, so the child dispatched a
# private copy. That was the private-copy design one level down, with two extra problems the parent
# never had: the copy sat in a directory we own (hence renameable by a same-UID adversary — the
# exact ABA this round removes), and copying /usr/bin/git copies the *CommandLineTools shim*, which
# outside /usr/bin is a code-signed binary stripped of SIP that the kernel is entitled to refuse.
#
# There is nothing to replace it with: the child carries the same frozen source table and the same
# ancestry walk, so it validates and execs the root-owned source itself. A bundle would only be a
# second, weaker copy of a decision the child can make correctly on its own.
def run_delivery_status(args: argparse.Namespace, *, include_lock_status: bool = True) -> tuple[dict[str, Any], int]:
    cmd: list[str] = []
    if args.repo:
        cmd += ["--repo", args.repo]
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    relay_role = getattr(args, "relay_role", None)
    if relay_role:
        cmd += ["--relay-role", relay_role]
    relay_config = getattr(args, "relay_config", None)
    if relay_config:
        cmd += ["--relay-config", relay_config]
    if relay_role and getattr(args, "relay_role_timeout", None) is not None:
        cmd += ["--relay-role-timeout", str(delivery_status_relay_role_timeout(args))]
    if args.pr:
        cmd += ["--pr", args.pr]
    cmd += ["--pr-grind-timeout", str(delivery_status_pr_grind_timeout(args))]
    cmd += ["--litmus-status-timeout", str(delivery_status_litmus_timeout(args))]
    litmus_base_ref = requested_litmus_base_ref(args)
    if litmus_base_ref:
        cmd += ["--litmus-base-ref", litmus_base_ref]
    drift_baseline = getattr(args, "drift_baseline", None)
    if drift_baseline:
        cmd += ["--drift-baseline", drift_baseline]
        cmd += ["--phase0-status-timeout", str(delivery_status_phase0_timeout(args))]
    state_dir_name = getattr(args, "busdriver_state_dir_name", None)
    if state_dir_name:
        cmd += ["--busdriver-state-dir-name", state_dir_name]
    if args.pr_grind_result_file:
        cmd += ["--pr-grind-result-file", args.pr_grind_result_file]
    if not include_lock_status:
        cmd += ["--no-lock-status"]

    timeout = effective_delivery_status_timeout(args)
    try:
        with tempfile.TemporaryDirectory(prefix="hermes-delivery-status-runtime-") as runtime_dir:
            runtime_root = Path(runtime_dir)
            delivery_status, delivery_status_program = materialize_delivery_status_runtime(runtime_root)
            cmd[:0] = [str(trusted_executable_path("python3")), "-I", "-c", DELIVERY_STATUS_STDIN_LOADER, str(delivery_status)]
            # The entrypoint bytes are retained in memory and sent on stdin. The materialized
            # pathname is only the virtual __file__ used for ROOT-relative reads, not something
            # Python re-opens for the program being executed.
            cp = _bounded_run(
                cmd,
                input=delivery_status_program,
                text=True,
                check=False,
                timeout=timeout,
                env=safe_git_env(),
            )
    except subprocess.TimeoutExpired as e:
        return {
            "ok": False,
            "error": "delivery_status_timeout",
            "returncode": 124,
            "timeout_seconds": timeout,
            "stdout_tail": tail(e.stdout),
            "stderr": tail(e.stderr),
        }, 124
    except (OSError, RuntimeError) as e:
        return {
            "ok": False,
            "error": "delivery_status_runtime_integrity_failed",
            "returncode": 2,
            "detail": str(e),
        }, 2

    try:
        data = json.loads(cp.stdout)
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "error": "delivery_status_invalid_json",
            "returncode": cp.returncode,
            "stdout_tail": tail(cp.stdout),
            "stderr": tail(cp.stderr.strip()),
            "parse_error": str(e),
        }, cp.returncode
    if not isinstance(data, dict):
        return {
            "ok": False,
            "error": "delivery_status_invalid_json_type",
            "returncode": cp.returncode,
            "stderr": tail(cp.stderr),
            "stdout_tail": tail(cp.stdout),
        }, cp.returncode
    if cp.returncode != 0:
        data["ok"] = False
        data["returncode"] = cp.returncode
        data["stderr"] = tail(cp.stderr)
    return data, cp.returncode


def delivery_status_decision_safe(value: Any) -> bool:
    return isinstance(value, dict) and authority_flags_safe(value)


def delivery_status_mutation_blocker(value: Any, operation: str) -> str | None:
    if not isinstance(value, dict):
        return "delivery_status_invalid"
    if value.get("schema") != DELIVERY_STATUS_SCHEMA:
        return "delivery_status_schema_invalid"
    if value.get("read_only") is not True:
        return "delivery_status_read_only_invalid"
    if value.get("ok") is not True:
        return "delivery_status_not_ok"
    decision_data = value.get("decision")
    if not delivery_status_decision_safe(decision_data):
        return "delivery_status_decision_unsafe"
    blockers = decision_data.get("blockers")
    if not isinstance(blockers, list):
        return "delivery_status_blockers_invalid"
    if blockers:
        return "delivery_status_blockers_present"
    markers = value.get("markers") if isinstance(value.get("markers"), dict) else {}
    if markers.get("blocking"):
        return "blocking_busdriver_marker_present"
    status = decision_data.get("status")
    allowed = {
        "pre-pr-review": {"no_local_delivery_candidate", "draft_changes_need_busdriver_finalization"},
        "commit": {"draft_changes_need_busdriver_finalization"},
        "push": {"no_local_delivery_candidate", "draft_changes_need_busdriver_finalization", "pr_review_fresh"},
        "pr-create": {"no_local_delivery_candidate", "draft_changes_need_busdriver_finalization", "pr_review_fresh"},
        "merge": {"pr_clean_read_only"},
    }.get(operation)
    if allowed is not None and status not in allowed:
        return "delivery_status_not_clean_for_operation"
    return None


def delivery_status_effect_summary(value: dict[str, Any], rc: int, blocker: str | None) -> dict[str, Any]:
    decision_data = value.get("decision") if isinstance(value.get("decision"), dict) else {}
    return {
        "name": "delivery_status_after_lock",
        "returncode": rc,
        "ok": blocker is None and rc == 0,
        "schema": value.get("schema"),
        "read_only": value.get("read_only"),
        "decision_status": decision_data.get("status"),
        "blocker": blocker,
        "decision_blockers": decision_data.get("blockers") if isinstance(decision_data.get("blockers"), list) else None,
    }


def args_for_locked_delivery_status(args: argparse.Namespace, repo: Path) -> argparse.Namespace:
    clone = argparse.Namespace(**vars(args))
    clone.repo = str(repo)
    return clone


def litmus_validation_status(delivery_status: dict[str, Any]) -> tuple[str | None, str | None]:
    litmus = delivery_status.get("litmus_status") if isinstance(delivery_status.get("litmus_status"), dict) else None
    if not litmus:
        return None, "litmus_status_missing"
    if litmus.get("available") is not True:
        return None, "litmus_status_unavailable"
    if litmus.get("ok") is not True:
        return None, str(litmus.get("reason") or "litmus_status_not_ok")
    if litmus.get("reason"):
        return None, str(litmus.get("reason"))
    summary = litmus.get("summary") if isinstance(litmus.get("summary"), dict) else None
    if not summary:
        return None, "litmus_status_summary_missing"
    if summary.get("schema") != LITMUS_STATUS_SCHEMA:
        return None, "litmus_status_schema_invalid"
    if summary.get("read_only") is not True or summary.get("ok") is not True:
        return None, "litmus_status_not_fresh"
    if summary.get("authority_safe") is not True:
        return None, "litmus_status_authority_flags_unsafe"
    if summary.get("decision_status_recognized") is not True:
        return None, "litmus_status_decision_unrecognized"
    decision_data = summary.get("decision") if isinstance(summary.get("decision"), dict) else {}
    if not authority_flags_safe(decision_data):
        return None, "litmus_status_decision_unsafe"
    status = decision_data.get("status")
    if not isinstance(status, str):
        return None, "litmus_status_decision_missing"
    return status, None


def require_litmus_status(delivery_status: dict[str, Any], allowed_statuses: set[str]) -> tuple[str | None, str | None]:
    status, blocker = litmus_validation_status(delivery_status)
    if blocker:
        return status, blocker
    if status not in allowed_statuses:
        return status, "fresh_litmus_required"
    return status, None


def staged_diff_hash(repo: Path) -> str | None:
    rc, raw, _stderr = git_observation_raw(
        repo, "diff", "--no-ext-diff", "--no-textconv", "--no-color", "--cached",
    )
    if rc != 0 or not raw:
        return None
    return hashlib.sha256(raw).hexdigest()


def reviewed_tree_diff_hash(repo: Path, parent_head: str, tree: str) -> str | None:
    rc, raw, _stderr = git_observation_raw(
        repo, "diff", "--no-ext-diff", "--no-textconv", "--no-color", parent_head, tree,
    )
    if rc != 0 or not raw:
        return None
    return hashlib.sha256(raw).hexdigest()


def commit_litmus_staged_diff_blocker(
    delivery_status: dict[str, Any],
    repo: Path,
    *,
    expected_parent_head: str | None = None,
    expected_tree: str | None = None,
) -> str | None:
    litmus = delivery_status.get("litmus_status") if isinstance(delivery_status.get("litmus_status"), dict) else {}
    summary = litmus.get("summary") if isinstance(litmus.get("summary"), dict) else {}
    markers = summary.get("markers") if isinstance(summary.get("markers"), dict) else {}
    marker = markers.get("litmus_passed") if isinstance(markers.get("litmus_passed"), dict) else {}
    marker_hash = marker.get("diff_hash")
    if not isinstance(marker_hash, str) or not re.fullmatch(r"[a-f0-9]{64}", marker_hash):
        return "commit_litmus_staged_diff_hash_missing"
    current_hash = (
        reviewed_tree_diff_hash(repo, expected_parent_head, expected_tree)
        if expected_parent_head is not None and expected_tree is not None
        else staged_diff_hash(repo)
    )
    if current_hash is None:
        return "staged_diff_hash_unavailable"
    if marker_hash != current_hash:
        return "commit_litmus_staged_diff_mismatch"
    return None


def diff_hash(repo: Path, *spec: str) -> str | None:
    rc, raw, _stderr = git_observation_raw(
        repo, "diff", "--no-ext-diff", "--no-textconv", "--no-color", *spec,
    )
    if rc != 0 or not raw:
        return None
    normalized = raw.rstrip(b"\n")
    if not normalized:
        return None
    return hashlib.sha256(normalized).hexdigest()


def resolve_default_base_ref(repo: Path) -> str:
    rc, ref, _err = git_output(repo, "symbolic-ref", "refs/remotes/origin/HEAD")
    if rc == 0 and ref:
        prefix = "refs/remotes/"
        return ref[len(prefix):] if ref.startswith(prefix) else ref
    return "origin/main"


def remote_branch_name_from_ref(ref: str | None) -> str | None:
    if not ref:
        return None
    for prefix in ("refs/remotes/origin/", "refs/heads/", "origin/"):
        if ref.startswith(prefix):
            return ref[len(prefix):]
    return ref


def normalize_pr_base_arg(base: str | None) -> str | None:
    if not isinstance(base, str) or not base:
        return None
    if base.startswith("refs/remotes/origin/"):
        return "origin/" + base[len("refs/remotes/origin/"):]
    if base.startswith("refs/heads/"):
        return "origin/" + base[len("refs/heads/"):]
    if base.startswith("refs/"):
        return None
    return base


def git_remote_names(repo: Path) -> set[str]:
    rc, out, _err = git_output(repo, "remote")
    if rc != 0 or not out:
        return set()
    return {line.strip() for line in out.splitlines() if line.strip()}


def pr_base_ref(repo: Path, base: str | None) -> str | None:
    if not base:
        candidate = resolve_default_base_ref(repo)
        rc, _out, _err = git_output(repo, "rev-parse", "--verify", f"{candidate}^{{commit}}")
        return candidate if rc == 0 else None
    base_name = normalize_pr_base_arg(base)
    if not base_name:
        return None
    if "/" in base_name and not base_name.startswith("origin/"):
        prefix = base_name.split("/", 1)[0]
        if prefix in git_remote_names(repo):
            return None
    candidates = (base_name,) if base_name.startswith("origin/") else (f"origin/{base_name}",)
    for candidate in candidates:
        rc, _out, _err = git_output(repo, "rev-parse", "--verify", f"{candidate}^{{commit}}")
        if rc == 0:
            return candidate
    return None


def live_remote_branch_head(repo: Path, branch: str, remote: str = "origin") -> tuple[str | None, str | None]:
    ref = f"refs/heads/{branch}"
    try:
        cp = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "ls-remote", "--heads", remote, ref],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_env({"GIT_CONFIG_NOSYSTEM": "1", "GIT_CONFIG_GLOBAL": os.devnull}),
        )
    except subprocess.TimeoutExpired:
        return None, "remote_branch_lookup_timeout"
    except (OSError, RuntimeError):
        return None, "remote_branch_lookup_failed"
    if cp.returncode != 0:
        return None, "remote_branch_lookup_failed"
    matches: list[str] = []
    for line in cp.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[1] == ref:
            matches.append(parts[0])
    if not matches:
        return None, "remote_branch_not_found"
    if len(matches) != 1:
        return None, "remote_branch_lookup_ambiguous"
    return matches[0], None


def remote_head_ancestor_status(repo: Path, remote_head: str | None) -> tuple[bool, str | None]:
    if not remote_head:
        return True, None
    try:
        cp = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "merge-base", "--is-ancestor", remote_head, "HEAD"],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_env(),
        )
    except subprocess.TimeoutExpired:
        return False, "remote_head_ancestor_check_timeout"
    except (OSError, RuntimeError):
        return False, "remote_head_ancestor_check_failed"
    if cp.returncode == 0:
        return True, None
    if cp.returncode == 1:
        return False, "remote_head_not_ancestor_for_push"
    return False, "remote_head_ancestor_unavailable_for_push"


def update_ref_command(ref: str, new_value: str, expected_old: str) -> list[str]:
    """A compare-and-swap on `ref`, with the same hook pin `push_command` carries.

    `git update-ref` fires the `reference-transaction` hook. `git_mutation_config_safety` checks
    the repo's hook config once, far upstream of the ref actually moving, so a concurrent actor
    can still drop a hook into the default path inside that window and get code execution as the
    Hermes user. The pin closes the window for every ref move on the commit path — publish and
    rollback alike.
    """
    return ["git", "-c", f"core.hooksPath={os.devnull}", "update-ref", ref, new_value, expected_old]


def push_command(repo: Path, remote: str, branch: str, remote_head: str | None, source_ref: str = "HEAD") -> list[str]:
    lease = f"refs/heads/{branch}:{remote_head or ''}"
    return ["git", "-c", f"core.hooksPath={os.devnull}", "push", "--no-follow-tags", "-u", f"--force-with-lease={lease}", remote, f"{source_ref}:refs/heads/{branch}"]


def run_isolated_push(repo: Path, remote_url: str, branch: str, remote_head: str | None, source_oid: str, base_branch: str, base_oid: str) -> dict[str, Any]:
    # Git omits an unchanged base refspec from the receive transaction, so it
    # cannot provide a server-side compare-only guard for the reviewed base.
    return {"cmd": ["git", "push"], "returncode": 2, "ok": False, "stdout_tail": "", "stderr_tail": "", "error": "atomic_push_base_binding_unavailable"}


def commit_staged_index(
    repo: Path,
    message: str,
    env_extra: dict[str, str] | None = None,
    *,
    expected_parent_head: str | None = None,
    expected_tree: str | None = None,
    reviewed_status: str | None = None,
    reviewed_untracked_snapshot: dict[str, str] | None = None,
    disable_hooks: bool = False,
) -> dict[str, Any]:
    started = time.time()
    env = safe_git_mutation_env(env_extra)
    substeps: list[dict[str, Any]] = []
    marker_dirs = set(DEFAULT_BUSDRIVER_MARKER_STATE_DIRS)
    marker_state_dir = (env_extra or {}).get("BUSDRIVER_STATE_DIR")
    if marker_state_dir:
        marker_state_path = Path(marker_state_dir)
        if marker_state_path.is_absolute():
            try:
                marker_dirs.add(marker_state_path.resolve().relative_to(repo.resolve()).as_posix())
            except ValueError:
                pass
        else:
            normalized_marker_state_dir = marker_state_dir.strip("/")
            if normalized_marker_state_dir:
                marker_dirs.add(normalized_marker_state_dir)
    allowed_marker_evidence_paths = allowed_marker_paths(marker_dirs)

    def marker_path_allowed(path: str, xy: str) -> bool:
        # No strip('"'): see decode_porcelain_path. Under `-z` a quote is part of the filename,
        # and stripping it is what let a hostile path land on an allow-listed marker.
        clean_path = path.strip()
        return clean_path in allowed_marker_evidence_paths and marker_dirty_status_allowed(xy)

    def porcelain_paths(line: str) -> list[str]:
        return porcelain_entry_paths(line)

    def literal_pathspecs(paths: list[str]) -> list[str]:
        return [f":(literal){path}" for path in paths]

    def pathspec_batches(paths: list[str], batch_size: int = 100, max_chars: int = 24_000):
        batch: list[str] = []
        batch_chars = 0
        batch_index = 1
        for path in paths:
            path_chars = len(f":(literal){path}".encode(errors="replace")) + 1
            if batch and (len(batch) >= batch_size or batch_chars + path_chars > max_chars):
                yield batch_index, batch
                batch_index += 1
                batch = []
                batch_chars = 0
            batch.append(path)
            batch_chars += path_chars
        if batch:
            yield batch_index, batch

    def aggregate_batch_effect(base_cmd: list[str], effects: list[dict[str, Any]]) -> dict[str, Any]:
        if not effects:
            return {"cmd": [*base_cmd, "--", "<no-pathspecs>"], "returncode": 0, "ok": True, "stdout_tail": "", "stderr_tail": "", "skipped": True, "batch_count": 0}
        ok = all(bool(effect.get("ok")) for effect in effects)
        returncode = 0 if ok else int(next((effect.get("returncode") for effect in effects if not effect.get("ok")), 1) or 1)
        return {"cmd": [*base_cmd, "--", "<pathspec-batches>"], "returncode": returncode, "ok": ok, "stdout_tail": "\n".join(str(effect.get("stdout_tail") or "") for effect in effects if effect.get("stdout_tail")), "stderr_tail": "\n".join(str(effect.get("stderr_tail") or "") for effect in effects if effect.get("stderr_tail")), "batch_count": len(effects)}

    def run_safe_pathspec_batches(base_cmd: list[str], paths: list[str], step_name: str, timeout: int = 60) -> dict[str, Any]:
        effects: list[dict[str, Any]] = []
        for batch_index, batch_paths in pathspec_batches(paths):
            batch_effect = run_safe([*base_cmd, "--", *literal_pathspecs(batch_paths)], repo, timeout=timeout, env=env)
            substeps.append({"name": f"{step_name}_batch", **batch_effect, "batch_index": batch_index, "path_count": len(batch_paths)})
            effects.append(batch_effect)
            if not batch_effect.get("ok"):
                break
        return aggregate_batch_effect(base_cmd, effects)

    def git_observation_effect_pathspec_batches(base_args: list[str], paths: list[str], step_name: str) -> dict[str, Any]:
        effects: list[dict[str, Any]] = []
        for batch_index, batch_paths in pathspec_batches(paths):
            batch_effect = git_observation_effect(repo, *base_args, "--", *literal_pathspecs(batch_paths))
            substeps.append({"name": f"{step_name}_batch", **batch_effect, "batch_index": batch_index, "path_count": len(batch_paths)})
            effects.append(batch_effect)
            if not batch_effect.get("ok"):
                break
        return aggregate_batch_effect(["git", *base_args], effects)

    def git_output_pathspec_batches(base_args: list[str], paths: list[str], step_name: str, separator: str = "\n") -> tuple[int, str, str, dict[str, Any]]:
        outputs: list[str] = []
        errors: list[str] = []
        effects: list[dict[str, Any]] = []
        for batch_index, batch_paths in pathspec_batches(paths):
            rc, out, err = git_output(repo, *base_args, "--", *literal_pathspecs(batch_paths))
            batch_effect = {"cmd": ["git", *base_args, "--", *literal_pathspecs(batch_paths)], "returncode": rc, "ok": rc == 0, "stdout_tail": tail(out), "stderr_tail": tail(err), "batch_index": batch_index, "path_count": len(batch_paths)}
            substeps.append({"name": f"{step_name}_batch", **batch_effect})
            effects.append(batch_effect)
            if out:
                outputs.append(out)
            if err:
                errors.append(err)
            if rc != 0:
                aggregate = aggregate_batch_effect(["git", *base_args], effects)
                return rc, separator.join(outputs), "\n".join(errors), aggregate
        aggregate = aggregate_batch_effect(["git", *base_args], effects)
        return 0, separator.join(outputs), "\n".join(errors), aggregate

    def git_observation_raw_pathspec_batches(base_args: list[str], paths: list[str], step_name: str) -> tuple[int, bytes, str, dict[str, Any]]:
        """The bytes-preserving twin of git_output_pathspec_batches, for NUL-framed reads.

        Batches concatenate with no separator: every `-z` record already carries its own NUL
        terminator, so joining the raw bytes reframes nothing.
        """
        outputs: list[bytes] = []
        errors: list[str] = []
        effects: list[dict[str, Any]] = []
        for batch_index, batch_paths in pathspec_batches(paths):
            rc, out, err = git_observation_raw(repo, *base_args, "--", *literal_pathspecs(batch_paths))
            batch_effect = {"cmd": ["git", *base_args, "--", *literal_pathspecs(batch_paths)], "returncode": rc, "ok": rc == 0, "stdout_tail": tail(out), "stderr_tail": tail(err), "batch_index": batch_index, "path_count": len(batch_paths)}
            substeps.append({"name": f"{step_name}_batch", **batch_effect})
            effects.append(batch_effect)
            if out:
                outputs.append(out)
            if err:
                errors.append(err)
            if rc != 0:
                return rc, b"".join(outputs), "\n".join(errors), aggregate_batch_effect(["git", *base_args], effects)
        return 0, b"".join(outputs), "\n".join(errors), aggregate_batch_effect(["git", *base_args], effects)

    def restore_reviewed_paths_from_tree(tree: str, paths: list[str], aggregate_step_name: str, ls_step_name: str) -> dict[str, Any]:
        tree_paths_rc, tree_paths_out, tree_paths_err, tree_paths_effect = git_output_pathspec_batches(["ls-tree", "-r", "-z", "--name-only", tree], paths, ls_step_name, separator="\0")
        tree_path_set = {path for path in tree_paths_out.split("\0") if path}
        paths_in_tree = [path for path in paths if path in tree_path_set]
        paths_deleted_in_tree = [path for path in paths if path not in tree_path_set]
        tree_paths_effect.update({"present_path_count": len(paths_in_tree), "deleted_path_count": len(paths_deleted_in_tree)})
        substeps.append({"name": ls_step_name, **tree_paths_effect})
        if tree_paths_rc != 0:
            aggregate = {"cmd": ["git", "restore_reviewed_tree"], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": tree_paths_err, "present_path_count": len(paths_in_tree), "deleted_path_count": len(paths_deleted_in_tree)}
            substeps.append({"name": aggregate_step_name, **aggregate, "path_count": len(paths)})
            return aggregate
        restore_index_effect = run_safe_pathspec_batches(["git", "restore", "--source", tree, "--staged"], paths_in_tree, "git_restore_reviewed_index") if paths_in_tree else {"ok": True, "returncode": 0, "stdout_tail": "", "stderr_tail": "", "skipped": True, "batch_count": 0}
        substeps.append({"name": "git_restore_reviewed_index", **restore_index_effect, "path_count": len(paths_in_tree)})
        remove_deleted_index_effect = run_safe_pathspec_batches(["git", "rm", "-f", "--cached", "--ignore-unmatch"], paths_deleted_in_tree, "git_remove_reviewed_deleted_paths_from_index") if paths_deleted_in_tree and restore_index_effect.get("ok") else {"ok": True, "returncode": 0, "stdout_tail": "", "stderr_tail": "", "skipped": not bool(paths_deleted_in_tree), "batch_count": 0}
        substeps.append({"name": "git_remove_reviewed_deleted_paths_from_index", **remove_deleted_index_effect, "path_count": len(paths_deleted_in_tree)})
        restore_worktree_effect = run_safe_pathspec_batches(["git", "restore", "--source", tree, "--worktree"], paths_in_tree, "git_restore_reviewed_worktree_existing_paths") if paths_in_tree and restore_index_effect.get("ok") and remove_deleted_index_effect.get("ok") else {"ok": True, "returncode": 0, "stdout_tail": "", "stderr_tail": "", "skipped": not bool(paths_in_tree), "batch_count": 0}
        substeps.append({"name": "git_restore_reviewed_worktree_existing_paths", **restore_worktree_effect, "path_count": len(paths_in_tree)})
        clean_deleted_worktree_effect = run_safe_pathspec_batches(["git", "clean", "-fd"], paths_deleted_in_tree, "git_clean_reviewed_deleted_paths_from_worktree") if paths_deleted_in_tree and restore_index_effect.get("ok") and remove_deleted_index_effect.get("ok") else {"ok": True, "returncode": 0, "stdout_tail": "", "stderr_tail": "", "skipped": not bool(paths_deleted_in_tree), "batch_count": 0}
        substeps.append({"name": "git_clean_reviewed_deleted_paths_from_worktree", **clean_deleted_worktree_effect, "path_count": len(paths_deleted_in_tree)})
        restore_effect_ok = bool(restore_index_effect.get("ok") and remove_deleted_index_effect.get("ok") and restore_worktree_effect.get("ok") and clean_deleted_worktree_effect.get("ok"))
        aggregate = {"cmd": ["git", "restore_reviewed_tree"], "returncode": 0 if restore_effect_ok else 1, "ok": restore_effect_ok, "stdout_tail": "", "stderr_tail": "\n".join(str(effect.get("stderr_tail") or "") for effect in (restore_index_effect, remove_deleted_index_effect, restore_worktree_effect, clean_deleted_worktree_effect) if effect.get("stderr_tail")), "present_path_count": len(paths_in_tree), "deleted_path_count": len(paths_deleted_in_tree)}
        substeps.append({"name": aggregate_step_name, **aggregate, "path_count": len(paths)})
        return aggregate

    pre_status_rc, pre_status_records, pre_status_err = git_status_records(repo, "--untracked-files=all")
    pre_status_out = status_records_text(pre_status_records)
    pre_allowed_marker_snapshot = marker_evidence_snapshot_from_status(repo, pre_status_records, allowed_marker_evidence_paths) if pre_status_rc == 0 else {}
    substeps.append({"name": "git_status_before_commit", "cmd": ["git", "status", "--porcelain=v1", "--untracked-files=all"], "returncode": pre_status_rc, "ok": pre_status_rc == 0, "stdout_tail": tail(pre_status_out), "stderr_tail": tail(pre_status_err), "pre_allowed_marker_entry_count": len(pre_allowed_marker_snapshot)})
    if pre_status_rc != 0:
        return {"cmd": ["git", "status", "--porcelain=v1", "--untracked-files=all"], "returncode": pre_status_rc or 1, "ok": False, "stdout_tail": pre_status_out, "stderr_tail": pre_status_err, "elapsed_seconds": round(time.time() - started, 3), "error": "pre_commit_status_failed", "substeps": substeps, "before_head": "", "after_head": ""}
    if reviewed_status is not None and pre_status_out != reviewed_status.rstrip("\n"):
        return {"cmd": ["git", "commit"], "returncode": 1, "ok": False, "stdout_tail": pre_status_out, "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "pre_commit_status_changed_after_review", "substeps": substeps, "before_head": "", "after_head": ""}
    pre_commit_dirty_entries: list[str] = []
    pre_existing_untracked_snapshot: dict[str, str] = dict(reviewed_untracked_snapshot or {})
    for pre_xy, pre_record_paths in pre_status_records:
        pre_line = status_record_entry(pre_xy, pre_record_paths)
        pre_paths = [path.rstrip("/") for path in pre_record_paths]
        if len(pre_paths) == 1 and marker_path_allowed(pre_paths[0], pre_xy):
            if pre_paths[0] in pre_allowed_marker_snapshot:
                continue
            pre_commit_dirty_entries.append(pre_line)
            continue
        if pre_xy == "??":
            for pre_path in pre_paths:
                identity = untracked_file_identity(repo, pre_path)
                if reviewed_untracked_snapshot is not None and pre_existing_untracked_snapshot.get(pre_path) != identity:
                    return {"cmd": ["git", "commit"], "returncode": 1, "ok": False, "stdout_tail": pre_status_out, "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "pre_commit_status_changed_after_review", "substeps": substeps, "before_head": "", "after_head": ""}
                pre_existing_untracked_snapshot[pre_path] = identity
            continue
        if len(pre_xy) > 1 and pre_xy[1] != " ":
            pre_commit_dirty_entries.append(pre_line)
    if pre_commit_dirty_entries:
        substeps.append({"name": "git_pre_commit_non_marker_dirty_check", "cmd": [], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": "", "blocking_dirty_entries": pre_commit_dirty_entries})
        return {"cmd": ["git", "commit"], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "pre_commit_non_marker_dirty_worktree", "substeps": substeps, "before_head": "", "after_head": ""}

    def non_marker_dirty_paths() -> tuple[list[str], list[str], dict[str, Any]]:
        rc, records, err = git_status_records(repo, "--untracked-files=all")
        effect = {"cmd": ["git", "status", "--porcelain=v1", "--untracked-files=all"], "returncode": rc, "ok": rc == 0, "stdout_tail": tail(status_records_text(records)), "stderr_tail": tail(err)}
        tracked: list[str] = []
        untracked: list[str] = []
        if rc != 0:
            return ["<status_failed>"], [], effect
        current_allowed_marker_snapshot = marker_evidence_snapshot_from_status(repo, records, allowed_marker_evidence_paths)
        seen_marker_paths: set[str] = set()
        seen_preexisting_untracked_paths: set[str] = set()
        for xy, record_paths in records:
            paths = [path.rstrip("/") for path in record_paths]
            if len(paths) == 1 and marker_path_allowed(paths[0], xy):
                seen_marker_paths.add(paths[0])
                if paths[0] in current_allowed_marker_snapshot and current_allowed_marker_snapshot.get(paths[0]) == pre_allowed_marker_snapshot.get(paths[0]):
                    continue
                if xy == "??":
                    untracked.extend(paths)
                else:
                    tracked.extend(paths)
                continue
            if xy == "??":
                unchanged_preexisting = True
                for path in paths:
                    identity = untracked_file_identity(repo, path)
                    if pre_existing_untracked_snapshot.get(path) != identity:
                        unchanged_preexisting = False
                        break
                if unchanged_preexisting:
                    seen_preexisting_untracked_paths.update(paths)
                    continue
                untracked.extend(paths)
            else:
                tracked.extend(paths)
        for marker_path, marker_snapshot in pre_allowed_marker_snapshot.items():
            if marker_path not in seen_marker_paths and current_allowed_marker_snapshot.get(marker_path) != marker_snapshot:
                tracked.append(marker_path)
        for untracked_path, identity in pre_existing_untracked_snapshot.items():
            if untracked_path not in seen_preexisting_untracked_paths and untracked_file_identity(repo, untracked_path) != identity:
                untracked.append(untracked_path)
        return tracked, untracked, effect

    before_effect = run_safe(["git", "rev-parse", "HEAD"], repo, timeout=30, env=env)
    substeps.append({"name": "git_rev_parse_before", **before_effect})
    before = str(before_effect.get("stdout_tail") or "").strip()
    if not before_effect.get("ok") or not before:
        return {"cmd": ["git", "commit"], "returncode": int(before_effect.get("returncode") or 1), "ok": False, "stdout_tail": "", "stderr_tail": before_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "head_lookup_failed", "substeps": substeps, "before_head": before, "after_head": before}
    if expected_parent_head is not None and before != expected_parent_head:
        return {"cmd": ["git", "commit"], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "commit_parent_changed_after_review", "expected_parent_head": expected_parent_head, "observed_parent_head": before, "substeps": substeps, "before_head": before, "after_head": before}

    ref_effect = run_safe(["git", "symbolic-ref", "--quiet", "HEAD"], repo, timeout=30, env=env)
    substeps.append({"name": "git_symbolic_ref_head", **ref_effect})
    branch_ref = str(ref_effect.get("stdout_tail") or "").strip()
    if not ref_effect.get("ok") or not branch_ref.startswith("refs/heads/"):
        return {"cmd": ["git", "commit"], "returncode": int(ref_effect.get("returncode") or 1), "ok": False, "stdout_tail": "", "stderr_tail": ref_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "branch_ref_lookup_failed", "substeps": substeps, "before_head": before, "after_head": before}

    tree_effect = run_safe(["git", "write-tree"], repo, timeout=60, env=env)
    substeps.append({"name": "git_write_tree_before", **tree_effect})
    observed_tree = str(tree_effect.get("stdout_tail") or "").strip()
    if not tree_effect.get("ok") or not observed_tree:
        return {"cmd": ["git", "write-tree"], "returncode": int(tree_effect.get("returncode") or 1), "ok": False, "stdout_tail": "", "stderr_tail": tree_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "write_tree_failed", "substeps": substeps, "before_head": before, "after_head": before}
    if expected_tree is not None and observed_tree != expected_tree:
        return {"cmd": ["git", "write-tree"], "returncode": 1, "ok": False, "stdout_tail": observed_tree, "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "commit_index_changed_after_review", "expected_tree": expected_tree, "observed_tree": observed_tree, "substeps": substeps, "before_head": before, "after_head": before}
    expected_tree = expected_tree or observed_tree

    reviewed_paths_rc, reviewed_paths_out, reviewed_paths_err = git_output(repo, "diff", "--cached", "--name-only", "-z", "--no-renames", before, "--")
    reviewed_paths = [path for path in reviewed_paths_out.split("\0") if path]
    substeps.append({"name": "git_reviewed_paths", "cmd": ["git", "diff", "--cached", "--name-only", "-z", "--no-renames", before, "--"], "returncode": reviewed_paths_rc, "ok": reviewed_paths_rc == 0 and bool(reviewed_paths), "stdout_tail": tail(reviewed_paths_out), "stderr_tail": tail(reviewed_paths_err), "path_count": len(reviewed_paths)})
    if reviewed_paths_rc != 0 or not reviewed_paths:
        return {"cmd": ["git", "diff", "--cached", "--name-only", "-z", "--no-renames", before, "--"], "returncode": reviewed_paths_rc or 1, "ok": False, "stdout_tail": reviewed_paths_out, "stderr_tail": reviewed_paths_err, "elapsed_seconds": round(time.time() - started, 3), "error": "reviewed_paths_unavailable", "substeps": substeps, "before_head": before, "after_head": before}
    reviewed_path_set = set(reviewed_paths)
    preexisting_untracked_reviewed_paths = sorted(path for path in pre_existing_untracked_snapshot if path in reviewed_path_set)
    if preexisting_untracked_reviewed_paths:
        substeps.append({"name": "git_pre_commit_reviewed_untracked_worktree_check", "cmd": [], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": "", "paths": preexisting_untracked_reviewed_paths})
        return {"cmd": ["git", "commit"], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "error": "pre_commit_reviewed_untracked_worktree", "substeps": substeps, "before_head": before, "after_head": before}

    candidate_commit = ""
    if disable_hooks:
        commit_tree_effect = run_safe(
            ["git", "commit-tree", expected_tree, "-p", before],
            repo,
            timeout=300,
            env=env,
            input_text=message.rstrip("\n") + "\n",
        )
        substeps.append({"name": "git_commit_tree", **commit_tree_effect})
        candidate_commit = str(commit_tree_effect.get("stdout_tail") or "").strip()
        if not commit_tree_effect.get("ok") or not re.fullmatch(r"[0-9a-fA-F]{40,64}", candidate_commit):
            return {"cmd": ["git", "commit-tree"], "returncode": int(commit_tree_effect.get("returncode") or 1), "ok": False, "stdout_tail": "", "stderr_tail": commit_tree_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "git_commit_tree_failed", "substeps": substeps, "before_head": before, "after_head": before}
        commit_cmd = update_ref_command(branch_ref, candidate_commit, before)
        commit_effect = run_safe(commit_cmd, repo, timeout=60, env=env)
        substeps.append({"name": "git_update_ref_commit_cas", **commit_effect, "candidate_commit": candidate_commit, "expected_old_head": before})
        if not commit_effect.get("ok"):
            live_head_effect = run_safe(["git", "rev-parse", "HEAD"], repo, timeout=30, env=env)
            substeps.append({"name": "git_rev_parse_after_commit_cas_failure", **live_head_effect})
            live_authoritative = bool(live_head_effect.get("ok"))
            live_head = str(live_head_effect.get("stdout_tail") or "").strip() if live_authoritative else ""
            base = {
                "cmd": commit_cmd,
                "returncode": int(commit_effect.get("returncode") or 1),
                "ok": False,
                "stdout_tail": "",
                "stderr_tail": commit_effect.get("stderr_tail", ""),
                "elapsed_seconds": round(time.time() - started, 3),
                "candidate_commit": candidate_commit,
                "commit_verified": True,
                "substeps": substeps,
                "before_head": before,
                "after_head": live_head,
            }
            if live_authoritative and live_head == candidate_commit:
                # The CAS postcondition is present even though the bounded transport lost command
                # completion. Retrying would duplicate already-published work.
                return {
                    **base,
                    "error": "commit_publish_completion_unconfirmed",
                    "effect_completed": True,
                    "reconciliation_required": True,
                }
            if live_authoritative and live_head == before:
                # Only this observation proves that this invocation's CAS had no ref effect.
                return {**base, "error": "commit_parent_changed_during_publish"}
            # A third value can mean either that our CAS lost or that it landed and another actor
            # advanced the ref before observation. A failed head read is equally unknowable. Both
            # prohibit an automatic retry and require explicit reconciliation.
            return {
                **base,
                "error": "commit_publish_outcome_unknown",
                "effect_completed": False,
                "effect_may_have_completed": True,
                "effect_outcome_unknown": True,
                "reconciliation_required": True,
            }
    else:
        commit_cmd = ["git", "-c", "commit.gpgsign=false", "commit", "--cleanup=verbatim", "-m", message]
        commit_effect = run_safe(commit_cmd, repo, timeout=300, env=env)
        substeps.append({"name": "git_commit", **commit_effect})
    after_effect = run_safe(["git", "rev-parse", "HEAD"], repo, timeout=30, env=env)
    substeps.append({"name": "git_rev_parse_after", **after_effect})
    # A failed head read is an UNKNOWN head, never `before`. Substituting `before` here would
    # fabricate an observation the code never made, and every downstream question asked of it —
    # most of all `merge-base --is-ancestor candidate before`, which the candidate's own parent
    # makes answer "no" by construction — would return a confident answer about a head nobody saw.
    after_authoritative = bool(after_effect.get("ok"))
    after = str(after_effect.get("stdout_tail") or "").strip() if after_authoritative else ""
    if disable_hooks and not after_authoritative:
        # An unobserved head is NOT drift. Our publish CAS succeeded, so `candidate_commit` went
        # onto the branch; we simply failed to read the head back. Falling into the rollback below
        # on `"" != candidate_commit` would CAS away this invocation's own valid publish in the
        # ordinary case where nothing raced at all — the branch is still exactly where we put it,
        # so the rollback CAS WINS and destroys a real commit. Only an authoritative, mismatched
        # observation is evidence of drift. The mutation is a fact; its fate is just unobserved.
        return {
            "cmd": commit_cmd,
            "returncode": 1,
            "ok": False,
            "stdout_tail": "",
            "stderr_tail": "",
            "elapsed_seconds": round(time.time() - started, 3),
            "candidate_commit": candidate_commit,
            "substeps": substeps,
            "before_head": before,
            "commit_verified": True,
            "effect_completed": True,
            "reconciliation_required": True,
            "error": "post_publish_ref_advance_reachability_unverified",
            "after_head": "",
            "post_publish_head_stderr": after_effect.get("stderr_tail", ""),
        }
    if disable_hooks and after != candidate_commit:
        # Our publish CAS succeeded, so `candidate_commit` was on the branch; the head then moved.
        # Try to take it back with a CAS against our own commit.
        reset_effect = run_safe(update_ref_command(branch_ref, before, candidate_commit), repo, timeout=60, env=env)
        substeps.append({"name": "git_update_ref_before_after_hook_drift", **reset_effect})
        base = {"cmd": commit_cmd, "returncode": 1, "ok": False, "stdout_tail": after, "stderr_tail": "", "elapsed_seconds": round(time.time() - started, 3), "candidate_commit": candidate_commit, "substeps": substeps, "before_head": before}
        if reset_effect.get("ok"):
            # The rollback CAS won: the ref was still at our commit, and it is now back at `before`.
            # The commit object survives but is off the branch — a true no-side-effect outcome.
            return {**base, "error": "post_publish_ref_advance_rolled_back", "after_head": before}
        # The rollback CAS lost: this invocation published `candidate_commit` to the branch and
        # could not take it back. The mutation is a fact from here on; only WHERE the branch
        # ended up is still open, and every answer below is a completed mutation awaiting
        # reconciliation. A published commit must never authenticate as no-side-effect.
        published = {
            **base,
            "commit_verified": True,
            "effect_completed": True,
            "reconciliation_required": True,
        }
        # `after` is authoritative here: the unobservable case returned above, before any rollback.
        ancestor_effect = run_safe(["git", "merge-base", "--is-ancestor", candidate_commit, after], repo, timeout=30, env=env)
        substeps.append({"name": "git_merge_base_is_ancestor_candidate_after", **ancestor_effect})
        ancestor_rc = int(ancestor_effect.get("returncode") or 0)
        if ancestor_rc == 0 and ancestor_effect.get("ok"):
            # Reachable: our commit is in the branch's history and another actor built on top.
            return {**published, "error": "post_publish_ref_advanced", "after_head": after}
        if ancestor_rc == 1:
            # `--is-ancestor` exits 1 for a definitive "not reachable": another actor moved the
            # branch somewhere that excludes our commit. That is a reconciliation problem, not an
            # undo — we still published to this ref and never removed what we published.
            return {**published, "error": "post_publish_ref_advance_not_reachable", "after_head": after}
        # Any other exit is the check itself failing: the fate is simply unknown.
        return {
            **published,
            "error": "post_publish_ref_advance_reachability_unverified",
            "after_head": after,
            "reachability_check_stderr": ancestor_effect.get("stderr_tail", ""),
        }
    verified_commit = candidate_commit or after
    after_tree_effect = run_safe(["git", "rev-parse", f"{verified_commit}^{{tree}}"], repo, timeout=30, env=env) if verified_commit and verified_commit != before else {"ok": False, "returncode": 1, "stdout_tail": "", "stderr_tail": ""}
    substeps.append({"name": "git_rev_parse_after_tree", **after_tree_effect})
    after_tree = str(after_tree_effect.get("stdout_tail") or "").strip() if after_tree_effect.get("ok") else ""

    def fail_and_restore_reviewed_tree(error: str) -> dict[str, Any]:
        # The ref rollback is a compare-and-swap against the commit published by
        # this invocation.  After that CAS, pathname-based restore/rm/clean is
        # unsafe: another actor may already own index or worktree bytes.  Keep
        # all bytes intact and require explicit reconciliation.
        if after and after != before:
            reset_effect = run_safe(update_ref_command(branch_ref, before, verified_commit), repo, timeout=60, env=env)
        else:
            reset_effect = {"cmd": update_ref_command(branch_ref, before, after or before), "returncode": 0, "ok": True, "stdout_tail": "", "stderr_tail": "", "skipped": True}
        substeps.append({"name": "git_update_ref_before_after_hook_drift", **reset_effect})
        tracked_dirty, untracked_dirty, status_effect = non_marker_dirty_paths()
        substeps.append({
            "name": "git_status_after_failed_commit_rollback_preserve",
            **status_effect,
            "tracked_dirty": tracked_dirty,
            "untracked_dirty": untracked_dirty,
            "reconciliation_required": True,
        })
        rollback_ok = bool(reset_effect.get("ok"))
        # A rollback CAS that wins (or is skipped because nothing was published) leaves the branch
        # at `before`: the original reason is a truthful no-side-effect blocker. A rollback CAS
        # that LOSES proves the opposite — this invocation published a commit and could not take
        # it back — so it must carry its own reason and report as a completed mutation awaiting
        # reconciliation, never as blocked.
        published = {} if rollback_ok else {
            "error": f"{error}_rollback_failed",
            "commit_verified": True,
            "effect_completed": True,
        }
        return {
            "cmd": commit_cmd,
            "returncode": 1,
            "ok": False,
            "stdout_tail": commit_effect.get("stdout_tail", ""),
            "stderr_tail": commit_effect.get("stderr_tail", ""),
            "elapsed_seconds": round(time.time() - started, 3),
            "error": error,
            **published,
            "expected_tree": expected_tree,
            "actual_tree": after_tree,
            "reset_to_before_ok": rollback_ok,
            "restore_reviewed_index_ok": False,
            "restore_reviewed_worktree_ok": False,
            "reconciliation_required": True,
            "worktree_index_preserved": True,
            "post_rollback_tracked_dirty": tracked_dirty,
            "post_rollback_untracked_dirty": untracked_dirty,
            "substeps": substeps,
            "before_head": before,
            "after_head": before if rollback_ok else after,
        }

    parent_effect = run_safe(["git", "rev-list", "--parents", "-n", "1", verified_commit], repo, timeout=30, env=env) if verified_commit and verified_commit != before else {"ok": False, "returncode": 1, "stdout_tail": "", "stderr_tail": ""}
    substeps.append({"name": "git_rev_list_head_parents_after_commit", **parent_effect})
    parent_line = str(parent_effect.get("stdout_tail") or "").strip()
    parent_ok = parent_line == f"{verified_commit} {before}"
    if after and after != before:
        message_rc, message_out, message_err = git_output(repo, "log", "-1", "--format=%B", verified_commit)
        message_effect = {"cmd": ["git", "log", "-1", "--format=%B", verified_commit], "returncode": message_rc, "ok": message_rc == 0, "stdout_tail": tail(message_out), "stderr_tail": tail(message_err)}
    else:
        message_rc, message_out, message_err = 1, "", ""
        message_effect = {"cmd": ["git", "log", "-1", "--format=%B"], "returncode": 1, "ok": False, "stdout_tail": "", "stderr_tail": ""}
    substeps.append({"name": "git_log_message_after_commit", **message_effect})
    actual_message = message_out.rstrip("\n")
    expected_message = str(message).rstrip("\n")
    message_ok = bool(message_rc == 0 and actual_message == expected_message)
    ok = bool(commit_effect.get("ok") and after and after != before and after_tree == expected_tree and parent_ok and message_ok)
    if commit_effect.get("ok") and after and after != before and (after_tree != expected_tree or not parent_ok):
        return fail_and_restore_reviewed_tree("committed_tree_or_parent_mismatch_after_hooks")
    if commit_effect.get("ok") and after and after != before and not message_ok:
        return fail_and_restore_reviewed_tree("committed_message_mismatch_after_hooks")
    if not ok:
        return fail_and_restore_reviewed_tree("git_commit_failed_or_hook_drift")

    index_clean_effect = git_observation_effect_pathspec_batches(["diff", "--cached", "--quiet"], reviewed_paths, "git_diff_cached_quiet_reviewed_paths_after_commit")
    substeps.append({"name": "git_diff_cached_quiet_reviewed_paths_after_commit", **index_clean_effect})
    worktree_clean_effect = git_observation_effect_pathspec_batches(["diff", "--quiet"], reviewed_paths, "git_diff_worktree_quiet_reviewed_paths_after_commit")
    substeps.append({"name": "git_diff_worktree_quiet_reviewed_paths_after_commit", **worktree_clean_effect})
    dirty_reviewed_paths_after_commit = index_clean_effect.get("returncode") == 1 or worktree_clean_effect.get("returncode") == 1
    # -z here for the same reason as every other status read: this list decides whether reviewed
    # paths drifted, and a fabricated `?? ` record is a fabricated drift verdict.
    reviewed_status_rc, reviewed_status_raw, reviewed_status_err, reviewed_status_effect = git_observation_raw_pathspec_batches(["status", "--porcelain=v1", "-z", "--untracked-files=all"], reviewed_paths, "git_status_reviewed_paths_after_commit")
    reviewed_untracked_after_commit: list[str] = []
    if reviewed_status_rc == 0:
        reviewed_path_set = set(reviewed_paths)
        for reviewed_xy, reviewed_record_paths in parse_porcelain_z(reviewed_status_raw):
            if reviewed_xy == "??":
                reviewed_untracked_after_commit.extend(path.rstrip("/") for path in reviewed_record_paths if path.rstrip("/") in reviewed_path_set)
    substeps.append({"name": "git_status_reviewed_paths_after_commit", **reviewed_status_effect, "reviewed_untracked_paths": reviewed_untracked_after_commit})
    diff_check_failed = index_clean_effect.get("returncode") not in {0, 1} or worktree_clean_effect.get("returncode") not in {0, 1} or reviewed_status_rc != 0
    if diff_check_failed:
        return {"cmd": commit_cmd, "returncode": 1, "ok": False, "stdout_tail": after, "stderr_tail": commit_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "post_commit_dirty_check_failed", "commit_verified": True, "substeps": substeps, "before_head": before, "after_head": after}
    if dirty_reviewed_paths_after_commit or reviewed_untracked_after_commit:
        substeps.append({
            "name": "git_post_commit_reviewed_drift_preserved",
            "cmd": [],
            "returncode": 0,
            "ok": True,
            "stdout_tail": "",
            "stderr_tail": "",
            "tracked_or_modified": bool(dirty_reviewed_paths_after_commit),
            "untracked_paths": reviewed_untracked_after_commit,
            "warning": "post_commit_concurrent_work_preserved",
        })

    tracked_dirty, untracked_dirty, status_effect = non_marker_dirty_paths()
    substeps.append({"name": "git_status_after_commit_non_marker_dirty", **status_effect, "tracked_dirty": tracked_dirty, "untracked_dirty": untracked_dirty})
    if tracked_dirty == ["<status_failed>"]:
        return {"cmd": commit_cmd, "returncode": 1, "ok": False, "stdout_tail": after, "stderr_tail": status_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "error": "post_commit_status_failed", "commit_verified": True, "substeps": substeps, "before_head": before, "after_head": after}
    if tracked_dirty or untracked_dirty:
        dirty_paths = sorted(set(tracked_dirty + untracked_dirty))
        substeps.append({"name": "git_post_commit_concurrent_work_left_for_operator", "cmd": [], "returncode": 0, "ok": True, "stdout_tail": "", "stderr_tail": "", "path_count": len(dirty_paths), "paths": dirty_paths, "warning": "post_commit_concurrent_work_preserved"})
        return {"cmd": commit_cmd, "returncode": 0, "ok": True, "stdout_tail": after, "stderr_tail": commit_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "warning": "post_commit_concurrent_work_preserved", "commit_verified": True, "post_commit_dirty_paths": dirty_paths, "substeps": substeps, "before_head": before, "after_head": after}
    return {"cmd": commit_cmd, "returncode": 0, "ok": True, "stdout_tail": after, "stderr_tail": commit_effect.get("stderr_tail", ""), "elapsed_seconds": round(time.time() - started, 3), "commit_verified": True, "substeps": substeps, "before_head": before, "after_head": after}


def push_remote_safety(repo: Path, remote: str) -> tuple[bool, str | None]:
    if github_repo_slug(repo, remote) is None:
        return False, "github_origin_remote_required_for_push"
    pushurl_rc, pushurl, _pushurl_err = git_output(repo, "config", "--get-all", f"remote.{remote}.pushurl")
    if pushurl_rc == 0 and pushurl:
        return False, "remote_pushurl_blocked_for_push"
    if pushurl_rc not in {0, 1}:
        return False, "remote_pushurl_check_failed_for_push"
    rewrite_rc, rewrite, _rewrite_err = git_output(repo, "config", "--get-regexp", r"^url\..*\.(pushInsteadOf|insteadOf)$")
    if rewrite_rc == 0 and rewrite:
        return False, "url_rewrite_blocked_for_push"
    if rewrite_rc not in {0, 1}:
        return False, "url_rewrite_check_failed_for_push"
    modifier_checks = (
        (f"remote.{remote}.mirror", "remote_mirror_blocked_for_push"),
        (f"remote.{remote}.push", "remote_push_refspec_blocked_for_push"),
        ("push.followTags", "push_follow_tags_blocked_for_push"),
        ("push.pushOption", "push_option_blocked_for_push"),
    )
    for key, reason in modifier_checks:
        rc, value, _err = git_output(repo, "config", "--get-all", key)
        if rc == 0 and value:
            return False, reason
        if rc not in {0, 1}:
            return False, f"{reason}_check_failed"
    return True, None


def git_mutation_config_safety(repo: Path) -> tuple[bool, str | None]:
    """Reject repository-local config that can redirect hooks, credentials, or network I/O."""
    try:
        cp = _bounded_run(
            [
                str(trusted_executable_path("git")), "-C", str(repo), "config", "--name-only", "--get-regexp",
                r"^(core\.(hookspath|sshcommand|gitproxy|askpass|fsmonitor|attributesfile)|credential\.|remote\..*\.(receivepack|uploadpack|proxy)|http\.|filter\.|diff\.|gpg\.|url\.|include\.|includeif\.)",
            ],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_mutation_env(),
        )
    except (OSError, subprocess.TimeoutExpired, RuntimeError):
        return False, "local_git_config_unreadable_for_mutation"
    if cp.returncode not in {0, 1}:
        return False, "local_git_config_unreadable_for_mutation"
    for raw_name in cp.stdout.splitlines() if cp.returncode == 0 else []:
        name = raw_name.strip().lower()
        if name == "core.hookspath":
            return False, "local_hooks_path_blocked_for_mutation"
        if name.startswith("credential."):
            return False, "local_credential_config_blocked_for_mutation"
        return False, "local_network_command_config_blocked_for_mutation"
    try:
        common = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "rev-parse", "--path-format=absolute", "--git-common-dir"],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_mutation_env(),
        )
    except (OSError, subprocess.TimeoutExpired, RuntimeError):
        return False, "local_git_hooks_unreadable_for_mutation"
    if common.returncode != 0 or not common.stdout.strip():
        return False, "local_git_hooks_unreadable_for_mutation"
    hooks_dir = Path(common.stdout.strip()) / "hooks"
    try:
        hook_entries = list(hooks_dir.iterdir()) if hooks_dir.exists() else []
    except OSError:
        return False, "local_git_hooks_unreadable_for_mutation"
    for hook in hook_entries:
        if hook.name.endswith(".sample"):
            continue
        try:
            if hook.is_symlink() or (hook.is_file() and os.access(hook, os.X_OK)):
                return False, "local_git_hooks_blocked_for_mutation"
        except OSError:
            return False, "local_git_hooks_unreadable_for_mutation"
    return True, None


def local_ref_head(repo: Path, ref: str | None) -> str | None:
    if not ref:
        return None
    rc, out, _err = git_output(repo, "rev-parse", "--verify", f"{ref}^{{commit}}")
    return out if rc == 0 and out else None


def base_remote(repo: Path, branch: str | None) -> str:
    if branch:
        rc, remote, _err = git_output(repo, "config", f"branch.{branch}.remote")
        if rc == 0 and remote:
            return remote
    return "origin"


def git_remote_owner(repo: Path, remote: str = "origin") -> str | None:
    slug = github_repo_slug(repo, remote)
    return slug.split("/", 1)[0] if slug else None


def github_remote_url(repo: Path, remote: str = "origin") -> str | None:
    if not isinstance(remote, str) or not re.fullmatch(r"[A-Za-z0-9_.-]+", remote):
        return None
    try:
        cp = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "config", "--get-all", f"remote.{remote}.url"],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_mutation_env(),
        )
    except (OSError, subprocess.TimeoutExpired, RuntimeError):
        return None
    if cp.returncode != 0:
        return None
    urls = [line.strip() for line in cp.stdout.splitlines() if line.strip()]
    if len(urls) != 1:
        return None
    url = urls[0]
    patterns = (
        r"^https://github\.com/[A-Za-z0-9-]+/[A-Za-z0-9_.-]+(?:\.git)?/?$",
        r"^git@github\.com:[A-Za-z0-9-]+/[A-Za-z0-9_.-]+(?:\.git)?$",
        r"^ssh://git@github\.com/[A-Za-z0-9-]+/[A-Za-z0-9_.-]+(?:\.git)?/?$",
    )
    return url if any(re.fullmatch(pattern, url) for pattern in patterns) else None


def github_slug_from_remote_url(url: str) -> str | None:
    patterns = (
        r"^https://github\.com/([A-Za-z0-9-]+)/([A-Za-z0-9_.-]+?)(?:\.git)?/?$",
        r"^git@github\.com:([A-Za-z0-9-]+)/([A-Za-z0-9_.-]+?)(?:\.git)?$",
        r"^ssh://git@github\.com/([A-Za-z0-9-]+)/([A-Za-z0-9_.-]+?)(?:\.git)?/?$",
    )
    for pattern in patterns:
        match = re.fullmatch(pattern, url)
        if match:
            return f"{match.group(1)}/{match.group(2)}"
    return None


def github_repo_slug(repo: Path, remote: str = "origin") -> str | None:
    url = github_remote_url(repo, remote)
    return github_slug_from_remote_url(url) if url is not None else None


def github_pr_snapshot(repo: Path, repo_slug: str, pr: int) -> tuple[dict[str, Any] | None, dict[str, Any], str | None]:
    effect = run_safe(
        ["gh", "api", f"repos/{repo_slug}/pulls/{pr}"],
        repo,
        timeout=60,
        env={"GH_REPO": repo_slug},
        allow_gh_repo=True,
        capture_stdout=True,
    )
    if not effect.get("ok"):
        return None, effect, "github_pr_snapshot_unavailable"
    raw_stdout = effect.pop("stdout", None)
    try:
        data = json.loads(str(raw_stdout if raw_stdout is not None else effect.get("stdout_tail") or ""))
    except json.JSONDecodeError:
        return None, effect, "github_pr_snapshot_invalid_json"
    if not isinstance(data, dict) or data.get("number") != pr:
        return None, effect, "github_pr_snapshot_identity_invalid"
    return data, effect, None


def github_matching_pull_requests(repo: Path, repo_slug: str, head: str, base: str) -> tuple[list[dict[str, Any]] | None, dict[str, Any], str | None]:
    effect = run_safe(
        ["gh", "api", "-X", "GET", f"repos/{repo_slug}/pulls", "-f", "state=all", "-f", f"head={head}", "-f", f"base={base}"],
        repo,
        timeout=60,
        env={"GH_REPO": repo_slug},
        allow_gh_repo=True,
        capture_stdout=True,
    )
    if not effect.get("ok"):
        return None, effect, "github_pr_reconciliation_unavailable"
    raw_stdout = effect.pop("stdout", None)
    try:
        data = json.loads(str(raw_stdout if raw_stdout is not None else effect.get("stdout_tail") or ""))
    except json.JSONDecodeError:
        return None, effect, "github_pr_reconciliation_invalid_json"
    if not isinstance(data, list) or any(not isinstance(item, dict) for item in data):
        return None, effect, "github_pr_reconciliation_invalid_shape"
    return data, effect, None


def pull_request_identity_matches(snapshot: dict[str, Any], repo_slug: str, expected_head_ref: str, expected_base: str) -> bool:
    head = snapshot.get("head") if isinstance(snapshot.get("head"), dict) else {}
    base = snapshot.get("base") if isinstance(snapshot.get("base"), dict) else {}
    head_repo = head.get("repo") if isinstance(head.get("repo"), dict) else {}
    base_repo = base.get("repo") if isinstance(base.get("repo"), dict) else {}
    expected_branch = expected_head_ref.split(":", 1)[-1]
    return (
        head.get("ref") == expected_branch
        and base.get("ref") == expected_base
        and head_repo.get("full_name") == repo_slug
        and base_repo.get("full_name") == repo_slug
    )


def exact_pull_request_matches(snapshot: dict[str, Any], repo_slug: str, expected_head: str, expected_base: str) -> bool:
    head = snapshot.get("head") if isinstance(snapshot.get("head"), dict) else {}
    base = snapshot.get("base") if isinstance(snapshot.get("base"), dict) else {}
    head_repo = head.get("repo") if isinstance(head.get("repo"), dict) else {}
    base_repo = base.get("repo") if isinstance(base.get("repo"), dict) else {}
    return (
        head.get("sha") == expected_head
        and base.get("ref") == expected_base
        and head_repo.get("full_name") == repo_slug
        and base_repo.get("full_name") == repo_slug
    )


def valid_local_branch_name(repo: Path, branch: str | None) -> bool:
    if not isinstance(branch, str) or not branch or branch.startswith("-") or ":" in branch:
        return False
    if any(ord(ch) < 32 for ch in branch):
        return False
    try:
        cp = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "check-ref-format", "--branch", branch],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_env(),
        )
    except (OSError, subprocess.TimeoutExpired, RuntimeError):
        return False
    return cp.returncode == 0


def trusted_busdriver_plugin_root(plugin: Path) -> bool:
    candidates = [str(Path.home() / ".claude" / "plugins" / "marketplaces" / "busdriver")]
    try:
        plugin_resolved = plugin.resolve()
    except OSError:
        return False
    for candidate in candidates:
        if not candidate:
            continue
        try:
            if plugin_resolved == Path(candidate).expanduser().resolve():
                return True
        except OSError:
            continue
    return False


def busdriver_plugin_root_safety(plugin: Path) -> tuple[bool, str | None]:
    if not trusted_busdriver_plugin_root(plugin):
        return False, "plugin_root_untrusted"
    required = [
        Path("package.json"),
        Path("skills/litmus/scripts/init-review-loop.sh"),
        Path("skills/litmus/scripts/run-review-loop.sh"),
    ]
    for rel in required:
        path = plugin / rel
        if not path.is_file() or path.is_symlink():
            return False, "plugin_root_integrity_failed"
    try:
        package = json.loads((plugin / "package.json").read_text())
    except (OSError, UnicodeDecodeError, json.JSONDecodeError):
        return False, "plugin_root_integrity_failed"
    if package.get("name") != "busdriver" or not isinstance(package.get("version"), str):
        return False, "plugin_root_integrity_failed"
    rels = [str(rel) for rel in required]
    try:
        trusted_git = str(trusted_executable_path("git"))
        top = _bounded_run([trusted_git, "-C", str(plugin), "rev-parse", "--show-toplevel"], text=True, check=False, timeout=30, env=safe_git_env())
        if top.returncode == 0 and top.stdout.strip() and Path(top.stdout.strip()).resolve() == plugin:
            tracked = _bounded_run([trusted_git, "-C", str(plugin), "ls-files", "--error-unmatch", *rels], text=True, check=False, timeout=30, env=safe_git_env())
            if tracked.returncode != 0:
                return False, "plugin_root_integrity_failed"
            worktree_clean = _bounded_run([trusted_git, "-C", str(plugin), "diff", "--quiet", "--", *rels], text=True, check=False, timeout=30, env=safe_git_env())
            index_clean = _bounded_run([trusted_git, "-C", str(plugin), "diff", "--cached", "--quiet", "--", *rels], text=True, check=False, timeout=30, env=safe_git_env())
            if worktree_clean.returncode != 0 or index_clean.returncode != 0:
                return False, "plugin_root_dirty"
    except (OSError, RuntimeError, subprocess.TimeoutExpired):
        return False, "plugin_root_integrity_failed"
    return True, None


def materialize_authenticated_busdriver_snapshot(plugin: Path, destination: Path) -> bool:
    """Materialize the pinned committed plugin tree without executing worktree bytes."""
    try:
        trusted_git = str(trusted_executable_path("git"))
        archive = _bounded_run(
            [trusted_git, "-C", str(plugin), "archive", "--format=tar", TRUSTED_BUSDRIVER_PLUGIN_COMMIT],
            check=False,
            timeout=60,
            env=safe_git_env(),
            # A tar of the whole pinned plugin tree, extracted whole: the tail bound is not the
            # right number for a payload nobody reads the last 4000 bytes of.
            limit=MAX_PAYLOAD_BYTES,
        )
        if archive.returncode != 0 or not archive.stdout:
            return False
        destination.mkdir(parents=True, exist_ok=False)
        with tarfile.open(fileobj=io.BytesIO(archive.stdout), mode="r:") as bundle:
            members = bundle.getmembers()
            destination_resolved = destination.resolve()
            for member in members:
                (destination / member.name).resolve().relative_to(destination_resolved)
                if member.issym() or member.islnk() or member.isdev() or member.isfifo():
                    return False
            bundle.extractall(destination, members=members, filter="data")
        package = json.loads((destination / "package.json").read_text())
        if package.get("name") != "busdriver" or package.get("version") != TRUSTED_BUSDRIVER_PLUGIN_VERSION:
            return False
        return True
    except (OSError, RuntimeError, ValueError, UnicodeDecodeError, json.JSONDecodeError, tarfile.TarError, subprocess.TimeoutExpired):
        return False


def normalized_pr_head_arg(repo: Path, head: str | None, current: str | None, remote: str = "origin") -> tuple[str | None, str | None]:
    if not current or not valid_local_branch_name(repo, current):
        return None, "current_branch_required_for_pr_create"
    origin_owner = git_remote_owner(repo, remote)
    if not origin_owner or not re.fullmatch(r"[A-Za-z0-9-]+", origin_owner):
        return None, "github_origin_owner_required_for_pr_create"
    qualified_current = f"{origin_owner}:{current}"
    if not head or head == current:
        return qualified_current, None
    if ":" in head:
        owner, branch = head.split(":", 1)
        if owner == origin_owner and branch == current and re.fullmatch(r"[A-Za-z0-9-]+", owner or ""):
            return head, None
        return None, "pr_head_must_match_origin_current_branch"
    return None, "pr_head_must_match_current_branch"


def candidate_backstop_diff_hash(repo: Path, base: str | None = "main", marker_state_dirs: tuple[str, ...] | list[str] | set[str] = (".claude", ".opencode"), head: str = "HEAD") -> str | None:
    # PR backstop evidence must cover the full clean branch candidate against the
    # PR base, not the branch upstream (which may be the already-pushed feature
    # branch). If local staged/unstaged changes exist, there is no single safe PR
    # candidate to bind; require commit finalization first. Trusted Busdriver
    # marker evidence is excluded because those files are intentionally left in
    # the worktree to authorize the next delivery step.
    if repo_blocking_dirty_entries(repo, marker_state_dirs):
        return None
    base_ref = pr_base_ref(repo, base)
    if not base_ref:
        return None
    return diff_hash(repo, f"{base_ref}...{head}")


def read_backstop_verdict_file(repo: Path, path_value: str | None) -> tuple[str | None, str | None]:
    if not isinstance(path_value, str) or not path_value:
        return None, "backstop_verdict_file_required"
    candidate = Path(path_value).expanduser()
    if not candidate.is_absolute():
        candidate = repo / candidate
    try:
        repo_root = repo.resolve(strict=True)
    except (OSError, RuntimeError):
        return None, "backstop_verdict_file_unreadable"
    path = Path(os.path.abspath(candidate))
    try:
        rel = path.relative_to(repo_root)
    except ValueError:
        return None, "backstop_verdict_file_outside_repo"
    if not rel.parts:
        return None, "backstop_verdict_file_not_regular"

    current = repo_root
    try:
        for index, part in enumerate(rel.parts):
            current = current / part
            st = os.lstat(current)
            if stat.S_ISLNK(st.st_mode):
                return None, "backstop_verdict_file_symlink"
            if index < len(rel.parts) - 1:
                if not stat.S_ISDIR(st.st_mode):
                    return None, "backstop_verdict_file_unreadable"
            elif not stat.S_ISREG(st.st_mode):
                return None, "backstop_verdict_file_not_regular"
    except OSError:
        return None, "backstop_verdict_file_unreadable"

    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    try:
        fd = os.open(current, flags)
    except OSError:
        return None, "backstop_verdict_file_unreadable"
    try:
        st = os.fstat(fd)
        if not stat.S_ISREG(st.st_mode):
            return None, "backstop_verdict_file_not_regular"
        if st.st_size > BACKSTOP_VERDICT_MAX_BYTES:
            return None, "backstop_verdict_file_too_large"
        data = os.read(fd, BACKSTOP_VERDICT_MAX_BYTES + 1)
    except OSError:
        return None, "backstop_verdict_file_unreadable"
    finally:
        os.close(fd)
    if len(data) > BACKSTOP_VERDICT_MAX_BYTES:
        return None, "backstop_verdict_file_too_large"
    try:
        return data.decode("utf-8"), None
    except UnicodeDecodeError:
        return None, "backstop_verdict_file_unreadable"


def validate_backstop_verdict_text(repo: Path, text: str, base: str | None = "main", marker_state_dirs: tuple[str, ...] | list[str] | set[str] = (".claude", ".opencode")) -> tuple[bool, str, dict[str, Any]]:
    try:
        payload = json.loads(text)
    except json.JSONDecodeError:
        return False, "backstop_verdict_invalid_json", {}
    if not isinstance(payload, dict):
        return False, "backstop_verdict_not_object", {}
    schema = payload.get("schema")
    if schema != "hermes-busdriver-backstop-verdict/v0":
        return False, "backstop_verdict_schema_required", {"schema": schema}
    if payload.get("read_only") is not True:
        return False, "backstop_verdict_read_only_required", {"schema": schema}
    reviewer_role = payload.get("reviewer_role")
    if reviewer_role != "independent_backstop":
        return False, "backstop_verdict_independent_backstop_required", {"schema": schema, "reviewer_role": reviewer_role}
    review_summary = payload.get("summary")
    if not isinstance(review_summary, str) or len(review_summary.strip()) < 20:
        return False, "backstop_verdict_summary_required", {"schema": schema, "reviewer_role": reviewer_role}
    status = payload.get("status")
    if status != "PASS":
        return False, "backstop_verdict_not_pass", {"schema": schema, "status": status}
    reviewed_root = payload.get("reviewed_repo_root")
    try:
        reviewed_root_path = Path(reviewed_root).expanduser().resolve() if isinstance(reviewed_root, str) else None
    except (OSError, ValueError, AttributeError):
        reviewed_root_path = None
    if reviewed_root_path != repo:
        return False, "backstop_verdict_repo_mismatch", {"schema": schema, "status": status}
    head_rc, expected_head, _head_err = git_output(repo, "rev-parse", "HEAD")
    reviewed_head = payload.get("reviewed_head")
    if head_rc != 0 or not isinstance(reviewed_head, str) or reviewed_head != expected_head:
        return False, "backstop_verdict_head_mismatch", {"schema": schema, "status": status, "reviewed_head": reviewed_head}
    expected_base = pr_base_ref(repo, base)
    reviewed_base = payload.get("reviewed_base_ref")
    if not isinstance(reviewed_base, str) or expected_base is None or reviewed_base != expected_base:
        return False, "backstop_verdict_base_mismatch", {"schema": schema, "status": status, "reviewed_base_ref": reviewed_base}
    reviewed_diff_hash = payload.get("reviewed_diff_hash")
    if not isinstance(reviewed_diff_hash, str) or not reviewed_diff_hash:
        return False, "backstop_verdict_diff_hash_required", {"schema": schema, "status": status}
    expected_hash = candidate_backstop_diff_hash(repo, base, marker_state_dirs)
    if not expected_hash:
        return False, "backstop_verdict_current_diff_unavailable", {"schema": schema, "status": status, "reviewed_diff_hash": reviewed_diff_hash}
    if reviewed_diff_hash != expected_hash:
        return False, "backstop_verdict_diff_hash_mismatch", {"schema": schema, "status": status, "reviewed_diff_hash": reviewed_diff_hash, "expected_hash": expected_hash}
    return True, "backstop_verdict_valid", {"schema": schema, "status": status, "reviewed_diff_hash": reviewed_diff_hash, "reviewed_head": reviewed_head, "reviewed_base_ref": reviewed_base}


def busdriver_backstop_writer_payload(verdict_text: str, validated_summary: dict[str, Any]) -> str:
    payload = json.loads(verdict_text)
    if not isinstance(payload, dict):
        raise ValueError("backstop verdict must be a JSON object")
    model = payload.get("model") or payload.get("reviewer_model") or payload.get("reviewer_role") or "independent_backstop"
    if not isinstance(model, str) or not model.strip():
        model = "independent_backstop"
    issues = payload.get("issues")
    if not isinstance(issues, list):
        issues = []
    reviewed_diff_hash = validated_summary.get("reviewed_diff_hash")
    if not isinstance(reviewed_diff_hash, str) or not reviewed_diff_hash:
        raise ValueError("validated reviewed_diff_hash required")
    writer_payload = {
        "status": payload.get("status"),
        "model": model.strip(),
        "issues": issues,
        "reviewed_diff_hash": reviewed_diff_hash,
    }
    return json.dumps(writer_payload, separators=(",", ":")) + "\n"


def pr_summary(pr: str | None, delivery_status: dict[str, Any]) -> dict[str, Any] | None:
    if not pr:
        return None
    pr_grind = delivery_status.get("pr_grind") or {}
    result = pr_grind.get("result") or {}
    return {
        "number": pr,
        "available": pr_grind.get("available"),
        "ok": pr_grind.get("ok"),
        "status": result.get("status"),
        "clean": result.get("clean"),
    }


def observed_litmus_base_ref(delivery_status: dict[str, Any]) -> str | None:
    litmus = delivery_status.get("litmus_status") if isinstance(delivery_status.get("litmus_status"), dict) else {}
    summary = litmus.get("summary") if isinstance(litmus.get("summary"), dict) else {}
    repo = summary.get("repo") if isinstance(summary.get("repo"), dict) else {}
    base_ref = repo.get("base_ref")
    return base_ref if isinstance(base_ref, str) and base_ref else None


def review_base_arg(args: argparse.Namespace, delivery_status: dict[str, Any]) -> str | None:
    return getattr(args, "base", None) or observed_litmus_base_ref(delivery_status)


def pr_review_base_matches(delivery_status: dict[str, Any], repo: Path, base: str | None, marker_state_dirs: tuple[str, ...] | list[str] | set[str] = (".claude", ".opencode"), expected_head: str | None = None, expected_base_head: str | None = None) -> bool:
    expected_base = pr_base_ref(repo, base)
    if expected_base is None:
        return False
    base_branch = remote_branch_name_from_ref(expected_base)
    head_rc, current_head, _head_err = git_output(repo, "rev-parse", "HEAD")
    reviewed_head = expected_head or current_head
    expected_hash = (
        None
        if repo_blocking_dirty_entries(repo, marker_state_dirs)
        else diff_hash(repo, f"{expected_base_head}...{reviewed_head}")
    ) if expected_base_head else candidate_backstop_diff_hash(repo, base, marker_state_dirs, reviewed_head)
    branch = current_branch(repo)
    expected_base_head = expected_base_head or local_ref_head(repo, expected_base)
    live_base_head, _live_base_error = live_remote_branch_head(repo, base_branch or "", "origin")
    litmus = delivery_status.get("litmus_status") if isinstance(delivery_status.get("litmus_status"), dict) else {}
    summary = litmus.get("summary") if isinstance(litmus.get("summary"), dict) else {}
    summary_repo = summary.get("repo") if isinstance(summary.get("repo"), dict) else {}
    observed_root = summary_repo.get("root")
    observed_base = summary_repo.get("base_ref")
    observed_hash = summary_repo.get("branch_diff_hash")
    observed_head = summary_repo.get("head")
    observed_branch = summary_repo.get("branch")
    return (
        isinstance(observed_root, str)
        and Path(observed_root).expanduser().resolve() == repo
        and isinstance(observed_base, str)
        and expected_base is not None
        and observed_base == expected_base
        and isinstance(observed_hash, str)
        and expected_hash is not None
        and observed_hash == expected_hash
        and expected_base_head is not None
        and live_base_head is not None
        and expected_base_head == live_base_head
        and isinstance(observed_head, str)
        and head_rc == 0
        and current_head == reviewed_head
        and observed_head == reviewed_head
        and isinstance(observed_branch, str)
        and branch is not None
        and observed_branch == branch
    )


def effective_operation(args: argparse.Namespace) -> str:
    if args.mode == "status":
        return "status"
    return args.operation


def pr_grind_loop_credential_env() -> dict[str, str]:
    return {
        key: value
        for key in CREDENTIAL_ENV_KEYS
        if isinstance((value := os.environ.get(key)), str)
    }


def pr_grind_loop_env() -> dict[str, str]:
    return safe_git_env(pr_grind_loop_credential_env())


def run_pr_grind_loop(repo: Path, args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    expected_repository = getattr(args, "expected_repository", None) or github_repo_slug(repo, "origin")
    if not expected_repository:
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_expected_repository_required"}, 2
    sources = (
        (PR_GRIND_LOOP, "hermes-busdriver-pr-grind-loop", TRUSTED_PR_GRIND_LOOP_SHA256),
        (PR_GRIND_CHECK, "hermes-busdriver-pr-grind-check", TRUSTED_PR_GRIND_CHECK_SHA256),
    )
    authenticated: dict[str, bytes] = {}
    try:
        for source, name, expected_digest in sources:
            if source.is_symlink() or not source.is_file():
                raise OSError(f"{name}_not_regular")
            content = _read_authenticated_relay_source(source, expected_digest)
            authenticated[name] = content
    except OSError as e:
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_bundle_integrity_failed", "detail": type(e).__name__}, 2
    snapshot, _, snapshot_error = github_pr_snapshot(repo, expected_repository, int(args.pr))
    if snapshot is None:
        return {"ok": False, "status": "blocked", "clean": False, "error": snapshot_error or "pr_grind_identity_unavailable"}, 2
    head = snapshot.get("head") if isinstance(snapshot.get("head"), dict) else {}
    base = snapshot.get("base") if isinstance(snapshot.get("base"), dict) else {}
    head_repo = head.get("repo") if isinstance(head.get("repo"), dict) else {}
    base_repo = base.get("repo") if isinstance(base.get("repo"), dict) else {}
    expected_identity = {
        "repo": str(repo),
        "repository": expected_repository,
        "pr": int(args.pr),
        "url": f"https://github.com/{expected_repository}/pull/{int(args.pr)}",
        "latest_head": head.get("sha"),
        "head_repository": head_repo.get("full_name"),
        "head_ref": head.get("ref"),
        "base_repository": base_repo.get("full_name"),
        "base": base.get("ref"),
        "base_sha": base.get("sha"),
    }
    if (
        snapshot.get("number") != expected_identity["pr"]
        or snapshot.get("html_url") != expected_identity["url"]
        or expected_identity["base_repository"] != expected_repository
        or not re.fullmatch(r"[A-Za-z0-9-]+/[A-Za-z0-9_.-]+", str(expected_identity["head_repository"] or ""))
        or not isinstance(expected_identity["head_ref"], str)
        or not expected_identity["head_ref"]
        or not isinstance(expected_identity["base"], str)
        or not expected_identity["base"]
        or not re.fullmatch(r"[0-9a-fA-F]{40,64}", str(expected_identity["latest_head"] or ""))
        or not re.fullmatch(r"[0-9a-fA-F]{40,64}", str(expected_identity["base_sha"] or ""))
    ):
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_identity_invalid"}, 2
    requested_base = getattr(args, "base", None)
    if requested_base and remote_branch_name_from_ref(normalize_pr_base_arg(requested_base)) != expected_identity["base"]:
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_base_binding_mismatch"}, 2
    bundle_guard = tempfile.TemporaryDirectory(prefix="hermes-pr-grind-bundle-")
    private_scripts = Path(bundle_guard.name) / "scripts"
    private_scripts.mkdir()
    # Exactly 0700, independent of the caller's umask: pr-grind-loop validates this directory
    # with _validate_private_metadata(..., 0o700), so a 022-umask 0755 makes the whole operation
    # unable to reach `clean`. mkdir(mode=...) would be masked; chmod is not.
    private_scripts.chmod(0o700)
    try:
        for name, content in authenticated.items():
            write_private_authenticated(private_scripts / name, content, 0o500)
    except OSError as e:
        bundle_guard.cleanup()
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_bundle_integrity_failed", "detail": type(e).__name__}, 2
    script = private_scripts / "hermes-busdriver-pr-grind-loop"
    loop_program = authenticated["hermes-busdriver-pr-grind-loop"]
    try:
        python3 = trusted_executable_path("python3")
    except RuntimeError as e:
        bundle_guard.cleanup()
        return {
            "ok": False,
            "status": "blocked",
            "clean": False,
            "error": "pr_grind_runtime_unavailable",
            "detail": tail(str(e)),
            "returncode": 127,
        }, 127
    cmd = [
        str(python3),
        "-I",
        "-c",
        DELIVERY_STATUS_STDIN_LOADER,
        str(script),
        "--repo",
        str(repo),
        "--pr",
        str(args.pr),
        "--max-wait-seconds",
        str(args.max_wait_seconds),
        "--poll-interval",
        str(args.poll_interval),
        "--max-polls",
        str(args.max_polls),
        "--check-timeout",
        str(args.check_timeout),
    ]
    cmd += [
        "--expected-repository", expected_repository,
        "--expected-head-repository", str(expected_identity["head_repository"]),
        "--expected-head-ref", str(expected_identity["head_ref"]),
        "--expected-base-repository", str(expected_identity["base_repository"]),
        "--expected-base-ref", str(expected_identity["base"]),
        "--expected-head-sha", str(expected_identity["latest_head"]),
        "--expected-base-sha", str(expected_identity["base_sha"]),
    ]
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    # Same shape as run_delivery_status: no private bin to lead with, because the child validates
    # and execs the root-owned source itself. safe_git_env()'s PATH no longer carries the
    # user-writable Homebrew prefixes either, so there is nothing left here to override.
    runtime_env = pr_grind_loop_env()
    try:
        cp = _bounded_run(cmd, cwd=str(repo), shell=False, text=True, check=False, timeout=max(args.max_wait_seconds + args.check_timeout + 30.0, 30.0), env=runtime_env, input=loop_program)
    except subprocess.TimeoutExpired as e:
        return {
            "ok": False,
            "status": "blocked",
            "clean": False,
            "error": "pr_grind_loop_timeout",
            "returncode": 124,
            "stdout_tail": tail(e.stdout),
            "stderr_tail": tail(e.stderr),
        }, 124
    except (OSError, RuntimeError) as e:
        return {"ok": False, "status": "blocked", "clean": False, "error": type(e).__name__, "returncode": 127, "stderr_tail": tail(str(e))}, 127

    try:
        data = json.loads(cp.stdout)
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "status": "blocked",
            "clean": False,
            "error": "pr_grind_loop_invalid_json",
            "returncode": cp.returncode,
            "stdout_tail": tail(cp.stdout),
            "stderr_tail": tail(cp.stderr),
            "parse_error": str(e),
        }, cp.returncode or 1
    if not isinstance(data, dict):
        return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_loop_json_not_object", "returncode": cp.returncode}, cp.returncode or 1
    for field, expected_value in expected_identity.items():
        if data.get(field) != expected_value:
            return {"ok": False, "status": "blocked", "clean": False, "error": "pr_grind_loop_identity_mismatch", "field": field}, 2
    data.setdefault("returncode", cp.returncode)
    if cp.stderr:
        data.setdefault("stderr_tail", tail(cp.stderr))
    return data, cp.returncode


PR_GRIND_LOOP_DECISION_FLAGS = (*BLOCKED_FLAGS.keys(), "fixing_allowed")
VALID_PR_GRIND_LOOP_STATUSES = {"clean", "needs_fix", "wait", "blocked"}


def pr_grind_loop_authority_safe(value: Any) -> bool:
    return isinstance(value, dict) and all(value.get(key) is False for key in PR_GRIND_LOOP_DECISION_FLAGS)


def pr_grind_loop_authority_tree_safe(value: Any) -> bool:
    if isinstance(value, dict):
        for key, item in value.items():
            if (key in PR_GRIND_LOOP_DECISION_FLAGS or key.endswith("_allowed")) and item is not False:
                return False
            if "authority" in key and isinstance(item, bool) and item is not False:
                return False
            if not pr_grind_loop_authority_tree_safe(item):
                return False
        return True
    if isinstance(value, list):
        return all(pr_grind_loop_authority_tree_safe(item) for item in value)
    return True


def pr_grind_loop_envelope_safe(value: Any) -> bool:
    if not isinstance(value, dict):
        return False
    status = value.get("status")
    clean = value.get("clean")
    decision_data = value.get("decision")
    iterations = value.get("iterations")
    policy_gaps = value.get("policy_gaps")
    limits = value.get("limits")
    identity_safe = (
        isinstance(value.get("repo"), str)
        and bool(value["repo"])
        and isinstance(value.get("repository"), str)
        and re.fullmatch(r"[A-Za-z0-9-]+/[A-Za-z0-9_.-]+", value["repository"]) is not None
        and isinstance(value.get("pr"), int)
        and not isinstance(value.get("pr"), bool)
        and value["pr"] > 0
        and value.get("url") == f"https://github.com/{value['repository']}/pull/{value['pr']}"
        and isinstance(value.get("latest_head"), str)
        and re.fullmatch(r"[0-9a-fA-F]{40,64}", value["latest_head"]) is not None
        and isinstance(value.get("head_repository"), str)
        and re.fullmatch(r"[A-Za-z0-9-]+/[A-Za-z0-9_.-]+", value["head_repository"]) is not None
        and isinstance(value.get("head_ref"), str)
        and bool(value["head_ref"])
        and isinstance(value.get("base_repository"), str)
        and re.fullmatch(r"[A-Za-z0-9-]+/[A-Za-z0-9_.-]+", value["base_repository"]) is not None
        and value["base_repository"] == value["repository"]
        and isinstance(value.get("base"), str)
        and bool(value["base"])
        and isinstance(value.get("base_sha"), str)
        and re.fullmatch(r"[0-9a-fA-F]{40,64}", value["base_sha"]) is not None
    )
    evidence_safe = (
        isinstance(iterations, list)
        and isinstance(policy_gaps, list)
        and all(isinstance(item, str) for item in policy_gaps)
        and isinstance(limits, dict)
        and isinstance(limits.get("max_wait_seconds"), (int, float))
        and isinstance(limits.get("poll_interval"), (int, float))
        and isinstance(limits.get("max_polls"), int)
        and not isinstance(limits.get("max_polls"), bool)
        and limits["max_polls"] > 0
        and limits.get("max_fix_rounds") == 0
        and isinstance(value.get("elapsed_seconds"), (int, float))
    )
    for iteration in iterations if isinstance(iterations, list) else []:
        checks = iteration.get("checks") if isinstance(iteration, dict) else None
        if (
            not isinstance(iteration, dict)
            or not isinstance(iteration.get("iteration"), int)
            or not isinstance(iteration.get("elapsed_seconds"), (int, float))
            or not isinstance(iteration.get("source"), str)
            or iteration.get("status") not in VALID_PR_GRIND_LOOP_STATUSES
            or not isinstance(iteration.get("clean"), bool)
            or iteration["clean"] is not (iteration["status"] == "clean")
            or not isinstance(iteration.get("head"), str)
            or re.fullmatch(r"[0-9a-fA-F]{40,64}", iteration["head"]) is None
            or not isinstance(iteration.get("base"), str)
            or not isinstance(iteration.get("blockers"), list)
            or not isinstance(checks, dict)
            or any(not isinstance(checks.get(field), int) or isinstance(checks.get(field), bool) for field in ("failed", "pending", "kept"))
            or not isinstance(checks.get("mode"), str)
            or not isinstance(checks.get("source"), str)
            or not isinstance(iteration.get("actionable_comment_count"), int)
            or not isinstance(iteration.get("decision_reason"), str)
        ):
            evidence_safe = False
            break
    clean_evidence = True
    if status == "clean":
        last = iterations[-1] if isinstance(iterations, list) and iterations else None
        last_checks = last.get("checks") if isinstance(last, dict) and isinstance(last.get("checks"), dict) else {}
        clean_evidence = (
            isinstance(last, dict)
            and not policy_gaps
            and last.get("status") == "clean"
            and last.get("clean") is True
            and last.get("head") == value.get("latest_head")
            and last.get("base") == value.get("base")
            and last.get("blockers") == []
            and last_checks.get("failed") == 0
            and last_checks.get("pending") == 0
            and isinstance(last_checks.get("kept"), int)
            and last_checks["kept"] > 0
            and last.get("actionable_comment_count") == 0
        )
    return (
        value.get("schema") == PR_GRIND_LOOP_SCHEMA
        and value.get("version") == 1
        and isinstance(value.get("ok"), bool)
        and value.get("ok") is (status == "clean")
        and value.get("read_only") is True
        and status in VALID_PR_GRIND_LOOP_STATUSES
        and isinstance(clean, bool)
        and (clean is (status == "clean"))
        and isinstance(decision_data, dict)
        and decision_data.get("status") == status
        and isinstance(decision_data.get("reason"), str)
        and decision_data.get("pr_grind_clean") is (status == "clean")
        and decision_data.get("fix_rounds_attempted") == 0
        and decision_data.get("marker_write_allowed") is False
        and isinstance(decision_data.get("ack_ledger_policy"), str)
        and pr_grind_loop_authority_safe(decision_data)
        and pr_grind_loop_authority_tree_safe(value)
        and identity_safe
        and evidence_safe
        and clean_evidence
    )


def new_run_id() -> str:
    return f"{time.strftime('%Y%m%d-%H%M%S')}-{os.getpid()}-{uuid.uuid4().hex[:8]}"


def artifact_token(run_id: str) -> str:
    token = ARTIFACT_TOKEN.sub("-", run_id).strip(".-")
    return token[:96] or "run"


def delivery_phase(args: argparse.Namespace, reason: str | None) -> str:
    if reason == "delivery_status_failed":
        return "delivery_status"
    if args.mode == "status":
        return "status"
    if args.mode == "execute":
        return {
            "verify": "verify",
            "pr-grind": "pr_grind",
            "pre-pr-review": "pre_pr_review",
            "commit": "commit",
            "push": "push",
            "pr-create": "pr_create",
            "merge": "merge",
        }.get(args.operation, "execute")
    return "plan"


def delivery_run(
    args: argparse.Namespace,
    delivery_status: dict[str, Any],
    result_decision: dict[str, Any],
    reason: str | None,
    *,
    create_identity: bool = True,
) -> dict[str, Any]:
    repo = delivery_status.get("repo") if isinstance(delivery_status.get("repo"), dict) else {}
    return {
        "schema": RUN_SCHEMA,
        "version": 1,
        "run_id": (args.run_id or new_run_id()) if create_identity else args.run_id,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()) if create_identity else None,
        "phase": delivery_phase(args, reason),
        "status": result_decision.get("status"),
        "reason": result_decision.get("reason"),
        "repo_root": repo.get("root"),
        "pr_number": args.pr,
        "authority": {key: result_decision[key] for key in BLOCKED_FLAGS},
        "artifacts": [],
    }


class ArtifactDirectoryInvalid(RuntimeError):
    """The configured artifact directory is not a safe, no-follow-reachable directory.

    A distinct type so main() can route this expected writer failure to the fail-closed stdout
    fallback without swallowing unrelated RuntimeErrors raised elsewhere in the run.
    """


class ArtifactTooLarge(RuntimeError):
    """The serialized result exceeds ARTIFACT_MAX_BYTES and must not be persisted.

    Distinct from ArtifactDirectoryInvalid for the same reason that one is distinct from a bare
    RuntimeError: main() routes it to the truthful write-failure fallback, and nothing else.
    """


# The single artifact byte ceiling, shared by the producer and the reader so neither can admit
# what the other refuses. The reader's bound is what keeps a same-UID 0600 *.json file from
# being read into memory unbounded; the producer's keeps this process from creating one.
ARTIFACT_MAX_BYTES = 1024 * 1024


def artifact_base() -> Path:
    """The configured artifact directory as an absolute LEXICAL path.

    abspath normalizes without resolving symlinks, which is the point: resolution is what the
    descriptor-relative traversal below refuses to do. Every component is checked by the kernel
    under O_NOFOLLOW instead of being trusted from a resolved string.
    """
    raw = os.path.expanduser(os.environ.get(ARTIFACT_ENV, "~/.hermes/busdriver-relay/delivery-runs"))
    return Path(os.path.abspath(raw))


def artifact_name(run_id: str) -> str:
    """A unique final artifact filename that still carries its run-id token.

    The stamp/token/pid prefix is second-granular, so two writes for one run id inside one process
    second collided and the later replace() destroyed the earlier artifact. The random component
    is what makes the name unique; the parts before it are for discoverability only, and nothing
    reads freshness out of any of them.
    """
    stamp = time.strftime("%Y%m%d-%H%M%S")
    return f"{stamp}-{artifact_token(run_id)}-{os.getpid()}-{uuid.uuid4().hex}.json"


# O_CLOEXEC is an optimization (it keeps these fds out of exec'd children); O_NOFOLLOW and
# O_DIRECTORY plus dir_fd support ARE the proof, so their absence fails closed rather than
# silently degrading to a followable path-based write.
_O_CLOEXEC = getattr(os, "O_CLOEXEC", 0)
_NOFOLLOW_DIR_FLAGS = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0) | getattr(os, "O_NOFOLLOW", 0) | _O_CLOEXEC
# O_NONBLOCK is what makes the entry open itself safe: without it, opening a FIFO parked in the
# artifact directory blocks until a writer appears, so the fstat that would reject it as
# non-regular is never reached. On a regular file the flag is inert.
_NOFOLLOW_FILE_FLAGS = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0) | getattr(os, "O_NONBLOCK", 0) | _O_CLOEXEC


def require_nofollow_primitives() -> None:
    if not hasattr(os, "O_NOFOLLOW") or not hasattr(os, "O_DIRECTORY"):
        raise ArtifactDirectoryInvalid("delivery_artifact_nofollow_unavailable")
    # Every POSIX platform has O_NONBLOCK; its absence means the entry open could block on a FIFO,
    # which is a fail-closed condition rather than a degradation to accept silently.
    if os.name == "posix" and not hasattr(os, "O_NONBLOCK"):
        raise ArtifactDirectoryInvalid("delivery_artifact_nonblock_unavailable")
    # os.replace is deliberately gated on os.rename: both are the same renameat syscall, but
    # os.supports_dir_fd lists only os.rename, so probing for os.replace would always fail
    # closed on platforms (macOS, Linux) that do support the descriptor-relative replace.
    if not {os.open, os.mkdir, os.unlink, os.rename} <= os.supports_dir_fd:
        raise ArtifactDirectoryInvalid("delivery_artifact_dir_fd_unavailable")
    if os.listdir not in os.supports_fd:
        raise ArtifactDirectoryInvalid("delivery_artifact_dir_fd_unavailable")


def artifact_dir_fd(*, create: bool) -> int:
    """Open the configured artifact directory without following a symlink at ANY component.

    Walks from the filesystem root opening one component at a time relative to its parent's
    descriptor. A symlink, a non-directory, a permission error, or a race at any existing
    component fails closed as ArtifactDirectoryInvalid. When create is true a MISSING component
    may be created with os.mkdir(dir_fd=...) at 0700 and then reopened no-follow — an existing
    component is never replaced. The caller owns the returned fd and must close it.
    """
    require_nofollow_primitives()
    base = artifact_base()
    parts = base.parts
    if not parts or parts[0] != os.sep:
        raise ArtifactDirectoryInvalid("delivery_artifact_directory_invalid")
    try:
        fd = os.open(os.sep, _NOFOLLOW_DIR_FLAGS)
    except OSError as e:
        raise ArtifactDirectoryInvalid("delivery_artifact_directory_invalid") from e
    try:
        for component in parts[1:]:
            try:
                child = os.open(component, _NOFOLLOW_DIR_FLAGS, dir_fd=fd)
            except OSError as e:
                if not create or not isinstance(e, FileNotFoundError):
                    # ELOOP (symlink), ENOTDIR (regular file), EACCES, and every other existing
                    # component failure is terminal: creation must never step over it.
                    raise ArtifactDirectoryInvalid("delivery_artifact_directory_invalid") from e
                try:
                    os.mkdir(component, 0o700, dir_fd=fd)
                except FileExistsError:
                    pass  # Lost a create race; the no-follow reopen below is the arbiter.
                except OSError as mkdir_error:
                    raise ArtifactDirectoryInvalid("delivery_artifact_directory_invalid") from mkdir_error
                try:
                    child = os.open(component, _NOFOLLOW_DIR_FLAGS, dir_fd=fd)
                except OSError as reopen_error:
                    raise ArtifactDirectoryInvalid("delivery_artifact_directory_invalid") from reopen_error
            os.close(fd)
            fd = child
    except BaseException:
        os.close(fd)
        raise
    return fd


def dir_identity(fd: int) -> tuple[int, int]:
    st = os.fstat(fd)
    return st.st_dev, st.st_ino


def blocked_flag_value(value: dict[str, Any], key: str) -> Any:
    if key == "marker_write_allowed":
        return value.get(key, False)
    return value.get(key)


def authority_flags_safe(value: Any) -> bool:
    if not isinstance(value, dict):
        return False
    return all(blocked_flag_value(value, key) is False for key in BLOCKED_FLAGS)


def decision_metadata_safe(value: Any) -> bool:
    return (
        isinstance(value, dict)
        and isinstance(value.get("status"), str)
        and isinstance(value.get("reason"), str)
        and authority_flags_safe(value)
    )


VALID_ARTIFACT_RUN_PHASES = {"verify", "pr_grind", "delivery_status", "commit", "push", "pr_create", "merge", "pre_pr_review", "pr_grind_fix_loop"}


def artifact_run_artifacts_safe(value: Any) -> bool:
    return isinstance(value, list) and all(
        isinstance(item, dict)
        and item.get("kind") == "result"
        and isinstance(item.get("path"), str)
        for item in value
    )


def run_metadata_safe(value: Any, run_id: str) -> bool:
    return (
        isinstance(value, dict)
        and value.get("schema") == RUN_SCHEMA
        and value.get("version") == 1
        and value.get("run_id") == run_id
        and isinstance(value.get("created_at"), str)
        and value.get("phase") in VALID_ARTIFACT_RUN_PHASES
        and isinstance(value.get("status"), str)
        and isinstance(value.get("reason"), str)
        and isinstance(value.get("repo_root"), (str, type(None)))
        and (value.get("pr_number") is None or isinstance(value.get("pr_number"), (int, str)))
        and authority_flags_safe(value.get("authority"))
        and artifact_run_artifacts_safe(value.get("artifacts"))
    )


def decision_summary(value: dict[str, Any]) -> dict[str, Any]:
    return {"status": value.get("status"), "reason": value.get("reason"), **{key: blocked_flag_value(value, key) for key in BLOCKED_FLAGS}}


def artifact_refs_summary(value: Any) -> list[dict[str, str]]:
    if not isinstance(value, list):
        return []
    return [
        {"kind": item["kind"], "path": item["path"]}
        for item in value
        if isinstance(item, dict) and isinstance(item.get("kind"), str) and isinstance(item.get("path"), str)
    ]


def run_summary(value: dict[str, Any]) -> dict[str, Any]:
    return {
        "schema": value.get("schema"),
        "version": value.get("version"),
        "run_id": value.get("run_id"),
        "created_at": value.get("created_at"),
        "phase": value.get("phase"),
        "status": value.get("status"),
        "reason": value.get("reason"),
        "repo_root": value.get("repo_root"),
        "pr_number": value.get("pr_number"),
        "authority": {key: blocked_flag_value(value.get("authority", {}), key) for key in BLOCKED_FLAGS},
        "artifacts": artifact_refs_summary(value.get("artifacts")),
    }


def mutating_authority_safe(value: Any, operation: str) -> bool:
    if not isinstance(value, dict):
        return False
    required_flag = {
        "commit": "commit_allowed",
        "push": "push_allowed",
        "pr-create": "pr_allowed",
        "merge": "merge_allowed",
    }.get(operation)
    if (
        value.get("schema") != FINALIZATION_AUTHORITY_SCHEMA
        or value.get("version") != 0
        or value.get("operation") != operation
        or not isinstance(value.get("allowed"), bool)
        or not isinstance(value.get("reason"), str)
        or not isinstance(value.get("sources"), list)
        or not all(isinstance(source, str) for source in value.get("sources", []))
        or not all(isinstance(value.get(key), bool) for key in BLOCKED_FLAGS)
        or value.get("marker_write_allowed") is not False
    ):
        return False
    positive = {key for key in BLOCKED_FLAGS if value.get(key) is True}
    if value.get("allowed") is False:
        return not positive
    expected_positive = {"finalization_allowed"}
    if required_flag:
        expected_positive.add(required_flag)
    return positive == expected_positive


def mutating_run_metadata_safe(value: Any, run_id: str) -> bool:
    if not isinstance(value, dict):
        return False
    operation = value.get("operation")
    return (
        value.get("schema") == MUTATING_RUN_SCHEMA
        and value.get("version") == 0
        and value.get("run_id") == run_id
        and isinstance(value.get("created_at"), str)
        and operation in {"pre-pr-review", "commit", "push", "pr-create", "merge"}
        and isinstance(value.get("status"), str)
        and isinstance(value.get("reason"), str)
        and isinstance(value.get("repo_root"), (str, type(None)))
        and (value.get("pr_number") is None or isinstance(value.get("pr_number"), (int, str)))
        and mutating_authority_safe(value.get("authority"), operation)
        and isinstance(value.get("side_effects"), list)
        and all(isinstance(effect, dict) for effect in value.get("side_effects", []))
        and isinstance(value.get("lock_acquire"), (dict, type(None)))
        and isinstance(value.get("lock_release"), (dict, type(None)))
    )


