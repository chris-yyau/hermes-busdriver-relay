def _blocked_artifact_outcomes(reasons: set[str]) -> set[tuple[bool, str, str]]:
    return {(False, "blocked", reason) for reason in reasons}


# Operations whose fixed early policy blocker fires in main() before run identity, delivery
# status, mutation execution, or artifact handling. Their results are printed only and never
# persisted, so none of them may appear in ARTIFACT_OUTCOME_CONTRACT, MUTATING_ARTIFACT_PHASES,
# or AUTHORITY_ALLOWED_MUTATING_OUTCOMES: the validator describes reachable artifact bytes, not
# the dormant executor code behind these blockers. Lifting a blocker and admitting its outcomes
# into the artifact contract must happen as one reviewed change.
FIXED_EARLY_BLOCKED_OPERATIONS = {
    "verify": "verifier_containment_unavailable",
    "pre-pr-review": "isolated_review_runtime_unavailable",
    "push": "atomic_push_base_binding_unavailable",
    "pr-create": "atomic_pr_create_binding_unavailable",
    "merge": "atomic_merge_base_binding_unavailable",
}


# Currently artifact-producing operations only: pr-grind and commit (plus the delivery_status
# subphase). See FIXED_EARLY_BLOCKED_OPERATIONS for the rest. execute verify is fixed-blocked
# before run identity, delivery status or artifact handling, so no verify artifact bytes reach
# production. The non-installed test harness retains a verifier executor solely for fixture tests;
# installed production contains no verifier command executor. execute pr-grind without --pr is
# absent for a narrower reason: it sets pr_required but never sets write_run_artifact.
#
# Both artifact-write-failure fallbacks are absent for a third reason: main() calls
# write_artifact exactly once, and each fallback only rewrites the dict main() then prints
# (run_artifact_path stays None, run.artifacts is emptied) without attempting a second write.
# Neither "artifact_write_failed" nor "artifact_write_failed_after_side_effect" can therefore
# reach a durable artifact byte, so admitting them here would authenticate state that no
# producer can create. The stdout fallbacks themselves are unaffected by this contract.
ARTIFACT_OUTCOME_CONTRACT = {
    "pr-grind": {
        "pr_grind": {
            (True, "pr_grind_clean", "latest_pr_head_clean_read_only"),
            (False, "blocked", "pr_grind_needs_fix"),
            (False, "blocked", "pr_grind_wait"),
            (False, "blocked", "pr_grind_blocked"),
            (False, "blocked", "pr_grind_loop_failed"),
        },
        "delivery_status": _DELIVERY_STATUS_ARTIFACT_OUTCOME,
    },
    "commit": {
        "commit": {
            (True, "committed", "committed"),
            *((False, "committed", reason) for reason in _COMMIT_RECONCILIATION_REASONS),
            (False, "commit_outcome_unknown", _COMMIT_OUTCOME_UNKNOWN_REASON),
            (False, "commit_outcome_unknown_release_failed", _COMMIT_OUTCOME_UNKNOWN_RELEASE_REASON),
            (False, "committed_release_failed", "finalization_lock_release_failed"),
            *_blocked_artifact_outcomes(_COMMON_MUTATION_FAILURE_REASONS | _LITMUS_MUTATION_FAILURE_REASONS | _COMMIT_FAILURE_REASONS),
        },
        "delivery_status": _DELIVERY_STATUS_ARTIFACT_OUTCOME,
    },
}


# Mutating-envelope cardinality contract (M-1). Only these run phases execute an actual
# mutation and therefore require a complete mutating run; verify/pr_grind/delivery_status
# never mutate and must carry mutating_run == None.
MUTATING_ARTIFACT_PHASES = {"commit"}

# The ONLY (status, reason) mutating outcomes whose nested authority carries allowed=True in
# production (mutating_authority(operation, True, reason)). Every other outcome — blockers,
# reconciliation and release-failed — is authority allowed=False. Derived from the reachable
# mutating_authority() call sites in execute_mutating_operation.
AUTHORITY_ALLOWED_MUTATING_OUTCOMES = {
    "commit": {("committed", "committed")},
}


def artifact_is_valid(data: dict[str, Any], run_id: str) -> bool:
    run = data.get("run")
    decision_data = data.get("decision")
    mutating_run = data.get("mutating_run")
    operation = data.get("operation")
    phase = run.get("phase") if isinstance(run, dict) else None
    run_status = run.get("status") if isinstance(run, dict) else None
    run_reason = run.get("reason") if isinstance(run, dict) else None
    outcome = (data.get("ok"), run_status, run_reason) if isinstance(run, dict) else None
    allowed_outcomes = ARTIFACT_OUTCOME_CONTRACT.get(operation, {}).get(phase, set())

    # M-1: every mutating-phase outcome requires a complete mutating run; all other phases
    # require mutating_run == None. No write-failure fallback is durable (see
    # ARTIFACT_OUTCOME_CONTRACT), so there is no non-mutating exception to carve out here.
    requires_mutating_run = phase in MUTATING_ARTIFACT_PHASES

    if isinstance(mutating_run, dict):
        authority = mutating_run.get("authority")
        mutating_outcome = (mutating_run.get("status"), mutating_run.get("reason"))
        # M-2: nested authority truth is keyed off the mutating run's OWN outcome, so it holds
        # for success/reconciliation/release-failed alike.
        expected_authority_allowed = mutating_outcome in AUTHORITY_ALLOWED_MUTATING_OUTCOMES.get(operation, set())
        mutating_run_correlated = (
            mutating_run.get("operation") == operation
            and mutating_run.get("status") == run_status
            # M-3: a durable nested run always shares its outer run's reason; no preserved
            # original-outcome class survives into durable bytes.
            and mutating_run.get("reason") == run_reason
            and isinstance(authority, dict)
            and authority.get("reason") == mutating_run.get("reason")
            and (authority.get("allowed") is True) == expected_authority_allowed
        )
    else:
        mutating_run_correlated = True

    outcome_consistent = (
        isinstance(run, dict)
        and isinstance(decision_data, dict)
        and data.get("mode") == "execute"
        and outcome in allowed_outcomes
        and decision_data.get("status") == run_status
        and decision_data.get("reason") == run_reason
        and (mutating_run is not None) == requires_mutating_run
        and mutating_run_correlated
    )
    return (
        data.get("schema") == SCHEMA
        and data.get("version") == 1
        and isinstance(data.get("ok"), bool)
        # Freshness is only decidable if every accepted artifact carries a usable sequence, so a
        # missing or malformed one is a schema failure rather than a body ordered by something else.
        and artifact_sequence_valid(data.get("artifact_sequence"))
        and decision_metadata_safe(decision_data)
        and run_metadata_safe(run, run_id)
        and (mutating_run is None or mutating_run_metadata_safe(mutating_run, run_id))
        and outcome_consistent
    )


_ARTIFACT_SEQUENCE = 0


def next_artifact_sequence() -> int:
    """The process-local monotonic freshness counter, advanced once per write attempt.

    This — not any filesystem timestamp — is what orders two authentic artifacts for one run id.
    mtime/ctime are attacker-writable by anyone sharing the UID; a number inside the HMAC-covered
    body is not forgeable without the writer key this process never persists.

    A write that fails after reaching this point still CONSUMES its number: reusing it would let a
    later artifact tie an earlier one, which is the one ambiguity the tie-break cannot resolve.
    """
    global _ARTIFACT_SEQUENCE
    _ARTIFACT_SEQUENCE += 1
    return _ARTIFACT_SEQUENCE


def artifact_sequence_valid(value: Any) -> bool:
    """A positive integer, and not a bool — True would otherwise pass as 1 and tie a real write."""
    return isinstance(value, int) and not isinstance(value, bool) and value >= 1


def new_artifact_auth_key() -> tuple[str, bytes]:
    """Create a process-scoped writer capability that is never persisted or inherited by exec children."""
    key_id = secrets.token_hex(16)
    key = os.urandom(32)
    _ARTIFACT_AUTH_KEYS[key_id] = key
    return key_id, key


def artifact_auth_message(data: dict[str, Any], path: Path) -> bytes:
    """Bind the MAC to the FULL absolute lexical path the artifact was discovered at.

    Binding only path.name let a byte-for-byte copy of a valid artifact authenticate under any
    other safe artifact base sharing the filename, while the writer key was live in-process. The
    writer signs artifact_base()/name and the lookup verifies the same base/name it discovered —
    both from artifact_base(), which is abspath-normalized and never symlink-resolved, so the
    string is deterministic between the two without depending on the filesystem's current shape.

    The canonical form is ASCII-safe, not merely UTF-8-encoded. POSIX argv admits lone surrogates
    and run_id flows from argv into this body, so ensure_ascii=False made signing raise
    UnicodeEncodeError on input a caller fully controls — after a mutation could already have
    landed, where an escaping error suppresses the truthful envelope. \\uXXXX escaping is a
    lossless encoding of the same value, so nothing is normalized away: the decoded Python string
    round-trips exactly, and writer and verifier derive identical bytes from identical values.
    """
    unsigned = dict(data)
    unsigned.pop("writer_authentication", None)
    canonical = json.dumps(unsigned, sort_keys=True, separators=(",", ":"), ensure_ascii=True).encode("ascii")
    # os.fsencode, not str().encode(): the artifact base comes from the environment, which POSIX
    # lets carry bytes that are not valid UTF-8. Signing must bind the path the kernel sees rather
    # than raise on it, and the same round-trip is what the verifier's own fsencode reproduces.
    return b"hermes-busdriver-delivery-artifact-v1\0" + os.fsencode(path) + b"\0" + canonical


def artifact_path_claims_bind(data: dict[str, Any], path: Path) -> bool:
    """The body's own path claims must name exactly the path the artifact was discovered at.

    The MAC already covers these fields, so this is not the only thing standing between a
    relocated copy and acceptance — it is the check that keeps a body signed by THIS process from
    being accepted somewhere it does not claim to live. Exactly one result entry: a duplicate,
    missing, or otherwise-shaped artifacts list is not the schema the writer produces.
    """
    target = str(path)
    run = data.get("run")
    if data.get("run_artifact_path") != target or not isinstance(run, dict):
        return False
    artifacts = run.get("artifacts")
    return (
        isinstance(artifacts, list)
        and len(artifacts) == 1
        and isinstance(artifacts[0], dict)
        and artifacts[0].get("kind") == "result"
        and artifacts[0].get("path") == target
    )


def artifact_auth_shape_valid(auth: Any) -> bool:
    return (
        isinstance(auth, dict)
        and auth.get("schema") == ARTIFACT_AUTH_SCHEMA
        and auth.get("algorithm") == "hmac-sha256-process-scoped"
        and isinstance(auth.get("key_id"), str)
        and re.fullmatch(r"[0-9a-f]{32}", auth["key_id"]) is not None
        and isinstance(auth.get("mac"), str)
        and re.fullmatch(r"[0-9a-f]{64}", auth["mac"]) is not None
    )


def authenticate_artifact(data: dict[str, Any], path: Path) -> bool:
    auth = data.get("writer_authentication")
    if not artifact_auth_shape_valid(auth) or not artifact_path_claims_bind(data, path):
        return False
    assert isinstance(auth, dict)
    key = _ARTIFACT_AUTH_KEYS.get(auth["key_id"])
    if key is None:
        return False
    expected = hmac.new(key, artifact_auth_message(data, path), hashlib.sha256).hexdigest()
    return hmac.compare_digest(expected, auth["mac"])


def read_fd_bounded(fd: int, limit: int) -> bytes:
    """At most `limit` bytes from fd, however many reads that takes.

    os.read is not obliged to return everything at once, and a short read is not EOF; only an
    empty return is. Nothing here trusts a size the caller learned from fstat.
    """
    chunks: list[bytes] = []
    remaining = limit
    while remaining > 0:
        chunk = os.read(fd, remaining)
        if not chunk:
            break
        chunks.append(chunk)
        remaining -= len(chunk)
    return b"".join(chunks)


def read_artifact_entry(dir_fd: int, name: str) -> dict[str, Any] | None:
    """Open one artifact entry no-follow RELATIVE to dir_fd and validate it via fstat.

    Returns the body only for a regular, owner-only 0600, single-link JSON object of at most
    ARTIFACT_MAX_BYTES. The file is never reached by path, so no component of the configured tree
    is traversed a second time.

    No filesystem metadata is returned. The stat is used to REJECT entries, never to order them:
    handing an mtime back to callers is what let a same-UID utime() decide which artifact won.

    Order is the point. The open is non-blocking, so a FIFO cannot wedge it; the fstat then
    rejects every non-regular entry before a byte is read. The size verdict comes from that same
    fstat, so an oversized regular file never reaches a read or the parser. fstat is only a
    snapshot, though, so the read is INDEPENDENTLY bounded at limit + 1: a file that grew after
    the stat is rejected by the second bound rather than trusted from the stale one.
    """
    try:
        fd = os.open(name, _NOFOLLOW_FILE_FLAGS, dir_fd=dir_fd)
    except OSError:
        return None
    try:
        st = os.fstat(fd)
        if (
            not stat.S_ISREG(st.st_mode)
            or st.st_uid != os.getuid()
            or st.st_nlink != 1
            or stat.S_IMODE(st.st_mode) != 0o600
            or not 0 <= st.st_size <= ARTIFACT_MAX_BYTES
        ):
            return None
        raw = read_fd_bounded(fd, ARTIFACT_MAX_BYTES + 1)
        if len(raw) > ARTIFACT_MAX_BYTES:
            return None
        data = json.loads(raw.decode("utf-8"))
    # Staying inside the 1 MiB bound is not the same as being parseable. Over-deep nesting raises
    # RecursionError and an integer past CPython's digit cap raises a bare ValueError; neither is a
    # JSONDecodeError, so both used to escape as a traceback from a file an attacker chose the
    # bytes of. They are entry-local rejections like any other malformed body.
    except (OSError, UnicodeDecodeError, ValueError, RecursionError):
        return None
    finally:
        os.close(fd)
    return data if isinstance(data, dict) else None


def artifact_entries(run_id: str) -> list[tuple[str, Path, dict[str, Any]]]:
    """Every no-follow-readable artifact entry structurally valid for run_id, in filename order.

    Filename order is for determinism only — it carries no freshness meaning. Ordering by anything
    the filesystem records would put the choice back in reach of a same-UID utime().

    An unsafe, unreadable, or symlinked artifact directory yields no entries: it is not evidence
    of anything, so callers fall back to their existing missing-directory behavior rather than
    accepting bytes reached through a followed component.
    """
    base = artifact_base()
    try:
        dir_fd = artifact_dir_fd(create=False)
    except ArtifactDirectoryInvalid:
        return []
    entries: list[tuple[str, Path, dict[str, Any]]] = []
    try:
        try:
            names = [name for name in os.listdir(dir_fd) if name.endswith(".json")]
        except OSError:
            return []
        for name in names:
            data = read_artifact_entry(dir_fd, name)
            if data is None or not artifact_is_valid(data, run_id):
                continue
            entries.append((name, base / name, data))
    finally:
        os.close(dir_fd)
    return sorted(entries, key=lambda entry: entry[0])


def artifact_for_run_id(run_id: str) -> tuple[Path, dict[str, Any]] | None:
    """The freshest AUTHENTICATED artifact for run_id, decided only by its signed sequence.

    Authentication and schema validity come first, so nothing an unauthenticated body claims can
    influence the choice; among the survivors the winner is the largest signed sequence. The
    filename tie-break is defence against an impossibility — this process never issues one number
    twice — not an ordering rule, and no filesystem metadata takes part in either step.
    """
    matches = [
        (data["artifact_sequence"], name, path, data)
        for name, path, data in artifact_entries(run_id)
        if authenticate_artifact(data, path)
    ]
    if not matches:
        return None
    _sequence, _name, path, data = max(matches, key=lambda match: (match[0], match[1]))
    return path, data


def write_artifact(result: dict[str, Any]) -> None:
    """Serialize result into the artifact directory without following any symlink component.

    The directory fd obtained by the no-follow traversal stays open across the whole write, so
    the temp create, the fsync, the atomic replace, and any cleanup all address the directory
    the traversal actually proved safe — not a path that could be re-pointed underneath us.
    """
    run = result.get("run") if isinstance(result.get("run"), dict) else {}
    run_id = str(run.get("run_id") or new_run_id())
    name = artifact_name(run_id)
    path = artifact_base() / name
    dir_fd = artifact_dir_fd(create=True)
    try:
        os.fchmod(dir_fd, 0o700)
        result["run_artifact_path"] = str(path)
        if isinstance(result.get("run"), dict):
            result["run"]["artifacts"] = [{"kind": "result", "path": str(path)}]
        # Top-level and set BEFORE the MAC, so the canonical signed body already covers it.
        result["artifact_sequence"] = next_artifact_sequence()
        key_id, key = new_artifact_auth_key()
        result["writer_authentication"] = {
            "schema": ARTIFACT_AUTH_SCHEMA,
            "algorithm": "hmac-sha256-process-scoped",
            "key_id": key_id,
            "mac": hmac.new(key, artifact_auth_message(result, path), hashlib.sha256).hexdigest(),
        }
        # Serialized once, after every signed field is final, so the bytes measured are exactly
        # the bytes written. The limit is enforced here — before the O_EXCL temp file exists — so
        # an oversized result leaves no residue to clean up.
        payload = (json.dumps(result, indent=2, sort_keys=True) + "\n").encode()
        if len(payload) > ARTIFACT_MAX_BYTES:
            raise ArtifactTooLarge("delivery_artifact_too_large")
        tmp_name = f".{name}.{os.getpid()}.{uuid.uuid4().hex}.tmp"
        write_artifact_bytes(payload, dir_fd, tmp_name, name)
        confirm_artifact_directory_identity(dir_fd, name)
    except (OSError, ArtifactDirectoryInvalid, ArtifactTooLarge):
        clear_artifact_result_fields(result)
        raise
    finally:
        os.close(dir_fd)


def _digest_artifact_fd(fd: int, size: int) -> str:
    """sha256 of exactly `size` bytes read back through `fd`, never through the name."""
    digest = hashlib.sha256()
    offset = 0
    while offset < size:
        # pread: neither moves the offset nor rides it, so the digest cannot race the writer.
        chunk = os.pread(fd, min(1 << 16, size - offset), offset)
        if not chunk:
            raise OSError("artifact_truncated")
        digest.update(chunk)
        offset += len(chunk)
    return digest.hexdigest()


def write_artifact_bytes(payload: bytes, dir_fd: int, tmp_name: str, name: str) -> None:
    """Publish `payload` at `name` atomically, having proved each claim it rests on.

    An INDEPENDENT writer, not a wrapper. `write_private_authenticated` creates its final name with
    O_EXCL and never renames, because nothing may already hold the name it is about to execute; a
    result artifact is the opposite — it must REPLACE what the previous run left. So the contract is
    restated here rather than delegated, and the durability tests enumerate this function by name.

    `handle.write` used to be the whole of the proof. `io.BufferedWriter` does loop over short
    writes, so that one claim was accidentally true — but it is also why an `os.write`-shaped
    enumeration could not see this function at all, and it left the rest unmade. Each is now its own
    step: the write loop terminates on a zero rather than spinning; the closing re-read separates
    "we wrote the authenticated bytes" from "the file holds them"; the destination reopen checks the
    second resolution of `name` that the rename performs; the parent fsync makes the directory entry
    the rename created as durable as the bytes it points at; and the unlink proves it is removing
    the inode this call created, not whatever took the name in the meantime.
    """
    # O_RDWR, not O_WRONLY: the closing digest reads back through THIS descriptor, and a write-only
    # one cannot be read (EBADF). Reopening the name to read it would resolve the name a second time.
    fd = os.open(tmp_name, os.O_RDWR | os.O_CREAT | os.O_EXCL | getattr(os, "O_NOFOLLOW", 0) | _O_CLOEXEC, 0o600, dir_fd=dir_fd)
    try:
        # The inode THIS call created. Every unlink below deletes only this one, never a replacement.
        created = os.fstat(fd)
        try:
            view = memoryview(payload)
            while view:
                written = os.write(fd, view)
                if written <= 0:
                    # Consuming the result only as a slice index makes a 0 an infinite loop, so this
                    # keeps the loop terminating as well as honest.
                    raise OSError("artifact_short_write")
                view = view[written:]
            os.fsync(fd)
            st = os.fstat(fd)
            if (
                not stat.S_ISREG(st.st_mode)
                or st.st_uid != os.geteuid()
                or st.st_nlink != 1
                or st.st_size != len(payload)
                or stat.S_IMODE(st.st_mode) != 0o600
            ):
                raise OSError("artifact_metadata_invalid")
            if _digest_artifact_fd(fd, st.st_size) != hashlib.sha256(payload).hexdigest():
                raise OSError("artifact_integrity_failed")
            if not _names_created_inode(dir_fd, tmp_name, created):
                # The digest proved OUR inode is intact; this proves `tmp_name` still reaches it, so
                # the rename below publishes our bytes rather than someone else's.
                raise OSError("artifact_integrity_failed")
        except BaseException:
            # A half-written artifact must not be left for the next run to read. But by now the name
            # may belong to something else, and deleting THAT is a second bug wearing the first
            # one's cleanup.
            if _names_created_inode(dir_fd, tmp_name, created):
                try:
                    os.unlink(tmp_name, dir_fd=dir_fd)
                except OSError:
                    pass
            raise
    finally:
        os.close(fd)

    try:
        os.replace(tmp_name, name, src_dir_fd=dir_fd, dst_dir_fd=dir_fd)
    except BaseException:
        if _names_created_inode(dir_fd, tmp_name, created):
            try:
                os.unlink(tmp_name, dir_fd=dir_fd)
            except OSError:
                pass
        raise

    # The rename resolved `name` a second time, and a second resolution is a second chance to land
    # somewhere else. Reopen it, no-follow, and prove it reaches the inode the digest just cleared —
    # then re-digest, because same-inode is not same-bytes to anyone who can write the file.
    published = os.open(name, os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0) | _O_CLOEXEC, dir_fd=dir_fd)
    try:
        landed = os.fstat(published)
        if (landed.st_dev, landed.st_ino) != (created.st_dev, created.st_ino):
            raise OSError("artifact_replaced_after_publish")
        if (
            not stat.S_ISREG(landed.st_mode)
            or landed.st_uid != os.geteuid()
            or landed.st_nlink != 1
            or landed.st_size != len(payload)
            or stat.S_IMODE(landed.st_mode) != 0o600
        ):
            raise OSError("artifact_metadata_invalid")
        if _digest_artifact_fd(published, landed.st_size) != hashlib.sha256(payload).hexdigest():
            raise OSError("artifact_replaced_after_publish")
    finally:
        os.close(published)
    # A rename is durable only once the DIRECTORY entry is: without this, a crash can leave the
    # parent pointing at the temp name, or at nothing, with the file itself perfectly intact.
    os.fsync(dir_fd)


def confirm_artifact_directory_identity(dir_fd: int, name: str) -> None:
    """Fail closed unless the configured path still names the directory just written into.

    Without this, a component swapped between the traversal and the write would leave the run
    reporting a path that resolves somewhere the bytes are not — a lie the stdout fallback would
    then repeat. On drift the artifact is removed through the ORIGINAL fd, not by path.

    A re-open that FAILS is drift too, not an excuse to skip the removal: an ancestor swapped to a
    symlink is the likeliest way this fires, and the bytes are still reachable through the original
    fd. Both outcomes converge on the same unlink and the same stable reason.
    """
    try:
        check_fd = artifact_dir_fd(create=False)
        try:
            drifted = dir_identity(check_fd) != dir_identity(dir_fd)
        finally:
            os.close(check_fd)
    except (OSError, ArtifactDirectoryInvalid) as e:
        cause: Exception | None = e
    else:
        if not drifted:
            return
        cause = None
    try:
        os.unlink(name, dir_fd=dir_fd)
    except OSError:
        pass
    raise ArtifactDirectoryInvalid("delivery_artifact_directory_identity_drift") from cause


def clear_artifact_result_fields(result: dict[str, Any]) -> None:
    result["run_artifact_path"] = None
    result.pop("writer_authentication", None)
    # The consumed number is not returned to the counter; only the failed result's claim to one is
    # withdrawn, so the stdout fallback reports no artifact state it does not have.
    result.pop("artifact_sequence", None)
    if isinstance(result.get("run"), dict):
        result["run"]["artifacts"] = []


def status_lookup_run(args: argparse.Namespace, result_decision: dict[str, Any], reason: str) -> dict[str, Any]:
    return {
        "schema": RUN_SCHEMA,
        "version": 1,
        "run_id": args.run_id,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "phase": "status",
        "status": result_decision.get("status"),
        "reason": result_decision.get("reason", reason),
        "repo_root": None,
        "pr_number": None,
        "authority": {key: result_decision[key] for key in BLOCKED_FLAGS},
        "artifacts": [],
    }


def status_mode_result(args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    if not args.run_id:
        result_decision = decision("blocked", "run_id_required")
        result = {
            "schema": SCHEMA,
            "version": 1,
            "ok": False,
            "mode": "status",
            "operation": "status",
            "repo": None,
            "pr": None,
            "delivery_status": None,
            "status_lookup": {"found": False, "reason": "run_id_required"},
            "verifiers": [],
            "steps": steps_for("run_id_required"),
            "decision": result_decision,
            "run": status_lookup_run(args, result_decision, "run_id_required"),
            "run_artifact_path": None,
        }
        return redact_value(result), 2

    found = artifact_for_run_id(args.run_id)
    if found is None:
        # Unverifiable bytes are not evidence that Hermes wrote an artifact. A plausible unknown
        # key_id is forgeable by any same-UID writer, so it cannot select a distinct wire reason.
        missing_reason = "run_not_found"
        result_decision = decision("blocked", missing_reason)
        result = {
            "schema": SCHEMA,
            "version": 1,
            "ok": False,
            "mode": "status",
            "operation": "status",
            "repo": None,
            "pr": None,
            "delivery_status": None,
            "status_lookup": {"found": False, "reason": missing_reason, "run_id": args.run_id},
            "verifiers": [],
            "steps": steps_for(missing_reason),
            "decision": result_decision,
            "run": delivery_run(args, {}, result_decision, missing_reason),
            "run_artifact_path": None,
        }
        return redact_value(result), 1

    path, artifact = found
    artifact_run = artifact.get("run") if isinstance(artifact.get("run"), dict) else {}
    result_decision = decision("found", "run_found")
    result = {
        "schema": SCHEMA,
        "version": 1,
        "ok": True,
        "mode": "status",
        "operation": "status",
        "repo": {"root": artifact_run.get("repo_root")},
        "pr": {"number": artifact_run.get("pr_number")} if artifact_run.get("pr_number") is not None else None,
        "delivery_status": None,
        "status_lookup": {
            "found": True,
            "run_id": args.run_id,
            "artifact_path": str(path),
            "artifact_schema": artifact.get("schema"),
            "artifact_ok": artifact.get("ok"),
            "artifact_decision": decision_summary(artifact.get("decision", {})),
            "artifact_run": run_summary(artifact_run),
        },
        "verifiers": [],
        "steps": steps_for("run_found"),
        "decision": result_decision,
        "run": delivery_run(args, {"repo": {"root": artifact_run.get("repo_root")}}, result_decision, "run_found"),
        "run_artifact_path": None,
    }
    result["run"]["pr_number"] = artifact_run.get("pr_number")
    result["run"]["artifacts"] = [{"kind": "result", "path": str(path)}]
    return redact_value(result), 0




# =============================================================================================
# Fixed root-owned source execution contract.
#
# What this replaces, and why the replacement is different in kind rather than degree:
#
# r26..r34 executed a *private copy* — read the pinned bytes, write them into a 0700 temp dir, exec
# the copy. That never removed the substitutable name; it relocated it into a directory the
# adversary still owns. macOS has no `fexecve` and refuses to exec `/dev/fd/N`, so the kernel must
# re-resolve a *pathname* at exec time. Any pathname we can write is one a same-UID adversary can
# rename between our last check and that re-resolution. r34 demonstrated it with a two-rename ABA:
# rename ours aside, move theirs in — `st_nlink` stays 1 and every descriptor-visible field still
# matches. No amount of re-checking a writable path closes that; the check and the exec cannot be
# made atomic.
#
# So the source moves somewhere the adversary has no write access at all: a fixed path whose every
# component, root to leaf, is root-owned and not group/world writable. The validation below is not
# trying to win the race — it proves there is no race, because a same-UID non-root adversary cannot
# rename, replace, or add a name anywhere along the path. `test_trusted_root_owned_execution.py`
# asserts that against the kernel rather than restating it here.
#
# Two platform facts this has to encode rather than assume away:
#
#   * /usr/bin/git and /usr/bin/python3 are THE SAME INODE — one 78-way-hardlinked CommandLineTools
#     multi-call shim that dispatches on argv[0]. `st_nlink == 1` is therefore not a property of a
#     trusted system source, and requiring it would fail-close git forever. It also buys nothing
#     here: an adversary who cannot write the directory cannot add a name to it. SF_RESTRICTED (SIP,
#     which denies modification even to root) is required of those sources instead — strictly
#     stronger than the nlink check it replaces.
#
#   * that shim re-dispatches through `xcrun`, which honours $DEVELOPER_DIR. With it set,
#     /usr/bin/git execs $DEVELOPER_DIR/usr/bin/xcrun: attacker code out of a user-writable
#     directory, from a root-owned SIP-restricted digest-matching binary. Verified with a planted
#     xcrun (exit 42). No ancestry walk can see this, so the contract also owns the child
#     environment — see ENV_DENIED_FOR_TRUSTED_DISPATCH. Today every env builder here is an
#     allowlist and none lists DEVELOPER_DIR, so the hole is latent rather than live; the denial is
#     explicit so that stays true by construction instead of by coincidence.
# =============================================================================================

SF_RESTRICTED = 0x00080000  # macOS SIP: modification denied even to root.
_NON_OWNER_WRITABLE = stat.S_IWGRP | stat.S_IWOTH
# Sources that are the CommandLineTools multi-call shim: nlink > 1 by design, SIP-restricted.
SHIM_BACKED_SOURCES = frozenset({"git", "python3"})
# Never allowed into a child that runs a trusted source, no matter who asks. DEVELOPER_DIR is the
# live redirection primitive; the rest are the same idea through xcrun's other knobs.
ENV_DENIED_FOR_TRUSTED_DISPATCH = frozenset({
    "DEVELOPER_DIR", "SDKROOT", "XCODE_DEVELOPER_DIR_PATH", "TOOLCHAINS", "XCRUN_CACHE_PATH",
})
# gh is the largest of these by an order of magnitude; the bound is a memory guard, not a policy.
MAX_TRUSTED_EXECUTABLE_BYTES = 256 * 1024 * 1024


def _trusted_source_refusal(name: str, reason: str, detail: str | None = None) -> RuntimeError:
    """Machine-readable refusal.

    gh gets its own top-level reason because a missing credential-bearing binary is an operational
    state an administrator resolves by provisioning /usr/local/bin/gh, not an integrity failure to
    debug. Callers route on it; keep it exact.
    """
    if reason == "unavailable" and name == "gh":
        code = "trusted_root_owned_gh_unavailable"
    else:
        code = f"trusted_root_owned_source_{reason}:{name}"
    return RuntimeError(code if detail is None else f"{code}:{detail}")


def _require_trusted_directory(st: os.stat_result, name: str, component: str) -> None:
    if not stat.S_ISDIR(st.st_mode) or st.st_uid != 0 or (st.st_mode & _NON_OWNER_WRITABLE):
        raise _trusted_source_refusal(name, "ancestry_untrusted", component)


def _open_root_owned_ancestry(path: Path, name: str) -> int:
    """Walk root-to-parent with O_NOFOLLOW directory descriptors; return the parent fd.

    The fd is returned rather than the path because the leaf must be opened *relative to the
    directory we just validated*. Re-opening the leaf by full pathname would re-traverse every
    component from `/` again, handing back the TOCTOU this walk exists to remove.
    """
    try:
        dir_fd = os.open("/", os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC)
    except OSError as exc:
        raise _trusted_source_refusal(name, "ancestry_untrusted", "/") from exc
    try:
        _require_trusted_directory(os.fstat(dir_fd), name, "/")
        for component in path.parts[1:-1]:
            try:
                # O_NOFOLLOW is what refuses a symlinked component: no traversal, no surprise.
                nxt = os.open(
                    component,
                    os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC | os.O_NOFOLLOW,
                    dir_fd=dir_fd,
                )
            except OSError as exc:
                raise _trusted_source_refusal(name, "ancestry_untrusted", component) from exc
            os.close(dir_fd)
            dir_fd = nxt
            _require_trusted_directory(os.fstat(dir_fd), name, component)
    except BaseException:
        os.close(dir_fd)
        raise
    return dir_fd


def _require_trusted_leaf(st: os.stat_result, name: str) -> None:
    if not stat.S_ISREG(st.st_mode):
        raise _trusted_source_refusal(name, "metadata_invalid", "not_regular")
    if st.st_uid != 0 or (st.st_mode & _NON_OWNER_WRITABLE):
        raise _trusted_source_refusal(name, "metadata_invalid", "writable_or_unowned")
    if not (st.st_mode & (stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)):
        raise _trusted_source_refusal(name, "metadata_invalid", "not_executable")
    if name in SHIM_BACKED_SOURCES:
        # nlink is waived for the shim (it is 78 by design); SIP replaces it, and is stronger.
        if not (getattr(st, "st_flags", 0) & SF_RESTRICTED):
            raise _trusted_source_refusal(name, "metadata_invalid", "not_sip_restricted")
    elif st.st_nlink != 1:
        raise _trusted_source_refusal(name, "metadata_invalid", "multiply_linked")


def _identity(st: os.stat_result) -> tuple:
    """Everything a substitution would have to forge, read from the descriptor we will digest."""
    return (
        st.st_dev, st.st_ino, st.st_uid, st.st_gid, st.st_mode,
        st.st_nlink, st.st_size, st.st_mtime_ns, st.st_ctime_ns,
    )


def _read_trusted_source_bytes(fd: int, name: str) -> bytes:
    chunks: list[bytes] = []
    total = 0
    while True:
        chunk = os.read(fd, 1024 * 1024)
        if not chunk:
            break
        total += len(chunk)
        if total > MAX_TRUSTED_EXECUTABLE_BYTES:
            raise _trusted_source_refusal(name, "metadata_invalid", "oversized")
        chunks.append(chunk)
    return b"".join(chunks)


def _validated_root_owned_source(path: Path, name: str) -> Path:
    """Prove `path` is a root-owned, non-writable, digest-pinned source, and return it unchanged.

    Pure seam: production callers reach this only through trusted_executable_path(), which supplies
    the path from a frozen table. Tests pass harmless already-root-owned system binaries here rather
    than production accepting an alternate source.
    """
    expected = TRUSTED_EXECUTABLE_DIGESTS[name]
    if not path.is_absolute():
        raise _trusted_source_refusal(name, "metadata_invalid", "not_absolute")
    parent_fd = _open_root_owned_ancestry(path, name)
    try:
        try:
            fd = os.open(path.name, os.O_RDONLY | os.O_CLOEXEC | os.O_NOFOLLOW, dir_fd=parent_fd)
        except OSError as exc:
            # ELOOP is O_NOFOLLOW refusing a symlink leaf — a distinct, reportable condition from
            # the file simply not being there, and the one an attacker would author.
            if exc.errno == errno.ELOOP:
                raise _trusted_source_refusal(name, "metadata_invalid", "symlink") from exc
            raise _trusted_source_refusal(name, "unavailable", type(exc).__name__) from exc
        try:
            opened = os.fstat(fd)
            _require_trusted_leaf(opened, name)
            data = _read_trusted_source_bytes(fd, name)
            if hashlib.sha256(data).hexdigest() != expected:
                raise _trusted_source_refusal(name, "integrity_failed")
            # Closing revalidation: the descriptor must still be the inode we metadata-checked...
            if _identity(os.fstat(fd)) != _identity(opened):
                raise _trusted_source_refusal(name, "identity_changed", "descriptor")
            # ...and the *name* must still resolve to that inode, since the name is what execs.
            final = os.lstat(path.name, dir_fd=parent_fd)
            if (final.st_dev, final.st_ino) != (opened.st_dev, opened.st_ino):
                raise _trusted_source_refusal(name, "identity_changed", "path")
        finally:
            os.close(fd)
    finally:
        os.close(parent_fd)
    return path


def trusted_executable_path(name: str) -> Path:
    """The only production entry point. Takes a name; the path is not negotiable.

    Revalidated on every call rather than cached: the contract is "validated immediately before
    dispatch", and a cache is a promise about the past.
    """
    source = TRUSTED_EXECUTABLE_SOURCES.get(name)
    if source is None:
        raise _trusted_source_refusal(name, "unsupported")
    return _validated_root_owned_source(source, name)


def run_safe(argv: list[str], cwd: Path, timeout: int = 300, env: dict[str, str] | None = None, *, allow_gh_repo: bool = False, input_text: str | None = None, capture_stdout: bool = False) -> dict[str, Any]:
    started = time.time()
    effective_argv = list(argv)
    trusted_name = Path(effective_argv[0]).name if effective_argv and Path(effective_argv[0]).name in TRUSTED_EXECUTABLE_SOURCES else None
    try:
        if trusted_name is not None:
            effective_argv[0] = str(trusted_executable_path(trusted_name))
    except RuntimeError as exc:
        return {"cmd": argv, "returncode": 126, "ok": False, "stdout_tail": "", "stderr_tail": str(exc), "error": "trusted_executable_rejected"}
    effective_env = safe_git_env(env, allow_gh_repo=allow_gh_repo)
    if trusted_name == "gh":
        for key in ("GH_TOKEN", "GITHUB_TOKEN", "GH_ENTERPRISE_TOKEN"):
            value = os.environ.get(key)
            if value:
                effective_env[key] = value
    try:
        proc = subprocess.Popen(
            effective_argv,
            cwd=str(cwd),
            shell=False,
            stdin=subprocess.PIPE if input_text is not None else subprocess.DEVNULL,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            env=effective_env,
            start_new_session=True,
        )
    except OSError as e:
        return {"cmd": argv, "returncode": 127, "ok": False, "stdout_tail": "", "stderr_tail": tail(str(e)), "error": type(e).__name__}

    # The 2MB `capture_stdout` check below used to be the only bound, and it ran AFTER
    # communicate() had already read the whole stream — a bound on retention, not on the read.
    # `git archive --format=tar` and a full worktree diff both come through here.
    captured = _bounded_communicate(
        proc, argv, timeout, input_text.encode() if input_text is not None else None,
        # A tail-only caller needs 64KB; a caller that parses the whole stdout (a `gh api` JSON
        # body) needs the payload bound. Either way the number is ours and the pipe enforces it.
        MAX_PAYLOAD_BYTES if capture_stdout else MAX_CAPTURED_BYTES,
    )
    stdout, stderr = captured.stdout, captured.stderr

    if captured.timed_out:
        return {
            "cmd": argv,
            "returncode": 124,
            "ok": False,
            "stdout_tail": tail(stdout),
            "stderr_tail": tail(stderr),
            "elapsed_seconds": round(time.time() - started, 3),
            "error": "timeout",
        }
    if captured.overflowed:
        # The bounded pipe layer already killed and reaped the process group before returning.
        return {
            "cmd": argv,
            "returncode": 1,
            "ok": False,
            "stdout_tail": "",
            "stderr_tail": "",
            "elapsed_seconds": round(time.time() - started, 3),
            "error": "stdout_capture_limit_exceeded",
        }
    result = {
        "cmd": argv,
        "returncode": proc.returncode,
        "ok": proc.returncode == 0,
        "stdout_tail": tail(stdout),
        "stderr_tail": tail(stderr),
        "elapsed_seconds": round(time.time() - started, 3),
    }
    if capture_stdout:
        result["stdout"] = stdout
    return result


def repo_root_from_status(delivery_status: dict[str, Any]) -> Path | None:
    repo = delivery_status.get("repo") if isinstance(delivery_status.get("repo"), dict) else {}
    root = repo.get("root")
    return Path(root).expanduser().resolve() if isinstance(root, str) and root else None


def git_observation_env(source: dict[str, str] | None = None) -> dict[str, str]:
    ambient = os.environ if source is None else source
    env = {
        key: value
        for key, value in ambient.items()
        if key in GIT_OBSERVATION_ENV_ALLOWLIST or key.startswith("LC_")
    }
    env.update({
        "PATH": "/usr/bin:/bin:/usr/sbin:/sbin",
        "GIT_CONFIG_NOSYSTEM": "1",
        "GIT_CONFIG_GLOBAL": os.devnull,
        "GIT_TERMINAL_PROMPT": "0",
        "GIT_PAGER": "cat",
        "GIT_OPTIONAL_LOCKS": "0",
        "GIT_NO_LAZY_FETCH": "1",
        "GIT_ALLOW_PROTOCOL": "",
    })
    return env


def git_observation_args_are_read_only(args: tuple[str, ...]) -> bool:
    """Accept only the read-only Git command shapes used by production callers.

    The first token is always the real verb: global options and aliases are deliberately not
    parsed.  New call shapes must be reviewed and added here rather than inheriting a generic Git
    execution primitive.
    """
    if not args or not args[0] or args[0].startswith("-"):
        return False
    verb = args[0]
    tail_args = args[1:]

    def inert(value: str) -> bool:
        return bool(value) and not value.startswith("-") and not any(char in value for char in "\x00\r\n")

    if verb == "symbolic-ref":
        return len(args) == 2 and args[1].startswith("refs/remotes/") and args[1].endswith("/HEAD")
    if verb == "remote":
        return len(args) == 1
    if verb == "branch":
        return args == ("branch", "--show-current")
    if verb == "config":
        if len(args) == 2:
            return inert(args[1])
        return len(args) == 3 and args[1] in {"--get", "--get-all", "--get-regexp"} and inert(args[2])
    if verb == "log":
        return len(args) == 4 and args[1:3] == ("-1", "--format=%B") and inert(args[3])
    if verb == "rev-list":
        return len(args) == 3 and args[1] == "--count" and inert(args[2]) and args[2].endswith("..HEAD")
    if verb == "ls-tree":
        return (
            len(args) >= 6
            and args[1:4] == ("-r", "-z", "--name-only")
            and inert(args[4])
            and args[5] == "--"
            and all(pathspec.startswith(":(literal)") for pathspec in args[6:])
        )
    if verb == "rev-parse":
        if args == ("rev-parse", "HEAD"):
            return True
        if args == ("rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}"):
            return True
        return len(args) == 3 and args[1] == "--verify" and inert(args[2]) and args[2].endswith("^{commit}")
    if verb == "status":
        return all(not arg.startswith("--output") for arg in tail_args)
    if verb == "diff":
        refused = {"--ext-diff", "--textconv"}
        return not any(arg in refused or arg == "--output" or arg.startswith("--output=") for arg in tail_args)
    return False


def git_observation_raw(repo: Path, *args: str) -> tuple[int, bytes, str]:
    try:
        if not git_observation_args_are_read_only(args):
            return 126, b"", "git_observation_command_refused"
        verb = args[0]
        safe_args = list(args)
        if verb == "status":
            safe_args = [
                arg for arg in safe_args
                if not arg.startswith("--untracked-files") and not arg.startswith("--ignore-submodules")
            ]
            safe_args[1:1] = ["--untracked-files=all", "--ignore-submodules=none"]
        if verb == "diff":
            for flag in reversed(("--no-ext-diff", "--no-textconv")):
                if flag not in safe_args:
                    safe_args.insert(1, flag)
        if verb == "config" and "--no-includes" not in safe_args:
            safe_args.insert(1, "--no-includes")
        config: list[str] = []
        for item in GIT_OBSERVATION_INERT_CONFIG:
            config.extend(("-c", item))
        argv = [
            str(trusted_executable_path("sandbox-exec")), "-p", GIT_OBSERVATION_SANDBOX_PROFILE,
            str(trusted_executable_path("git-real")), "--no-pager", *config,
            "-C", str(repo), *safe_args,
        ]
    except RuntimeError as exc:
        return 126, b"", f"trusted_runtime_executable_integrity_failed:git_observation:{exc}"
    try:
        completed = _bounded_run(
            argv,
            env=git_observation_env(),
            timeout=30,
            text=False,
            limit=MAX_PAYLOAD_BYTES,
        )
    except subprocess.TimeoutExpired:
        return 124, b"", "git command timed out"
    except RuntimeError as exc:
        if str(exc) == "child_output_too_large":
            return 125, b"", "git_output_too_large"
        return 126, b"", f"git_observation_refused:{exc}"
    except OSError as exc:
        return 127, b"", str(exc)
    if completed.stderr:
        return 126, b"", "git_observation_stderr"
    return completed.returncode, completed.stdout, ""


def git_observation_effect(repo: Path, *args: str) -> dict[str, Any]:
    started = time.time()
    rc, raw, stderr = git_observation_raw(repo, *args)
    stdout = raw.decode("utf-8", errors="replace").rstrip("\n")
    return {
        "cmd": ["git", *args],
        "returncode": rc,
        "ok": rc == 0,
        "stdout_tail": tail(stdout),
        "stderr_tail": tail(stderr),
        "elapsed_seconds": round(time.time() - started, 3),
    }


def git_raw(repo: Path, *args: str) -> tuple[int, bytes, str]:
    # Disabled by construction.  All Git reads go through git_observation_raw; fixed mutation
    # commands use run_safe.  Keeping this compatibility surface fail-closed prevents global
    # options, aliases, or a future caller from rebuilding an unsandboxed observation path.
    del repo, args
    return 126, b"", "git_raw_disabled"


def git_output(repo: Path, *args: str) -> tuple[int, str, str]:
    rc, raw, stderr = git_observation_raw(repo, *args)
    return rc, raw.decode("utf-8", errors="replace").rstrip("\n"), stderr


# Enumerated from the CONSUMER, not restated by hand — the same derivation pr-grind-check uses for
# its check rows: every character `str.splitlines()` treats as a boundary can fabricate a status
# record, because that is the split these paths used to go through.
#
# Do not be reassured by git's own quoting. git quotes C0 controls (LF, CR, VT, FF) in a pathname
# even under `core.quotePath=false`, but it does NOT quote the non-ASCII separators once that
# config is off — and `splitlines()` splits on NEL (U+0085), LS (U+2028) and PS (U+2029) just the
# same. A repo-local `.git/config` setting `core.quotePath=false` plus a directory named
# `evil<U+2028> M .claude` therefore fabricated a ` M .claude/...` marker record out of one
# untracked file, which `marker_path_allowed()` then accepted (it strips the stray quote the split
# leaves behind). Verified against real git before this fix, not inferred.
#
# So the framing is changed rather than the config pinned: `--porcelain=v1 -z` frames every record
# with NUL and cannot be reconfigured into ambiguity by the repo under inspection.
STATUS_PATH_DELIMITERS = frozenset(
    {"\t"}
    | {chr(code) for code in range(0x11000) if len(f"a{chr(code)}b".splitlines()) > 1}
    | {chr(code) for code in range(0x00, 0x20)}
    | {chr(0x7F)}
    | {chr(code) for code in range(0x80, 0xA0)}
)


def escape_status_path(path: str) -> str:
    """Render a pathname safe to interpolate into an entry string a consumer may re-split.

    The entries below travel into envelopes and across the delivery-status process boundary as
    plain strings. A path that still carries a raw separator would fabricate a record for the NEXT
    parser even though NUL framing protected this one, so the boundary characters are escaped once,
    here, at the point the bytes become a string.
    """
    return "".join(f"\\x{ord(char):02x}" if char in STATUS_PATH_DELIMITERS else char for char in path)


def parse_porcelain_z(raw: bytes) -> list[tuple[str, list[str]]]:
    """NUL-framed `status --porcelain=v1 -z` → [(xy, [paths])].

    `-z` never quotes, so nothing is unquoted here; a rename/copy record spends a second NUL field
    on its source path, which is the only reason the fields cannot be walked one-to-one.
    """
    fields = [field for field in raw.split(b"\0")]
    if fields and fields[-1] == b"":
        fields.pop()
    records: list[tuple[str, list[str]]] = []
    index = 0
    while index < len(fields):
        field = fields[index].decode("utf-8", errors="replace")
        index += 1
        if len(field) < 4 or field[2] != " ":
            continue
        xy, destination = field[:2], field[3:]
        if xy[0:1] in {"R", "C"} and index < len(fields):
            source = fields[index].decode("utf-8", errors="replace")
            index += 1
            records.append((xy, [source, destination]))
            continue
        records.append((xy, [destination]))
    return records


def git_status_records(repo: Path, *extra: str) -> tuple[int, list[tuple[str, list[str]]], str]:
    rc, raw, err = git_observation_raw(repo, "status", "--porcelain=v1", "-z", *extra)
    if rc != 0:
        return rc, [], err
    return rc, parse_porcelain_z(raw), err


def status_record_entry(xy: str, paths: list[str]) -> str:
    """The porcelain-shaped display string for a record, with every path boundary-escaped."""
    return f"{xy} " + " -> ".join(escape_status_path(path) for path in paths)


def status_records_text(records: list[tuple[str, list[str]]]) -> str:
    return "\n".join(status_record_entry(xy, paths) for xy, paths in records)


def safe_git_env(extra: dict[str, str] | None = None, *, allow_gh_repo: bool = False) -> dict[str, str]:
    allowed = {"HOME", "TMPDIR", "TMP", "TEMP", "LANG", "LC_ALL", "LC_CTYPE", "USER", "LOGNAME", "TERM", "NO_COLOR", "SSH_AUTH_SOCK"}
    env = {key: value for key, value in os.environ.items() if key in allowed or key.startswith("LC_")}
    # /opt/homebrew/bin is gone from here deliberately. This PATH is the one a credential-bearing
    # git/gh child searches, and git resolves its own subcommands, credential helpers and ssh
    # through it. /usr/bin winning the race for names that exist in both is not a defence: any name
    # /usr/bin lacks — git-credential-*, for one — resolves straight into a uid=501 drwxrwxr-x
    # directory. /usr/local/bin stays: root-owned 0755, and where the trusted gh lives.
    env["PATH"] = "/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin"
    if extra:
        for key, value in extra.items():
            # ENV_DENIED_FOR_TRUSTED_DISPATCH is enforced on `extra` too: os.environ can't reach
            # DEVELOPER_DIR (it isn't in `allowed`), but a caller passing it here would have
            # redirected the CLT shim straight out of the ancestry walk's blind spot.
            if key in ENV_DENIED_FOR_TRUSTED_DISPATCH:
                continue
            if key in {"BASH_ENV", "ENV", "ZDOTDIR", "PYTHONPATH", "PYTHONHOME", "GH_HOST"}:
                continue
            if key == "GH_REPO":
                if allow_gh_repo and isinstance(value, str) and re.fullmatch(r"[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+", value):
                    env[key] = value
                continue
            if key == "GIT_CONFIG_NOSYSTEM" and value == "1":
                env[key] = value
            elif key == "GIT_CONFIG_GLOBAL" and value == os.devnull:
                env[key] = value
            elif key == "GIT_ALTERNATE_OBJECT_DIRECTORIES" and isinstance(value, str) and os.path.isabs(value):
                env[key] = value
            elif not key.startswith("GIT_"):
                env[key] = value
    return env


def safe_git_mutation_env(extra: dict[str, str] | None = None) -> dict[str, str]:
    env = safe_git_env(extra)
    env["GIT_CONFIG_GLOBAL"] = os.devnull
    env["GIT_CONFIG_NOSYSTEM"] = "1"
    env["GIT_TERMINAL_PROMPT"] = "0"
    return env


def current_branch(repo: Path) -> str | None:
    rc, out, _err = git_output(repo, "branch", "--show-current")
    return out if rc == 0 and out else None


def live_remote_head(repo: Path, branch: str) -> tuple[str | None, str | None]:
    remote_rc, remote, _remote_err = git_output(repo, "config", f"branch.{branch}.remote")
    merge_rc, merge_ref, _merge_err = git_output(repo, "config", f"branch.{branch}.merge")
    if remote_rc != 0 or merge_rc != 0 or not remote or not merge_ref:
        return None, "upstream_config_missing"
    try:
        cp = _bounded_run(
            [str(trusted_executable_path("git")), "-C", str(repo), "ls-remote", "--heads", remote, merge_ref],
            text=True,
            check=False,
            timeout=30,
            env=safe_git_env(),
        )
    except subprocess.TimeoutExpired:
        return None, "remote_head_lookup_timeout"
    except (OSError, RuntimeError):
        return None, "remote_head_lookup_failed"
    if cp.returncode != 0:
        return None, "remote_head_lookup_failed"
    matches: list[str] = []
    for line in cp.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[1] == merge_ref:
            matches.append(parts[0])
    if len(matches) != 1:
        return None, "remote_head_lookup_ambiguous"
    return matches[0], None


def repo_clean(repo: Path) -> bool:
    rc, records, _err = git_status_records(repo, "--untracked-files=all")
    return rc == 0 and not records


def repo_status_lines(repo: Path) -> tuple[int, list[str]]:
    rc, records, _err = git_status_records(repo, "--untracked-files=all")
    return rc, [status_record_entry(xy, paths) for xy, paths in records]


BUSDRIVER_MARKER_FILES = {
    "freeze.local",
    "careful.local",
    "design-review-needed.local.md",
    "skip-litmus.local",
    "litmus-passed.local",
    "pr-codex-lead.local.json",
    "pr-backstop-verdict.local.json",
    "pr-review-passed.local",
    "pr-grind-clean.local",
}


def allowed_marker_paths(state_dir_names: tuple[str, ...] | list[str] | set[str]) -> set[str]:
    paths: set[str] = set()
    for state_dir in state_dir_names:
        marker_dir = str(state_dir).strip("/")
        if not marker_dir:
            continue
        paths.update(f"{marker_dir}/{name}" for name in BUSDRIVER_MARKER_FILES)
    return paths


def marker_dirty_status_allowed(xy: str) -> bool:
    if xy == "??":
        return True
    return xy == " M"


def marker_file_fingerprint(repo: Path, path: str) -> str:
    target = repo / path
    try:
        st = target.lstat()
    except FileNotFoundError:
        return "<missing>"
    except OSError:
        return "<stat-error>"
    mode = st.st_mode
    if stat.S_ISLNK(mode):
        try:
            link_target = os.readlink(target)
        except OSError:
            link_target = "<readlink-error>"
        return "<symlink>:" + hashlib.sha256(link_target.encode(errors="replace")).hexdigest()
    if not stat.S_ISREG(mode):
        return f"<non-regular:{stat.S_IFMT(mode):o}>"
    if st.st_size > MARKER_FINGERPRINT_MAX_BYTES:
        return f"<too-large:{st.st_size}>"
    fd: int | None = None
    try:
        flags = os.O_RDONLY
        if hasattr(os, "O_NOFOLLOW"):
            flags |= os.O_NOFOLLOW
        fd = os.open(target, flags)
        opened = os.fstat(fd)
        if not stat.S_ISREG(opened.st_mode):
            return f"<non-regular:{stat.S_IFMT(opened.st_mode):o}>"
        if (opened.st_dev, opened.st_ino) != (st.st_dev, st.st_ino):
            return "<read-error>"
        if opened.st_size != st.st_size:
            return "<read-error>"
        h = hashlib.sha256()
        with os.fdopen(fd, "rb") as fh:
            fd = None
            while True:
                chunk = fh.read(1024 * 1024)
                if not chunk:
                    break
                h.update(chunk)
        return h.hexdigest()
    except OSError:
        return "<read-error>"
    finally:
        if fd is not None:
            try:
                os.close(fd)
            except OSError:
                pass


def untracked_file_identity(repo: Path, path: str) -> str:
    target = repo / path
    try:
        st = target.lstat()
    except FileNotFoundError:
        return "<missing>"
    except OSError:
        return "<stat-error>"
    mode = st.st_mode
    if stat.S_ISLNK(mode):
        try:
            link_target = os.readlink(target)
        except OSError:
            link_target = "<readlink-error>"
        return "symlink:" + hashlib.sha256(link_target.encode(errors="replace")).hexdigest()
    return ":".join(
        (
            f"mode:{stat.S_IFMT(mode):o}:{mode & 0o7777:o}",
            f"dev:{st.st_dev}",
            f"ino:{st.st_ino}",
            f"size:{st.st_size}",
            f"mtime:{getattr(st, 'st_mtime_ns', int(st.st_mtime * 1_000_000_000))}",
            f"ctime:{getattr(st, 'st_ctime_ns', int(st.st_ctime * 1_000_000_000))}",
        )
    )


def marker_fingerprint_valid(fingerprint: str) -> bool:
    return not (
        fingerprint.startswith("<too-large:")
        or fingerprint.startswith("<symlink>:")
        or fingerprint.startswith("<non-regular:")
        or fingerprint in {"<missing>", "<read-error>", "<stat-error>"}
    )


def untracked_fingerprint_valid(fingerprint: str) -> bool:
    return not (
        fingerprint.startswith("<too-large:")
        or fingerprint.startswith("<non-regular:")
        or fingerprint in {"<read-error>", "<stat-error>"}
    )


def marker_evidence_snapshot_from_status(repo: Path, records: list[tuple[str, list[str]]], allowed_paths: set[str]) -> dict[str, dict[str, str]]:
    """Marker evidence from NUL-framed records, never from a re-split of status text.

    Records, not text: a snapshot keyed off `splitlines()` accepted a marker record that no file
    produced (see STATUS_PATH_DELIMITERS), which is precisely the evidence this snapshot exists to
    make tamper-evident.
    """
    snapshot: dict[str, dict[str, str]] = {}
    for xy, record_paths in records:
        paths = [path.rstrip("/") for path in record_paths]
        if len(paths) == 1 and paths[0] in allowed_paths and marker_dirty_status_allowed(xy):
            fingerprint = marker_file_fingerprint(repo, paths[0])
            if marker_fingerprint_valid(fingerprint):
                snapshot[paths[0]] = {"xy": xy, "fingerprint": fingerprint}
    return snapshot


def blocking_dirty_entries(status_lines: list[str], allowed_paths: set[str]) -> list[str]:
    blocked: list[str] = []
    for entry in status_lines:
        paths = [path.rstrip("/") for path in porcelain_entry_paths(entry)]
        xy = entry[:2] if len(entry) >= 2 else ""
        marker_evidence_only = len(paths) == 1 and paths[0] in allowed_paths and marker_dirty_status_allowed(xy)
        if not marker_evidence_only:
            blocked.append(entry)
    return blocked


def repo_blocking_dirty_entries(repo: Path, state_dir_names: tuple[str, ...] | list[str] | set[str]) -> list[str]:
    rc, status_lines = repo_status_lines(repo)
    if rc != 0:
        return ["<git status failed>"]
    return blocking_dirty_entries(status_lines, allowed_marker_paths(state_dir_names))


def staged_changes_status(repo: Path) -> tuple[bool, str | None]:
    rc, _raw, _error = git_observation_raw(
        repo,
        "diff",
        "--no-ext-diff",
        "--no-textconv",
        "--no-color",
        "--cached",
        "--quiet",
    )
    if rc == 1:
        return True, None
    if rc == 0:
        return False, None
    return False, "staged_diff_status_failed"


def staged_changes_present(repo: Path) -> bool:
    present, _reason = staged_changes_status(repo)
    return present


def branch_ahead_count(repo: Path) -> int | None:
    branch = current_branch(repo)
    if not branch:
        return None
    rc, upstream, _err = git_output(repo, "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}")
    if rc != 0 or not upstream:
        return None
    rc, out, _err = git_output(repo, "rev-list", "--count", f"{upstream}..HEAD")
    if rc != 0 or not out.isdigit():
        return None
    return int(out)


def litmus_decision_status(delivery_status: dict[str, Any]) -> str | None:
    status, blocker = litmus_validation_status(delivery_status)
    return None if blocker else status


def delivery_status_unstaged_or_untracked_entries(delivery_status: dict[str, Any]) -> list[str]:
    repo = delivery_status.get("repo") if isinstance(delivery_status.get("repo"), dict) else {}
    entries: list[str] = []
    for key in ("unstaged_entries", "untracked_entries"):
        value = repo.get(key)
        if isinstance(value, list):
            entries.extend(str(item) for item in value if isinstance(item, str))
        if repo.get(f"{key}_truncated") is True:
            # delivery-status bounds these lists, so what is absent from one is not thereby absent
            # from the worktree. This value decides whether a commit or push may proceed; reading
            # a cut-off tail as "nothing blocking" would fail open on exactly the biggest, dirtiest
            # repos. An entry nobody can name still blocks.
            entries.append(f"<{key}_truncated_total_{repo.get(f'{key}_total_count')}>")
    return entries


def decode_porcelain_path(path: str) -> str:
    """A `-z` path is already the pathname. The only thing to drop is the untracked-dir slash.

    There is deliberately no un-quoting here. Quoting is what `--porcelain=v1` does WITHOUT `-z`;
    both status producers now pass `-z`, which frames with NUL and never quotes. So a leading and
    trailing `"` no longer means "git quoted this" — it means the file is literally named with
    quote characters, and decoding them rewrites a hostile path into some other path. r26 found
    the reachable case: a directory named `".claude` holding `freeze.local"` decodes straight onto
    the allow-listed marker path and stops blocking_dirty_entries from blocking it.
    """
    return path.rstrip("/")


def split_porcelain_rename_payload(payload: str) -> tuple[str, str] | None:
    """Split `old -> new`, the shape status_record_entry emits for a rename/copy.

    Quote-aware splitting went with the un-quoting above, for the same reason: `-z` producers emit
    no quotes. A pathname that itself contains ` -> ` is ambiguous in this display form and splits
    at the last one — which yields a path matching no allowlist entry, so it blocks. Wrong name in
    the message, right decision.
    """
    if " -> " in payload:
        return payload.rsplit(" -> ", 1)
    return None


def porcelain_entry_paths(entry: str) -> list[str]:
    value = str(entry)
    if len(value) >= 4 and value[2] == " ":
        payload = value[3:]
    else:
        parts = value.strip().split(maxsplit=1)
        payload = parts[-1] if parts else value.strip()
    xy = value[:2] if len(value) >= 2 else ""
    if xy[0:1] in {"R", "C"}:
        split_payload = split_porcelain_rename_payload(payload)
        if split_payload is not None:
            old_path, new_path = split_payload
            return [decode_porcelain_path(old_path), decode_porcelain_path(new_path)]
    return [decode_porcelain_path(payload)]


def porcelain_entry_path(entry: str) -> str:
    paths = porcelain_entry_paths(entry)
    return paths[-1] if paths else str(entry).strip()


def commit_blocking_dirty_entries(delivery_status: dict[str, Any], args: argparse.Namespace) -> list[str]:
    return blocking_dirty_entries(
        delivery_status_unstaged_or_untracked_entries(delivery_status),
        allowed_marker_paths(busdriver_marker_state_dirs(args)),
    )


def staged_marker_entries(repo: Path, state_dir_names: tuple[str, ...] | list[str] | set[str]) -> list[str]:
    allowed_paths = allowed_marker_paths(state_dir_names)
    if not allowed_paths:
        return []
    rc, raw, _stderr = git_observation_raw(
        repo, "diff", "--cached", "--no-renames", "--name-only", "-z",
    )
    if rc != 0:
        return ["<staged marker check failed>"]
    staged_paths = [part.decode("utf-8", errors="replace").rstrip("/") for part in raw.split(b"\0") if part]
    return [path for path in staged_paths if path in allowed_paths]


def run_lock_helper(cmd: list[str], program: bytes, timeout: int = 30) -> tuple[dict[str, Any], dict[str, Any]]:
    started = time.time()
    try:
        cp = _bounded_run(cmd, input=program, cwd=str(ROOT), shell=False, text=False, check=False, timeout=timeout, env=safe_git_env())
        result = {
            "cmd": cmd,
            "returncode": cp.returncode,
            "ok": cp.returncode == 0,
            "stdout_tail": tail(cp.stdout),
            "stderr_tail": tail(cp.stderr),
            "elapsed_seconds": round(time.time() - started, 3),
        }
        try:
            payload = json.loads(cp.stdout or b"{}")
        except (json.JSONDecodeError, UnicodeDecodeError):
            payload = {"parse_error": "invalid_json"}
        return payload if isinstance(payload, dict) else {"parse_error": "non_object_json"}, result
    except subprocess.TimeoutExpired as e:
        result = {
            "cmd": cmd,
            "returncode": 124,
            "ok": False,
            "stdout_tail": tail(e.stdout),
            "stderr_tail": tail(e.stderr),
            "elapsed_seconds": round(time.time() - started, 3),
            "error": "timeout",
        }
        return {"parse_error": "timeout"}, result
    except (OSError, RuntimeError) as e:
        result = {"cmd": cmd, "returncode": 127, "ok": False, "stdout_tail": "", "stderr_tail": tail(str(e)), "error": type(e).__name__}
        return {"parse_error": type(e).__name__}, result


_RETAINED_LOCK_BYTES: bytes | None = None
LOCK_SOURCE_MAX_BYTES = 1 << 20


def _stat_identity(st: os.stat_result) -> tuple[int, ...]:
    return (st.st_dev, st.st_ino, st.st_mode, st.st_uid, st.st_gid, st.st_nlink, st.st_size, st.st_mtime_ns, st.st_ctime_ns)


def authenticated_lock_bytes(source: Path) -> bytes:
    """Read the lock helper once and prove the bytes read are the reviewed bytes.

    Everything here exists because the attacker shares our UID. `commit` and `push` run repository
    hooks, and a hook is free to unlink and replace any pathname we own — including one inside a
    0o700 temp directory, whose mode stops other users and not its owner. So a pathname can never
    be authenticated once and executed later; only bytes already in memory can.

    Identity is therefore pinned to an open fd, not to a name: O_NOFOLLOW refuses a symlinked
    source, the fstat pair brackets the read so a swap mid-read cannot pass, and the lstat compares
    the name back to the fd so a source replaced between validation and use is caught rather than
    silently trusted.
    """
    try:
        fd = os.open(source, os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0))
    except OSError as exc:
        # O_NOFOLLOW refuses a symlinked source with ELOOP; report that as the metadata rejection
        # it is rather than as the source being absent, which is a different operator problem.
        if exc.errno in {errno.ELOOP, errno.EMLINK}:
            raise OSError("trusted_lock_source_metadata_invalid") from exc
        raise OSError("trusted_lock_source_unavailable") from exc
    try:
        pre = os.fstat(fd)
        chunks: list[bytes] = []
        size = 0
        while True:
            chunk = os.read(fd, 1 << 16)
            if not chunk:
                break
            size += len(chunk)
            if size > LOCK_SOURCE_MAX_BYTES:
                raise OSError("trusted_lock_source_too_large")
            chunks.append(chunk)
        post = os.fstat(fd)
    finally:
        os.close(fd)
    if _stat_identity(pre) != _stat_identity(post):
        raise OSError("trusted_lock_source_mutated_during_read")
    if (
        not stat.S_ISREG(pre.st_mode)
        or pre.st_uid != os.getuid()
        or pre.st_nlink != 1
        or stat.S_IMODE(pre.st_mode) & 0o022
    ):
        raise OSError("trusted_lock_source_metadata_invalid")
    link = os.lstat(source)
    if (link.st_dev, link.st_ino) != (pre.st_dev, pre.st_ino):
        raise OSError("trusted_lock_source_path_replaced")
    data = b"".join(chunks)
    if hashlib.sha256(data).hexdigest() != TRUSTED_LOCK_SHA256:
        raise OSError("trusted_lock_integrity_failed")
    return data


def retained_lock_bytes() -> bytes:
    """The authenticated helper bytes, read before any untrusted git operation and kept in memory.

    Cached deliberately: acquire happens before the hooks run, release after. Re-reading the source
    at release would hand the window back to the attacker this retention closes.
    """
    global _RETAINED_LOCK_BYTES
    if _RETAINED_LOCK_BYTES is None:
        _RETAINED_LOCK_BYTES = authenticated_lock_bytes(LOCK_SOURCE)
    return _RETAINED_LOCK_BYTES


def lock_helper_argv(action: str, repo: Path, *extra: str) -> list[str]:
    """`-` reads the program from stdin: an fd we wrote, with no pathname to race."""
    try:
        python3 = trusted_executable_path("python3")
    except RuntimeError as exc:
        raise OSError("trusted_lock_python_unavailable") from exc
    return [str(python3), "-I", "-", action, "--repo", str(repo), "--operation", "finalization", *extra]


def acquire_finalization_lock(repo: Path, state_dir: str | None = None) -> dict[str, Any]:
    try:
        program = retained_lock_bytes()
    except OSError as exc:
        return {"acquired": False, "reason": str(exc)}
    try:
        cmd = lock_helper_argv("acquire", repo, "--ttl-seconds", str(6 * 60 * 60))
        if state_dir:
            cmd += ["--state-dir", state_dir]
        payload, result = run_lock_helper(cmd, program)
    except (OSError, RuntimeError) as exc:
        return {"acquired": False, "reason": "finalization_lock_helper_unavailable", "error": str(exc)}
    if "parse_error" in payload:
        payload = {"acquired": False, **payload}
    payload["command"] = result
    return payload


def release_finalization_lock(repo: Path, token: str, state_dir: str | None = None, lock_path: str = "") -> dict[str, Any]:
    """Release the finalization lock. This function must NEVER raise.

    It is called from an unguarded outer `finally`, so an escaping exception does not merely lose
    the release result — it REPLACES the already-computed result of a commit or push that really
    happened, before `last_release` and `release_failure_reconciliation()` are ever consulted. The
    operator is then shown a traceback and no record of the mutation, which is the one outcome
    worse than a stuck lock. Every failure is therefore returned as a truthful payload the caller
    reconciles into a `*_release_failed` status.

    r24 guarded only `rmdir()`: `run_lock_helper()` and `helper.unlink()` both sat outside it.
    r25 then executed a materialized PATHNAME here, which a git hook could replace between acquire
    and release; the retained bytes it now runs cannot be swapped, and nothing is left to clean up.
    """
    if not lock_path:
        return {"released": False, "reason": "lock-identity-missing"}
    try:
        program = retained_lock_bytes()
    except OSError as exc:
        return {"released": False, "reason": "finalization_lock_release_helper_unavailable", "error": str(exc)}
    try:
        cmd = lock_helper_argv("release", repo, "--token", token, "--lock-path", lock_path)
        if state_dir:
            cmd += ["--state-dir", state_dir]
        payload, result = run_lock_helper(cmd, program)
        if "parse_error" in payload:
            payload = {"released": False, **payload}
        payload["command"] = result
    except Exception as exc:  # noqa: BLE001 - see docstring: escaping here erases a real mutation
        payload = {
            "released": False,
            "reason": "finalization_lock_release_helper_failed",
            "error": tail(f"{type(exc).__name__}: {exc}", 512),
        }
    return payload


release_finalization_lock.supports_lock_identity = True  # type: ignore[attr-defined]

RELEASE_REDACTION_FALLBACK = {
    "released": False,
    "reason": "finalization_lock_release_failed",
    "error": "release_payload_redaction_failed",
}


def safe_release_error(exc: BaseException) -> str:
    """Describe a release failure without being able to fail describing it.

    `tail()` redacts, and redaction is the thing that may have just raised MemoryError. The class
    name alone is a fixed-size string built from an already-live object, so the fallback cannot
    re-enter the failure it is reporting.
    """
    try:
        return tail(f"{type(exc).__name__}: {exc}", 512)
    except BaseException:  # noqa: BLE001 - a description must never outrank the mutation truth
        try:
            return type(exc).__name__
        except BaseException:  # noqa: BLE001
            return "release_error_undescribable"


def finalization_state_dir(args: argparse.Namespace) -> str | None:
    return getattr(args, "state_dir", None)


def busdriver_marker_state_dir(args: argparse.Namespace) -> str:
    return getattr(args, "busdriver_state_dir_name", None) or ".claude"


def busdriver_marker_state_dirs(args: argparse.Namespace) -> tuple[str, ...]:
    names = [*DEFAULT_BUSDRIVER_MARKER_STATE_DIRS, busdriver_marker_state_dir(args)]
    return tuple(dict.fromkeys(name for name in names if isinstance(name, str) and name))


def marker_state_dir_safety(repo: Path, state_dir_name: str) -> tuple[bool, str | None]:
    marker_dir = str(state_dir_name)
    marker_path = Path(marker_dir)
    if not marker_dir or marker_path.is_absolute() or any(part in {"", ".", ".."} for part in marker_path.parts):
        return False, "busdriver_state_dir_name_unsafe"
    repo_root = repo.resolve()
    current = repo_root
    for part in marker_path.parts:
        current = current / part
        try:
            if current.is_symlink():
                return False, "busdriver_state_dir_symlink_unsafe"
            if current.exists():
                current.resolve().relative_to(repo_root)
        except (OSError, ValueError, AttributeError):
            return False, "busdriver_state_dir_unsafe"
    return True, None


def mutating_authority(operation: str, allowed: bool, reason: str, sources: list[str] | None = None) -> dict[str, Any]:
    flags = {key: False for key in BLOCKED_FLAGS}
    if allowed:
        flags["finalization_allowed"] = True
        if operation == "commit":
            flags["commit_allowed"] = True
        elif operation == "push":
            flags["push_allowed"] = True
        elif operation == "pr-create":
            flags["pr_allowed"] = True
        elif operation == "merge":
            flags["merge_allowed"] = True
        elif operation == "pre-pr-review":
            # Hermes is not a raw trusted marker writer. This operation may only
            # invoke Busdriver-owned writer commands and records that distinction.
            flags["marker_write_allowed"] = False

    return {
        "schema": FINALIZATION_AUTHORITY_SCHEMA,
        "version": 0,
        "operation": operation,
        "allowed": allowed,
        "reason": reason,
        "sources": sources or [],
        **flags,
        "trusted_marker_writer": "busdriver_script_only" if operation == "pre-pr-review" else None,
    }


def legacy_decision_for_mutation(status: str, reason: str) -> dict[str, Any]:
    # Keep the legacy v0 decision default-deny so existing status lookup cannot
    # mistake a completed side-effect artifact for reusable standing authority.
    return {"status": status, "reason": reason, **BLOCKED_FLAGS}


def mutating_run_envelope(args: argparse.Namespace, operation: str, status: str, reason: str, repo: Path | None, authority: dict[str, Any], side_effects: list[dict[str, Any]], lock: dict[str, Any] | None, release: dict[str, Any] | None, extra: dict[str, Any] | None = None) -> dict[str, Any]:
    success_statuses = {"pre_pr_review_complete", "committed", "pushed", "pr_created", "merged", "already_up_to_date"}
    release_tracked_statuses = success_statuses | {"commit_outcome_unknown"}
    release_placeholder = getattr(args, "_lock_release_placeholder", None) if status in release_tracked_statuses else None
    release_value: Any = release if release is not None else release_placeholder
    return {
        "schema": MUTATING_RUN_SCHEMA,
        "version": 0,
        "run_id": args.run_id or new_run_id(),
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "operation": operation,
        "status": status,
        "reason": reason,
        "repo_root": str(repo) if repo else None,
        "pr_number": args.pr,
        "authority": authority,
        "lock_acquire": redact_value(lock),
        "lock_release": release_value if release_value is release_placeholder else redact_value(release_value),
        "side_effects": redact_value(side_effects),
        **(extra or {}),
    }


# Every status meaning "the operation finished; releasing the finalization lock afterwards did
# not". The operation itself passed in all of them, so `steps_for` reads this rather than trying
# to infer completion from the release-failure reason, which is the same for every one.
_RELEASE_FAILED_STATUSES = {
    "pre_pr_review_complete_release_failed",
    "committed_release_failed",
    "pushed_release_failed",
    "pr_created_release_failed",
    "merged_release_failed",
    "already_up_to_date_release_failed",
}


def side_effect_completed_release_failed_status(operation: str, effects: list[dict[str, Any]]) -> str:
    completed = {
        "pre-pr-review": ("busdriver_write_pr_marker", "pre_pr_review_complete_release_failed"),
        "commit": ("git_commit", "committed_release_failed"),
        "push": ("git_push", "pushed_release_failed"),
        "pr-create": ("gh_pr_create", "pr_created_release_failed"),
        "merge": ("gh_pr_merge", "merged_release_failed"),
    }
    expected = completed.get(operation)
    if expected:
        effect_name, status = expected
        if any(effect.get("name") == effect_name and effect.get("ok") is True for effect in effects):
            return status
    return "finalization_lock_release_failed"


def release_failure_reconciliation(operation: str, mutating_run: dict[str, Any] | None, release: Any) -> tuple[dict[str, Any], list[dict[str, str]], int] | None:
    if mutating_run is None or not isinstance(release, dict) or release.get("released") is True:
        return None
    if mutating_run.get("status") == "commit_outcome_unknown":
        status = "commit_outcome_unknown_release_failed"
        reason = _COMMIT_OUTCOME_UNKNOWN_RELEASE_REASON
        mutating_run["status"] = status
        mutating_run["reason"] = reason
        mutating_run["authority"] = mutating_authority(operation, False, reason)
        return legacy_decision_for_mutation(status, reason), steps_for(reason, operation, status), 2
    if mutating_run.get("status") not in {"pre_pr_review_complete", "committed", "pushed", "pr_created", "merged", "already_up_to_date"}:
        return None
    if mutating_run.get("status") == "already_up_to_date":
        reason = "finalization_lock_release_failed"
        mutating_run["status"] = "already_up_to_date_release_failed"
        mutating_run["reason"] = reason
        mutating_run["authority"] = mutating_authority(operation, False, reason)
        return legacy_decision_for_mutation("already_up_to_date_release_failed", reason), steps_for(reason, operation, "already_up_to_date_release_failed"), 2
    side_effects = mutating_run.get("side_effects") if isinstance(mutating_run.get("side_effects"), list) else []
    release_status = side_effect_completed_release_failed_status(operation, side_effects)
    if release_status == "finalization_lock_release_failed":
        release_status = {
            "pre-pr-review": "pre_pr_review_complete_release_failed",
            "commit": "committed_release_failed",
            "push": "pushed_release_failed",
            "pr-create": "pr_created_release_failed",
            "merge": "merged_release_failed",
        }.get(operation, release_status)
    if release_status == "finalization_lock_release_failed":
        return None
    reason = "finalization_lock_release_failed"
    mutating_run["status"] = release_status
    mutating_run["reason"] = reason
    mutating_run["authority"] = mutating_authority(operation, False, reason)
    return legacy_decision_for_mutation(release_status, reason), steps_for(reason, operation, release_status), 2


def run_busdriver_pre_pr_review(repo: Path, args: argparse.Namespace) -> tuple[dict[str, Any], int]:
    # The pinned Busdriver helper still shells out to Git/Codex and cannot yet be
    # given a config-free Git runtime plus a minimal isolated model credential
    # store. Do not execute it with the user's HOME or SSH agent.
    return {"ok": False, "reason": "isolated_review_runtime_unavailable", "side_effects": []}, 2

    effects: list[dict[str, Any]] = []
    if not args.plugin_root:
        return {"ok": False, "reason": "plugin_root_required"}, 2
    plugin = Path(args.plugin_root).expanduser().resolve()
    marker_state_dir = busdriver_marker_state_dir(args)
    state_dir_safe, state_dir_reason = marker_state_dir_safety(repo, marker_state_dir)
    if not state_dir_safe:
        return {"ok": False, "reason": state_dir_reason or "busdriver_state_dir_unsafe", "side_effects": effects}, 2
    plugin_safe, plugin_reason = busdriver_plugin_root_safety(plugin)
    if not plugin_safe:
        return {"ok": False, "reason": plugin_reason or "plugin_root_untrusted", "side_effects": effects}, 2
    snapshot_guard = tempfile.TemporaryDirectory(prefix="hermes-busdriver-authenticated-plugin-")
    authenticated_plugin = Path(snapshot_guard.name) / "busdriver"
    if not materialize_authenticated_busdriver_snapshot(plugin, authenticated_plugin):
        return {"ok": False, "reason": "plugin_snapshot_authentication_failed", "side_effects": effects}, 2
    init = authenticated_plugin / "skills" / "litmus" / "scripts" / "init-review-loop.sh"
    loop = authenticated_plugin / "skills" / "litmus" / "scripts" / "run-review-loop.sh"
    if not init.exists() or not loop.exists():
        return {"ok": False, "reason": "busdriver_litmus_scripts_missing", "init": str(init), "loop": str(loop)}, 2
    env_extra = {"LITMUS_MODE": "pr", "BUSDRIVER_PLUGIN_ROOT": str(authenticated_plugin), "CLAUDE_PLUGIN_ROOT": str(authenticated_plugin), "BUSDRIVER_STATE_DIR": marker_state_dir}
    litmus_base_ref = requested_litmus_base_ref(args)
    if litmus_base_ref:
        env_extra["LITMUS_PR_BASE"] = litmus_base_ref
    env = safe_git_env(env_extra)
    verdict, verdict_error = read_backstop_verdict_file(repo, args.backstop_verdict_file)
    if verdict_error:
        return {"ok": False, "reason": verdict_error, "side_effects": effects}, 2
    verdict_ok, verdict_reason, verdict_summary = validate_backstop_verdict_text(repo, verdict or "", args.base, busdriver_marker_state_dirs(args))
    effects.append({"name": "validate_backstop_verdict", "ok": verdict_ok, "reason": verdict_reason, "summary": verdict_summary})
    if not verdict_ok:
        return {"ok": False, "reason": verdict_reason, "side_effects": effects}, 2
    first = run_safe(["/bin/bash", str(init)], repo, timeout=max(args.verifier_timeout, 180), env=env)
    effects.append({"name": "busdriver_init_review_loop", **first})
    if not first.get("ok"):
        return {"ok": False, "reason": "busdriver_init_review_loop_failed", "side_effects": effects}, int(first.get("returncode") or 1)
    second = run_safe(["/bin/bash", str(loop)], repo, timeout=max(args.verifier_timeout, 1200), env=env)
    effects.append({"name": "busdriver_codex_lead", **second})
    if not second.get("ok"):
        return {"ok": False, "reason": "busdriver_codex_lead_failed", "side_effects": effects}, int(second.get("returncode") or 1)
    verdict, verdict_error = read_backstop_verdict_file(repo, args.backstop_verdict_file)
    if verdict_error:
        effects.append({"name": "revalidate_backstop_verdict", "ok": False, "reason": verdict_error})
        return {"ok": False, "reason": verdict_error, "side_effects": effects}, 2
    verdict_ok, verdict_reason, verdict_summary = validate_backstop_verdict_text(repo, verdict or "", args.base, busdriver_marker_state_dirs(args))
    effects.append({"name": "revalidate_backstop_verdict", "ok": verdict_ok, "reason": verdict_reason, "summary": verdict_summary})
    if not verdict_ok:
        return {"ok": False, "reason": verdict_reason, "side_effects": effects}, 2
    try:
        writer_verdict = busdriver_backstop_writer_payload(verdict, verdict_summary)
    except (TypeError, ValueError, json.JSONDecodeError) as e:
        effects.append({"name": "busdriver_backstop_writer_payload", "ok": False, "error": type(e).__name__})
        return {"ok": False, "reason": "backstop_verdict_writer_payload_invalid", "side_effects": effects}, 2
    write_backstop = run_safe(["/bin/bash", str(loop), "--write-backstop-verdict"], repo, timeout=180, env=env, input_text=writer_verdict)
    effects.append({"name": "busdriver_write_backstop_verdict", **write_backstop})
    if not write_backstop.get("ok"):
        return {"ok": False, "reason": "busdriver_write_backstop_verdict_failed", "side_effects": effects}, int(write_backstop.get("returncode") or 1)
    marker = run_safe(["/bin/bash", str(loop), "--write-pr-marker"], repo, timeout=180, env=env)
    effects.append({"name": "busdriver_write_pr_marker", **marker})
    if not marker.get("ok"):
        return {"ok": False, "reason": "busdriver_write_pr_marker_failed", "side_effects": effects}, int(marker.get("returncode") or 1)
    return {"ok": True, "reason": "busdriver_pre_pr_review_marker_written", "side_effects": effects}, 0


def execute_mutating_operation(args: argparse.Namespace, delivery_status: dict[str, Any]) -> tuple[dict[str, Any], int]:
    operation = args.operation
    repo = repo_root_from_status(delivery_status)
    effects: list[dict[str, Any]] = []
    execute_mutating_operation.last_release = None  # type: ignore[attr-defined]
    lock_payload: dict[str, Any] | None = None
    release_payload: dict[str, Any] | None = None
    release_placeholder: dict[str, Any] = {"released": False, "reason": "finalization_lock_not_released"}
    setattr(args, "_lock_release_placeholder", release_placeholder)
    token = ""
    lock_state_dir: str | None = None
    lock_state_dir_initialized = False
    authority_sources = ["explicit_user_request", "delivery_status_ok", "finalization_lock", "fresh_busdriver_equivalent_evidence"]
    if repo is None:
        reason = "repo_unavailable"
        authority = mutating_authority(operation, False, reason)
        result_decision = legacy_decision_for_mutation("blocked", reason)
        mut_run = mutating_run_envelope(args, operation, "blocked", reason, None, authority, effects, None, None)
        return {"ok": False, "decision": result_decision, "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
    requested_repo = Path(args.repo).expanduser().resolve() if getattr(args, "repo", None) else None
    if requested_repo is not None and repo != requested_repo:
        reason = "delivery_status_repo_mismatch"
        authority = mutating_authority(operation, False, reason)
        mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, None, None, {"requested_repo": str(requested_repo), "delivery_status_repo": str(repo)})
        return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
    expected_repository = getattr(args, "expected_repository", None)
    if expected_repository and github_repo_slug(repo, "origin") != expected_repository:
        reason = "expected_repository_mismatch"
        authority = mutating_authority(operation, False, reason)
        mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, None, None, {"expected_repository": expected_repository})
        return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
    if operation == "commit" and not args.commit_message:
        reason = "commit_message_required"
        authority = mutating_authority(operation, False, reason)
        mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, None, None)
        return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
    try:
        lock_state_dir = finalization_state_dir(args)
        lock_state_dir_initialized = True
        lock_payload = acquire_finalization_lock(repo, lock_state_dir)
        if not lock_payload.get("acquired"):
            reason = "finalization_lock_not_acquired"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        token = str(lock_payload.get("token") or "")
        if not token:
            reason = "finalization_lock_token_missing"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        locked_args = args_for_locked_delivery_status(args, repo)
        delivery_status_after_lock, delivery_status_after_lock_rc = run_delivery_status(locked_args, include_lock_status=False)
        delivery_status_blocker = delivery_status_mutation_blocker(delivery_status_after_lock, operation)
        if delivery_status_blocker is None and delivery_status_after_lock_rc == 0:
            after_lock_repo = repo_root_from_status(delivery_status_after_lock)
            if after_lock_repo != repo:
                delivery_status_blocker = "delivery_status_repo_mismatch_after_lock"
        if delivery_status_after_lock_rc != 0 and delivery_status_blocker is None:
            delivery_status_blocker = "delivery_status_after_lock_failed"
        effects.append(delivery_status_effect_summary(delivery_status_after_lock, delivery_status_after_lock_rc, delivery_status_blocker))
        if delivery_status_blocker:
            reason = delivery_status_blocker
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"delivery_status_after_lock": delivery_status_effect_summary(delivery_status_after_lock, delivery_status_after_lock_rc, delivery_status_blocker)})
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        delivery_status = delivery_status_after_lock
        if expected_repository and github_repo_slug(repo, "origin") != expected_repository:
            reason = "expected_repository_changed_after_lock"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"expected_repository": expected_repository})
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        litmus_status = litmus_decision_status(delivery_status)
        config_safe, config_safety_reason = git_mutation_config_safety(repo)
        effects.append({"name": "git_local_config_mutation_safety", "ok": config_safe, "reason": config_safety_reason})
        if not config_safe:
            reason = config_safety_reason or "git_local_config_unsafe_for_mutation"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        if operation == "pre-pr-review":
            blocking_entries = repo_blocking_dirty_entries(repo, busdriver_marker_state_dirs(args))
            if blocking_entries:
                reason = "clean_worktree_required_for_pre_pr_review"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"blocking_dirty_entries": blocking_entries})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            review_result, rc = run_busdriver_pre_pr_review(repo, args)
            effects.extend(review_result.get("side_effects") or [])
            ok = review_result.get("ok") is True and rc == 0
            reason = str(review_result.get("reason") or ("pre_pr_review_complete" if ok else "pre_pr_review_failed"))
            authority = mutating_authority(operation, ok, reason, ["busdriver_run_review_loop_trusted_writer"])
            status = "pre_pr_review_complete" if ok else "blocked"
            mut_run = mutating_run_envelope(args, operation, status, reason, repo, authority, effects, lock_payload, None, {"marker_write_policy": "Hermes did not write .claude markers directly; Busdriver run-review-loop.sh writer commands were invoked."})
            return {"ok": ok, "decision": legacy_decision_for_mutation(status, reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 0 if ok else (rc or 1)
        if operation == "commit":
            if not args.commit_message:
                reason = "commit_message_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            staged_present, staged_status_blocker = staged_changes_status(repo)
            if staged_status_blocker:
                reason = staged_status_blocker
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if not staged_present:
                reason = "staged_changes_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            staged_marker_blockers = staged_marker_entries(repo, busdriver_marker_state_dirs(args))
            if staged_marker_blockers:
                reason = "staged_busdriver_marker_files_blocked_for_commit"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"staged_marker_entries": staged_marker_blockers})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            other_dirty_entries = commit_blocking_dirty_entries(delivery_status, args)
            if other_dirty_entries:
                reason = "clean_unstaged_untracked_required_for_commit"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"unstaged_or_untracked_entries": other_dirty_entries})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            litmus_status, litmus_blocker = require_litmus_status(delivery_status, {"commit_litmus_fresh"})
            if litmus_blocker:
                reason = litmus_blocker
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"litmus_decision_status": litmus_status})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            reviewed_status_rc, reviewed_status_records, _reviewed_status_err = git_status_records(repo, "--untracked-files=all")
            if reviewed_status_rc != 0:
                reason = "commit_status_snapshot_failed"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            reviewed_status = status_records_text(reviewed_status_records)
            reviewed_untracked_snapshot = {
                path.rstrip("/"): untracked_file_identity(repo, path.rstrip("/"))
                for xy, record_paths in reviewed_status_records
                if xy == "??"
                for path in record_paths
            }
            parent_rc, reviewed_parent_head, _parent_err = git_output(repo, "rev-parse", "HEAD")
            tree_effect = run_safe(
                ["git", "write-tree"],
                repo,
                timeout=60,
                env=safe_git_mutation_env(),
                capture_stdout=True,
            )
            effects.append({"name": "git_write_tree_candidate_snapshot", **tree_effect})
            tree_rc = int(tree_effect.get("returncode") or 0)
            reviewed_tree = str(tree_effect.get("stdout") or tree_effect.get("stdout_tail") or "").strip()
            if (
                parent_rc != 0
                or not reviewed_parent_head
                or not tree_effect.get("ok")
                or tree_rc != 0
                or not re.fullmatch(r"[0-9a-fA-F]{40,64}", reviewed_tree)
            ):
                reason = "commit_candidate_snapshot_failed"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            staged_hash_blocker = commit_litmus_staged_diff_blocker(
                delivery_status,
                repo,
                expected_parent_head=reviewed_parent_head,
                expected_tree=reviewed_tree,
            )
            if staged_hash_blocker:
                reason = staged_hash_blocker
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"litmus_decision_status": litmus_status})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            before = reviewed_parent_head
            effect = commit_staged_index(
                repo,
                args.commit_message,
                {"BUSDRIVER_STATE_DIR": busdriver_marker_state_dir(args)},
                expected_parent_head=reviewed_parent_head,
                expected_tree=reviewed_tree,
                reviewed_status=reviewed_status,
                reviewed_untracked_snapshot=reviewed_untracked_snapshot,
                disable_hooks=True,
            )
            after_rc, after, after_err = git_output(repo, "rev-parse", "HEAD")
            helper_after = effect.get("after_head")
            # Once the helper has positively completed the publish, no failure of the OUTER HEAD
            # re-read may downgrade the report to blocked/git_commit_failed — that would be a
            # false no-mutation claim
            # A concurrent actor can move HEAD after our failed CAS. Neither a changed HEAD nor
            # candidate verification proves that this invocation published anything; only the
            # helper's positive effect_completed postcondition establishes landing.
            outcome_unknown = effect.get("effect_outcome_unknown") is True
            landed = bool(
                effect.get("commit_verified") is True
                and effect.get("effect_completed") is True
                and not outcome_unknown
            )
            outer_head_verified = bool(after_rc == 0 and after and after == helper_after)
            effect.update({"before_head": before, "after_head": after, "verified_after_head": helper_after})
            commit_completed = bool(landed and outer_head_verified)
            post_commit_warning = effect.get("warning")
            if landed and not outer_head_verified:
                effect.update({
                    "effect_completed": True,
                    "reconciliation_required": True,
                    "post_commit_head_verification_error": after_err or f"outer_head_lookup_rc={after_rc} head={after!r} verified={helper_after!r}",
                })
            elif commit_completed and post_commit_warning:
                effect.update({"effect_completed": True, "reconciliation_required": True})
            effects.append({"name": "git_commit", **effect})
            ok = bool(effect.get("ok") and commit_completed and not post_commit_warning)
            if outcome_unknown:
                reason = str(effect.get("error") or _COMMIT_OUTCOME_UNKNOWN_REASON)
            elif landed and not outer_head_verified:
                reason = "post_commit_head_verification_failed"
            elif effect.get("ok") and commit_completed:
                reason = str(post_commit_warning or "committed")
            else:
                reason = str(effect.get("error") or "git_commit_failed")
            commit_status = "commit_outcome_unknown" if outcome_unknown else ("committed" if landed else "blocked")
            authority = mutating_authority(operation, ok, reason, authority_sources)
            mut_run = mutating_run_envelope(args, operation, commit_status, reason, repo, authority, effects, lock_payload, None)
            return {"ok": ok, "decision": legacy_decision_for_mutation(commit_status, reason), "mutating_run": mut_run, "steps": steps_for(reason, operation, commit_status)}, 0 if ok else int(effect.get("returncode") or 1)
        if operation == "push":
            blocking_entries = commit_blocking_dirty_entries(delivery_status, args)
            if blocking_entries:
                reason = "clean_worktree_required_for_push"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"blocking_dirty_entries": blocking_entries})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            branch = args.push_branch or current_branch(repo)
            current = current_branch(repo)
            if not branch:
                reason = "branch_required_for_push"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if not valid_local_branch_name(repo, branch):
                reason = "push_branch_invalid"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"requested_branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if current and not valid_local_branch_name(repo, current):
                reason = "current_branch_invalid_for_push"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"current_branch": current})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if current and branch != current:
                reason = "push_branch_must_match_current_branch"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"current_branch": current, "requested_branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if args.push_remote != "origin":
                reason = "push_remote_must_be_origin"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"remote": args.push_remote})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            remote_safe, remote_safety_reason = push_remote_safety(repo, args.push_remote)
            push_url = github_remote_url(repo, args.push_remote)
            if not remote_safe or not push_url or (expected_repository and github_slug_from_remote_url(push_url) != expected_repository):
                reason = remote_safety_reason or "push_remote_safety_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"remote": args.push_remote})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if branch in {"main", "master"}:
                reason = "protected_branch_push_blocked"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            litmus_status, litmus_blocker = require_litmus_status(delivery_status, {"pr_review_fresh"})
            if litmus_blocker:
                reason = "fresh_pre_pr_dual_review_required" if litmus_blocker == "fresh_litmus_required" else litmus_blocker
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"litmus_decision_status": litmus_status})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            push_head_rc, push_head, _push_head_err = git_output(repo, "rev-parse", "HEAD")
            if push_head_rc != 0 or not push_head:
                reason = "push_head_lookup_failed"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            review_base = review_base_arg(args, delivery_status)
            if not pr_review_base_matches(delivery_status, repo, review_base, busdriver_marker_state_dirs(args), expected_head=push_head):
                reason = "pr_review_base_mismatch"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"base": review_base, "branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            remote_head, remote_head_error = live_remote_branch_head(repo, branch, args.push_remote)
            if remote_head_error not in {None, "remote_branch_not_found"}:
                reason = "remote_head_verification_required_for_push"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "remote_head_error": remote_head_error})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if remote_head == push_head:
                reason = "remote_branch_already_at_reviewed_head"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "already_up_to_date", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "remote_head": remote_head, "expected_remote_head": push_head})
                return {"ok": True, "decision": legacy_decision_for_mutation("already_up_to_date", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 0
            reviewed_base_ref = pr_base_ref(repo, review_base)
            reviewed_base_branch = remote_branch_name_from_ref(reviewed_base_ref)
            reviewed_base_head = local_ref_head(repo, reviewed_base_ref) if reviewed_base_ref else None
            if not reviewed_base_branch or not reviewed_base_head or not pr_review_base_matches(delivery_status, repo, review_base, busdriver_marker_state_dirs(args), expected_head=push_head, expected_base_head=reviewed_base_head):
                reason = "pr_review_base_mismatch"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"base": review_base, "branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            remote_ancestor_ok, remote_ancestor_reason = remote_head_ancestor_status(repo, remote_head)
            if not remote_ancestor_ok:
                reason = remote_ancestor_reason or "remote_head_ancestor_required_for_push"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "remote_head": remote_head})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            live_head_rc, live_head, _live_head_err = git_output(repo, "rev-parse", "HEAD")
            if live_head_rc != 0 or live_head != push_head:
                reason = "local_head_changed_after_review"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "reviewed_head": push_head, "live_head": live_head})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 1
            pre_push_status_rc, pre_push_status_records, pre_push_status_err = git_status_records(repo, "--untracked-files=all")
            pre_push_status = status_records_text(pre_push_status_records)
            push_allowed_marker_paths = allowed_marker_paths(busdriver_marker_state_dirs(args))
            pre_push_marker_snapshot = marker_evidence_snapshot_from_status(repo, pre_push_status_records, push_allowed_marker_paths) if pre_push_status_rc == 0 else {}
            pre_push_status_lines = [status_record_entry(xy, paths) for xy, paths in pre_push_status_records]
            pre_push_dirty_entries = blocking_dirty_entries(pre_push_status_lines, push_allowed_marker_paths) if pre_push_status_rc == 0 else ["<git status failed>"]
            for pre_push_xy, pre_push_record_paths in pre_push_status_records:
                pre_push_paths = [path.rstrip("/") for path in pre_push_record_paths]
                if len(pre_push_paths) == 1 and pre_push_paths[0] in push_allowed_marker_paths and marker_dirty_status_allowed(pre_push_xy) and pre_push_paths[0] not in pre_push_marker_snapshot:
                    pre_push_dirty_entries.append(status_record_entry(pre_push_xy, pre_push_record_paths))
            effects.append({"name": "git_push_pre_status", "ok": pre_push_status_rc == 0 and not pre_push_dirty_entries, "returncode": pre_push_status_rc, "stdout_tail": tail(pre_push_status), "stderr_tail": tail(pre_push_status_err), "pre_allowed_marker_entry_count": len(pre_push_marker_snapshot), "blocking_dirty_entries": pre_push_dirty_entries})
            if pre_push_status_rc != 0:
                reason = "pre_push_status_failed"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            if pre_push_dirty_entries:
                reason = "pre_push_dirty_worktree"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "blocking_dirty_entries": pre_push_dirty_entries})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            final_config_safe, final_config_reason = git_mutation_config_safety(repo)
            final_remote_safe, final_remote_reason = push_remote_safety(repo, args.push_remote)
            final_push_url = github_remote_url(repo, args.push_remote)
            if not final_config_safe or not final_remote_safe or final_push_url != push_url or (expected_repository and github_slug_from_remote_url(str(final_push_url or "")) != expected_repository):
                reason = final_config_reason or final_remote_reason or "push_destination_changed_before_side_effect"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"branch": branch, "remote": args.push_remote})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            effect = run_isolated_push(repo, push_url, branch, remote_head, push_head, reviewed_base_branch, reviewed_base_head)
            effects.append({"name": "git_push", **effect, "expected_remote_head": push_head})
            if effect.get("error") == "atomic_push_base_binding_unavailable":
                reason = "atomic_push_base_binding_unavailable"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"remote": args.push_remote, "branch": branch, "expected_remote_head": push_head, "expected_base_head": reviewed_base_head})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            ok = bool(effect.get("ok"))
            push_completed = False
            target_observed_unattributed = False
            reason = "pushed" if ok else "git_push_failed"
            recheck_head = None
            recheck_error = None
            if ok:
                recheck_head, recheck_error = live_remote_branch_head(repo, branch, args.push_remote)
                effects.append({"name": "git_push_remote_post_verify", "ok": recheck_error is None and recheck_head == push_head, "remote_head": recheck_head, "expected_remote_head": push_head, "reason": recheck_error})
                if recheck_error is not None or recheck_head != push_head:
                    ok = False
                    reason = "remote_head_post_push_mismatch"
                else:
                    push_completed = True
                    post_push_head_rc, post_push_head, _post_push_head_err = git_output(repo, "rev-parse", "HEAD")
                    effects.append({"name": "git_push_local_head_post_verify", "ok": post_push_head_rc == 0 and post_push_head == push_head, "local_head": post_push_head, "expected_local_head": push_head})
                    if post_push_head_rc != 0 or post_push_head != push_head:
                        ok = False
                        reason = "local_head_post_push_mismatch"
                    else:
                        post_push_status_rc, post_push_status_records, post_push_status_err = git_status_records(repo, "--untracked-files=all")
                        post_push_status = status_records_text(post_push_status_records)
                        post_push_dirty_entries = repo_blocking_dirty_entries(repo, busdriver_marker_state_dirs(args))
                        status_unchanged = post_push_status_rc == 0 and post_push_status == pre_push_status
                        post_push_marker_snapshot = marker_evidence_snapshot_from_status(repo, post_push_status_records, push_allowed_marker_paths) if post_push_status_rc == 0 else {}
                        marker_unchanged = post_push_marker_snapshot == pre_push_marker_snapshot
                        effects.append({"name": "post_push_dirty_check", "ok": post_push_status_rc == 0 and not post_push_dirty_entries and status_unchanged and marker_unchanged, "blocking_dirty_entries": post_push_dirty_entries, "status_unchanged": status_unchanged, "marker_unchanged": marker_unchanged, "returncode": post_push_status_rc, "stdout_tail": tail(post_push_status), "stderr_tail": tail(post_push_status_err)})
                        if post_push_status_rc != 0:
                            ok = False
                            reason = "post_push_status_failed"
                        elif post_push_dirty_entries or not status_unchanged or not marker_unchanged:
                            ok = False
                            reason = "pushed_with_post_push_dirty_worktree"
            else:
                post_push_head_rc, post_push_head, _post_push_head_err = git_output(repo, "rev-parse", "HEAD")
                post_push_status_rc, post_push_status_records, post_push_status_err = git_status_records(repo, "--untracked-files=all")
                post_push_status = status_records_text(post_push_status_records)
                post_push_dirty_entries = repo_blocking_dirty_entries(repo, busdriver_marker_state_dirs(args))
                status_unchanged = post_push_status_rc == 0 and post_push_status == pre_push_status
                post_push_marker_snapshot = marker_evidence_snapshot_from_status(repo, post_push_status_records, push_allowed_marker_paths) if post_push_status_rc == 0 else {}
                marker_unchanged = post_push_marker_snapshot == pre_push_marker_snapshot
                local_post_failure_ok = post_push_head_rc == 0 and post_push_head == push_head and not post_push_dirty_entries and status_unchanged and marker_unchanged
                effects.append({"name": "git_push_local_post_failure_verify", "ok": local_post_failure_ok, "local_head": post_push_head, "expected_local_head": push_head, "blocking_dirty_entries": post_push_dirty_entries, "status_unchanged": status_unchanged, "marker_unchanged": marker_unchanged, "status_returncode": post_push_status_rc, "status_stdout_tail": tail(post_push_status), "status_stderr_tail": tail(post_push_status_err)})
                recheck_head, recheck_error = live_remote_branch_head(repo, branch, args.push_remote)
                recheck_effect = {"name": "git_push_remote_recheck", "ok": recheck_error is None and (recheck_head in {push_head, remote_head}), "remote_head": recheck_head, "expected_remote_head": push_head, "previous_remote_head": remote_head, "reason": recheck_error}
                effects.append(recheck_effect)
                if recheck_error is None and recheck_head == push_head:
                    target_observed_unattributed = True
                    recheck_effect.update({"attributed_to_current_push": False, "reconciliation_required": True})
                    reason = "push_failed_target_observed_reconciliation_required"
                elif recheck_head and recheck_head != remote_head and reason == "git_push_failed":
                    reason = "remote_branch_changed_before_push"
                elif not local_post_failure_ok:
                    reason = "post_push_local_drift_after_failed_push_unverified"
            push_status = "pushed" if push_completed else ("observed_target_unattributed" if target_observed_unattributed else "blocked")
            authority = mutating_authority(operation, ok, reason, authority_sources)
            mut_run = mutating_run_envelope(args, operation, push_status, reason, repo, authority, effects, lock_payload, None, {"remote": args.push_remote, "branch": branch, "expected_remote_head": push_head, "observed_remote_head": recheck_head})
            return {"ok": ok, "decision": legacy_decision_for_mutation(push_status, reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 0 if ok else int(effect.get("returncode") or 1)
        if operation == "pr-create":
            # GitHub's PR-create APIs bind mutable branch names and expose no
            # atomic reviewed head+base SHA precondition. A postcondition can
            # attribute an already-created effect, but cannot make the mutation
            # fail closed. Keep the operation present but non-dispatchable until
            # such a server-side capability exists.
            reason = "atomic_pr_create_binding_unavailable"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
        if operation == "merge":
            if not args.pr:
                reason = "pr_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            loop, loop_rc = run_pr_grind_loop(repo, args)
            effects.append({"name": "pr_grind_loop_pre_merge", "returncode": loop_rc, "ok": loop_rc == 0, "summary": {"status": loop.get("status"), "clean": loop.get("clean"), "reason": (loop.get("decision") or {}).get("reason") if isinstance(loop.get("decision"), dict) else None}})
            if not pr_grind_loop_envelope_safe(loop) or loop.get("ok") is not True or loop.get("status") != "clean" or loop.get("clean") is not True or loop_rc != 0:
                reason = "clean_pr_grind_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, loop_rc or 2
            latest_head = loop.get("latest_head")
            if not isinstance(latest_head, str) or not latest_head:
                reason = "pr_grind_latest_head_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            slug = expected_repository or github_repo_slug(repo, "origin")
            if not slug:
                reason = "github_origin_remote_required_for_merge"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"remote": "origin"})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            loop_repo = loop.get("repo")
            try:
                loop_repo_matches = isinstance(loop_repo, str) and Path(loop_repo).expanduser().resolve() == repo
            except OSError:
                loop_repo_matches = False
            if loop.get("repository") != slug or not loop_repo_matches:
                reason = "pr_grind_repository_binding_mismatch"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop, "repo_slug": slug})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            pre_merge_snapshot, pre_merge_effect, pre_merge_error = github_pr_snapshot(repo, slug, int(args.pr))
            effects.append({"name": "gh_pr_merge_precondition_query", **pre_merge_effect, "reason": pre_merge_error})
            if pre_merge_snapshot is None:
                reason = "merge_precondition_query_required"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop, "repo_slug": slug})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            base_data = pre_merge_snapshot.get("base") if isinstance(pre_merge_snapshot.get("base"), dict) else {}
            snapshot_base = base_data.get("ref")
            snapshot_base_sha = base_data.get("sha")
            requested_base = remote_branch_name_from_ref(normalize_pr_base_arg(args.base)) if args.base else snapshot_base
            if (
                not isinstance(snapshot_base, str)
                or not snapshot_base
                or not isinstance(snapshot_base_sha, str)
                or not snapshot_base_sha
                or requested_base != snapshot_base
                or not exact_pull_request_matches(pre_merge_snapshot, slug, latest_head, snapshot_base)
                or pre_merge_snapshot.get("state") != "open"
                or pre_merge_snapshot.get("merged_at") is not None
            ):
                reason = "merge_pr_identity_or_state_mismatch"
                authority = mutating_authority(operation, False, reason)
                mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop, "repo_slug": slug, "pr_number": args.pr})
                return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
            reason = "atomic_merge_base_binding_unavailable"
            authority = mutating_authority(operation, False, reason)
            mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None, {"pr_grind_loop": loop, "repo_slug": slug, "pr_number": args.pr, "expected_head": latest_head, "expected_base": snapshot_base, "expected_base_sha": snapshot_base_sha})
            return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2

        reason = "unsupported_operation"
        authority = mutating_authority(operation, False, reason)
        mut_run = mutating_run_envelope(args, operation, "blocked", reason, repo, authority, effects, lock_payload, None)
        return {"ok": False, "decision": legacy_decision_for_mutation("blocked", reason), "mutating_run": mut_run, "steps": steps_for(reason, operation)}, 2
    finally:
        if token and lock_state_dir_initialized:
            # Defense in depth for the same hazard release_finalization_lock() documents: this
            # `finally` runs after a commit/push may already have LANDED, and an exception raised
            # here discards that completed result instead of reporting it. The release helper is
            # contracted not to raise; if it ever does, the mutation outcome still survives and is
            # reconciled into a truthful `*_release_failed` status by the caller below.
            try:
                if getattr(release_finalization_lock, "supports_lock_identity", False):
                    release_payload = release_finalization_lock(
                        repo,
                        token,
                        lock_state_dir,
                        str((lock_payload or {}).get("path") or ""),
                    )
                else:
                    release_payload = release_finalization_lock(repo, token, lock_state_dir)
            except BaseException as exc:  # noqa: BLE001 - never let cleanup erase a real mutation
                # BaseException, not Exception: by the time this runs the commit has LANDED, and a
                # MemoryError, RecursionError or a Ctrl-C landing in the release window is exactly
                # as capable of erasing that truth as an OSError. Nothing above this point catches
                # these before the side effect is known, which is the rule this must not break.
                release_payload = {
                    "released": False,
                    "reason": "finalization_lock_release_failed",
                    "error": safe_release_error(exc),
                }
            try:
                redacted_release = redact_value(release_payload)
            except BaseException:  # noqa: BLE001 - redaction failure must not leak, or erase, truth
                # Redaction runs regexes over attacker-influenced text and can itself raise. Emit a
                # fixed literal rather than the unredacted payload: the release truth survives and
                # nothing unredacted escapes, whichever way redaction failed.
                redacted_release = dict(RELEASE_REDACTION_FALLBACK)
            release_placeholder.clear()
            if isinstance(redacted_release, dict):
                release_placeholder.update(redacted_release)
            else:
                release_placeholder.update({"released": False, "reason": "release_payload_invalid"})
            execute_mutating_operation.last_release = release_placeholder  # type: ignore[attr-defined]

def early_policy_steps(reason: str, operation: str) -> list[dict[str, str]]:
    return [
        {
            "name": "finalization_lock",
            "status": "skipped",
            "reason": "early_policy_blocker_before_lock",
        },
        {"name": operation, "status": "blocked", "reason": reason},
        {"name": "postflight_reconciliation", "status": "skipped", "reason": reason},
    ]


def steps_for(reason: str | None, operation: str | None = None, status: str | None = None) -> list[dict[str, str]]:
    if operation in {"pre-pr-review", "commit", "push", "pr-create", "merge"}:
        if status in {"commit_outcome_unknown", "commit_outcome_unknown_release_failed"}:
            release_failed = status == "commit_outcome_unknown_release_failed"
            return [
                {
                    "name": "finalization_lock",
                    "status": "failed" if release_failed else "passed",
                    "reason": "finalization_lock_release_failed" if release_failed else "single_flight_finalization",
                },
                {"name": operation, "status": "failed", "reason": reason or _COMMIT_OUTCOME_UNKNOWN_REASON},
                {"name": "postflight_reconciliation", "status": "failed", "reason": reason or _COMMIT_OUTCOME_UNKNOWN_REASON},
            ]
        if status in _RELEASE_FAILED_STATUSES:
            # The operation COMPLETED and only the lock release failed. `reason` alone cannot say
            # that — `finalization_lock_release_failed` is in neither success nor reconciliation
            # set below, so deriving from it reported a landed commit as `blocked` with
            # `postflight_reconciliation: skipped`. Both false, and the stuck lock is precisely
            # the thing that needs a human.
            return [
                {"name": "finalization_lock", "status": "failed", "reason": "finalization_lock_release_failed"},
                {"name": operation, "status": "passed", "reason": "finalization_lock_release_failed"},
                {"name": "postflight_reconciliation", "status": "failed", "reason": "finalization_lock_release_failed"},
            ]
        if reason == "push_failed_target_observed_reconciliation_required":
            return [
                {"name": "finalization_lock", "status": "passed", "reason": "single_flight_finalization"},
                {"name": operation, "status": "failed", "reason": reason},
                {"name": "postflight_reconciliation", "status": "failed", "reason": reason},
            ]
        success_reasons = {"busdriver_pre_pr_review_marker_written", "committed", "pushed", "remote_branch_already_at_reviewed_head", "pr_created"}
        # Every commit reconciliation reason reports status "committed" (the mutation happened),
        # so its steps must show the operation passed and reconciliation OUTSTANDING. Derived from
        # the contract set rather than restated, so a new reconciliation reason can never fall
        # through to `postflight_reconciliation: skipped` — a claim that nothing needs fixing.
        completed_warning_reasons = _COMMIT_RECONCILIATION_REASONS | {"pushed_with_post_push_dirty_worktree", "post_push_status_failed", "local_head_post_push_mismatch", "post_push_local_drift_after_failed_push", "pushed_after_failed_push_remote_verified", "pr_created_after_failed_command_reconciled", "pr_created_non_open_postcondition"}
        operation_passed = reason in success_reasons or reason in completed_warning_reasons
        return [
            {"name": "finalization_lock", "status": "passed" if operation_passed else "checked", "reason": "single_flight_finalization"},
            {"name": operation, "status": "passed" if operation_passed else "blocked", "reason": reason or "unknown"},
            {"name": "postflight_reconciliation", "status": "passed" if reason in success_reasons else ("failed" if reason in completed_warning_reasons else "skipped"), "reason": reason or "unknown"},
        ]
    if reason == "run_found":
        return [
            {"name": "status_lookup", "status": "found", "reason": "run_found"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "run_id_required":
        return [
            {"name": "status_lookup", "status": "blocked", "reason": "run_id_required"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "run_not_found":
        return [
            {"name": "status_lookup", "status": "blocked", "reason": "run_not_found"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verifier_containment_unavailable":
        return [
            {"name": "verify", "status": "blocked", "reason": "verifier_containment_unavailable"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "delivery_status_failed":
        skipped_operation = "pr_grind" if operation == "pr-grind" else "verify"
        return [
            {"name": "delivery_status", "status": "blocked", "reason": "helper_failed"},
            {"name": skipped_operation, "status": "skipped", "reason": "delivery_status_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "unsupported_operation":
        return [
            {"name": "execute", "status": "blocked", "reason": "unsupported_operation"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "no_verifiers":
        return [
            {"name": "verify", "status": "blocked", "reason": "no_verifiers"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "pr_required":
        return [
            {"name": "pr_grind", "status": "blocked", "reason": "pr_required"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "latest_pr_head_clean_read_only":
        return [
            {"name": "pr_grind", "status": "passed", "reason": "latest_pr_head_clean_read_only"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason in {"pr_grind_needs_fix", "pr_grind_wait", "pr_grind_blocked", "pr_grind_loop_failed"}:
        return [
            {"name": "pr_grind", "status": "blocked", "reason": reason},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verifier_failed":
        return [
            {"name": "verify", "status": "blocked", "reason": "verifier_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "artifact_write_failed":
        return [
            {"name": "write_artifact", "status": "blocked", "reason": "artifact_write_failed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    if reason == "verified":
        return [
            {"name": "verify", "status": "passed", "reason": "local_verifiers_passed"},
            {"name": "commit", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "push", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "pr", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "merge", "status": "skipped", "reason": "finalization_disabled"},
            {"name": "deploy", "status": "skipped", "reason": "finalization_disabled"},
        ]
    return [
        {"name": "review_delivery_status", "status": "pending", "reason": "plan_only"},
        {"name": "commit", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "push", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "pr", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "merge", "status": "blocked", "reason": "finalization_disabled"},
        {"name": "deploy", "status": "blocked", "reason": "finalization_disabled"},
    ]


def decision(status: str, reason: str) -> dict[str, Any]:
    return {"status": status, "reason": reason, **BLOCKED_FLAGS}


def early_policy_result(args: argparse.Namespace, blocker: str) -> dict[str, Any]:
    blocked_decision = decision("blocked", blocker)
    empty_status: dict[str, Any] = {}
    return {
        "schema": SCHEMA,
        "version": 1,
        "ok": False,
        "mode": args.mode,
        "operation": args.operation,
        "repo": None,
        "pr": pr_summary(args.pr, empty_status),
        "delivery_status": None,
        "pr_grind_loop": None,
        "mutating_run": None,
        "verifiers": [],
        "steps": early_policy_steps(blocker, args.operation),
        "decision": blocked_decision,
        "run": delivery_run(args, empty_status, blocked_decision, blocker, create_identity=False),
        "run_artifact_path": None,
    }


def main() -> int:
    args = parse_args()
    if args.mode == "execute" and args.operation == "plan":
        result = early_policy_result(args, "unsupported_operation")
        print(json.dumps(redact_value(result), indent=2 if args.pretty else None, sort_keys=True))
        return 2
    if args.mode == "execute" and args.operation in FIXED_EARLY_BLOCKED_OPERATIONS:
        result = early_policy_result(args, FIXED_EARLY_BLOCKED_OPERATIONS[args.operation])
        print(json.dumps(redact_value(result), indent=2 if args.pretty else None, sort_keys=True))
        return 2

    if args.mode != "status" and not args.run_id:
        args.run_id = new_run_id()
    if args.mode == "status":
        result, returncode = status_mode_result(args)
        print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
        return returncode

    delivery_status, status_rc = run_delivery_status(args)
    delivery_ok = bool(delivery_status.get("ok"))
    reason: str | None = None
    result_ok = delivery_ok
    result_decision = decision("plan_only", "read_only_plan")
    verifiers: list[dict[str, Any]] = []
    pr_grind_loop: dict[str, Any] | None = None
    mutating_run: dict[str, Any] | None = None
    explicit_steps: list[dict[str, str]] | None = None
    write_run_artifact = False
    returncode = 0 if delivery_ok else (status_rc or 1)

    if not delivery_ok:
        reason = "delivery_status_failed"
        result_ok = False
        result_decision = decision("blocked", reason)
        write_run_artifact = args.mode == "execute" and (
            args.operation == "verify"
            or args.operation in {"pre-pr-review", "commit", "push", "pr-create", "merge"}
            or (args.operation == "pr-grind" and bool(args.pr))
        )
    elif args.mode == "execute":
        if args.operation in {"pre-pr-review", "commit", "push", "pr-create", "merge"}:
            mutation_result, mutation_rc = execute_mutating_operation(args, delivery_status)
            result_ok = bool(mutation_result.get("ok"))
            result_decision = mutation_result.get("decision") if isinstance(mutation_result.get("decision"), dict) else decision("blocked", "mutating_operation_failed")
            reason = str(result_decision.get("reason") or "mutating_operation_failed")
            mutating_run = mutation_result.get("mutating_run") if isinstance(mutation_result.get("mutating_run"), dict) else None
            explicit_steps = mutation_result.get("steps") if isinstance(mutation_result.get("steps"), list) else None
            returncode = mutation_rc
            release = getattr(execute_mutating_operation, "last_release", None)
            if mutating_run is not None and release is not None:
                mutating_run["lock_release"] = release
                reconciliation = release_failure_reconciliation(args.operation, mutating_run, release)
                if reconciliation is not None:
                    result_decision, explicit_steps, returncode = reconciliation
                    result_ok = False
                    reason = str(result_decision.get("reason") or "finalization_lock_release_failed")
            write_run_artifact = True
        elif args.operation == "pr-grind":
            if not args.pr:
                reason = "pr_required"
                result_ok = False
                result_decision = decision("blocked", reason)
                returncode = 2
            else:
                repo = Path(args.repo or ".").expanduser().resolve()
                pr_grind_loop, loop_rc = run_pr_grind_loop(repo, args)
                loop_status = str(pr_grind_loop.get("status") or "")
                loop_decision = pr_grind_loop.get("decision") if isinstance(pr_grind_loop.get("decision"), dict) else {}
                loop_reason = str(loop_decision.get("reason") or "")
                loop_safe = pr_grind_loop_envelope_safe(pr_grind_loop)
                loop_clean = loop_safe and loop_status == "clean" and pr_grind_loop.get("clean") is True and pr_grind_loop.get("ok") is True and loop_rc == 0
                if loop_clean:
                    reason = loop_reason or "latest_pr_head_clean_read_only"
                    result_ok = True
                    result_decision = decision("pr_grind_clean", reason)
                    returncode = 0
                elif not loop_safe:
                    reason = "pr_grind_loop_failed"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                elif loop_rc != 0 and (pr_grind_loop.get("clean") is True or loop_status == "clean"):
                    reason = "pr_grind_loop_failed"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                elif loop_status == "needs_fix":
                    reason = "pr_grind_needs_fix"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                elif loop_status == "wait":
                    reason = "pr_grind_wait"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                elif loop_status == "blocked":
                    reason = "pr_grind_blocked"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                else:
                    reason = "pr_grind_loop_failed"
                    result_ok = False
                    result_decision = decision("blocked", reason)
                    returncode = loop_rc or 1
                write_run_artifact = True
        else:
            reason = "unsupported_operation"
            result_ok = False
            result_decision = decision("blocked", reason)
            returncode = 2

    result = {
        "schema": SCHEMA,
        "version": 1,
        "ok": result_ok,
        "mode": args.mode,
        "operation": effective_operation(args),
        "repo": delivery_status.get("repo"),
        "pr": pr_summary(args.pr, delivery_status),
        "delivery_status": delivery_status,
        "pr_grind_loop": pr_grind_loop,
        "mutating_run": mutating_run,
        "verifiers": verifiers,
        "steps": explicit_steps if explicit_steps is not None else steps_for(reason, args.operation),
        "decision": result_decision,
        "run": delivery_run(args, delivery_status, result_decision, reason),
        "run_artifact_path": None,
    }
    result = redact_value(result)
    if write_run_artifact:
        try:
            write_artifact(result)
        except (OSError, ArtifactDirectoryInvalid, ArtifactTooLarge) as e:
            artifact_error = redact_text(str(e))
            # Deliberately a superset of the reachable-commit completed statuses: any status that
            # could carry a real side effect must take the preserving branch, so a future
            # unblocked executor cannot silently report a completed mutation as "no side effect".
            # This governs the stdout fallback only — neither fallback writes an artifact (the
            # single write_artifact call above already failed), so no write-failure outcome is
            # durable and ARTIFACT_OUTCOME_CONTRACT admits none of them.
            completed_statuses = {
                "pre_pr_review_complete", "committed", "pushed", "pr_created", "merged",
                "commit_outcome_unknown", "commit_outcome_unknown_release_failed",
                "pre_pr_review_complete_release_failed", "committed_release_failed", "pushed_release_failed",
                "pr_created_release_failed", "merged_release_failed",
            }
            completed_status = mutating_run.get("status") if isinstance(mutating_run, dict) else None
            if isinstance(completed_status, str) and completed_status in completed_statuses:
                result["ok"] = False
                result["run_artifact_error"] = artifact_error
                result["decision"] = legacy_decision_for_mutation(completed_status, "artifact_write_failed_after_side_effect")
                if isinstance(result.get("mutating_run"), dict):
                    result["mutating_run"]["artifact_write_error"] = artifact_error
                if isinstance(result.get("run"), dict):
                    result["run"]["reason"] = "artifact_write_failed_after_side_effect"
                    result["run"]["artifact_write_error"] = artifact_error
                    result["run"]["artifacts"] = []
                result["steps"] = [{"name": "write_artifact", "status": "blocked", "reason": "artifact_write_failed_after_side_effect"}]
                returncode = 1
            else:
                result["ok"] = False
                result["run_artifact_error"] = artifact_error
                result["decision"] = decision("blocked", "artifact_write_failed")
                # M-1: the ordinary write failure is a pre-side-effect, NON-mutating outcome. A
                # blocked mutating operation may already have populated a nested run; it is stale
                # once the outer run becomes an ordinary write failure and must not persist.
                result["mutating_run"] = None
                if isinstance(result.get("run"), dict):
                    result["run"]["status"] = "blocked"
                    result["run"]["reason"] = "artifact_write_failed"
                    result["run"]["authority"] = {key: False for key in BLOCKED_FLAGS}
                    result["run"]["artifacts"] = []
                result["steps"] = steps_for("artifact_write_failed")
                returncode = 1

    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return returncode


if __name__ == "__main__":
    raise SystemExit(main())
