# Fixed root-owned system sources, executed in place. No `.resolve()` anywhere in this table:
# resolving *follows* symlinks, and a symlinked name is exactly what this contract refuses. The walk
# in _validated_root_owned_source() proves the literal path, component by component.
#
# gh is bound to /usr/local/bin/gh and nothing else. Homebrew's /opt/homebrew/bin is uid=501
# drwxrwxr-x — user *and* group writable — so every binary under it is renameable by the same-UID
# adversary this contract exists to stop. That it is where `gh` happens to be installed is not a
# reason to trust it; a credential-bearing dispatch is the last place to make that trade.
TRUSTED_EXECUTABLE_SOURCES = {
    "git": Path("/usr/bin/git"),
    "git-real": Path("/Library/Developer/CommandLineTools/usr/bin/git"),
    "sandbox-exec": Path("/usr/bin/sandbox-exec"),
    "gh": Path("/usr/local/bin/gh"),
    "jq": Path("/usr/bin/jq"),
    "bash": Path("/bin/bash"),
    "python3": Path("/usr/bin/python3"),
}
