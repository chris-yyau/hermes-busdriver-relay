#!/usr/bin/env python3
"""Run the safe Hermes Busdriver Relay v1 smoke checks.

This smoke runner is intentionally non-mutating for Busdriver and target repos.
It may run pytest inside this relay repository, which can create local pytest
cache files ignored by git.
"""
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
STATUS = ROOT / "scripts" / "hermes-busdriver-status"
LOCK = ROOT / "scripts" / "hermes-busdriver-lock"
RUNTIME = ROOT / "scripts" / "hermes-busdriver-runtime-check"
GATE = ROOT / "scripts" / "hermes-busdriver-gate"
AGENT_DRAFT = ROOT / "scripts" / "hermes-busdriver-agent-draft"
AGENT_SMOKE = ROOT / "scripts" / "hermes-busdriver-agent-smoke"
DELIVERY_STATUS = ROOT / "scripts" / "hermes-busdriver-delivery-status"
RELAY_ROLE = ROOT / "scripts" / "hermes-busdriver-relay-role"
LITMUS_STATUS = ROOT / "scripts" / "hermes-busdriver-litmus-status"
PR_GRIND_CHECK = ROOT / "scripts" / "hermes-busdriver-pr-grind-check"
PR_GRIND_LOOP = ROOT / "scripts" / "hermes-busdriver-pr-grind-loop"
DELIVER = ROOT / "scripts" / "hermes-busdriver-deliver"
FINALIZATION_READINESS = ROOT / "scripts" / "hermes-busdriver-finalization-readiness"
FINALIZATION_CONTRACT_STATUS = ROOT / "scripts" / "hermes-busdriver-finalization-contract-status"
SMOKE = ROOT / "scripts" / "hermes-busdriver-smoke"
PY_COMPILE_SCRIPTS = [
    STATUS,
    RELAY_ROLE,
    LOCK,
    RUNTIME,
    GATE,
    AGENT_DRAFT,
    AGENT_SMOKE,
    DELIVERY_STATUS,
    FINALIZATION_READINESS,
    FINALIZATION_CONTRACT_STATUS,
    DELIVER,
    LITMUS_STATUS,
    PR_GRIND_CHECK,
    PR_GRIND_LOOP,
    SMOKE,
]


def run(cmd: list[str], cwd: Path = ROOT, timeout: int = 120) -> dict[str, Any]:
    try:
        p = subprocess.run(cmd, cwd=str(cwd), text=True, capture_output=True, timeout=timeout)
    except subprocess.TimeoutExpired as e:
        stdout = e.stdout.decode(errors="replace") if isinstance(e.stdout, bytes) else (e.stdout or "")
        stderr = e.stderr.decode(errors="replace") if isinstance(e.stderr, bytes) else (e.stderr or "")
        return {
            "cmd": cmd,
            "returncode": 124,
            "ok": False,
            "stdout": stdout.strip(),
            "stderr": (stderr.strip() or f"timed out after {timeout}s"),
        }
    return {"cmd": cmd, "returncode": p.returncode, "ok": p.returncode == 0, "stdout": p.stdout.strip(), "stderr": p.stderr.strip()}


def mark_summary_parse_error(check: dict[str, Any], error: Exception) -> None:
    check["summary_parse_error"] = str(error)
    check["ok"] = False
    if check.get("returncode") == 0:
        check["returncode"] = 1


def pytest_cmd() -> list[str]:
    probe = subprocess.run([sys.executable, "-c", "import pytest"], text=True, capture_output=True)
    if probe.returncode == 0:
        return [sys.executable, "-m", "pytest"]
    pytest_bin = shutil.which("pytest")
    if pytest_bin:
        return [pytest_bin]
    uvx = shutil.which("uvx")
    if uvx:
        return [uvx, "--from", "pytest", "pytest"]
    return [sys.executable, "-m", "pytest"]


def summarize_finalization_readiness(readiness: dict[str, Any]) -> dict[str, Any]:
    dec = readiness.get("readiness") or {}
    guardrails = readiness.get("finalization_guardrails") or {}
    dual_review = readiness.get("dual_review_readiness") or {}
    contract_status = readiness.get("finalization_contract_status") or {}
    contract_authority = contract_status.get("authority") or {}
    return {
        "status": dec.get("status"),
        "ready": dec.get("ready"),
        "commit_allowed": dec.get("commit_allowed"),
        "merge_allowed": dec.get("merge_allowed"),
        "handoff_schema": (readiness.get("handoff_envelope") or {}).get("schema"),
        "finalization_guardrails": {
            "schema": guardrails.get("schema"),
            "read_only": guardrails.get("read_only"),
        },
        "dual_review_readiness": {
            "schema": dual_review.get("schema"),
            "programmatic_execution_allowed": dual_review.get("programmatic_execution_allowed"),
        },
        "finalization_contract_status": {
            "schema": contract_status.get("schema"),
            "read_only": contract_status.get("read_only"),
            "current_policy": contract_status.get("current_policy"),
            "summary": contract_status.get("summary"),
            "authority": {
                "finalization_allowed": contract_authority.get("finalization_allowed"),
                "marker_write_allowed": contract_authority.get("marker_write_allowed"),
                "programmatic_execution_allowed": contract_authority.get("programmatic_execution_allowed"),
            },
        },
    }


def main() -> int:
    ap = argparse.ArgumentParser(description="Safe v1 smoke checks for Hermes Busdriver Relay")
    ap.add_argument("--plugin-root", help="Busdriver plugin root for live status probe")
    ap.add_argument("--repo", help="Target repo/worktree for read-only status probe")
    ap.add_argument("--pretty", action="store_true")
    args = ap.parse_args()

    checks = []
    checks.append(run([sys.executable, "-m", "py_compile", *map(str, PY_COMPILE_SCRIPTS)]))
    checks.append(run([*pytest_cmd(), "tests/contract", "-q"], timeout=180))

    if args.plugin_root:
        cmd = [sys.executable, str(STATUS), "--plugin-root", args.plugin_root]
        if args.repo:
            cmd += ["--repo", args.repo]
        checks.append(run(cmd, timeout=60))
        if checks[-1]["ok"]:
            try:
                status = json.loads(checks[-1]["stdout"])
                checks[-1]["summary"] = {
                    "package_version": (status.get("package") or {}).get("version"),
                    "hook_event_count": len((status.get("hooks") or {}).get("events") or {}),
                    "route_count": len(status.get("effective_routes") or {}),
                    "active_marker_count": (status.get("active_markers") or {}).get("active_count"),
                    "repo_dirty": (status.get("repo") or {}).get("dirty") if status.get("repo") else None,
                }
                checks[-1]["stdout"] = "<json omitted; rerun hermes-busdriver-status --pretty for details>"
            except Exception as e:  # noqa: BLE001
                mark_summary_parse_error(checks[-1], e)

        runtime_cmd = [sys.executable, str(RUNTIME), "--plugin-root", args.plugin_root]
        if args.repo:
            runtime_cmd += ["--repo", args.repo]
        checks.append(run(runtime_cmd, timeout=60))
        if checks[-1]["ok"]:
            try:
                runtime = json.loads(checks[-1]["stdout"])
                eq = runtime.get("runtime_equivalence") or {}
                checks[-1]["summary"] = {
                    "inside_claude_code_hook_invocation": eq.get("inside_claude_code_hook_invocation"),
                    "hook_manifest_available": eq.get("hook_manifest_available"),
                    "gate_hooks_declared": eq.get("gate_hooks_declared"),
                    "mutating_launcher_allowed": eq.get("mutating_launcher_allowed"),
                }
                checks[-1]["stdout"] = "<json omitted; rerun hermes-busdriver-runtime-check --pretty for details>"
            except Exception as e:  # noqa: BLE001
                mark_summary_parse_error(checks[-1], e)

        readiness_cmd = [sys.executable, str(FINALIZATION_READINESS), "--plugin-root", args.plugin_root]
        if args.repo:
            readiness_cmd += ["--repo", args.repo]
        checks.append(run(readiness_cmd, timeout=90))
        if checks[-1]["ok"]:
            try:
                readiness = json.loads(checks[-1]["stdout"])
                checks[-1]["summary"] = summarize_finalization_readiness(readiness)
                checks[-1]["stdout"] = "<json omitted; rerun hermes-busdriver-finalization-readiness --pretty for details>"
            except Exception as e:  # noqa: BLE001
                mark_summary_parse_error(checks[-1], e)

        if args.repo:
            gate_cmd = [sys.executable, str(GATE), "preflight", "--plugin-root", args.plugin_root, "--repo", args.repo]
            checks.append(run(gate_cmd, timeout=60))
            if checks[-1]["ok"]:
                try:
                    gate = json.loads(checks[-1]["stdout"])
                    dec = gate.get("decision") or {}
                    checks[-1]["summary"] = {
                        "phase": gate.get("phase"),
                        "agent_implementation_draft_allowed": dec.get("agent_implementation_draft_allowed"),
                        "commit_allowed": dec.get("commit_allowed"),
                        "push_allowed": dec.get("push_allowed"),
                        "pr_allowed": dec.get("pr_allowed"),
                    }
                    checks[-1]["stdout"] = "<json omitted; rerun hermes-busdriver-gate preflight --pretty for details>"
                except Exception as e:  # noqa: BLE001
                    mark_summary_parse_error(checks[-1], e)

    ok = all(c["ok"] for c in checks)
    result = {"schema": "hermes-busdriver-smoke/v0", "ok": ok, "checks": checks}
    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return 0 if ok else 1


if __name__ == "__main__":
    raise SystemExit(main())
