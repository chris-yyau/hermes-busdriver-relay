#!/usr/bin/python3
"""Read-only finalization contract status / capability matrix.

This helper is deliberately informational. It translates ADR 0005 and the
existing finalization-readiness remaining-work IDs into a machine-readable
policy-blocked capability matrix. It never inspects, writes, or mutates target
repositories, Busdriver marker state, GitHub, or relay run artifacts.
"""
from __future__ import annotations

import argparse
import json
from typing import Any

SCHEMA = "hermes-busdriver-finalization-contract-status/v0"
VERSION = 0
CONTRACT_ADR = "ADRs/0005-finalization-authority-integration-contract.md"
ADR_0006 = "ADRs/0006-programmatic-dual-review-marker-interop.md"
CONTRACT_ADRS = [CONTRACT_ADR, ADR_0006]
RELATED_DESIGN_ADRS = [ADR_0006]
CURRENT_POLICY = "gated_delivery_mode_executor"
GUARDRAILS_SCHEMA = "hermes-busdriver-finalization-guardrails/v0"
SOURCE_REMAINING_WORK = "scripts/hermes-busdriver-finalization-readiness:finalization_guardrails.remaining_work"
POLICY = (
    "Explicit Hermes Delivery Mode now has a narrow gated executor surface for pre-PR-review/commit/push/PR/merge. "
    "Operation availability is narrower: pre-PR review is policy-blocked by isolated_review_runtime_unavailable before delivery-status or lock handling; "
    "verify-only command execution is policy-blocked by verifier_containment_unavailable; "
    "push is policy-blocked by atomic_push_base_binding_unavailable; PR creation is policy-blocked by "
    "atomic_pr_create_binding_unavailable; and merge is policy-blocked by atomic_merge_base_binding_unavailable. "
    "This helper remains read-only and grants no standing authority: each dispatchable mutating operation must first pass its fixed policy blocker, then prove "
    "fresh evidence at runtime, acquire a finalization lock, and write a redacted side-effect transcript. "
    "Programmatic dual review, raw marker interop/writes, autonomous PR-grind fix loops, deploy, release, "
    "and publish remain blocked."
)

