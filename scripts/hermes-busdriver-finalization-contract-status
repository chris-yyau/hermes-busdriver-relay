#!/usr/bin/env python3
"""Read-only finalization contract status / capability matrix.

This helper is deliberately informational. It translates ADR 0005 and the
existing finalization-readiness remaining-work IDs into a machine-readable
policy-blocked capability matrix. It never inspects, writes, or mutates target
repositories, Busdriver marker state, GitHub, or relay run artifacts.
"""
from __future__ import annotations

import argparse
import json
from typing import Any

SCHEMA = "hermes-busdriver-finalization-contract-status/v0"
VERSION = 0
CONTRACT_ADR = "ADRs/0005-finalization-authority-integration-contract.md"
ADR_0006 = "ADRs/0006-programmatic-dual-review-marker-interop.md"
CONTRACT_ADRS = [CONTRACT_ADR, ADR_0006]
RELATED_DESIGN_ADRS = [ADR_0006]
CURRENT_POLICY = "non_mutating_relay_only"
GUARDRAILS_SCHEMA = "hermes-busdriver-finalization-guardrails/v0"
SOURCE_REMAINING_WORK = "scripts/hermes-busdriver-finalization-readiness:finalization_guardrails.remaining_work"
POLICY = (
    "Finalization expansion is policy-blocked until a later implementation slice proves the ADR 0005 "
    "Busdriver-approved authority contract for the specific surface. This status helper is read-only "
    "and does not retire remaining_work or authorize mutation."
)

AUTHORITY = {
    "finalization_allowed": False,
    "commit_allowed": False,
    "push_allowed": False,
    "pr_allowed": False,
    "merge_allowed": False,
    "deploy_allowed": False,
    "release_allowed": False,
    "publish_allowed": False,
    "marker_write_allowed": False,
}

NON_MUTATING_CAPABILITY_FLAGS = {
    **AUTHORITY,
    "dispatch_allowed": False,
    "mutation_allowed": False,
    "programmatic_execution_allowed": False,
    "marker_interop_allowed": False,
    "raw_codex_exec_allowed": False,
    "non_codex_agent_enablement_allowed": False,
}

UNSUPPORTED_MUTATING_OPERATIONS = [
    "commit",
    "push",
    "pr_create",
    "merge",
    "deploy",
    "release",
    "publish",
    "busdriver_marker_write",
    "gate_bypass",
    "raw_codex_exec",
    "non_codex_agent_enablement",
    "autonomous_git_github_mutation",
]

ADR_AUTHORITY_SOURCES = [
    "explicit_user_intent_for_exact_side_effect",
    "busdriver_source_of_truth_approval",
    "hook_runtime_or_equivalent_proof",
    "fresh_repo_pr_evidence",
    "fresh_gate_review_evidence",
    "concurrency_authority",
    "data_boundary_authority",
    "schema_authority",
]

FUTURE_SCHEMAS_REQUIRED = [
    "hermes-busdriver-finalization-authority/v0",
    "hermes-busdriver-mutating-delivery-run/v0",
    "hermes-busdriver-pr-grind-mutation-loop/v0",
    "hermes-busdriver-dual-review-execution/v0",
    "hermes-busdriver-marker-interop/v0",
]

CAPABILITY_MATRIX = [
