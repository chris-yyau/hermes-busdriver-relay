def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Read-only finalization contract status / capability matrix")
    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON")
    return parser.parse_args()


def matrix_rows() -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    for item in CAPABILITY_MATRIX:
        implemented = bool(item.get("implemented", False))
        rows.append({
            **item,
            "status": str(item.get("status") or "policy_blocked"),
            "retired": bool(item.get("retired", False)),
            "implemented": implemented,
            "safe_to_execute_by_this_helper": False,
            "capability_allowed": False,
            "authority": dict(NON_MUTATING_CAPABILITY_FLAGS),
            "missing_authority_sources": list(ADR_AUTHORITY_SOURCES),
        })
    return rows


def authority_source_rows() -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    for item in AUTHORITY_SOURCE_MATRIX:
        rows.append({
            **item,
            "status": "policy_blocked",
            "retired": False,
            "implemented": False,
            "current_evidence": [],
            "capability_allowed": False,
            "safe_to_execute_by_this_helper": False,
            "authority": dict(NON_MUTATING_CAPABILITY_FLAGS),
        })
    return rows


def build_status() -> dict[str, Any]:
    rows = matrix_rows()
    authority_rows = authority_source_rows()
    retired_ids = [row["id"] for row in rows if row["retired"]]
    return {
        "schema": SCHEMA,
        "version": VERSION,
        "ok": True,
        "read_only": True,
        "contract_adr": CONTRACT_ADR,
        "contract_adrs": list(CONTRACT_ADRS),
        "related_design_adrs": list(RELATED_DESIGN_ADRS),
        "source_remaining_work": SOURCE_REMAINING_WORK,
        "current_policy": CURRENT_POLICY,
        "policy": POLICY,
        "guardrails_schema": GUARDRAILS_SCHEMA,
        "unsupported_mutating_operations": list(UNSUPPORTED_MUTATING_OPERATIONS),
        "authority": dict(NON_MUTATING_CAPABILITY_FLAGS),
        "required_authority_sources": list(ADR_AUTHORITY_SOURCES),
        "authority_sources": authority_rows,
        "future_schemas_required": list(FUTURE_SCHEMAS_REQUIRED),
        "remaining_work": rows,
        "retired_remaining_work": retired_ids,
        "summary": {
            "remaining_work_count": len(rows),
            "policy_blocked_count": sum(1 for row in rows if row["status"] == "policy_blocked"),
            "implemented_count": sum(1 for row in rows if row["implemented"]),
            "retired_count": len(retired_ids),
            "capability_allowed_count": sum(1 for row in rows if row["capability_allowed"]),
            "finalization_flags_policy": CURRENT_POLICY,
        },
        "decision": {
            "status": "partial_policy_blocked",
            "reason": "gated_executor_available_other_surfaces_blocked",
            **NON_MUTATING_CAPABILITY_FLAGS,
        },
    }


def main() -> int:
    args = parse_args()
    print(json.dumps(build_status(), indent=2 if args.pretty else None, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
