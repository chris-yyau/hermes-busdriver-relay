#!/usr/bin/python3
"""Production authority-negative parser smoke for agent draft dispatch."""

from __future__ import annotations

import argparse
import json
import os

SCHEMA = "hermes-busdriver-agent-smoke/v0"
BLOCKER = "agent_containment_and_credential_broker_unavailable"


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__,
        epilog=(
            "policy_blocked\n"
            f"{BLOCKER}\n"
            "Production never dispatches an agent from this entrypoint."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--plugin-root", required=True)
    ap.add_argument("--agent", default="pi", choices=["pi", "opencode"])
    ap.add_argument("--pi-bin", default=os.environ.get("PI_BIN", "pi"), help="Pi executable for --agent pi")
    ap.add_argument("--pi-model", default=os.environ.get("PI_BD_MODEL", "openai-codex/gpt-5.4-mini"), help="Pi model for --agent pi")
    ap.add_argument("--opencode-bin", default=os.environ.get("OPENCODE_BIN", "opencode"), help="OpenCode executable for --agent opencode")
    ap.add_argument("--opencode-agent", default=os.environ.get("OPENCODE_BD_AGENT", "build"), help="OpenCode agent for --agent opencode")
    ap.add_argument("--opencode-model", default=os.environ.get("OPENCODE_BD_MODEL", ""), help="Optional OpenCode provider/model")
    ap.add_argument("--timeout", type=int, default=900)
    ap.add_argument("--keep-repo", action="store_true", help="Accepted for parser compatibility; production never creates a repository")
    ap.add_argument("--pretty", action="store_true")
    args = ap.parse_args()

    result = {"schema": SCHEMA, "ok": False, "status": "blocked", "reason": BLOCKER}
    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
