REDACTION = "[REDACTED]"
# Kept byte-identical to the sibling relays (deliver, delivery-status, pr-grind-check,
# pr-grind-loop, litmus-status, finalization-readiness). These are standalone executables with no
# shared import path, so the block is restated rather than shared; a contract test asserts they
# agree, which is what keeps one copy from drifting into a leak.
SENSITIVE_PATTERNS = [
    # URL userinfo runs FIRST and on purpose. Generic token matching can redact the whole
    # non-whitespace tail, including the host and repository needed for diagnostics.
    # Collapsing only userinfo removes credentials while preserving that safe suffix.
    (re.compile(r"(?i)\b([a-z][a-z0-9+.-]*://)([^/\s:@]+(?::[^/\s@]*)?)@"), rf"\1{REDACTION}@"),
    (re.compile(r"(?i)\b(authorization\s*:\s*bearer\s+)([A-Za-z0-9._~+/=-]{8,})"), rf"\1{REDACTION}"),
    (re.compile(r"\bgh[pousr]_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bgithub_pat_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b"), REDACTION),
    (re.compile(r"(?i)((?:--(?:api[_-]?key|secret|token|password|passwd))\s+)([^\s'\"&]+)"), rf"\1{REDACTION}"),
    (re.compile(r'(?i)("(?:api[_-]?key|secret|token|password|passwd)"\s*:\s*")([^"]+)(")'), rf"\1{REDACTION}\3"),
    (re.compile(r"(?i)\b((?:api[_-]?key|secret|token|password|passwd)\s*[:=]\s*)([^\s'\"&]+)"), rf"\1{REDACTION}"),
]
CREDENTIAL_ENV_KEYS = ("GH_TOKEN", "GITHUB_TOKEN", "GH_ENTERPRISE_TOKEN", "GITHUB_ENTERPRISE_TOKEN")


def credential_env_values() -> list[str]:
    """Our own credential values, longest first, so a nested value cannot survive its container."""
    values = {os.environ.get(key) for key in CREDENTIAL_ENV_KEYS}
    return sorted((value for value in values if isinstance(value, str) and len(value) >= 8), key=len, reverse=True)


def redact_text(text: str) -> str:
    for value in credential_env_values():
        text = text.replace(value, REDACTION)
    for pattern, replacement in SENSITIVE_PATTERNS:
        text = pattern.sub(replacement, text)
    return text


def redact_value(value: Any, known: tuple[str, ...] = (), _depth: int = 0) -> Any:
    """`known` is the capability values this payload's own keys named — see capability_scalars().

    Replaced before the shape patterns run, and for the same reason credential_env_values() is: an
    opaque credential matches no shape, so its literal value is the only thing that can find it
    again where no key names it. redact_text() keeps its single-argument signature — the parity
    suite monkeypatches it as a one-arg function — so the learned values are applied here.

    Kept byte-compatible with delivery-status.redact_value, plus a depth/size bound because the
    input here can be a hostile JSON document rather than our own envelope.
    """
    if _depth > 100:
        return REDACTION
    if isinstance(value, str):
        for secret in known:
            value = value.replace(secret, REDACTION)
        return redact_text(value)
    if isinstance(value, list):
        return [redact_value(item, known, _depth + 1) for item in value[:10000]]
    if isinstance(value, dict):
        # The key is untrusted text too, and here emphatically so: this input is a hostile JSON
        # document, not our own envelope, so `{"<token>": "seen"}` is simply one of the shapes it
        # can be. `known` and the shape patterns find a credential in a VALUE; neither reaches a key
        # that IS one. Routing the key through the str branch applies both halves to it.
        return {
            redact_value(str(key), known, _depth + 1): redact_value(item, known, _depth + 1)
            for key, item in value.items()
        }
    return value


# Restated from hermes-busdriver-delivery-status, which restates it from agent-draft, whose leaked
# lock token established the rule: a KEY names a capability, and no value pattern can see one.
# redact_text() matches SHAPES — `ghp_…`, `token: <value>`, a URL userinfo — so an opaque enterprise
# credential under an opaque key has nothing to match on and is emitted verbatim. That is r32 High 1
# precisely: every validator here binds the fields it REQUIRES and says nothing about the ones it
# does not, so a fully-bound child payload carrying one extra nested `token` was accepted, retained
# under `delivery_status`/`agent_balance_plan`, and printed. The key is the only thing that names
# it, so the key is what gets read.
#
# `capability` stays SINGULAR deliberately: `relay_capabilities` is delivery-status's own map of
# relay script paths, which this probe re-emits wholesale, and redacting it would destroy the field
# rather than protect anything in it.
CAPABILITY_KEYS = re.compile(
    r"(?i)(^|_)(tokens?|secrets?|credentials?|capability|password|passwd|passphrase"
    r"|authorization|bearer|api[_-]?key|access[_-]?key|private[_-]?key)($|_)"
)


def capability_value(key: str, value: Any) -> Any:
    """What a capability-shaped key is still allowed to say.

    A bool or null under `token_redacted` / `has_secret` is a fact ABOUT a capability, not one: no
    credential survives in one bit. hermes-busdriver-lock publishes exactly that — `token_redacted:
    true` — as its proof that it stripped the release token, so blanket-redacting every key that
    merely says "token" would replace the proof with a string and cost the reader the only signal
    that says the strip happened. Everything that can carry bytes — a string, a number, or a
    container nesting either — is redacted, because only those can be a credential.

    The `_count` carve-out is this relay's alone, and it is why the signature takes the key that
    delivery-status's copy has no need of: readiness ingests finalization-contract-status, whose
    `summary.capability_allowed_count: 0` is capability-shaped by key and numeric by value. A count
    of capabilities is a fact ABOUT them in exactly the sense a bool is, and it is the
    authority-negative signal this envelope exists to publish — so redacting it would destroy the
    field rather than protect anything in it, which is the same reason `capability` stays singular.
    """
    if isinstance(value, bool) or value is None:
        return value
    if isinstance(value, int) and key.endswith("_count"):
        return value
    return REDACTION


def strip_capabilities(value: Any, _depth: int = 0) -> Any:
    """Recursively drop capability-bearing keys from anything bound for the envelope.

    Recursive because the capability is not always at the top, and keyed on shape rather than on an
    allowlist because the leak was always a field nobody enumerated: `unknown_extra_field` nesting
    a `token` is exactly the payload a strict-but-partial validator waves through.
    """
    if _depth > 100:
        return REDACTION
    if isinstance(value, dict):
        return {
            key: capability_value(str(key), item)
            if CAPABILITY_KEYS.search(str(key))
            else strip_capabilities(item, _depth + 1)
            for key, item in value.items()
        }
    if isinstance(value, list):
        return [strip_capabilities(item, _depth + 1) for item in value[:10000]]
    return value


def capability_scalars(value: Any) -> tuple[str, ...]:
    """Collect bounded opaque values named by capability-shaped keys.

    Shape redaction cannot recognize a random enterprise token. A sensitive key is the
    provenance that identifies it; collect that value before stripping the key so copies nested
    elsewhere in the same child payload are redacted too.
    """
    found: set[str] = set()
    stack: list[tuple[Any, bool, int]] = [(value, False, 0)]
    visited = 0
    while stack and visited < 10_000 and len(found) < 256:
        item, sensitive, depth = stack.pop()
        visited += 1
        if depth > 64:
            continue
        if isinstance(item, dict):
            for key, child in item.items():
                child_sensitive = sensitive or bool(CAPABILITY_KEYS.search(str(key)))
                stack.append((child, child_sensitive, depth + 1))
        elif isinstance(item, list):
            stack.extend((child, sensitive, depth + 1) for child in item)
        elif sensitive and isinstance(item, bytes):
            text = item[:4097].decode(errors="replace")
            if 8 <= len(text) <= 4096:
                found.add(text)
        elif sensitive and isinstance(item, str) and 8 <= len(item) <= 4096:
            found.add(item)
    return tuple(sorted(found, key=len, reverse=True))


# What one child named, every later pass redacts — for the life of the process.
#
# sanitized_payload() STRIPS the key that names a value, so by the time the final envelope crosses
# the funnel there is nothing left to learn from. A copy of those same opaque bytes sitting under an
# ordinary key in a DIFFERENT child would then have nothing to match on: delivery-status embeds its
# own phase-0 view while this probe runs phase-0 again itself, so the same value genuinely does
# arrive twice, named once. Learning is therefore cumulative rather than per-payload, which is the
# only ordering in which "collect before stripping" survives a second pass over already-stripped
# output. Bounded like capability_scalars()'s own collect, since a hostile child chooses how much
# it names.
LEARNED_CAPABILITY_VALUES: set[str] = set()
MAX_LEARNED_CAPABILITY_VALUES = 256


def sanitized_payload(value: Any) -> Any:
    """The one funnel every untrusted child object crosses on its way into this envelope.

    Both transforms, always, in one place: capability-shaped keys stripped, then every remaining
    string redacted by shape. Two call sites that each remembered to do this would be two call
    sites that can forget, and r32 is the list of the ones that did.
    """
    if len(LEARNED_CAPABILITY_VALUES) < MAX_LEARNED_CAPABILITY_VALUES:
        LEARNED_CAPABILITY_VALUES.update(capability_scalars(value))
    known = tuple(sorted(LEARNED_CAPABILITY_VALUES, key=len, reverse=True))
    return redact_value(strip_capabilities(value), known)


# The window handed to redact_text() is bounded BEFORE the regexes run. redact_text() walks every
# SENSITIVE_PATTERN over its whole input — including a URL-userinfo class with no length bound — so
# a hostile subprocess returning 500MB of stderr, or a remote URL of the same size, costs that much
# CPU and memory inside a helper whose entire job is to emit a few KB. Bounding after redaction, as
# r25 did, means the bound never applies to the expensive step it exists to protect.
#
# 8192, not a tight bound: every shape pattern above matches far less than this, so the span exists
# to keep a long-but-real match (a `token: <value>` with a verbose value, a long URL) whole inside
# the budget. It costs 8KB of regex work and buys the guarantee below.
REDACTION_PATTERN_SPAN = 8192

# Over budget, output is REFUSED — not sliced to its last `budget` bytes, which is what r26 did and
# what leaked. The value classes for `token:`, `--token`, `"token":` and `Bearer` are unbounded, so
# a long enough value has the very prefix that IDENTIFIES it as a secret cut away by that slice;
# the remainder matches no shape pattern and the tail is emitted raw. No window size fixes it —
# the prefix sits arbitrarily far from the tail. An unmatched fragment of a secret is still a
# secret, and no diagnostic from an attacker-controlled 12KB+ of output is worth emitting one.
REDACTED_OVERSIZED = "[REDACTED:OVERSIZED_OUTPUT]"


def redaction_overlap() -> int:
    """Enough headroom that anything redact_text() can match fits whole inside the scan budget.

    Sized from our OWN credential values, not guessed: an opaque enterprise token matches no shape
    pattern, so length is the only thing that can guarantee a configured credential lands inside
    the budget whole rather than pushing a legitimate output over it.
    """
    longest_secret = max((len(value) for value in credential_env_values()), default=0)
    return max(REDACTION_PATTERN_SPAN, longest_secret + 64)


def bounded_redacted_tail(value: "str | bytes | None", limit: int) -> str:
    if isinstance(value, bytes):
        text = value.decode(errors="replace")
    else:
        text = value or ""
    if limit <= 0:
        return ""
    if len(text) > limit + redaction_overlap():
        return REDACTED_OVERSIZED
    # Every pattern now sees its whole candidate span, so a match that ends inside the emitted
    # region was matched whole; the slice below can only cut text no pattern claimed.
    return redact_text(text)[-limit:]


def tail(value: str | bytes | None, limit: int = 4000) -> str:
    """Redact, then bound — over a window bounded first. See bounded_redacted_tail()."""
    return bounded_redacted_tail(value, limit)


# Every flag that lets the caller name a program this probe runs or forwards for execution.
CUSTOM_HELPER_FLAGS = ("pr_grind_check_script", "litmus_status_script", "agent_balance_plan_script")
# Production authors none of its own evidence, so this is False here and stays False. Only
# tests/fixtures/finalization-readiness-test-harness flips it, and production never loads it.
FIXTURE_MODE = False


def custom_helper_refusal(custom: "list[str]") -> "dict[str, Any] | None":
    """Refuse every caller-named helper executable, before anything spawns.

    The same refusal delivery-status makes, made here too rather than only relied on downstream:
    --agent-balance-plan-script never reaches delivery-status, so a child-only gate would leave
    this probe spawning the caller's program itself. See delivery-status.custom_helper_refusal()
    for why r28's --fixture-mode was not a boundary — the caller that names the program is the
    caller that passes the flag, so it only labelled the output of code that had already run.
    """
    if custom:
        return {"ok": False, "error": "custom_helper_execution_not_permitted", "flags": custom}
    return None


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Read-only finalization readiness / Busdriver handoff envelope")
    parser.add_argument("--repo", default=".", help="Target git repo/worktree to inspect read-only")
    parser.add_argument("--plugin-root", help="Busdriver plugin root")
    parser.add_argument("--state-dir", default=".claude", help="Busdriver state dir name for Phase-0 marker/config discovery")
    parser.add_argument("--relay-state-dir", help="Hermes relay state dir for lock/run lookup")
    parser.add_argument("--relay-role", help="Optionally resolve one relay equivalent role through delivery-status")
    parser.add_argument("--relay-config", help="Relay config JSON path for optional relay role resolution")
    parser.add_argument("--relay-role-timeout", type=int, default=DEFAULT_RELAY_ROLE_TIMEOUT)
    parser.add_argument("--user-config", help="Busdriver user config path for Phase-0 discovery")
    parser.add_argument("--pr", help="Pull request number for post-PR readiness")
    parser.add_argument("--target", default="auto", choices=["auto", "commit", "pr", "merge", "delivery"], help="Finalization handoff target to evaluate")
    parser.add_argument("--pr-grind-check-script", help="Path to hermes-busdriver-pr-grind-check for delivery-status")
    parser.add_argument("--pr-grind-timeout", type=int, default=180)
    parser.add_argument("--litmus-status-script", help="Path to hermes-busdriver-litmus-status for delivery-status")
    parser.add_argument("--litmus-status-timeout", type=int, default=60)
    parser.add_argument("--agent-balance-plan-script", help="Path hermes-busdriver-agent-balance-plan helper")
    parser.add_argument("--agent-balance-plan-timeout", type=int, default=DEFAULT_AGENT_BALANCE_PLAN_TIMEOUT)
    parser.add_argument("--drift-baseline", help="Read-only Busdriver drift baseline JSON to compare through delivery/Phase-0 status")
    parser.add_argument(
        "--delivery-status-timeout",
        type=int,
        default=None,
        help="Wrapper timeout for delivery-status; defaults to max(180, nested delivery-status helper timeouts + 30s margin)",
    )
    parser.add_argument("--phase0-status-timeout", type=int, default=60)
    parser.add_argument("--pretty", action="store_true")
    args = parser.parse_args()

    custom = sorted(flag for flag in CUSTOM_HELPER_FLAGS if getattr(args, flag, None))
    refusal = custom_helper_refusal(custom)
    if refusal is not None:
        # Refusal is a normal fail-closed envelope, so it ships on stdout with the blocked exit
        # code every other envelope here uses — stderr would make the only machine-readable
        # signal a caller gets for this path the one place they do not parse.
        print(json.dumps(refusal, sort_keys=True))
        raise SystemExit(2)
    return args


CONTAINED_PATH = "/usr/bin:/bin:/usr/sbin:/sbin"
# The readiness probe's trusted children are relay scripts that re-derive their own trusted runtime
# from their frozen root-owned tables, so they need no ambient help to find git/gh/jq.
# HERMES_BUSDRIVER_PRIVATE_RUNTIME is gone with the directory of private copies it used to select.
FORWARDED_CHILD_ENV_KEYS = ("GH_TOKEN", "GITHUB_TOKEN", "GH_ENTERPRISE_TOKEN")
CREDENTIAL_CHILD_ENV_KEYS = ("GH_TOKEN", "GITHUB_TOKEN", "GH_ENTERPRISE_TOKEN")
# Every helper this probe executes by default, plus the helpers delivery-status can execute,
# pinned to the bytes that were reviewed.
# Kept in sync with config/trusted-runtime-manifest.json by test_trusted_runtime_manifest.
# This is intentionally narrower than delivery_status_runtime, which also contains metadata-only
# public entrypoints. Including metadata-only smoke here creates a smoke<->readiness hash cycle.
TRUSTED_READINESS_HELPER_DIGESTS = {'scripts/hermes-busdriver-agent-balance-plan': '5d10873d3606b96e27ef5a33cb0c9f130f9e96f08e5dd71b753a3fd1fa64c719',
                                    'scripts/hermes-busdriver-delivery-status': '576716169dd6236275e4924c8cfa16fe792b30818d1d15c452993bc75894ad4d',
                                    'scripts/hermes-busdriver-finalization-contract-status': 'd85a8f97a488d82d0e8a99cdaf46aeec516344c94aadb65448e3fbcffc6c738c',
                                    'scripts/hermes-busdriver-litmus-status': 'fd59d1ab20ee85f4d3dab1d072697aed6596a017dd5a18b8b8f15b71b325d68a',
                                    'scripts/hermes-busdriver-lock': '193219fe3223ef1454a31d860233c693d7fa662a5edae36c5aafb1c9316561a1',
                                    'scripts/hermes-busdriver-pr-grind-check': 'e68251118772df8752c38fb958748cd5751a8a822d549b625fd756c86026c212',
                                    'scripts/hermes-busdriver-relay-role': '1a3fa071a9f7b4c990120d8a9dfa6e9c32fc44ec70714a29ab29c90151f0992f',
                                    'scripts/hermes-busdriver-status': 'da1b826bc7c61ad425e9aef771069ed89ddfde69917b8dfd3890cebb7d278643'}


def child_env(*, credentials: bool = False) -> dict[str, str]:
    """Explicit allowlist for every child of this probe.

    An inherited environment lets a caller pick the child's PATH and inject startup/loader code
    through PYTHONPATH/BASH_ENV/LD_*/DYLD_*; ambient GIT_* redirects git. None of it is forwarded.

    `credentials` defaults to FALSE and is opt-in per call site. r25 forwarded GH_TOKEN and friends
    to EVERY child, including the arbitrary executable named by --agent-balance-plan-script — so
    pointing that flag at any program handed it the operator's GitHub credentials. Only the
    digest-authenticated helpers that actually talk to GitHub get them.
    """
    allowed = {"HOME", "TMPDIR", "TMP", "TEMP", "LANG", "LC_ALL", "LC_CTYPE", "USER", "LOGNAME", "TERM", "NO_COLOR"}
    env = {key: value for key, value in os.environ.items() if key in allowed or key.startswith("LC_")}
    env["PATH"] = CONTAINED_PATH
    keys = FORWARDED_CHILD_ENV_KEYS if credentials else tuple(k for k in FORWARDED_CHILD_ENV_KEYS if k not in CREDENTIAL_CHILD_ENV_KEYS)
    env.update({key: os.environ[key] for key in keys if isinstance(os.environ.get(key), str)})
    return env


def _read_authenticated(path: Path, expected_digest: str) -> bytes:
    """Read a helper's bytes, proving identity and cost across the read rather than trusting the name.

    Two things run after the open, and until r34 neither was proved. The READ was unbounded: the
    candidate chose how much memory this process spent, and it chose before the digest that would
    have rejected it. And identity was compared once, at open, so everything the read spans — a
    truncation, a growth, a new hard link, a chmod, a rename away from the name — was covered by
    nothing at all.

    So the size is checked before the read, the read is capped one byte past the bound (reading
    exactly the bound cannot distinguish "this file IS the bound" from "this is a prefix of a larger
    one"), and the fd is re-examined afterwards against what it said at open. `st_size` is never
    trusted as a stopping condition — it is read from the very file the check exists to doubt.

    The closing lstat is the half no descriptor can see: the fd proves OUR inode is unchanged and
    says nothing about where the NAME points, and the name is what the caller goes on to use.
    """
    before = path.lstat()
    if path.is_symlink() or not stat.S_ISREG(before.st_mode):
        raise OSError("helper_not_regular")
    fd = os.open(path, os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0))
    try:
        opened = os.fstat(fd)
        if (opened.st_dev, opened.st_ino) != (before.st_dev, before.st_ino):
            raise OSError("helper_identity_changed")
        if (
            not stat.S_ISREG(opened.st_mode)
            or opened.st_uid != os.getuid()
            or opened.st_nlink != 1
        ):
            raise OSError("helper_metadata_invalid")
        if opened.st_size > MAX_AUTHENTICATED_HELPER_BYTES:
            # Refused without ever holding it. This is the whole point of the bound.
            raise OSError("helper_too_large")
        chunks: list[bytes] = []
        remaining = MAX_AUTHENTICATED_HELPER_BYTES + 1
        while remaining > 0:
            chunk = os.read(fd, min(1024 * 1024, remaining))
            if not chunk:
                break
            chunks.append(chunk)
            remaining -= len(chunk)
        data = b"".join(chunks)
        if len(data) > MAX_AUTHENTICATED_HELPER_BYTES:
            raise OSError("helper_too_large")
        after = os.fstat(fd)
        if (
            (after.st_dev, after.st_ino) != (opened.st_dev, opened.st_ino)
            or not stat.S_ISREG(after.st_mode)
            or after.st_uid != os.getuid()
            or after.st_nlink != 1
            or after.st_size != opened.st_size
            or stat.S_IMODE(after.st_mode) != stat.S_IMODE(opened.st_mode)
            or len(data) != after.st_size
        ):
            raise OSError("helper_changed_during_read")
        landed = os.lstat(path)
        if (landed.st_dev, landed.st_ino) != (after.st_dev, after.st_ino):
            raise OSError("helper_replaced_during_read")
    finally:
        os.close(fd)
    if hashlib.sha256(data).hexdigest() != expected_digest:
        raise OSError("helper_digest_invalid")
    return data


def _names_created_inode(parent_fd: int, name: str, created: os.stat_result) -> bool:
    """True iff `name` under `parent_fd` still resolves, no-follow, to the inode we created.

    The immediate parent plus the final component, not the whole path: the last component is the
    only one this call created, and resolving it through the descriptor the create already held
    means an ancestor swapped afterwards cannot redirect the answer.
    """
    try:
        landed = os.lstat(name, dir_fd=parent_fd)
    except OSError:
        return False
    return (landed.st_dev, landed.st_ino) == (created.st_dev, created.st_ino)


def _write_exclusive(path: Path, data: bytes, mode: int) -> os.stat_result:
    """Write the retained helper, then prove the descriptor still holds exactly what was authenticated.

    The bytes reaching here were hashed against a pin, but the hash authenticated MEMORY. Without a
    flush they need not be on disk when the child is launched to read them, and without a closing
    re-read "we wrote it" and "the file holds it" stay separate claims — the second is the one the
    execution below actually depends on. `os.chmod(path, ...)` was the same shape of gap: it names
    the file a second time, and a second resolution can land somewhere else.

    The digest proves OUR inode is intact and can prove nothing else; the closing identity check
    proves the other direction — that `path` still REACHES it — which is the half no descriptor can
    see. An adversary who renames our file aside and its own into place leaves every fd-visible
    field (type, owner, link count, size, mode, digest) describing our inode exactly, and leaves the
    name the child is about to execute pointing at theirs.
    """
    # One parent descriptor for the whole operation: the create, the identity check and the failure
    # unlink all resolve the final component through it, so they cannot disagree about the parent.
    parent_fd = os.open(path.parent, os.O_RDONLY | getattr(os, "O_DIRECTORY", 0) | getattr(os, "O_NOFOLLOW", 0))
    try:
        # O_RDWR, not O_WRONLY: _digest_fd reads the bytes back through THIS descriptor, and a
        # write-only one cannot be read. Reopening the name would resolve it a second time.
        fd = os.open(path.name, os.O_RDWR | os.O_CREAT | os.O_EXCL | getattr(os, "O_NOFOLLOW", 0), mode, dir_fd=parent_fd)
        # The inode THIS call created. The failure path deletes only this one, never a replacement.
        created = os.fstat(fd)
        try:
            view = memoryview(data)
            while view:
                written = os.write(fd, view)
                if written <= 0:
                    raise OSError("short_write")
                view = view[written:]
            os.fsync(fd)
            os.fchmod(fd, mode)
            st = os.fstat(fd)
            if (
                not stat.S_ISREG(st.st_mode)
                or st.st_uid != os.geteuid()
                or st.st_nlink != 1
                or st.st_size != len(data)
                or stat.S_IMODE(st.st_mode) != mode
            ):
                raise OSError("retained_helper_metadata_invalid")
            if _digest_fd(fd, st.st_size) != hashlib.sha256(data).hexdigest():
                raise OSError("retained_helper_replaced_after_write")
            if not _names_created_inode(parent_fd, path.name, created):
                raise OSError("retained_helper_replaced_after_write")
        except BaseException:
            # Never leave a half-written helper for the next step to execute. But by now the name may
            # belong to something else — the case the identity check above fails on — and deleting
            # THAT is a second bug wearing the first one's cleanup.
            if _names_created_inode(parent_fd, path.name, created):
                try:
                    os.unlink(path.name, dir_fd=parent_fd)
                except OSError:
                    pass
            raise
        finally:
            os.close(fd)
        # Handed back so a caller whose own later step fails can prove, before unlinking, that the
        # name still reaches THIS inode. Without it the caller's cleanup resolves the name a second
        # time — the very thing every check above refuses to do.
        return created
    finally:
        os.close(parent_fd)


def _digest_fd(fd: int, size: int) -> str:
    """sha256 of the bytes behind THIS descriptor. `pread` so it neither moves nor rides the offset."""
    digest = hashlib.sha256()
    offset = 0
    while offset < size:
        chunk = os.pread(fd, min(1 << 16, size - offset), offset)
        if not chunk:
            raise OSError("retained_helper_truncated")
        digest.update(chunk)
        offset += len(chunk)
    return digest.hexdigest()


@contextlib.contextmanager
def authenticated_helper(*relatives: str) -> Any:
    """Yield private copies of default helpers, executed from the bytes we verified.

    r25 executed `ROOT / relative` directly with no digest and no metadata check at all — any
    tampered or swapped sibling answered, and the readiness gate believed it. Hashing the path and
    then executing the same pathname would still leave the TOCTOU window the r25 review named: the
    file can be replaced, or a hard link mutated, between the check and the exec. So the verified
    BYTES are what get written to a private 0700 bundle and run; the source path never reaches the
    exec line.

    The WHOLE runtime closure is materialized, not just the requested helper, because
    delivery-status resolves its own siblings (lock, litmus-status, pr-grind-check) through
    `ROOT = Path(__file__).resolve().parents[1]`. Copying one script into a bare temp dir would
    silently repoint ROOT at that dir and every sibling lookup would miss — which is why the
    bundle mirrors `scripts/` layout. This is the same closure, and the same reason, as
    deliver.materialize_delivery_status_runtime.
    """
    authenticated = {
        relative: _read_authenticated(ROOT / relative, digest)
        for relative, digest in TRUSTED_READINESS_HELPER_DIGESTS.items()
    }
    with tempfile.TemporaryDirectory(prefix="hermes-readiness-runtime-") as temp:
        bundle = Path(temp)
        bundle.chmod(0o700)
        scripts_dir = bundle / "scripts"
        scripts_dir.mkdir()
        # chmod, not mkdir(mode=): mkdir's mode is masked by the caller's umask.
        scripts_dir.chmod(0o700)
        for relative, data in authenticated.items():
            target = bundle / relative
            _write_exclusive(target, data, 0o500)
            # Re-authenticate the copy we are about to execute, not the one we read.
            _read_authenticated(target, TRUSTED_READINESS_HELPER_DIGESTS[relative])
        retained = {relative: (bundle / relative, authenticated[relative]) for relative in relatives}
        yield tuple(retained[relative] for relative in relatives) if len(relatives) != 1 else retained[relatives[0]]


RETAINED_PYTHON_STDIN_LOADER = (
    "import sys\n"
    "virtual = sys.argv[1]\n"
    "program = sys.stdin.buffer.read()\n"
    "sys.argv = [virtual, *sys.argv[2:]]\n"
    "namespace = {'__name__': '__main__', '__file__': virtual, '__package__': None, '__cached__': None}\n"
    "exec(compile(program, virtual, 'exec'), namespace)\n"
)


class RetainedPythonCommand(list[str]):
    def __init__(self, argv: list[str], stdin_bytes: bytes) -> None:
        super().__init__(argv)
        self.stdin_bytes = stdin_bytes


def python_child(script: Path | tuple[Path, bytes], *args: str) -> list[str]:
    # -I: no PYTHONPATH, no user site-packages, no cwd on sys.path for the trusted child.
    if isinstance(script, tuple):
        virtual, program = script
        return RetainedPythonCommand(
            [str(trusted_executable_path("python3")), "-I", "-c", RETAINED_PYTHON_STDIN_LOADER, str(virtual), *args],
            program,
        )
    return [str(trusted_executable_path("python3")), "-I", str(script), *args]


def run_json(cmd: list[str], timeout: int, *, credentials: bool = False) -> tuple[dict[str, Any], int]:
    """Every child of this probe is ingested here, so this is where they are sanitized.

    All four loaders reach their helper through this one function, on the success path and on every
    error path alike — which is what makes it the boundary rather than four boundaries that can each
    forget one. r32 High 1 was four call sites' worth of "the validator bound the fields it
    required": the payloads were embedded verbatim under `delivery_status`, `phase0_status`,
    `finalization_contract_status` and `agent_balance_plan`, and only the agent-balance-plan FIXTURE
    path redacted anything at all.

    Sanitizing here rather than after validation is safe in the one direction that matters: the
    funnel preserves bools and rewrites only strings and capability-shaped keys, so it can never
    turn a payload a validator would REJECT into one it accepts — `has_positive_contract_authority`
    still sees `is not False`, and a redacted string still fails an `== SCHEMA` literal.
    """
    data, rc = _ingest_json(cmd, timeout, credentials=credentials)
    return sanitized_payload(data), rc


def _ingest_json(cmd: list[str], timeout: int, *, credentials: bool = False) -> tuple[dict[str, Any], int]:
    try:
        bounded = run_bounded(cmd, timeout=timeout, env=child_env(credentials=credentials), stdin_bytes=getattr(cmd, "stdin_bytes", None))
        if bounded.overflowed:
            # A tuple like every other path here: the callers unpack `data, rc`, so the bare dict
            # this returned before unpacked to its own KEYS — `data="ok"`, `rc="error"` — and the
            # refusal it exists to deliver never survived its own return statement.
            return {"ok": False, "error": "helper_output_too_large"}, 1
        if bounded.timed_out:
            raise subprocess.TimeoutExpired(cmd, timeout)
        cp = subprocess.CompletedProcess(cmd, bounded.returncode, bounded.stdout, bounded.stderr)
    except subprocess.TimeoutExpired as e:
        return {
            "ok": False,
            "error": "timeout",
            "cmd": cmd,
            "returncode": 124,
            "stdout_tail": tail(e.stdout),
            "stderr": tail(e.stderr),
        }, 124
    except OSError as e:
        # FileNotFoundError plus NotADirectoryError/PermissionError from an unusable child
        # path: keep the existing rc 127 shape rather than tracebacking out of the probe.
        return {"ok": False, "error": "command_not_found", "cmd": cmd, "stderr": tail(str(e))}, 127
    try:
        data = json.loads(cp.stdout)
    except json.JSONDecodeError as e:
        return {
            "ok": False,
            "error": "invalid_json",
            "cmd": cmd,
            "returncode": cp.returncode,
            "parse_error": tail(str(e), 512),
            "stdout_tail": tail(cp.stdout),
            "stderr": tail(cp.stderr),
        }, cp.returncode
    if not isinstance(data, dict):
        return {"ok": False, "error": "invalid_json_type", "cmd": cmd, "returncode": cp.returncode}, cp.returncode
    if cp.returncode != 0:
        data["ok"] = False
        data["returncode"] = cp.returncode
        data["stderr"] = tail(cp.stderr)
    return data, cp.returncode


def effective_delivery_status_timeout(args: argparse.Namespace) -> int:
    if args.delivery_status_timeout is not None:
        return args.delivery_status_timeout
    nested_budget = int(args.pr_grind_timeout or 0) + int(args.litmus_status_timeout or 0) + DELIVERY_STATUS_TIMEOUT_MARGIN
    if args.relay_role:
        nested_budget += int(args.relay_role_timeout or 0)
    if args.drift_baseline:
        nested_budget += int(args.phase0_status_timeout or 0)
    return max(DEFAULT_DELIVERY_STATUS_TIMEOUT, nested_budget)


def helper_unavailable(schema: str, reason: str, detail: str) -> dict[str, Any]:
    return {
        "schema": schema,
        "ok": False,
        "read_only": True,
        "available": False,
        "reason": reason,
        "detail": detail,
        "authority": BLOCKED_FLAGS,
    }


def load_delivery_status(args: argparse.Namespace, delivery_status: Path) -> tuple[dict[str, Any], int]:
    cmd = python_child(delivery_status, "--repo", args.repo)
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    if args.relay_state_dir:
        cmd += ["--state-dir", args.relay_state_dir]
    if args.relay_role:
        cmd += ["--relay-role", args.relay_role]
    if args.relay_config:
        cmd += ["--relay-config", args.relay_config]
    if args.relay_role and args.relay_role_timeout is not None:
        cmd += ["--relay-role-timeout", str(args.relay_role_timeout)]
    if args.pr:
        cmd += ["--pr", args.pr]
    # No mode to forward: production refuses every --*-script at parse_args(), so the forwards
    # below are unreachable here and exist for the contract harness, which routes the child
    # through the delivery-status harness that honours them.
    if args.pr_grind_check_script:
        cmd += ["--pr-grind-check-script", args.pr_grind_check_script]
    if args.pr_grind_timeout is not None:
        cmd += ["--pr-grind-timeout", str(args.pr_grind_timeout)]
    if args.litmus_status_script:
        cmd += ["--litmus-status-script", args.litmus_status_script]
    if args.litmus_status_timeout is not None:
        cmd += ["--litmus-status-timeout", str(args.litmus_status_timeout)]
    if args.drift_baseline:
        cmd += ["--drift-baseline", args.drift_baseline]
    if args.phase0_status_timeout is not None:
        cmd += ["--phase0-status-timeout", str(args.phase0_status_timeout)]
    if args.state_dir:
        cmd += ["--busdriver-state-dir-name", args.state_dir]
    # delivery-status is the one child that reaches GitHub (through its authenticated pr-grind
    # checker), so it is the one child that gets the credentials.
    return run_json(cmd, effective_delivery_status_timeout(args), credentials=True)


def load_phase0_status(args: argparse.Namespace, phase0_status: Path) -> tuple[dict[str, Any], int]:
    # Readiness reads Phase-0 status; it has no use for resolver bytes, so it does not ask for
    # them. Defense in depth behind the status probe's own canonical-root/digest binding.
    cmd = python_child(phase0_status, "--repo", args.repo, "--state-dir", args.state_dir, "--operation", "repo-mutation", "--no-external-resolver")
    if args.relay_state_dir:
        cmd += ["--relay-state-dir", args.relay_state_dir]
    if args.plugin_root:
        cmd += ["--plugin-root", args.plugin_root]
    if args.user_config:
        cmd += ["--user-config", args.user_config]
    if args.relay_config:
        cmd += ["--relay-config", args.relay_config]
    if args.drift_baseline:
        cmd += ["--drift-baseline", args.drift_baseline]
    return run_json(cmd, args.phase0_status_timeout)


def has_positive_contract_authority(payload: Any) -> bool:
    if isinstance(payload, dict):
        for key, value in payload.items():
            if key in CONTRACT_STATUS_UNSAFE_BOOLEAN_KEYS and value is not False:
                return True
            if has_positive_contract_authority(value):
                return True
    elif isinstance(payload, list):
        return any(has_positive_contract_authority(item) for item in payload)
    return False


def invalid_contract_status(reason: str, data: dict[str, Any], rc: int) -> dict[str, Any]:
    return {
        "schema": FINALIZATION_CONTRACT_STATUS_SCHEMA,
        "ok": False,
        "read_only": True,
        "available": False,
        "reason": reason,
        "helper_returncode": rc,
        "source_schema": data.get("schema") if isinstance(data.get("schema"), str) else None,
        "source_read_only": data.get("read_only") if isinstance(data.get("read_only"), bool) else None,
        "source_ok": data.get("ok") if isinstance(data.get("ok"), bool) else None,
        "authority": BLOCKED_FLAGS,
    }


def load_contract_status(contract_status: Path) -> tuple[dict[str, Any], int]:
    data, rc = run_json(python_child(contract_status), DEFAULT_CONTRACT_STATUS_TIMEOUT)
    if rc != 0:
        return invalid_contract_status("finalization_contract_status_subprocess_failed", data, rc), rc
    if data.get("schema") != FINALIZATION_CONTRACT_STATUS_SCHEMA or data.get("read_only") is not True or data.get("ok") is not True:
        return invalid_contract_status("finalization_contract_status_schema_invalid", data, rc), 1
    if has_positive_contract_authority(data):
        return invalid_contract_status("finalization_contract_status_authority_flags_unsafe", data, rc), 1
    return data, rc


def invalid_agent_balance_plan(reason: str, data: dict[str, Any], rc: int) -> dict[str, Any]:
    return {
        "schema": AGENT_BALANCE_PLAN_SCHEMA,
        "ok": False,
        "read_only": True,
        "available": False,
        "reason": reason,
        "helper_returncode": rc,
        "source_schema": data.get("schema") if isinstance(data.get("schema"), str) else None,
        "source_read_only": data.get("read_only") if isinstance(data.get("read_only"), bool) else None,
        "source_ok": data.get("ok") if isinstance(data.get("ok"), bool) else None,
        "authority": BLOCKED_FLAGS,
    }


AGENT_BALANCE_PLAN_FIXTURE_BLOCKER = "agent_balance_plan_fixture_not_authoritative"


def load_agent_balance_plan(args: argparse.Namespace, balance_plan: Path) -> tuple[dict[str, Any], int]:
    """Run the pinned plan helper, or a caller-named one demoted to a fixture.

    Two separate questions, which r25 conflated into "it printed the right shape":

    1. PROVENANCE. `--agent-balance-plan-script` names an arbitrary executable that authors its
       own stdout. Structural validation proves shape, never origin — the same reason a
       `--*-result-file` is non-authoritative. r25 accepted any script printing
       `schema`/`ok: true`/`read_only: true`, cleared `agent_balance_plan_unavailable` with it,
       and let readiness reach a ready handoff on evidence the caller wrote. It is now labeled
       `fixture` and carries its own blocker, exactly as delivery-status treats a caller-named
       --pr-grind-check-script.
    2. INTEGRITY. The DEFAULT helper is the only authoritative one, and only when its bytes are
       the reviewed bytes, executed from a private copy.
    """
    if args.agent_balance_plan_script:
        script = Path(args.agent_balance_plan_script).expanduser()
        # No credentials: this is an arbitrary executable, not a trusted relay helper.
        # Sanitized whether or not it succeeded — by run_json(), for every child rather than this
        # one. r25 redacted only the failure tails through tail(), so a SUCCESSFUL custom payload
        # was embedded verbatim; r32 then found the same hole under the three children that had no
        # redact_value() call here at all, which is why the funnel moved to the ingest boundary.
        data, rc = run_json(python_child(script), args.agent_balance_plan_timeout)
        result = _validated_balance_plan(data, rc)
        if isinstance(result[0], dict):
            result[0].update({"source": "fixture", "authoritative": False, "script": str(script)})
        return result

    data, rc = run_json(python_child(balance_plan), args.agent_balance_plan_timeout)
    plan, code = _validated_balance_plan(data, rc)
    plan.update({"source": "script", "authoritative": plan.get("ok") is True})
    return plan, code


def _validated_balance_plan(data: dict[str, Any], rc: int) -> tuple[dict[str, Any], int]:
    if rc != 0:
        return invalid_agent_balance_plan("agent_balance_plan_subprocess_failed", data, rc), rc
    if data.get("schema") != AGENT_BALANCE_PLAN_SCHEMA or data.get("read_only") is not True or data.get("ok") is not True:
        return invalid_agent_balance_plan("agent_balance_plan_schema_invalid", data, rc), 1
    if has_positive_contract_authority(data):
        return invalid_agent_balance_plan("agent_balance_plan_authority_flags_unsafe", data, rc), 1
    return data, rc


def summarize_pr(pr: str | None, delivery: dict[str, Any]) -> dict[str, Any] | None:
    if not pr:
        return None
    pr_grind = delivery.get("pr_grind") or {}
    result = pr_grind.get("result") or {}
    return {
        "number": pr,
        "available": pr_grind.get("available"),
        "ok": pr_grind.get("ok"),
        "status": result.get("status"),
        "clean": result.get("clean"),
        "head": result.get("head") or result.get("headRefOid"),
        "url": result.get("url"),
    }


def summarize_dual_review_role(phase0: dict[str, Any], role: str) -> dict[str, Any]:
    relay_roles = phase0.get("relay_equivalent_roles") if isinstance(phase0.get("relay_equivalent_roles"), dict) else {}
    roles = relay_roles.get("roles") if isinstance(relay_roles.get("roles"), dict) else {}
    entry = roles.get(role)
    base = {
        "role": role,
        "configured": False,
        "status": "unavailable",
        "selected_agent": None,
        "configured_route": [],
        "default_route": [],
        "source": None,
        "degraded": True,
        "config_error": "role_not_reported_by_phase0_status",
        "dispatch_allowed": False,
        "mutation_allowed": False,
        "finalization_allowed": False,
        "not_busdriver_native_claude_runtime": True,
    }
    if not isinstance(entry, dict):
        return base
    selected_agent = entry.get("selected_agent") if isinstance(entry.get("selected_agent"), str) else None
    degraded = entry.get("degraded") is not False
    config_error = entry.get("config_error") if isinstance(entry.get("config_error"), str) else None
    return {
        **base,
        "configured": True,
        "status": "degraded" if degraded or not selected_agent else "configured_non_dispatchable_status_only",
        "native_busdriver_role": entry.get("native_busdriver_role"),
        "selected_agent": selected_agent,
        "configured_route": entry.get("configured_route") if isinstance(entry.get("configured_route"), list) else [],
        "default_route": entry.get("default_route") if isinstance(entry.get("default_route"), list) else [],
        "source": entry.get("source") if isinstance(entry.get("source"), str) else None,
        "degraded": degraded,
        "config_error": config_error,
        "same_as_coding_agent": entry.get("same_as_coding_agent") is True,
        "not_busdriver_native_claude_runtime": True,
        "mutation_allowed": False,
        "finalization_allowed": False,
        "dispatch_allowed": False,
    }


def dual_review_readiness(phase0: dict[str, Any]) -> dict[str, Any]:
    configured_roles = {spec["role"]: summarize_dual_review_role(phase0, spec["role"]) for spec in DUAL_REVIEW_REQUIRED_ROLE_SPECS}
    phase0_relay_roles = phase0.get("relay_equivalent_roles") if isinstance(phase0.get("relay_equivalent_roles"), dict) else {}
    relay_config = phase0.get("relay_config") if isinstance(phase0.get("relay_config"), dict) else None
    config_errors = [
        key
        for key in [
            "relay_config_parse_error",
            "relay_config_shape_error",
            "routes_config_error",
            "coding_agent_config_error",
            "avoid_coding_agent_for_review_config_error",
        ]
        if phase0_relay_roles.get(key)
    ]
    return {
        "schema": DUAL_REVIEW_READINESS_SCHEMA,
        "version": DUAL_REVIEW_READINESS_VERSION,
        "read_only": True,
        "ok": False,
        "status": "unsupported_in_this_relay",
        "reason": "programmatic_litmus_pre_pr_dual_review_execution_unsupported",
        "programmatic_execution_supported": False,
        "programmatic_execution_allowed": False,
        "dispatch_allowed": False,
        "not_busdriver_native_claude_runtime": True,
        "required_roles": [spec["role"] for spec in DUAL_REVIEW_REQUIRED_ROLE_SPECS],
        "role_requirements": DUAL_REVIEW_REQUIRED_ROLE_SPECS,
        "configured_relay_roles": configured_roles,
        "relay_config": relay_config,
        "relay_config_errors": config_errors,
        "authority": BLOCKED_FLAGS,
        "required_next_actor": "Busdriver/Claude Code or an explicit operator finalizer with current litmus/pre-PR gates",
        "next_action": "Use this as advisory role-readiness evidence only; do not launch programmatic dual review or write Busdriver markers from this relay.",
        "unsupported_operations": [
            "programmatic_litmus_review_execution",
            "programmatic_pre_pr_lead_review_execution",
            "programmatic_pre_pr_backstop_review_execution",
            "busdriver_marker_write",
            "commit",
            "push",
            "pr_create",
        ],
    }


def marker_flag(summary: dict[str, Any], marker: str, field: str) -> bool | None:
    markers = summary.get("markers") if isinstance(summary.get("markers"), dict) else {}
    entry = markers.get(marker)
    if not isinstance(entry, dict):
        return None
    value = entry.get(field)
    return value if isinstance(value, bool) else None


def fixture_sourced_delivery(delivery: dict[str, Any]) -> bool:
    """True when any delivery evidence came from a caller-named result file."""
    return any(
        isinstance(delivery.get(key), dict) and delivery[key].get("source") == "fixture"
        for key in ("pr_grind", "litmus_status")
    )


def pre_pr_dual_review_evidence(litmus_summary: Any) -> dict[str, Any]:
    """Classify sanitized litmus/pre-PR evidence without reading markers.

    The input must be the already-normalized/redacted
    delivery_status.litmus_status.summary object. This helper deliberately does
    not inspect raw marker files and treats missing/malformed/unsafe summary
    shapes as not fresh.
    """
    base = {
        "schema": PRE_PR_DUAL_REVIEW_EVIDENCE_SCHEMA,
        "version": PRE_PR_DUAL_REVIEW_EVIDENCE_VERSION,
        "read_only": True,
        "advisory_only": True,
        "source": "delivery_status.litmus_status.summary",
        "programmatic_execution_allowed": False,
        "dispatch_allowed": False,
        **BLOCKED_FLAGS,
    }
    if not isinstance(litmus_summary, dict):
        return {**base, "ok": False, "status": "unavailable", "reason": "litmus_summary_unavailable"}

    decision = litmus_summary.get("decision") if isinstance(litmus_summary.get("decision"), dict) else {}
    decision_status = decision.get("status") if isinstance(decision.get("status"), str) else None
    fresh = {
        "litmus_passed_fresh_for_head": marker_flag(litmus_summary, "litmus_passed", "fresh_for_head"),
        "pr_codex_lead_fresh_for_branch_diff": marker_flag(litmus_summary, "pr_codex_lead", "fresh_for_branch_diff"),
        "pr_backstop_verdict_fresh_for_branch_diff": marker_flag(litmus_summary, "pr_backstop_verdict", "fresh_for_branch_diff"),
        "pr_review_passed_fresh_for_branch_diff": marker_flag(litmus_summary, "pr_review_passed", "fresh_for_branch_diff"),
    }
    missing_or_malformed = sorted(key for key, value in fresh.items() if value is None)
    summary_safe = (
        litmus_summary.get("schema") == "hermes-busdriver-litmus-status/v0"
        and litmus_summary.get("read_only") is True
        and litmus_summary.get("authority_safe") is True
        and litmus_summary.get("decision_status_recognized") is True
        and isinstance(litmus_summary.get("ok"), bool)
        and decision.get("not_busdriver_native_claude_runtime") is True
        and all(decision.get(key) is False for key in BLOCKED_FLAGS)
    )
    evidence = {
        "litmus_decision_status": decision_status,
        "freshness": fresh,
        "missing_or_malformed_fields": missing_or_malformed,
    }
    if not summary_safe:
        return {**base, **evidence, "ok": False, "status": "unavailable", "reason": "litmus_summary_unsafe_or_malformed"}
    if litmus_summary.get("ok") is False:
        return {**base, **evidence, "ok": False, "status": "blocked", "reason": "litmus_summary_not_ok"}
    if decision_status == "blocked":
        return {**base, **evidence, "ok": False, "status": "blocked", "reason": "litmus_status_blocked"}

    pr_fresh_keys = [
        "pr_codex_lead_fresh_for_branch_diff",
        "pr_backstop_verdict_fresh_for_branch_diff",
        "pr_review_passed_fresh_for_branch_diff",
    ]
    all_pr_fresh = all(fresh[key] is True for key in pr_fresh_keys)
    all_pr_not_fresh = all(fresh[key] is False for key in pr_fresh_keys)
    if decision_status == "pr_review_fresh" and all_pr_fresh:
        return {**base, **evidence, "ok": True, "status": "fresh_read_only", "reason": "pre_pr_dual_review_markers_fresh"}
    if decision_status == "commit_litmus_fresh" and fresh["litmus_passed_fresh_for_head"] is True and all_pr_not_fresh:
        return {**base, **evidence, "ok": False, "status": "commit_litmus_only", "reason": "commit_litmus_fresh_but_pre_pr_dual_review_not_fresh"}
    if decision_status == "stale_or_missing":
        return {**base, **evidence, "ok": False, "status": "stale_or_missing", "reason": "pre_pr_dual_review_stale_or_missing"}
    return {**base, **evidence, "ok": False, "status": "stale_or_missing", "reason": "pre_pr_dual_review_not_fresh"}


def phase0_blockers(phase0: dict[str, Any]) -> list[str]:
    blockers: list[str] = []
    if phase0.get("returncode", 0) != 0 or phase0.get("ok") is False:
        blockers.append("phase0_status_failed")
    if phase0.get("status_schema") != "hermes-busdriver-status/v0":
        if "phase0_status_failed" not in blockers:
            blockers.append("phase0_status_failed")
        return blockers
    if not ((phase0.get("plugin_root") or {}).get("exists")):
        blockers.append("phase0_busdriver_plugin_unavailable")
    hooks = phase0.get("hooks") or {}
    if not hooks.get("exists") or hooks.get("parse_error"):
        blockers.append("phase0_hooks_unavailable")
    repo = phase0.get("repo") or {}
    if not repo.get("is_git_repo"):
        blockers.append("phase0_repo_unavailable")
    locks = phase0.get("relay_locks") or {}
    if locks.get("active_for_repo_count", 0):
        blockers.append("relay_repo_mutation_lock_active")
    busdriver_drift = phase0.get("busdriver_drift")
    if isinstance(busdriver_drift, dict) and busdriver_drift.get("finalization_compatible") is False:
        blockers.append("busdriver_drift_incompatible")
    return blockers


def phase0_warnings(phase0: dict[str, Any]) -> list[str]:
    warnings: list[str] = []
    if phase0.get("status_schema") != "hermes-busdriver-status/v0":
        return warnings
    cfg = phase0.get("user_config") or {}
    if not cfg.get("exists"):
        warnings.append("busdriver_user_config_unavailable")
    elif cfg.get("parse_error"):
        warnings.append("busdriver_user_config_parse_error")
    resolver = phase0.get("resolve_cli") or {}
    if not resolver.get("ok"):
        warnings.append("busdriver_resolve_cli_unavailable")
    gates = phase0.get("minimum_gate_scripts") or {}
    missing_gates = sorted(name for name, present in gates.items() if not present)
    if missing_gates:
        warnings.append("minimum_gate_scripts_missing")
    return warnings


def infer_target(args: argparse.Namespace, delivery: dict[str, Any]) -> str:
    if args.target != "auto":
        return args.target
    if args.pr:
        return "merge"
    repo = delivery.get("repo") or {}
    if repo.get("dirty"):
        return "commit_or_pr"
    return "delivery"


def delivery_status_schema_valid(delivery: dict[str, Any]) -> bool:
    return (
        delivery.get("schema") == DELIVERY_STATUS_SCHEMA
        and delivery.get("read_only") is True
        and isinstance(delivery.get("ok"), bool)
    )


def is_idle_without_finalization_candidate(args: argparse.Namespace, delivery: dict[str, Any]) -> bool:
    if args.pr:
        return False
    repo = delivery.get("repo") if isinstance(delivery.get("repo"), dict) else {}
    decision = delivery.get("decision") if isinstance(delivery.get("decision"), dict) else {}
    return repo.get("dirty") is False and (
        decision.get("stage") == "no_local_changes"
        or decision.get("status") == "no_local_delivery_candidate"
    )


def readiness(
    args: argparse.Namespace,
    delivery: dict[str, Any],
    phase0: dict[str, Any],
    contract_status: dict[str, Any],
    agent_balance_plan: dict[str, Any],
) -> dict[str, Any]:
    delivery_decision = delivery.get("decision") or {}
    blockers = list(delivery_decision.get("blockers") or [])
    warnings = list(delivery_decision.get("warnings") or [])
    blockers.extend(b for b in phase0_blockers(phase0) if b not in blockers)
    warnings.extend(w for w in phase0_warnings(phase0) if w not in warnings)
    if not delivery_status_schema_valid(delivery):
        blockers.append("delivery_status_schema_invalid")
    elif delivery.get("ok") is not True:
        blockers.append("delivery_status_failed")
    if contract_status.get("ok") is not True:
        blockers.append("finalization_contract_status_unavailable")
    if agent_balance_plan.get("ok") is not True:
        blockers.append("agent_balance_plan_unavailable")
    # Re-derived from the evidence's own provenance, not from whether it validated: a caller-named
    # plan script authors its own stdout, so a forged-but-well-formed plan must not clear a
    # production blocker or reach a ready handoff.
    if agent_balance_plan.get("source") == "fixture" and AGENT_BALANCE_PLAN_FIXTURE_BLOCKER not in blockers:
        blockers.append(AGENT_BALANCE_PLAN_FIXTURE_BLOCKER)
    if is_idle_without_finalization_candidate(args, delivery):
        blockers = [b for b in blockers if b != "litmus_status_not_fresh"]
    # Re-derived from the evidence's own provenance rather than inherited from the child's
    # blocker list: a fixture must not reach ready_for_merge_handoff even if a custom
    # --delivery-status-script were to hand us a decision that omitted the blocker.
    if fixture_sourced_delivery(delivery) and FIXTURE_EVIDENCE_BLOCKER not in blockers:
        blockers.append(FIXTURE_EVIDENCE_BLOCKER)

    repo = delivery.get("repo") or {}
    target = infer_target(args, delivery)
    state = "blocked" if blockers else "no_finalization_candidate"
    next_action = "Resolve blockers, then re-run this read-only readiness helper."
    handoff_ready = False

    if not blockers:
        if target == "merge":
            if args.pr and delivery_decision.get("status") == "pr_clean_read_only":
                state = "ready_for_merge_handoff"
                handoff_ready = True
                next_action = "Hand this envelope to Busdriver/Claude or an explicit operator finalizer; this helper must not merge."
            elif args.pr:
                state = "pr_not_clean_read_only"
                next_action = "PR was supplied but read-only pr-grind is not clean; wait for checks/reviewers or fix actionable feedback, then re-run."
            else:
                next_action = "Merge handoff target requires --pr plus a clean read-only pr-grind result."
        elif target in {"commit", "pr", "commit_or_pr"}:
            if repo.get("dirty"):
                state = "ready_for_commit_or_pr_handoff"
                handoff_ready = True
                next_action = "Hand this envelope to Busdriver/Claude for current litmus/pre-PR semantics; this helper must not commit, push, or create a PR."
            else:
                next_action = "Commit/PR handoff target requires a dirty worktree to finalize."
        else:
            next_action = "No dirty worktree or clean PR was supplied for the requested target; continue draft work or pass --pr for PR readiness."

    return {
        "ready": handoff_ready,
        "status": state,
        "target": target,
        "blockers": blockers,
        "warnings": warnings,
        "next_action": next_action,
        "policy": POLICY,
        "finalization_guardrail_status": FINALIZATION_GUARDRAILS["status"],
        **BLOCKED_FLAGS,
    }


def handoff_envelope(
    args: argparse.Namespace,
    delivery: dict[str, Any],
    phase0: dict[str, Any],
    ready: dict[str, Any],
    contract_status: dict[str, Any],
    agent_balance_plan: dict[str, Any],
    dual_review: dict[str, Any],
    pre_pr_evidence: dict[str, Any],
) -> dict[str, Any]:
    repo = delivery.get("repo") or {}
    busdriver = phase0.get("plugin_root") or {}
    hooks = phase0.get("hooks") or {}
    user_config = phase0.get("user_config") or {}
    return {
        "schema": HANDOFF_SCHEMA,
        "read_only": True,
        "target": ready["target"],
        "readiness_status": ready["status"],
        "ready_for_handoff": ready["ready"],
        "repo": {
            "root": repo.get("root"),
            "branch": repo.get("branch"),
            "head": repo.get("head"),
            "dirty": repo.get("dirty"),
            "merge_state": repo.get("merge_state"),
            "dirty_entries": repo.get("dirty_entries"),
            # The list is bounded by delivery-status; re-emitting it without these would hand a
            # reader a short list that looks complete.
            "dirty_entries_total_count": repo.get("dirty_entries_total_count"),
            "dirty_entries_truncated": repo.get("dirty_entries_truncated"),
        },
        "pr": summarize_pr(args.pr, delivery),
        "busdriver_phase0": {
            "plugin_root": busdriver,
            "user_config": {"path": user_config.get("path"), "exists": user_config.get("exists"), "parse_error": user_config.get("parse_error")},
            "hooks": {"path": hooks.get("path"), "exists": hooks.get("exists"), "parse_error": hooks.get("parse_error"), "events": hooks.get("events")},
            "active_markers": phase0.get("active_markers"),
            "busdriver_drift": phase0.get("busdriver_drift"),
        },
        "evidence": {
            "delivery_status_schema": delivery.get("schema"),
            "phase0_status_schema": phase0.get("status_schema"),
            "delivery_decision": delivery.get("decision"),
            "busdriver_drift": phase0.get("busdriver_drift") or ((delivery.get("phase0_status") or {}).get("busdriver_drift")),
            "litmus_status": (delivery.get("litmus_status") or {}).get("summary"),
            # The summary alone drops the wrapper's `source`, so a fixture-sourced summary became
            # indistinguishable from a live run to every downstream reader of this envelope.
            "litmus_status_source": (delivery.get("litmus_status") or {}).get("source"),
            "pr_grind_source": (delivery.get("pr_grind") or {}).get("source"),
            # Re-derived from provenance, not read back from the child's blocker list: a custom
            # --delivery-status-script that omits the blocker must not also clear this flag.
            "fixture_sourced_evidence": fixture_sourced_delivery(delivery) or FIXTURE_EVIDENCE_BLOCKER in (delivery.get("decision") or {}).get("blockers", []),
            "finalization_lock": delivery.get("finalization_lock"),
            "relay_role_resolution": delivery.get("relay_role_resolution"),
            "finalization_contract_status": contract_status,
            "agent_balance_plan": agent_balance_plan,
            "dual_review_readiness": dual_review,
            "pre_pr_dual_review_evidence": pre_pr_evidence,
        },
        "finalization_contract_status": contract_status,
        "agent_balance_plan": agent_balance_plan,
        "dual_review_readiness": dual_review,
        "pre_pr_dual_review_evidence": pre_pr_evidence,
        "required_next_actor": "Busdriver/Claude Code or an explicit operator finalizer with current litmus/pre-PR/pr-grind gates",
        "required_next_actions": [
            "Re-read live Busdriver source-of-truth before any repo-changing finalization.",
            "Run current litmus/pre-PR-equivalent gates before commit/push/PR creation.",
            "Run current latest-head pr-grind-equivalent loop before merge.",
            "Treat this envelope as advisory evidence only; do not bypass gates or marker freshness checks.",
        ],
        "forbidden_by_this_helper": UNSUPPORTED_FINALIZATION_OPERATIONS,
        "authority": BLOCKED_FLAGS,
        "finalization_guardrails": FINALIZATION_GUARDRAILS,
        "policy": POLICY,
    }


def load_all(args: argparse.Namespace) -> tuple[tuple[dict[str, Any], int], ...]:
    """Materialize the authenticated runtime once, then run every default helper out of it."""
    with authenticated_helper(
        "scripts/hermes-busdriver-delivery-status",
        "scripts/hermes-busdriver-status",
        "scripts/hermes-busdriver-finalization-contract-status",
        "scripts/hermes-busdriver-agent-balance-plan",
    ) as (delivery_status, phase0_status, contract_status, balance_plan):
        return (
            load_delivery_status(args, delivery_status),
            load_phase0_status(args, phase0_status),
            load_contract_status(contract_status),
            load_agent_balance_plan(args, balance_plan),
        )


def main() -> int:
    args = parse_args()
    try:
        (delivery, delivery_rc), (phase0, phase0_rc), (contract_status, contract_status_rc), (agent_balance_plan, agent_balance_plan_rc) = load_all(args)
    except OSError as exc:
        # The reviewed bytes are not on disk, so no helper here can answer. Fail closed rather
        # than fall back to whatever is at the path.
        detail = str(exc) or type(exc).__name__
        delivery, delivery_rc = helper_unavailable(DELIVERY_STATUS_SCHEMA, "readiness_runtime_integrity_failed", detail), 1
        phase0, phase0_rc = helper_unavailable("hermes-busdriver-status/v0", "readiness_runtime_integrity_failed", detail), 1
        contract_status, contract_status_rc = invalid_contract_status("readiness_runtime_integrity_failed", {"detail": detail}, 1), 1
        agent_balance_plan, agent_balance_plan_rc = invalid_agent_balance_plan("readiness_runtime_integrity_failed", {"detail": detail}, 1), 1
    ready = readiness(args, delivery, phase0, contract_status, agent_balance_plan)
    dual_review = dual_review_readiness(phase0)
    pre_pr_evidence = pre_pr_dual_review_evidence((delivery.get("litmus_status") or {}).get("summary"))
    result = {
        "schema": SCHEMA,
        "ok": bool(
            delivery_status_schema_valid(delivery)
            and delivery.get("ok") is True
            and phase0.get("status_schema") == "hermes-busdriver-status/v0"
            and contract_status.get("ok") is True
            and delivery_rc == 0
            and phase0_rc == 0
            and contract_status_rc == 0
            and agent_balance_plan_rc == 0
            and agent_balance_plan.get("ok") is True
        ),
        "read_only": True,
        # Stated on the envelope's face: a fixture run authors some of its own evidence.
        "fixture_mode": bool(FIXTURE_MODE),
        "delivery_status_returncode": delivery_rc,
        "phase0_status_returncode": phase0_rc,
        "finalization_contract_status_returncode": contract_status_rc,
        "agent_balance_plan_returncode": agent_balance_plan_rc,
        "readiness": ready,
        "finalization_contract_status": contract_status,
        "agent_balance_plan": agent_balance_plan,
        "dual_review_readiness": dual_review,
        "pre_pr_dual_review_evidence": pre_pr_evidence,
        "finalization_guardrails": FINALIZATION_GUARDRAILS,
        "handoff_envelope": handoff_envelope(args, delivery, phase0, ready, contract_status, agent_balance_plan, dual_review, pre_pr_evidence),
        "delivery_status": delivery,
        "phase0_status": phase0,
        "decision": {"status": ready["status"], "reason": "read_only_finalization_readiness", **BLOCKED_FLAGS},
    }
    # The same funnel again, over the assembled envelope: defense in depth against THIS file rather
    # than against the children. run_json() already sanitized every child object, so what this pass
    # covers is the assembly — a field projected into the handoff envelope, a `detail` built from an
    # OSError string on the integrity path, a future key nobody has written yet. It costs one walk
    # of a few KB and removes "someone adds an emitter and forgets" as a way to leak.
    print(json.dumps(sanitized_payload(result), indent=2 if args.pretty else None, sort_keys=True))
    return 0 if result["ok"] else (delivery_rc or phase0_rc or contract_status_rc or agent_balance_plan_rc or 1)


if __name__ == "__main__":
    raise SystemExit(main())
