#!/usr/bin/env python3
"""Read-only Hermes Delivery Mode status probe.

This command is intentionally non-finalizing: it does not commit, push, create a
PR, merge, write Busdriver markers, or mutate GitHub. It collects the local repo
state, live Busdriver source availability, and (when available) the PR-grind
readiness result from `hermes-busdriver-pr-grind-check`.

The goal is to give Hermes a deterministic status envelope for the next delivery
step while keeping Busdriver as the canonical workflow/gate authority.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
SCHEMA = "hermes-busdriver-delivery-status/v0"
LITMUS_STATUS_SCHEMA = "hermes-busdriver-litmus-status/v0"
FINALIZATION_POLICY = (
    "Read-only delivery status never authorizes commit/push/PR/merge. "
    "Use explicit Hermes Delivery Mode only after current Busdriver litmus/pre-PR "
    "semantics and a clean pr-grind-equivalent loop have been verified."
)
FINALIZATION_LOCK_OPERATION = "finalization"
LITMUS_AUTHORITY_FALSE_KEYS = [
    "finalization_allowed",
    "commit_allowed",
    "push_allowed",
    "pr_allowed",
    "merge_allowed",
    "deploy_allowed",
    "release_allowed",
    "publish_allowed",
    "marker_write_allowed",
]
LITMUS_DECISION_STATUSES = {
    "stale_or_missing",
    "blocked",
    "commit_litmus_fresh",
    "pr_review_fresh",
}
LITMUS_OUTPUT_TAIL_LIMIT = 4000
REDACTION = "[REDACTED]"
SENSITIVE_PATTERNS = [
    (re.compile(r"(?i)\b(authorization\s*:\s*bearer\s+)([A-Za-z0-9._~+/=-]{8,})"), rf"\1{REDACTION}"),
    (re.compile(r"\bgh[pousr]_[A-Za-z0-9_]{20,}\b"), REDACTION),
    (re.compile(r"\bsk-[A-Za-z0-9_-]{20,}\b"), REDACTION),
    (re.compile(r"(?i)((?:--(?:api[_-]?key|secret|token|password|passwd))\s+)([^\s'\"&]+)"), rf"\1{REDACTION}"),
    (re.compile(r"(?i)\b((?:api[_-]?key|secret|token|password|passwd)\s*[:=]\s*)([^\s'\"&]+)"), rf"\1{REDACTION}"),
]


def redact_text(text: str) -> str:
    for pattern, replacement in SENSITIVE_PATTERNS:
        text = pattern.sub(replacement, text)
    return text


def redact_value(value: Any) -> Any:
    if isinstance(value, str):
        return redact_text(value)
    if isinstance(value, list):
        return [redact_value(item) for item in value]
    if isinstance(value, dict):
        return {key: redact_value(item) for key, item in value.items()}
    return value


def sanitized_tail(value: str | bytes | None, limit: int = LITMUS_OUTPUT_TAIL_LIMIT) -> str:
    if isinstance(value, bytes):
        text = value.decode(errors="replace")
    else:
        text = value or ""
    text = redact_text(text)
    if limit <= 0:
        return ""
    return text[-limit:]


def run(cmd: list[str], cwd: Path | None = None, timeout: int = 60) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(cmd, cwd=str(cwd) if cwd else None, text=True, capture_output=True, timeout=timeout)
    except FileNotFoundError as e:
        return subprocess.CompletedProcess(cmd, 127, "", str(e))
    except subprocess.TimeoutExpired as e:
        stdout = e.stdout.decode(errors="replace") if isinstance(e.stdout, bytes) else (e.stdout or "")
        stderr_tail = e.stderr.decode(errors="replace") if isinstance(e.stderr, bytes) else (e.stderr or "")
        stderr = f"timeout after {timeout}s"
        if stderr_tail:
            stderr = f"{stderr}: {stderr_tail}"
        return subprocess.CompletedProcess(cmd, 124, stdout, stderr)


def read_json(path: str | None, default: Any) -> Any:
    if not path:
        return default
    try:
        return json.loads(Path(path).expanduser().read_text())
    except Exception:  # noqa: BLE001 - status probe should not crash on optional fixtures
        return default


def git(repo: Path, *args: str) -> subprocess.CompletedProcess[str]:
    return run(["git", "-C", str(repo), *args])


def repo_status(repo_arg: str) -> dict[str, Any]:
    repo = Path(repo_arg).expanduser()
    root_cp = git(repo, "rev-parse", "--show-toplevel")
    if root_cp.returncode != 0:
        return {"ok": False, "error": "not_a_git_repo", "path": str(repo), "stderr": root_cp.stderr.strip()}
    root = Path(root_cp.stdout.strip()).resolve()
    git_dir_cp = git(root, "rev-parse", "--git-dir")
    git_dir = Path(git_dir_cp.stdout.strip()) if git_dir_cp.returncode == 0 else root / ".git"
    if not git_dir.is_absolute():
        git_dir = root / git_dir
    branch = git(root, "branch", "--show-current").stdout.strip()
    head = git(root, "rev-parse", "HEAD").stdout.strip()
    upstream_cp = git(root, "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{u}")
    status_lines = git(root, "status", "--porcelain=v1").stdout.splitlines()
    staged = [line for line in status_lines if line and line[0] != "?" and line[0] != " "]
    unstaged = [line for line in status_lines if len(line) > 1 and line[1] not in (" ", "?")]
    untracked = [line for line in status_lines if line.startswith("??")]
    merge_state = any((git_dir / name).exists() for name in ["MERGE_HEAD", "REBASE_HEAD", "CHERRY_PICK_HEAD", "BISECT_LOG"])
    return {
        "ok": True,
        "root": str(root),
        "git_dir": str(git_dir),
        "branch": branch,
        "head": head,
        "upstream": upstream_cp.stdout.strip() if upstream_cp.returncode == 0 else None,
        "dirty": bool(status_lines),
        "dirty_entries": status_lines,
        "staged_entries": staged,
        "unstaged_entries": unstaged,
        "untracked_entries": untracked,
        "merge_state": merge_state,
    }


def package_version(plugin_root: Path) -> str | None:
    p = plugin_root / "package.json"
    if not p.exists():
        return None
    try:
        data = json.loads(p.read_text())
        return data.get("version") if isinstance(data, dict) else None
    except Exception:
        return None


def existing_paths(root: Path, rels: list[str]) -> list[str]:
    return [rel for rel in rels if (root / rel).exists()]


def busdriver_status(plugin_root_arg: str | None) -> dict[str, Any]:
    candidates: list[Path] = []
    if plugin_root_arg:
        candidates.append(Path(plugin_root_arg).expanduser())
    for env_name in ("BUSDRIVER_PLUGIN_ROOT", "CLAUDE_PLUGIN_ROOT"):
        if os.environ.get(env_name):
            candidates.append(Path(os.environ[env_name]).expanduser())
    candidates.append(Path.home() / ".claude/plugins/marketplaces/busdriver")

    seen: set[str] = set()
    deduped: list[Path] = []
    for candidate in candidates:
        key = str(candidate)
        if key not in seen:
            seen.add(key)
            deduped.append(candidate)

    selected = next((p for p in deduped if p.exists()), deduped[0] if deduped else Path(""))
    scripts = [
        "scripts/relevant-check-status.sh",
        "scripts/ack-ledger.sh",
        "scripts/fetch-pr-state.sh",
        "hooks/gate-scripts/pre-pr-gate.sh",
        "hooks/gate-scripts/pre-merge-gate.sh",
    ]
    skills = ["skills/pr-grind/SKILL.md", "opencode/skills/pr-grind/SKILL.md", "agents/pr-grinder.md", "opencode/agents/pr-grinder.md"]
    present_scripts = existing_paths(selected, scripts)
    present_skills = existing_paths(selected, skills)
    return {
        "ok": selected.exists(),
        "plugin_root": str(selected),
        "version": package_version(selected) if selected.exists() else None,
        "required_sources": {
            "present": present_scripts + present_skills,
            "missing": [rel for rel in scripts + skills if rel not in present_scripts and rel not in present_skills],
        },
        "pr_grind_sources_available": bool({"scripts/relevant-check-status.sh", "scripts/ack-ledger.sh"} <= set(present_scripts) and present_skills),
    }


def marker_status(repo: dict[str, Any]) -> dict[str, Any]:
    if not repo.get("ok"):
        return {"blocking": [], "present": []}
    root = Path(repo["root"])
    names = [
        "freeze.local",
        "careful.local",
        "design-review-needed.local.md",
        "skip-litmus.local",
        "litmus-passed.local",
        "pr-review-passed.local",
        "pr-grind-clean.local",
    ]
    present: list[dict[str, Any]] = []
    for state_dir_name in (".claude", ".opencode"):
        state_dir = root / state_dir_name
        for name in names:
            path = state_dir / name
            if path.exists():
                st = path.stat()
                present.append({"path": str(path), "state_dir": state_dir_name, "name": name, "mtime": st.st_mtime, "age_seconds": max(0, int(time.time() - st.st_mtime))})
    blocking = [m for m in present if m["name"] in {"freeze.local", "careful.local", "design-review-needed.local.md"}]
    return {"present": present, "blocking": blocking}


def relay_capabilities() -> dict[str, Any]:
    scripts = {
        "status": ROOT / "scripts" / "hermes-busdriver-status",
        "relay_role": ROOT / "scripts" / "hermes-busdriver-relay-role",
        "runtime_check": ROOT / "scripts" / "hermes-busdriver-runtime-check",
        "gate": ROOT / "scripts" / "hermes-busdriver-gate",
        "agent_draft": ROOT / "scripts" / "hermes-busdriver-agent-draft",
        "pr_grind_check": ROOT / "scripts" / "hermes-busdriver-pr-grind-check",
        "pr_grind_loop": ROOT / "scripts" / "hermes-busdriver-pr-grind-loop",
        "litmus_status": ROOT / "scripts" / "hermes-busdriver-litmus-status",
        "delivery_status": ROOT / "scripts" / "hermes-busdriver-delivery-status",
    }
    return {name: {"path": str(path), "available": path.exists()} for name, path in scripts.items()}


def load_lock_status(args: argparse.Namespace) -> dict[str, Any] | None:
    if args.no_lock_status:
        return None
    lock = ROOT / "scripts" / "hermes-busdriver-lock"
    if not lock.exists():
        return {"available": False}
    cmd = [sys.executable, str(lock), "status"]
    if args.state_dir:
        cmd += ["--state-dir", args.state_dir]
    cp = run(cmd, timeout=20)
    if cp.returncode != 0:
        return {"available": True, "ok": False, "returncode": cp.returncode, "stderr": cp.stderr.strip()}
    try:
        data = json.loads(cp.stdout)
        data["available"] = True
        return data
    except Exception as e:  # noqa: BLE001
        return {"available": True, "ok": False, "parse_error": str(e), "stdout_tail": cp.stdout[-2000:]}


def finalization_lock_summary(lock_status: dict[str, Any] | None, repo: dict[str, Any]) -> dict[str, Any]:
    summary: dict[str, Any] = {
        "operation": FINALIZATION_LOCK_OPERATION,
        "available": bool(lock_status and lock_status.get("available", True)),
        "ok": True,
        "status": "not_collected" if lock_status is None else "ok",
        "active_for_repo": [],
        "active_for_repo_count": 0,
        "stale_for_repo_count": 0,
    }
    if lock_status is None:
        return summary
    if not summary["available"] or lock_status.get("ok") is False:
        summary["ok"] = False
        summary["status"] = "unavailable" if not summary["available"] else "collection_failed"
        return summary
    if not repo.get("ok"):
        return summary
    locks = lock_status.get("locks")
    if not isinstance(locks, list):
        summary["ok"] = False
        summary["status"] = "invalid_lock_status"
        return summary
    repo_root = repo.get("root")
    for lock in locks:
        if not isinstance(lock, dict):
            summary["ok"] = False
            summary["status"] = "invalid_lock_entry"
            return summary
        if lock.get("parse_error"):
            summary["ok"] = False
            summary["status"] = "invalid_lock_entry"
            return summary
        lock_repo = lock.get("repo") if isinstance(lock.get("repo"), dict) else {}
        if lock_repo.get("root") != repo_root or lock.get("operation") != FINALIZATION_LOCK_OPERATION:
            continue
        if lock.get("stale") is True:
            summary["stale_for_repo_count"] += 1
            continue
        summary["active_for_repo"].append(lock)
    summary["active_for_repo_count"] = len(summary["active_for_repo"])
    return summary


def latest_agent_runs(args: argparse.Namespace, repo: dict[str, Any]) -> list[dict[str, Any]]:
    if args.no_agent_runs:
        return []
    state_root = Path(args.state_dir).expanduser() if args.state_dir else Path.home() / ".hermes" / "busdriver-relay"
    runs_dir = state_root / "agent-runs"
    if not runs_dir.exists():
        return []
    repo_root = repo.get("root") if repo.get("ok") else None
    rows: list[dict[str, Any]] = []
    for report in sorted(runs_dir.glob("*/final-report.json"), key=lambda p: p.stat().st_mtime, reverse=True)[: args.max_agent_runs * 4]:
        try:
            data = json.loads(report.read_text())
        except Exception:
            continue
        if repo_root and data.get("repo") and data.get("repo") != repo_root:
            continue
        rows.append({
            "report": str(report),
            "mtime": report.stat().st_mtime,
            "status": data.get("status"),
            "ok": data.get("ok"),
            "agent": data.get("agent"),
            "run_dir": data.get("run_dir"),
            "decision": data.get("decision"),
        })
        if len(rows) >= args.max_agent_runs:
            break
    return rows


def run_pr_grind_check(args: argparse.Namespace, repo: dict[str, Any], busdriver: dict[str, Any]) -> dict[str, Any] | None:
    if args.pr_grind_result_file:
        data = read_json(args.pr_grind_result_file, {})
        return {"available": True, "source": "fixture", "ok": True, "result": data}
    if not args.pr:
        return None
    script = Path(args.pr_grind_check_script).expanduser() if args.pr_grind_check_script else ROOT / "scripts" / "hermes-busdriver-pr-grind-check"
    if not script.exists():
        return {"available": False, "script": str(script), "reason": "hermes-busdriver-pr-grind-check not available in this branch"}
    if not repo.get("ok"):
        return {"available": True, "ok": False, "script": str(script), "reason": "repo_unavailable"}
    cmd = [sys.executable, str(script), "--repo", repo["root"], "--pr", str(args.pr)]
    if busdriver.get("ok"):
        cmd += ["--plugin-root", busdriver["plugin_root"]]
    cp = run(cmd, cwd=Path(repo["root"]), timeout=args.pr_grind_timeout)
    if cp.returncode != 0:
        return {"available": True, "ok": False, "script": str(script), "returncode": cp.returncode, "stderr": cp.stderr.strip(), "stdout_tail": cp.stdout[-4000:]}
    try:
        return {"available": True, "ok": True, "script": str(script), "result": json.loads(cp.stdout)}
    except Exception as e:  # noqa: BLE001
        return {"available": True, "ok": False, "script": str(script), "parse_error": str(e), "stdout_tail": cp.stdout[-4000:]}


def load_json_result_file(path: str) -> tuple[Any, str | None]:
    try:
        return json.loads(Path(path).expanduser().read_text()), None
    except Exception as e:  # noqa: BLE001 - optional fixture/status input should fail closed
        return None, str(e)


def litmus_authority_is_safe(result: dict[str, Any]) -> bool:
    decision = result.get("decision")
    return (
        result.get("schema") == LITMUS_STATUS_SCHEMA
        and result.get("read_only") is True
        and isinstance(decision, dict)
        and all(decision.get(key) is False for key in LITMUS_AUTHORITY_FALSE_KEYS)
        and decision.get("not_busdriver_native_claude_runtime") is True
    )


def litmus_decision_status_is_recognized(result: dict[str, Any]) -> bool:
    decision = result.get("decision")
    return isinstance(decision, dict) and decision.get("status") in LITMUS_DECISION_STATUSES


def sanitize_litmus_marker(marker: Any) -> dict[str, Any]:
    if not isinstance(marker, dict):
        return {"invalid_marker_type": type(marker).__name__}
    allowed = {
        "path",
        "exists",
        "is_symlink",
        "unsafe_symlink",
        "state_dir_unsafe",
        "read_error",
        "stat_error",
        "size",
        "mtime",
        "age_seconds",
        "max_age_seconds",
        "recognized_format",
        "accepted_by_commit_gate",
        "fresh_for_head",
        "fresh_for_branch_diff",
        "value_sha256",
        "value_length",
        "diff_hash",
        "ts",
    }
    return {key: redact_value(marker.get(key)) for key in sorted(allowed) if key in marker}


def sanitize_litmus_summary(result: dict[str, Any]) -> dict[str, Any]:
    decision = result.get("decision") if isinstance(result.get("decision"), dict) else {}
    markers = result.get("markers") if isinstance(result.get("markers"), dict) else {}
    repo = result.get("repo") if isinstance(result.get("repo"), dict) else {}
    state_dir = result.get("state_dir") if isinstance(result.get("state_dir"), dict) else {}
    allowed_repo = {"root", "branch", "head", "head_timestamp", "base_ref", "branch_diff_hash"}
    allowed_state_dir = {"path", "exists", "is_symlink", "has_symlink_component"}
    allowed_markers = {"litmus_passed", "pr_codex_lead", "pr_backstop_verdict", "pr_review_passed"}
    return {
        "schema": result.get("schema"),
        "read_only": result.get("read_only"),
        "ok": result.get("ok"),
        "repo": {key: redact_value(repo.get(key)) for key in allowed_repo if key in repo},
        "state_dir": {key: redact_value(state_dir.get(key)) for key in allowed_state_dir if key in state_dir},
        "markers": {name: sanitize_litmus_marker(markers[name]) for name in allowed_markers if name in markers},
        "decision": {
            "status": redact_value(decision.get("status")),
            "warnings": [],
            "blockers": [],
            **{key: False for key in LITMUS_AUTHORITY_FALSE_KEYS},
            "not_busdriver_native_claude_runtime": decision.get("not_busdriver_native_claude_runtime") is True,
        },
    }


def litmus_repo_identity_matches(result: dict[str, Any], repo: dict[str, Any]) -> bool:
    if not repo.get("ok"):
        return True
    litmus_repo = result.get("repo")
    if not isinstance(litmus_repo, dict):
        return False
    if litmus_repo.get("root") != repo.get("root"):
        return False
    repo_branch = repo.get("branch")
    litmus_branch = litmus_repo.get("branch")
    if repo_branch and (not isinstance(litmus_branch, str) or litmus_branch != repo_branch):
        return False
    repo_head = repo.get("head")
    litmus_head = litmus_repo.get("head")
    if repo_head and (not isinstance(litmus_head, str) or litmus_head != repo_head):
        return False
    return True


def validated_litmus_status(result: Any, *, source: str, repo: dict[str, Any], script: str | None = None, returncode: int | None = None, stderr: str = "") -> dict[str, Any]:
    base: dict[str, Any] = {"available": True, "source": source}
    if script:
        base["script"] = script
    if returncode is not None:
        base["returncode"] = returncode
    if stderr:
        base["stderr"] = sanitized_tail(stderr)
    if not isinstance(result, dict):
        return {**base, "ok": False, "reason": "litmus_status_malformed", "result_type": type(result).__name__}
    summary = sanitize_litmus_summary(result)
    if result.get("schema") != LITMUS_STATUS_SCHEMA:
        return {**base, "ok": False, "reason": "litmus_status_schema_invalid", "summary": summary}
    if result.get("read_only") is not True:
        return {**base, "ok": False, "reason": "litmus_status_read_only_unsafe", "summary": summary}
    if not isinstance(result.get("ok"), bool):
        return {**base, "ok": False, "reason": "litmus_status_schema_invalid", "summary": summary}
    if not litmus_repo_identity_matches(result, repo):
        return {**base, "ok": False, "reason": "litmus_status_schema_invalid", "summary": summary}
    if not litmus_authority_is_safe(result):
        return {**base, "ok": False, "reason": "litmus_status_authority_flags_unsafe", "summary": summary}
    if not litmus_decision_status_is_recognized(result):
        return {**base, "ok": False, "reason": "litmus_status_schema_invalid", "summary": summary}
    if returncode not in (None, 0):
        return {**base, "ok": False, "reason": "litmus_status_subprocess_failed", "summary": summary}
    return {**base, "ok": result["ok"], "summary": summary}


def run_litmus_status(args: argparse.Namespace, repo: dict[str, Any]) -> dict[str, Any]:
    if args.litmus_status_result_file:
        data, error = load_json_result_file(args.litmus_status_result_file)
        if error:
            return {"available": True, "source": "fixture", "ok": False, "reason": "litmus_status_malformed", "parse_error": error}
        return validated_litmus_status(data, source="fixture", repo=repo)
    script = Path(args.litmus_status_script).expanduser() if args.litmus_status_script else ROOT / "scripts" / "hermes-busdriver-litmus-status"
    if not script.exists():
        return {"available": False, "ok": False, "script": str(script), "reason": "hermes-busdriver-litmus-status not available in this branch"}
    if not repo.get("ok"):
        return {"available": True, "ok": False, "script": str(script), "reason": "repo_unavailable"}
    cmd = [sys.executable, str(script), "--repo", repo["root"]]
    try:
        cp = run(cmd, cwd=Path(repo["root"]), timeout=args.litmus_status_timeout)
    except subprocess.TimeoutExpired as e:
        return {
            "available": True,
            "ok": False,
            "script": str(script),
            "returncode": 124,
            "reason": "litmus_status_subprocess_failed",
            "timeout_seconds": args.litmus_status_timeout,
            "stdout_tail": sanitized_tail(e.stdout),
            "stderr": sanitized_tail(e.stderr),
        }
    if cp.returncode == 124:
        return {
            "available": True,
            "ok": False,
            "script": str(script),
            "returncode": 124,
            "reason": "litmus_status_subprocess_failed",
            "timeout_seconds": args.litmus_status_timeout,
            "stdout_tail": sanitized_tail(cp.stdout),
            "stderr": sanitized_tail(cp.stderr),
        }
    try:
        data = json.loads(cp.stdout)
    except Exception as e:  # noqa: BLE001
        return {
            "available": True,
            "ok": False,
            "script": str(script),
            "returncode": cp.returncode,
            "reason": "litmus_status_malformed",
            "parse_error": str(e),
            "stdout_tail": sanitized_tail(cp.stdout),
            "stderr": sanitized_tail(cp.stderr),
        }
    return validated_litmus_status(data, source="script", repo=repo, script=str(script), returncode=cp.returncode, stderr=cp.stderr)


def relay_role_authority_is_safe(result: dict[str, Any], requested_role: str) -> bool:
    decision = result.get("decision")
    return (
        result.get("schema") == "hermes-busdriver-relay-role/v0"
        and result.get("role") == requested_role
        and result.get("read_only") is True
        and result.get("ok") is True
        and result.get("dispatch_allowed") is True
        and result.get("mutation_allowed") is False
        and result.get("finalization_allowed") is False
        and result.get("not_busdriver_native_claude_runtime") is True
        and isinstance(decision, dict)
        and decision.get("dispatch_allowed") is True
        and decision.get("mutation_allowed") is False
        and decision.get("finalization_allowed") is False
        and decision.get("not_busdriver_native_claude_runtime") is True
    )


def run_relay_role_resolution(args: argparse.Namespace) -> dict[str, Any] | None:
    if not args.relay_role:
        return None
    script = Path(args.relay_role_script).expanduser() if args.relay_role_script else ROOT / "scripts" / "hermes-busdriver-relay-role"
    if not script.exists():
        return {"available": False, "ok": False, "script": str(script), "role": args.relay_role, "reason": "hermes-busdriver-relay-role not available in this branch"}
    cmd = [sys.executable, str(script), "--role", args.relay_role]
    if args.relay_config:
        cmd += ["--relay-config", args.relay_config]
    if args.state_dir:
        cmd += ["--relay-state-dir", args.state_dir]
    cp = run(cmd, timeout=args.relay_role_timeout)
    base: dict[str, Any] = {"available": True, "script": str(script), "role": args.relay_role, "returncode": cp.returncode}
    try:
        result = json.loads(cp.stdout)
    except Exception as e:  # noqa: BLE001
        return {**base, "ok": False, "parse_error": str(e), "stdout_tail": cp.stdout[-4000:], "stderr": cp.stderr[-4000:]}
    if not isinstance(result, dict):
        return {**base, "ok": False, "reason": "relay_role_result_not_object", "result": result, "stderr": cp.stderr[-4000:]}
    authority_safe = relay_role_authority_is_safe(result, args.relay_role)
    ok = cp.returncode == 0 and authority_safe
    reason = None if ok else ("relay_role_authority_flags_unsafe" if cp.returncode == 0 else "relay_role_not_dispatchable")
    return {**base, "ok": ok, "reason": reason, "result": result, "stderr": cp.stderr[-4000:] if cp.stderr else ""}


def delivery_decision(repo: dict[str, Any], busdriver: dict[str, Any], markers: dict[str, Any], finalization_lock: dict[str, Any], pr_grind: dict[str, Any] | None, relay_role: dict[str, Any] | None, litmus_status: dict[str, Any], pr: str | None) -> dict[str, Any]:
    blockers: list[str] = []
    warnings: list[str] = []
    stage = "unknown"
    status = "blocked"
    next_action = "Resolve blocking status before delivery."

    if not repo.get("ok"):
        blockers.append("repo_not_available")
    else:
        stage = "post_pr" if pr else ("draft_changes" if repo.get("dirty") else "no_local_changes")
        if repo.get("merge_state"):
            blockers.append("git_merge_rebase_cherry_pick_state_active")
        if markers.get("blocking"):
            blockers.append("blocking_busdriver_marker_present")
        if finalization_lock.get("ok") is False:
            blockers.append("relay_finalization_lock_status_unavailable")
        elif finalization_lock.get("active_for_repo_count", 0):
            blockers.append("relay_finalization_lock_active")

    if not busdriver.get("ok"):
        blockers.append("busdriver_plugin_unavailable")
    elif not busdriver.get("pr_grind_sources_available"):
        warnings.append("busdriver_pr_grind_sources_incomplete")

    if relay_role is not None:
        if not relay_role.get("available"):
            warnings.append("relay_role_resolver_unavailable")
        elif not relay_role.get("ok"):
            warnings.append("relay_role_not_dispatchable")

    if not litmus_status.get("available"):
        blockers.append("litmus_status_unavailable")
    elif litmus_status.get("reason") in {
        "litmus_status_malformed",
        "litmus_status_schema_invalid",
        "litmus_status_read_only_unsafe",
        "litmus_status_authority_flags_unsafe",
        "litmus_status_subprocess_failed",
    }:
        blockers.append(str(litmus_status["reason"]))
    else:
        litmus_decision = ((litmus_status.get("summary") or {}).get("decision") or {})
        litmus_decision_status = litmus_decision.get("status")
        if litmus_decision_status == "blocked" or litmus_status.get("ok") is False:
            blockers.append("litmus_status_not_fresh")
        elif litmus_decision_status == "stale_or_missing":
            warnings.append("litmus_pre_pr_stale_or_missing")

    if pr:
        if pr_grind is None:
            blockers.append("pr_grind_status_not_collected")
        elif not pr_grind.get("available"):
            blockers.append("hermes_pr_grind_checker_unavailable")
            next_action = "Install or supply the PR-grind readiness checker, or run Busdriver pr-grind in Claude Code."
        elif not pr_grind.get("ok"):
            blockers.append("pr_grind_checker_failed")
        else:
            result = pr_grind.get("result") or {}
            pr_status = result.get("status")
            if result.get("clean") is True or pr_status == "clean":
                if not blockers:
                    status = "pr_clean_read_only"
                    next_action = "PR appears clean by read-only checker; only an explicit Delivery Mode finalizer may merge after re-verifying current Busdriver semantics."
            elif pr_status == "wait":
                blockers.append("pr_checks_or_reviewer_bots_pending")
                next_action = "Wait bounded rounds for required checks/reviewer bots, then re-run PR-grind status."
            elif pr_status == "needs_fix":
                blockers.append("actionable_pr_feedback_present")
                next_action = "Fix actionable feedback on the PR branch, push, then re-run PR-grind status."
            else:
                blockers.append("pr_not_clean")
    elif repo.get("ok") and repo.get("dirty"):
        if not blockers:
            status = "draft_changes_need_busdriver_finalization"
            next_action = "Run local verification plus current Busdriver litmus/pre-PR semantics before any commit or PR."
    elif repo.get("ok"):
        if not blockers:
            status = "no_local_delivery_candidate"
            next_action = "No local changes or PR were supplied; continue draft work or pass --pr for post-PR status."

    if blockers:
        status = "blocked"

    return {
        "status": status,
        "stage": stage,
        "blockers": blockers,
        "warnings": warnings,
        "next_action": next_action,
        "finalization_allowed": False,
        "commit_allowed": False,
        "push_allowed": False,
        "pr_allowed": False,
        "merge_allowed": False,
        "deploy_allowed": False,
        "release_allowed": False,
        "publish_allowed": False,
        "marker_write_allowed": False,
        "policy": FINALIZATION_POLICY,
    }


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--repo", default=".", help="Target git repo/worktree to inspect")
    ap.add_argument("--plugin-root", help="Busdriver plugin root; falls back to env/default install path")
    ap.add_argument("--pr", help="Pull request number for post-PR delivery status")
    ap.add_argument("--pr-grind-check-script", help="Path to hermes-busdriver-pr-grind-check; defaults to this relay repo's scripts dir")
    ap.add_argument("--pr-grind-result-file", help="Fixture/result JSON from hermes-busdriver-pr-grind-check")
    ap.add_argument("--pr-grind-timeout", type=int, default=180)
    ap.add_argument("--litmus-status-script", help="Path to hermes-busdriver-litmus-status; defaults to this relay repo's scripts dir")
    ap.add_argument("--litmus-status-result-file", help="Fixture/result JSON from hermes-busdriver-litmus-status")
    ap.add_argument("--litmus-status-timeout", type=int, default=60)
    ap.add_argument("--state-dir", help="Hermes busdriver-relay state dir for lock/run lookup")
    ap.add_argument("--relay-role", help="Optionally resolve one relay equivalent role into the status envelope")
    ap.add_argument("--relay-config", help="Relay config JSON path to pass to hermes-busdriver-relay-role")
    ap.add_argument("--relay-role-script", help="Path to hermes-busdriver-relay-role; defaults to this relay repo's scripts dir")
    ap.add_argument("--relay-role-timeout", type=int, default=90)
    ap.add_argument("--max-agent-runs", type=int, default=3)
    ap.add_argument("--no-agent-runs", action="store_true")
    ap.add_argument("--no-lock-status", action="store_true")
    ap.add_argument("--pretty", action="store_true")
    args = ap.parse_args()

    repo = repo_status(args.repo)
    busdriver = busdriver_status(args.plugin_root)
    markers = marker_status(repo)
    capabilities = relay_capabilities()
    pr_grind = run_pr_grind_check(args, repo, busdriver)
    litmus_status = run_litmus_status(args, repo)
    relay_role = run_relay_role_resolution(args)
    locks = load_lock_status(args)
    finalization_lock = finalization_lock_summary(locks, repo)
    runs = latest_agent_runs(args, repo)
    decision = delivery_decision(repo, busdriver, markers, finalization_lock, pr_grind, relay_role, litmus_status, args.pr)

    result = {
        "schema": SCHEMA,
        "ok": bool(repo.get("ok") and busdriver.get("ok")),
        "repo": repo,
        "busdriver": busdriver,
        "markers": markers,
        "relay_capabilities": capabilities,
        "lock_status": locks,
        "finalization_lock": finalization_lock,
        "recent_agent_runs": runs,
        "pr_grind": pr_grind,
        "litmus_status": litmus_status,
        "relay_role_resolution": relay_role,
        "decision": decision,
    }
    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=True))
    return 0 if result["ok"] else 2


if __name__ == "__main__":
    raise SystemExit(main())
