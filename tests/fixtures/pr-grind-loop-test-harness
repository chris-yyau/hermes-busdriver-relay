#!/usr/bin/env python3
"""Contract-test-only dependency injection for pr-grind-loop.

This file is not installed or referenced by production entrypoints.
"""
from pathlib import Path
import argparse
import json
import runpy
import sys

ROOT = Path(__file__).resolve().parents[2]

# v16-r33 A: the caller-supplied RESULT files are parsed and read HERE, not by production.
#
# r32 moved the caller-named EXECUTABLE flag out of production, on the reasoning that the caller who
# names the program is the caller who passes the flag — so no flag can gate the affordance. A file is
# that same affordance with one step removed: `--fixture-result-file` reads whatever JSON a caller
# points it at and hands it back as a polling round's result, and everything production then checks
# it for — schema, PR identity, authority flags — is content authored by whoever wrote the file.
# Labelling the verdict `fixture` afterwards demoted the OUTPUT but left production shipping the
# parser AND the reader. So both live here, where nothing installed can reach them, and production
# obtains evidence only from bytes it digest-checked and ran itself.
#
# Bounded and strict even so, because a harness input is still input: a fixture that will not read
# must look like a broken test rather than like an absent result.
MAX_FIXTURE_BYTES = 1024 * 1024

# allow_abbrev=False is load-bearing, not tidiness. argparse abbreviates by default, so with this
# flag declared, `--fixture-result-f` and friends would be swallowed here by prefix rather than by
# name; a pre-parser that strips flags out of someone else's argv must match exactly what it owns
# and forward the rest untouched.
fixtures = argparse.ArgumentParser(add_help=False, allow_abbrev=False)
fixtures.add_argument("--fixture-result-file", action="append", default=[])
injected, remaining = fixtures.parse_known_args(sys.argv[1:])
# Production never sees it: its parser is about to read this argv and has no such flag.
sys.argv[1:] = remaining

ns = runpy.run_path(str(ROOT / "scripts" / "hermes-busdriver-pr-grind-loop"))
globals_ = ns["main"].__globals__

if injected.fixture_result_file:
    # The two halves of the affordance production refuses outright: the identity bindings a fixture
    # result cannot satisfy (it is about no real PR, so there is no true --expected-* to state), and
    # the envelope label that keeps whatever this run prints authority-negative. Waiving the first
    # is exactly what production's own fixture branch used to do silently; it is confined here now,
    # and the second is what makes the waiver safe to grant — nothing this run emits can claim to be
    # authoritative, so no reader can mistake an unbound fixture for a bound live result.
    globals_["require_identity_bindings"] = lambda args: None
    globals_["FIXTURE_MODE"] = True

_run_check = globals_["run_check"]
_rounds = 0


def read_fixture(path):
    """One fixture result file: bounded read, strict parse, never authoritative."""
    with open(path, "rb") as handle:
        raw = handle.read(MAX_FIXTURE_BYTES + 1)
    if len(raw) > MAX_FIXTURE_BYTES:
        raise ValueError("fixture_result_file_too_large")
    return json.loads(raw.decode("utf8"))


def run_check(args):
    """The fixture branch production used to carry, with its `source: fixture` label intact.

    The label is what keeps a hand-authored result out of a top-level clean: fixture_sourced()
    reads FIXTURE_MODE and demotes the envelope whatever the result says. The round counter lives
    here rather than in production's loop because serving fixture[i] to poll i is a property of
    having fixtures at all — production polls one authenticated checker and has nothing to index.
    """
    global _rounds
    if not injected.fixture_result_file:
        return _run_check(args)
    index = min(_rounds, len(injected.fixture_result_file) - 1)
    _rounds += 1
    path = Path(injected.fixture_result_file[index]).expanduser()
    try:
        data = read_fixture(path)
    except Exception as exc:  # noqa: BLE001 - a fixture that will not read is a broken test
        return None, {"ok": False, "source": "fixture", "path": str(path), "error": "fixture_parse_failed", "detail": str(exc)}
    return data, {"ok": True, "source": "fixture", "path": str(path)}


globals_["run_check"] = run_check
raise SystemExit(ns["main"]())
